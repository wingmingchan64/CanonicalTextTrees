{
    "0002": {
        "篇名": "送高三十五書記",
        "1": {
            "3": {
                "1": "鮑云：高書記，適也，字達夫，渤海人。",
                "2": "少落魄。",
                "3": "客梁、宋間。",
                "4": "宋州刺史張九皋奇之，舉有道，調封丘尉，不得志，去，客河西。",
                "5": "河西節度使哥舒翰表爲左驍衞兵曹參軍，掌書記。"
            }
        },
        "2": {
            "5": {
                "1": "《家語》：宓子賤爲單父宰，百姓化之。",
                "2": "齊攻魯，道由單父。",
                "3": "單父老請曰：麥已熟矣，今齊寇至，不及人人自收其麥，請放民皆使出穫麥，可以益糧，且不資寇。",
                "4": "三請而宓子賤不聽。",
                "5": "俄而齊寇逮乎麥，季孫聞之，怒，使人讓之。",
                "6": "宓子蹵然曰：今茲無麥，明年可種。",
                "7": "若使不耕者得穫，是使民樂有寇也。",
                "8": "季孫聞之，赧然愧曰：地若可入，吾豈忍見宓子哉！。"
            },
            "6": {
                "1": "◯賈誼書同。",
                "2": "《續漢書》曰：桓帝時，童謠曰：小麥青青大麥枯，誰當穫者婦與姑。",
                "3": "丈夫何在西撃胡。"
            },
            "7": {
                "1": "◯杜《正謬》云：崆峒，西方山也。"
            },
            "8": {
                "1": "按《史記》云：黃帝西至於崆峒。",
                "2": "韋昭注曰：在隴右。"
            },
            "9": {
                "1": "《九域圖志》云：岷州和政郡有崆峒山，皆非《爾雅》所載。"
            },
            "10": {
                "1": "按《爾雅》乃作空峒字。"
            },
            "11": {
                "1": "汝州亦有崆峒山，蓋名同爾。"
            },
            "12": {
                "1": "◯趙云：曹操云：麥熟更來。"
            }
        },
        "3": {
            "14": {
                "1": "祿山亂，哥舒翰討賊。",
                "2": "適佐翰守潼關。",
                "3": "翰敗，適奔赴行在。"
            },
            "15": {
                "1": "◯趙云：窮荒，謂適爲書記，隨翰遠事於吐蕃也。",
                "2": "舊以爲佐翰守潼關，乃在天寶十二年之後，誤矣。",
                "3": "主將，指哥舒翰。",
                "4": "《吳書·張紘傳》：紘諫孫權曰：主將乃籌謀之所自出。",
                "5": "孔子云：焉用彼相。"
            }
        },
        "4": {
            "17": {
                "1": "《魏志》：呂布因陳登求徐州牧不得，布怒，登喩之曰：登見曹公言待將軍，譬如養虎，當飽其肉，不則噬人。",
                "2": "公曰：不如卿言。",
                "3": "譬如養鷹，飢則爲用，飽則揚去。",
                "4": "布乃解。",
                "5": "《載記》：慕容垂猶鷹，飢則附人，飽則高飛。",
                "6": "①。"
            },
            "18": {
                "1": "◯趙云：鮑照《蕪城賦》：飢鷹厲吻。"
            }
        },
        "5": {
            "20": {
                "1": "曹子建：白馬飾金覊，連翩西北馳。",
                "2": "借問誰家子，幽幷遊俠兒。",
                "3": "《山簡》：舉鞭問葛強，何如幷州兒。"
            },
            "21": {
                "1": "◯趙云：幽幷兒，蓋遊俠者。",
                "2": "高以文士而從軍，故云。",
                "3": "鞍馬，吳質《答東阿王書》曰：情踴躍於鞍馬。",
                "4": "舊注引鮑照詩云鞍馬光照地，在後矣。"
            },
            "22": {
                "1": "◯今考西漢《匈奴傳》：文帝親御鞍馬。",
                "2": "則趙所引又在後矣。",
                "3": "➁。"
            }
        },
        "6": {
            "24": {
                "1": "韓愈云：判司卑官不堪說，未免捶楚塵埃間。"
            },
            "25": {
                "1": "◯鮑云：謂唐時參軍簿尉受杖，非也。",
                "2": "今詳杜所言，捶有罪者也。",
                "3": "退之《江陵途中》云：栖栖法曹掾，何處事卑陬。",
                "4": "何況親犴獄，敲榜發姦偸。",
                "5": "此豈身受杖如漢諸署郎耶？。"
            },
            "26": {
                "1": "◯趙云：適舉有道科中第，調封丘尉。",
                "2": "翰表用之，故云。",
                "3": "《漢紀》：張良曰：脫身去間至軍矣。",
                "4": "路溫舒云：捶楚之下，何求不得？。"
            }
        },
        "7": {
            "28": {
                "1": "《前漢》：武威郡，匈奴休屠王地，武帝太初四年開。"
            },
            "29": {
                "1": "◯趙云：武威，唐涼州也。",
                "2": "今脫身一尉，爲翰見知而辟用，雖熱行而不憚矣。"
            }
        },
        "8": {
            "31": {
                "1": "陳琳，袁本初書記之士。",
                "2": "又，阮瑀管書記之任。"
            },
            "32": {
                "1": "《賈誼傳》：豫子曰：中行以眾人畜我，我故眾人事之；智伯以國士遇我，我故國士報之。"
            }
        },
        "9": {
            "34": {
                "1": "《范雎傳》：侯嬴謂信陵君曰：人固未易知，知人亦未易。"
            },
            "35": {
                "1": "◯趙云：《詩》：九十其儀。"
            }
        },
        "10": {
            "37": {
                "1": "《李廣傳》：幕府省文書。",
                "2": "師古曰：幕府者，以車幕爲儀。",
                "3": "軍旅無常居止，故以帳幕言之。"
            },
            "38": {
                "1": "廉頗、李牧，市租皆入幕府是也。"
            }
        },
        "11": {
            "40": {
                "1": "◯趙云：《易·乾》卦：體仁足以長人。",
                "2": "曹子建《責躬》四言：威靈所加，足以沒齒。"
            }
        },
        "12": {
            "42": {
                "1": "《古樂府》：少壯不努力，老大徒悲傷。"
            },
            "43": {
                "1": "◯趙云：「男兒」字，起於剖竹視之，得一男兒也；「功名遂」字，《老子》「功成名遂」之摘文也。"
            }
        },
        "13": {
            "45": {
                "1": "《古詩》：相去萬餘里，各在一天涯。"
            },
            "46": {
                "1": "◯趙云：《左傳》：楚子使椒舉如晉，曰：君願結歡於二三君。"
            }
        },
        "14": {
            "48": {
                "1": "蘇武詩：昔爲鴛與鴦，今爲參與辰。"
            },
            "49": {
                "1": "王正長《雜詩》云：王事離我老，殊隔過參商。"
            },
            "50": {
                "1": "陸士衡詩：形聲參商乖，音息曠不達。"
            },
            "51": {
                "1": "《昭元年傳》：子產曰：昔高辛氏有二子，伯曰閼伯，季曰實沉，居於曠林，不相能也。",
                "2": "日尋干戈，以相征討。",
                "3": "后帝不臧，遷閼伯於商丘，主辰，商人是因，故辰爲商星。",
                "4": "遷實沉於大夏，主參，唐人是因，以服事夏、商，故參爲晉星。"
            },
            "52": {
                "1": "◯趙云：揚子曰：吾不觀參辰之相比也。",
                "2": "鮑照《行路難》：朝悲慘慘遂成滴。",
                "3": "阮籍詩：容好結中腸。"
            }
        },
        "15": {
            "54": {
                "1": "趙云：離別之言。",
                "2": "曹子建詩：飛蓋相追隨。"
            }
        },
        "16": {
            "56": {
                "1": "《前漢·匈奴傳》：隔以山谷，壅以沙漠。"
            },
            "57": {
                "1": "盧諶《贈崔溫》詩：北眺沙漠燕。",
                "2": "曹子建《樂府》：少小去鄕邑，揚聲沙漠垂。",
                "3": "蘇武：欲展清商曲，念子不能歸。",
                "4": "江淹詩：飲馬出城濠，北望沙漠路。",
                "5": "《陳湯傳》：匈奴不敢南鄕沙漠。",
                "6": "《前書音義》②：沙土曰漠，卽今磧也。"
            },
            "58": {
                "1": "◯趙云：曹子建賦云：大風隱其四起，揚黃塵之冥冥。",
                "2": "李陵歌曰：徑萬里兮渡沙漠。",
                "3": "鮑照《北風涼行》有云：問君得行何當歸？。"
            }
        },
        "17": {
            "60": {
                "1": "王仲宣云：從軍征遐路，討彼東南夷。"
            },
            "61": {
                "1": "陸士衡樂府詩有《從軍行》：苦哉遠征人，北戍長城阿。"
            },
            "62": {
                "1": "◯趙云：《史記》：士蔿曰：邊城少寇。",
                "2": "而《長楊賦》：永無邊城之警。",
                "3": "曹子建《白馬篇》：邊城多警急。",
                "4": "《論語》：行有餘力。"
            }
        },
        "18": {
            "64": {
                "1": "【永明校記】。"
            },
            "65": {
                "1": "①《載記》，云當作《晉書》。"
            },
            "66": {
                "1": "②稱「今考……又在後矣」爲郭知達之按語。"
            },
            "67": {
                "1": "➂作《漢書音義》。"
            }
        }
    }
}