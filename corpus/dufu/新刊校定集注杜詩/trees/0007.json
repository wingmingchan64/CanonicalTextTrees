{
    "0007": {
        "篇名": "同前（登歷下古城員外新亭）",
        "1": {
            "3": {
                "1": "公自注：「亭對鵲湖。",
                "2": "」趙云：李北海唱之於前，而公和之於後。"
            }
        },
        "2": {
            "5": {
                "1": "左太冲《招隱詩》：巖穴無結構。"
            },
            "6": {
                "1": "何平叔《景福殿賦》：結構則修梁彩制。"
            },
            "7": {
                "1": "◯趙云：孟浩然詩：結構竟不淺。",
                "2": "又云：結構依空林。"
            }
        },
        "3": {
            "9": {
                "1": "謝惠連《西陵遇風》詩：分袂澄湖陰。",
                "2": "注：水南曰陰。"
            },
            "10": {
                "1": "◯趙云：言昏明異候也。",
                "2": "梁簡文帝《梔子花》詩：日斜光隱見，風還影合離。"
            }
        },
        "4": {
            "12": {
                "1": "趙云：亭之形迹憑籍臺觀之舊製。",
                "2": "籍字言圖籍所載，舊有臺觀之迹，於義皆通。"
            }
        },
        "5": {
            "14": {
                "1": "趙云：言東海太山之氣相與接也。",
                "2": "此句乃接巫峽、通雪山之法。"
            }
        },
        "6": {
            "16": {
                "1": "遺堞，城堞也。",
                "2": "趙云：。"
            },
            "17": {
                "1": "指物感槪，蓋詩人之興。"
            }
        },
        "7": {
            "19": {
                "1": "杜《補遺》：哀絲，琴也。",
                "2": "《記》曰：絲聲哀，哀以立廉，廉以立志。",
                "3": "君子聽琴瑟之聲，則思志義之臣。",
                "4": "又枚叔《七發》曰：龍門之桐，高百尺而無枝。",
                "5": "使班爾斫斬以爲琴，野繭之絲以爲絃，孤子之鉤以爲隱，九寡之珥以爲㢩。",
                "6": "師堂操張，伯牙爲之歌。",
                "7": "此亦天下之至悲也，子能彊起而聽之乎？注：㢩，音的。",
                "8": "鉤、珥皆寶也。",
                "9": "隱、㢩皆琴上飾。",
                "10": "取孤子寡婦之寶而用之，欲其聲多悲哀。",
                "11": "九寡，九度寡也。",
                "12": "《琴錄》曰：琴曲有《蔡氏五弄》、《雙鳳》、《離鸞》、《歸鳳》、《遠送》①、《長清》、《短清》、《幽蘭》、《白雪》、《風入松》、《烏夜啼》、《楚明光》、《石上流泉》。"
            }
        },
        "8": {
            "21": {
                "1": "曹子建詩：主稱千金壽，賓奉萬年酬。",
                "2": "趙云：《記》曰：尊客之前不叱狗。"
            }
        },
        "9": {
            "23": {
                "1": "《詩》：賓之初筵，左右秩秩。"
            },
            "24": {
                "1": "◯趙云：《詩》云：鬱彼北林。",
                "2": "因所宴實在北林，故借用也。",
                "3": "然上有「芳宴」字，今又有「宴」字。",
                "4": "公應不緊重，必誤也。"
            }
        },
        "10": {
            "26": {
                "1": "傅長虞《酬何劭》：歸身蓬蓽廬。"
            },
            "27": {
                "1": "蓽，荆織門也。",
                "2": "《禮》：蓽門圭竇。"
            },
            "28": {
                "1": "◯趙云：蓽，《官韻》注云：藩落也。",
                "2": "謂亭處幽遠，故有篷蓽之興。"
            }
        },
        "11": {
            "30": {
                "1": "陸士衡詩：齊僮《梁甫吟》。"
            },
            "31": {
                "1": "諸葛亮躬耕隴畝，好爲《梁甫吟》。"
            },
            "32": {
                "1": "盛弘之《荆州記》：鄧城西七里有獨樂山，諸葛亮常登此山，作《梁甫吟》。"
            },
            "33": {
                "1": "◯杜《補遺》：孔明《梁甫吟》，傳所不載，故世莫得而聞，唯《高齋錄》②載之。",
                "2": "又：二桃事出《晏子春秋》，人亦罕見，故幷錄云：步出齊城門，遙望蕩陰里。",
                "3": "里中有三墳，纍纍正相似。",
                "4": "問是誰家墳，田疆古冶氏。",
                "5": "力可排南山，文能絕地紀。",
                "6": "一朝被讒言，一桃殺三士③。",
                "7": "誰能爲此謀，相國齊晏子。",
                "8": "李太白《梁甫吟》亦云：力排南山三壯士，齊相殺之費二桃。",
                "9": "蓋謂此也。"
            },
            "34": {
                "1": "《晏子春秋》曰：景公畜士公孫接、田開疆、古冶子三人，見晏子，不起。",
                "2": "晏子見公，請去之。",
                "3": "乃餽之二桃，令三子計功而食。",
                "4": "公孫接曰：接一搏特𧱚④，再搏乳虎，若接之功，可以食桃而毋與人同矣。",
                "5": "援桃而起。",
                "6": "田開疆曰：吾杖兵卻三軍者再，若開疆之功，可以食桃而毋與人同矣。",
                "7": "援桃而起。",
                "8": "古冶子曰：吾嘗從軍濟河。",
                "9": "黿銜左驂，以入砥柱之一流，冶少不能游，潛行逆流百歩，順流九里得黿而殺。",
                "10": "左操馬尾，右挈黿頭，鶴躍而出津。",
                "11": "若冶之功，可以食桃而毋與人同矣。",
                "12": "二子耻功不逮而自殺，冶亦自殺。"
            },
            "35": {
                "1": "◯黃魯直言：觀此詩乃小曹公專國，殺楊修、孔融、荀彧。",
                "2": "云武侯躬耕壠畝，好爲《梁甫吟》，不知來意所指，豈能作此詩，時爲究歌之，故云耳乎？⑤。"
            }
        },
        "12": {
            "37": {
                "1": "附：。"
            },
            "38": {
                "1": "登歷下古城員外新亭[北海太守李邕作。",
                "2": "]。"
            },
            "39": {
                "1": "本傳云。",
                "2": "李邕。",
                "3": "天寶初爲汲郡。",
                "4": "北海二大守。",
                "5": "時李之芳自尙書郎出齊州司馬。",
                "6": "作此亭歷下。",
                "7": "齊州。",
                "8": "春秋戰國並屬齊。",
                "9": "秦屬齊郡。",
                "10": "漢韓信伐齊至歷下。",
                "11": "卽其地。",
                "12": "文帝分置濟南。",
                "13": "景帝改爲濟南郡。",
                "14": "宋後周同。",
                "15": "隋初郡廢。",
                "16": "煬帝初置齊州。",
                "17": "大唐復爲齊州。",
                "18": "或爲臨溜郡。",
                "19": "復改爲濟南郡。"
            },
            "40": {
                "1": "吾宗固神秀。",
                "2": "[謝宣遠《答靈運》詩：華宗誕吾秀。",
                "3": "之子紹前胤。",
                "4": "公有譜系。",
                "5": "自言李杜同出。",
                "6": "故言吾宗也。",
                "7": "◯薛云。",
                "8": "按。",
                "9": "此亭乃李之芳所構。",
                "10": "詩乃北海太守李邕爲之芳作。",
                "11": "注言李杜同出。",
                "12": "其誤甚矣。",
                "13": "]體物寫謀長。",
                "14": "[陸士衡《文賦》。",
                "15": "體物而瀏湸。",
                "16": "潘岳《西征賦》。",
                "17": "摹寫舊豐，制造新邑。",
                "18": "◯趙云。",
                "19": "《書》。",
                "20": "爾乃不謀長。",
                "21": "]形制開古迹。",
                "22": "[趙云。",
                "23": "舊有此亭而之芳新之。",
                "24": "杜公所謂海右此亭古也。",
                "25": "]曽冰延樂方。",
                "26": "趙云。",
                "27": "曾字音層。",
                "28": "與曾雲之曾同。",
                "29": "謝靈運《苦寒行》曰。",
                "30": "峨峨曽冰合。",
                "31": "樂方。",
                "32": "猶言樂土。",
                "33": "]太山雄地里。",
                "34": "巨壑眇雲莊。",
                "35": "[陳江總《鍾銘》。",
                "36": "舟移巨壑。",
                "37": "◯趙云。",
                "38": "上句言東岳之大。",
                "39": "於地里爲雄。",
                "40": "下句言東海之廣。",
                "41": "視雲路可眇小之。",
                "42": "《列子》曰。",
                "43": "渤海之東。",
                "44": "不知幾億萬里。",
                "45": "有大壑焉。",
                "46": "則海可言壑矣。",
                "47": "北齊祖孝徵《望海》詩曰。",
                "48": "登高臨巨壑。",
                "49": "雲莊。",
                "50": "大路也。",
                "51": "雲路至闊大者。",
                "52": "而海猶眇小之。",
                "53": "]高興泊煩促。",
                "54": "[張荗先《答何邵》詩。",
                "55": "煩促每有餘。",
                "56": "]永懷清典常。",
                "57": "[《詩》。",
                "58": "維以不永懷。",
                "59": "《易》。",
                "60": "旣有典常。",
                "61": "]含弘知四大。",
                "62": "[《易》卦。",
                "63": "含弘光大。",
                "64": "品物咸亨。",
                "65": "《老子》。",
                "66": "域中有四大。",
                "67": "]出入見三光。",
                "68": "[日月星爲三光。",
                "69": "亦謂之三辰。",
                "70": "又《前漢·郊祀志》。",
                "71": "三光。",
                "72": "天文也。",
                "73": "]負郭喜粳稻。",
                "74": "[左太冲《蜀都賦》。",
                "75": "粳稻漠漠。",
                "76": "◯新添。",
                "77": "蘇秦曰。",
                "78": "使我有洛湯負郭田二頃。",
                "79": "安能佩六國相印乎。",
                "80": "]安時歌吉祥。",
                "81": "[《莊子》。",
                "82": "吉祥止止。",
                "83": "新添。",
                "84": "《莊子》。",
                "85": "安時處順。",
                "86": "哀樂不能入也。",
                "87": "◯趙云：邕詩雖亦兩字多有出處。",
                "88": "似同杜公法門。",
                "89": "而句法類皆枯瘠僻澀。",
                "90": "然公集中錄首唱之人無幾。",
                "91": "而公今錄邕此詩於集。",
                "92": "豈亦取其同法門邪。",
                "93": "]。"
            }
        },
        "13": {
            "42": {
                "1": "【永明校記】。"
            },
            "43": {
                "1": "①《琴錄》原文作「歸風送遠」。"
            },
            "44": {
                "1": "②《高齋錄》，誤作《高齊錄》。"
            },
            "45": {
                "1": "③「一桃殺三士」當作「二桃殺三士」。",
                "2": "作「二」。"
            },
            "46": {
                "1": "④「特」作「持」。",
                "2": "「𧱚」，《晏子春秋·晏子諫第二十四》作「豣」。",
                "3": "按：二字通。"
            },
            "47": {
                "1": "⑤此段引文，作：「黃魯直言：觀此詩乃以曹公專國，殺楊修、孔融、荀彧。",
                "2": "云武侯躬耕壠畝，好爲《梁甫吟》，不知壽意所指，豈能作此詩，時爲客歌之，故云耳乎？」，出自黃庭堅《黃山谷詩話》、《跋梁甫吟》。"
            }
        }
    }
}