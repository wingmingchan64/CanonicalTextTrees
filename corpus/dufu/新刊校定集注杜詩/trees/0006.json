{
    "0006": {
        "篇名": "陪李北海宴歷下亭",
        "1": {
            "3": {
                "1": "公自注云：「時邑人蹇處士等在坐",
                "2": "」北海，漢中壽縣也",
                "3": "齊置北海，唐屬青州",
                "4": "李北海，李邕也"
            }
        },
        "2": {
            "5": {
                "1": "《後漢志》：中二千石皆皁蓋"
            },
            "6": {
                "1": "趙云：《上林賦》：齊列爲東藩"
            }
        },
        "3": {
            "8": {
                "1": "陸士衡詩：永歎遵北渚",
                "2": "◯趙云：屈原《湘夫人》云：帝子降兮北渚",
                "3": "其後張平子《南都賦》云：亂北渚兮掲南涯",
                "4": "清河，則指言濟河",
                "5": "濟河謂之清濟故也",
                "6": "燕王曰「吾聞齊有清濟、濁河以爲固」是已"
            }
        },
        "4": {
            "10": {
                "1": "《書》曰：濟南伏生"
            },
            "11": {
                "1": "◯趙云：海在東而州在西則謂之海右，宜矣",
                "2": "濟南則指齊州"
            }
        },
        "5": {
            "13": {
                "1": "魏武帝《短歌行》：對酒當歌，人生幾何？"
            },
            "14": {
                "1": "◯薛云：《左傳》：吳申叔儀①乞糧於公孫有山氏，曰：佩玉蕊兮，余無所繫之"
            },
            "15": {
                "1": "◯趙云：鮑照《園中秋散》云：臨歌不知調，發興誰與歡？《詩》：瓊琚玉佩",
                "2": "魏武帝《短歌行》云：對酒當歌"
            },
            "16": {
                "1": "師：《楚辭》：玉佩兮陸離",
                "2": "②"
            }
        },
        "6": {
            "18": {
                "1": "《東京賦》：修竹冬青，陰池幽流"
            },
            "19": {
                "1": "◯趙云：《楚詞》：㛹娟之修竹",
                "2": "曹大家《東征賦》：望河洛之交流",
                "3": "鮑照詩：不受外嫌猜",
                "4": "魏文帝《浮淮賦》曰：驚風泛，湧波駭",
                "5": "其後左太冲《蜀都賦》云：沛若濛汜之湧波"
            }
        },
        "7": {
            "21": {
                "1": "謝靈運《登孤嶼》詩：表靈物莫賞，蘊眞誰爲傳？"
            },
            "22": {
                "1": "江淹詩：悠悠蘊眞趣"
            },
            "23": {
                "1": "下言落日則惜其景之幽眞而酒筵將散也"
            }
        },
        "8": {
            "25": {
                "1": "趙：《易》云：貴賤位矣",
                "2": "《文選》有「牽以物役」",
                "3": "《詩》：「從公于邁」",
                "4": "《左傳》：「繾綣從公」",
                "5": "此兩句非特言邕當之官而各別，又見公之不趨貴以爲誇矣",
                "6": "彼淺丈夫者冀宵燭之末光，分玉斝之餘瀝而不知恥，與公有間哉！"
            }
        },
        "9": {
            "27": {
                "1": "【永明校語】"
            },
            "28": {
                "1": "①「儀」，作「時」，從改"
            },
            "29": {
                "1": "②重「離」字"
            }
        }
    }
}