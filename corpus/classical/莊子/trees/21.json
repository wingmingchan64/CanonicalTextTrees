{
    "21": {
        "篇名": "外篇·田子方第二十一",
        "1": {
            "3": {
                "1": "田子方侍坐於魏文侯",
                "2": "數稱谿工"
            },
            "4": {
                "1": "文侯曰",
                "2": "谿工",
                "3": "子之師邪"
            },
            "5": {
                "1": "子方曰",
                "2": "非也",
                "3": "無擇之里人也",
                "4": "稱道數當",
                "5": "故無擇稱之"
            },
            "6": {
                "1": "文侯曰",
                "2": "然則子無師邪"
            },
            "7": {
                "1": "子方曰",
                "2": "有"
            },
            "8": {
                "1": "曰",
                "2": "子之師誰邪"
            },
            "9": {
                "1": "子方曰",
                "2": "東郭順子"
            },
            "10": {
                "1": "文侯曰",
                "2": "然則夫子何故未嘗稱之"
            },
            "11": {
                "1": "子方曰",
                "2": "其爲人也眞",
                "3": "人貌而天虛",
                "4": "緣而葆眞",
                "5": "清而容物",
                "6": "物無道",
                "7": "正容以悟之",
                "8": "使人之意也消",
                "9": "無擇何足以稱之"
            },
            "12": {
                "1": "子方出",
                "2": "文侯儻然終日不言",
                "3": "召前立臣而語之曰",
                "4": "遠矣",
                "5": "全德之君子",
                "6": "始吾以聖知之言仁義之行爲至矣",
                "7": "吾聞子方之師",
                "8": "吾形解而不欲動",
                "9": "口鉗而不欲言",
                "10": "吾所學者直土梗耳",
                "11": "夫魏眞爲我累耳"
            }
        },
        "2": {
            "14": {
                "1": "溫伯雪子適齊",
                "2": "舍於魯",
                "3": "魯人有請見之者",
                "4": "溫伯雪子曰",
                "5": "不可",
                "6": "吾聞中國之君子",
                "7": "明乎禮義而陋於知人心",
                "8": "吾不欲見也"
            },
            "15": {
                "1": "至於齊",
                "2": "反舍於魯",
                "3": "是人也又請見",
                "4": "溫伯雪子曰",
                "5": "往也蘄見我",
                "6": "今也又蘄見我",
                "7": "是必有以振我也"
            },
            "16": {
                "1": "出而見客",
                "2": "入而歎",
                "3": "明日見客",
                "4": "又入而歎",
                "5": "其僕曰",
                "6": "每見之客也",
                "7": "必入而歎",
                "8": "何耶"
            },
            "17": {
                "1": "曰",
                "2": "吾固告子矣",
                "3": "中國之民",
                "4": "明乎禮義而陋乎知人心",
                "5": "昔之見我者",
                "6": "進退一成規一成矩",
                "7": "從容一若龍一若虎",
                "8": "其諫我也似子",
                "9": "其道我也似父",
                "10": "是以歎也"
            },
            "18": {
                "1": "仲尼見之而不言",
                "2": "子路曰",
                "3": "吾子欲見溫伯雪子久矣",
                "4": "見之而不言",
                "5": "何邪"
            },
            "19": {
                "1": "仲尼曰",
                "2": "若夫人者",
                "3": "目擊而道存矣",
                "4": "亦不可以容聲矣"
            }
        },
        "3": {
            "21": {
                "1": "顏淵問於仲尼曰",
                "2": "夫子步亦步",
                "3": "夫子趨亦趨",
                "4": "夫子馳亦馳",
                "5": "夫子奔逸絕塵",
                "6": "而回瞠若乎後矣"
            },
            "22": {
                "1": "夫子曰",
                "2": "回",
                "3": "何謂邪"
            },
            "23": {
                "1": "曰",
                "2": "夫子步",
                "3": "亦步也",
                "4": "夫子言",
                "5": "亦言也",
                "6": "夫子趨",
                "7": "亦趨也",
                "8": "夫子辯",
                "9": "亦辯也",
                "10": "夫子馳",
                "11": "亦馳也",
                "12": "夫子言道",
                "13": "回亦言道也",
                "14": "及奔逸絕塵而回瞠若乎後者",
                "15": "夫子不言而信",
                "16": "不比而周",
                "17": "無器而民滔乎前",
                "18": "而不知所以然而已矣"
            },
            "24": {
                "1": "仲尼曰",
                "2": "惡",
                "3": "可不察與",
                "4": "夫哀",
                "5": "莫大於心死",
                "6": "而人死亦次之",
                "7": "日出東方而入於西極",
                "8": "萬物莫不比方",
                "9": "有首有趾者",
                "10": "待是而後成功",
                "11": "是出則存",
                "12": "是入則亡",
                "13": "萬物亦然",
                "14": "有待也而死",
                "15": "有待也而生",
                "16": "吾一受其成形",
                "17": "而不化以待盡",
                "18": "效物而動",
                "19": "日夜無隙",
                "20": "而不知其所終",
                "21": "薰然其成形",
                "22": "知命不能規乎其前",
                "23": "丘以是日徂"
            },
            "25": {
                "1": "吾終身與汝交一臂而失之",
                "2": "可不哀與",
                "3": "女殆著乎吾所以著也",
                "4": "彼已盡矣",
                "5": "而女求之以爲有",
                "6": "是求馬於唐肆也",
                "7": "吾服女也甚忘",
                "8": "女服吾也亦甚忘",
                "9": "雖然",
                "10": "女奚患焉",
                "11": "雖忘乎故吾",
                "12": "吾有不忘者存"
            }
        },
        "4": {
            "27": {
                "1": "孔子見老聃",
                "2": "老聃新沐",
                "3": "方將被髮而乾",
                "4": "慹然似非人",
                "5": "孔子便而待之",
                "6": "少焉見",
                "7": "曰",
                "8": "丘也眩與",
                "9": "其信然與",
                "10": "向者先生形體掘若槁木",
                "11": "似遺物離人而立於獨也"
            },
            "28": {
                "1": "老聃曰",
                "2": "吾遊心於物之初"
            },
            "29": {
                "1": "孔子曰",
                "2": "何謂邪"
            },
            "30": {
                "1": "曰",
                "2": "心困焉而不能知",
                "3": "口辟焉而不能言",
                "4": "嘗爲汝議乎其將",
                "5": "至陰肅肅",
                "6": "至陽赫赫",
                "7": "肅肅出乎天",
                "8": "赫赫發乎地",
                "9": "兩者交通成和而物生焉",
                "10": "或爲之紀而莫見其形",
                "11": "消息滿虛",
                "12": "一晦一明",
                "13": "日改月化",
                "14": "日有所爲",
                "15": "而莫見其功",
                "16": "生有所乎萌",
                "17": "死有所乎歸",
                "18": "始終相反乎無端而莫知乎其所窮",
                "19": "非是也",
                "20": "且孰爲之宗"
            },
            "31": {
                "1": "孔子曰",
                "2": "請問遊是"
            },
            "32": {
                "1": "老聃曰",
                "2": "夫得是",
                "3": "至美至樂也",
                "4": "得至美而遊乎至樂",
                "5": "謂之至人"
            },
            "33": {
                "1": "孔子曰",
                "2": "願聞其方"
            },
            "34": {
                "1": "曰",
                "2": "草食之獸不疾易藪",
                "3": "水生之蟲不疾易水",
                "4": "行小變而不失其大常也",
                "5": "喜怒哀樂不入於胸次",
                "6": "夫天下也者",
                "7": "萬物之所一也",
                "8": "得其所一而同焉",
                "9": "則四支百體將爲塵垢",
                "10": "而死生終始將爲晝夜而莫之能滑",
                "11": "而況得喪禍福之所介乎",
                "12": "棄隸者若棄泥塗",
                "13": "知身貴於隸也",
                "14": "貴在於我而不失於變",
                "15": "且萬化而未始有極也",
                "16": "夫孰足以患心",
                "17": "已爲道者解乎此"
            },
            "35": {
                "1": "孔子曰",
                "2": "夫子德配天地",
                "3": "而猶假至言以修心",
                "4": "古之君子",
                "5": "孰能脫焉"
            },
            "36": {
                "1": "老聃曰",
                "2": "不然",
                "3": "夫水之於汋也",
                "4": "無爲而才自然矣",
                "5": "至人之於德也",
                "6": "不修而物不能離焉",
                "7": "若天之自高",
                "8": "地之自厚",
                "9": "日月之自明",
                "10": "夫何修焉"
            },
            "37": {
                "1": "孔子出",
                "2": "以告顏回曰",
                "3": "丘之於道也",
                "4": "其猶醯雞與",
                "5": "微夫子之發吾覆也",
                "6": "吾不知天地之大全也"
            }
        },
        "5": {
            "39": {
                "1": "莊子見魯哀公",
                "2": "哀公曰",
                "3": "魯多儒士",
                "4": "少爲先生方者"
            },
            "40": {
                "1": "莊子曰",
                "2": "魯少儒"
            },
            "41": {
                "1": "哀公曰",
                "2": "舉魯國而儒服",
                "3": "何謂少乎"
            },
            "42": {
                "1": "莊子曰",
                "2": "周聞之",
                "3": "儒者冠圜冠者",
                "4": "知天時",
                "5": "履句屨者",
                "6": "知地形",
                "7": "緩佩玦者",
                "8": "事至而斷",
                "9": "君子有其道者",
                "10": "未必爲其服也",
                "11": "爲其服者",
                "12": "未必知其道也",
                "13": "公固以爲不然",
                "14": "何不號於國中曰",
                "15": "無此道而爲此服者",
                "16": "其罪死"
            },
            "43": {
                "1": "於是哀公號之五日",
                "2": "而魯國無敢儒服者",
                "3": "獨有一丈夫儒服而立乎公門",
                "4": "公卽召而問以國事",
                "5": "千轉萬變而不窮"
            },
            "44": {
                "1": "莊子曰",
                "2": "以魯國而儒者一人耳",
                "3": "可謂多乎"
            }
        },
        "6": {
            "46": {
                "1": "百里奚爵祿不入於心",
                "2": "故飯牛而牛肥",
                "3": "使秦穆公忘其賤",
                "4": "與之政也",
                "5": "有虞氏死生不入於心",
                "6": "故足以動人"
            }
        },
        "7": {
            "48": {
                "1": "宋元君將畫圖",
                "2": "眾史皆至",
                "3": "受揖而立",
                "4": "舐筆和墨",
                "5": "在外者半",
                "6": "有一史後至者",
                "7": "儃儃然不趨",
                "8": "受揖不立",
                "9": "因之舍",
                "10": "公使人視之",
                "11": "則解衣槃礴臝",
                "12": "君曰",
                "13": "可矣",
                "14": "是眞畫者也"
            }
        },
        "8": {
            "50": {
                "1": "文王觀於臧",
                "2": "見一丈人釣",
                "3": "而其釣莫釣",
                "4": "非持其釣有釣者也",
                "5": "常釣也"
            },
            "51": {
                "1": "文王欲舉而授之政",
                "2": "而恐大臣父兄之弗安也",
                "3": "欲終而釋之",
                "4": "而不忍百姓之無天也",
                "5": "於是旦而屬之大夫曰",
                "6": "昔者寡人夢見良人",
                "7": "黑色而髯",
                "8": "乘駁馬而偏朱蹄",
                "9": "號曰",
                "10": "寓而政於臧丈人",
                "11": "庶幾乎民有瘳乎"
            },
            "52": {
                "1": "諸大夫蹴然曰",
                "2": "先君王也"
            },
            "53": {
                "1": "文王曰",
                "2": "然則卜之"
            },
            "54": {
                "1": "諸大夫曰",
                "2": "先君之命",
                "3": "王其無它",
                "4": "又何卜焉"
            },
            "55": {
                "1": "遂迎臧丈人而授之政",
                "2": "典法無更",
                "3": "偏令無出",
                "4": "三年",
                "5": "文王觀於國",
                "6": "則列士壞植散羣",
                "7": "長官者不成德",
                "8": "斔斛不敢入於四竟",
                "9": "列士壞植散羣",
                "10": "則尙同也",
                "11": "長官者不成德",
                "12": "則同務也",
                "13": "斔斛不敢入於四竟",
                "14": "則諸侯無二心也"
            },
            "56": {
                "1": "文王於是焉以爲大師",
                "2": "北面而問曰",
                "3": "政可以及天下乎",
                "4": "臧丈人昧然而不應",
                "5": "泛然而辭",
                "6": "朝令而夜遁",
                "7": "終身無聞"
            },
            "57": {
                "1": "顏淵問於仲尼曰",
                "2": "文王其猶未邪",
                "3": "又何以夢爲乎"
            },
            "58": {
                "1": "仲尼曰",
                "2": "默",
                "3": "汝無言",
                "4": "夫文王盡之也",
                "5": "而又何論剌焉",
                "6": "彼直以循斯須也"
            }
        },
        "9": {
            "60": {
                "1": "列禦寇爲伯昏無人射",
                "2": "引之盈貫",
                "3": "措杯水其肘上",
                "4": "發之",
                "5": "適矢復沓",
                "6": "方矢復寓",
                "7": "當是時",
                "8": "猶象人也"
            },
            "61": {
                "1": "伯昏無人曰",
                "2": "是射之射",
                "3": "非不射之射也",
                "4": "嘗與汝登高山",
                "5": "履危石",
                "6": "臨百仞之淵",
                "7": "若能射乎"
            },
            "62": {
                "1": "於是無人遂登高山",
                "2": "履危石",
                "3": "臨百仞之淵",
                "4": "背逡巡",
                "5": "足二分垂在外",
                "6": "揖禦寇而進之",
                "7": "禦寇伏地",
                "8": "汗流至踵"
            },
            "63": {
                "1": "伯昏無人曰",
                "2": "夫至人者",
                "3": "上闚青天",
                "4": "下潛黃泉",
                "5": "揮斥八極",
                "6": "神氣不變",
                "7": "今汝怵然有恂目之志",
                "8": "爾於中也殆矣夫"
            }
        },
        "10": {
            "65": {
                "1": "肩吾問於孫叔敖曰",
                "2": "子三爲令尹而不榮華",
                "3": "三去之而無憂色",
                "4": "吾始也疑子",
                "5": "今視子之鼻間栩栩然",
                "6": "子之用心獨柰何"
            },
            "66": {
                "1": "孫叔敖曰",
                "2": "吾何以過人哉",
                "3": "吾以其來不可卻也",
                "4": "其去不可止也",
                "5": "吾以爲得失之非我也",
                "6": "而無憂色而已矣",
                "7": "我何以過人哉",
                "8": "且不知其在彼乎",
                "9": "其在我乎",
                "10": "其在彼邪",
                "11": "亡乎我",
                "12": "在我邪",
                "13": "亡乎彼",
                "14": "方將躊躇",
                "15": "方將四顧",
                "16": "何暇至乎人貴人賤哉"
            },
            "67": {
                "1": "仲尼聞之曰",
                "2": "古之眞人",
                "3": "知者不得說",
                "4": "美人不得濫",
                "5": "盜人不得劫",
                "6": "伏戲",
                "7": "黃帝不得友",
                "8": "死生亦大矣",
                "9": "而無變乎己",
                "10": "況爵祿乎",
                "11": "若然者",
                "12": "其神經乎大山而無介",
                "13": "入乎淵泉而不濡",
                "14": "處卑細而不憊",
                "15": "充滿天地",
                "16": "旣以與人",
                "17": "己愈有"
            }
        },
        "11": {
            "69": {
                "1": "楚王與凡君坐",
                "2": "少焉",
                "3": "楚王左右曰凡亡者三",
                "4": "凡君曰",
                "5": "凡之亡也",
                "6": "不足以喪吾存",
                "7": "夫凡之亡不足以喪吾存",
                "8": "則楚之存不足以存存",
                "9": "由是觀之",
                "10": "則凡未始亡而楚未始存也"
            }
        }
    }
}