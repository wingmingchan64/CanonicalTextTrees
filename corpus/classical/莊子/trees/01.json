{
    "01": {
        "篇名": "內篇·逍遙遊第一",
        "1": {
            "3": {
                "1": "北冥有魚",
                "2": "其名爲鯤",
                "3": "鯤之大",
                "4": "不知其幾千里也",
                "5": "化而爲鳥",
                "6": "其名爲鵬",
                "7": "鵬之背",
                "8": "不知其幾千里也",
                "9": "怒而飛",
                "10": "其翼若垂天之雲",
                "11": "是鳥也",
                "12": "海運則將徙於南冥",
                "13": "南冥者",
                "14": "天池也"
            }
        },
        "2": {
            "5": {
                "1": "齊諧者",
                "2": "志怪者也",
                "3": "諧之言曰",
                "4": "鵬之徙於南冥也",
                "5": "水擊三千里",
                "6": "摶扶搖而上者九萬里",
                "7": "去以六月息者也",
                "8": "野馬也",
                "9": "塵埃也",
                "10": "生物之以息相吹也",
                "11": "天之蒼蒼",
                "12": "其正色邪",
                "13": "其遠而無所至極邪",
                "14": "其視下也",
                "15": "亦若是則已矣"
            }
        },
        "3": {
            "7": {
                "1": "且夫水之積也不厚",
                "2": "則負大舟也無力",
                "3": "覆杯水於坳堂之上",
                "4": "則芥爲之舟",
                "5": "置杯焉則膠",
                "6": "水淺而舟大也",
                "7": "風之積也不厚",
                "8": "則其負大翼也無力",
                "9": "故九萬里",
                "10": "則風斯在下矣",
                "11": "而後乃今培風",
                "12": "背負青天而莫之夭閼者",
                "13": "而後乃今將圖南"
            }
        },
        "4": {
            "9": {
                "1": "蜩與學鳩笑之曰",
                "2": "我決起而飛",
                "3": "槍榆枋",
                "4": "時則不至",
                "5": "而控於地而已矣",
                "6": "奚以之九萬里而南爲",
                "7": "適莽蒼者",
                "8": "三飡而反",
                "9": "腹猶果然",
                "10": "適百里者",
                "11": "宿舂糧",
                "12": "適千里者",
                "13": "三月聚糧",
                "14": "之二蟲又何知"
            }
        },
        "5": {
            "11": {
                "1": "小知不及大知",
                "2": "小年不及大年",
                "3": "奚以知其然也",
                "4": "朝菌不知晦朔",
                "5": "蟪蛄不知春秋",
                "6": "此小年也",
                "7": "楚之南有冥靈者",
                "8": "以五百歲爲春",
                "9": "五百歲爲秋",
                "10": "上古有大椿者",
                "11": "以八千歲爲春",
                "12": "八千歲爲秋",
                "13": "此大年也",
                "14": "而彭祖乃今以久特聞",
                "15": "眾人匹之",
                "16": "不亦悲乎"
            }
        },
        "6": {
            "13": {
                "1": "湯之問棘也是已",
                "2": "湯問棘曰",
                "3": "上下四方有極乎",
                "4": "棘曰",
                "5": "無極之外",
                "6": "復無極也",
                "7": "窮髮之北有冥海者",
                "8": "天池也",
                "9": "有魚焉",
                "10": "其廣數千里",
                "11": "未有知其修者",
                "12": "其名爲鯤",
                "13": "有鳥焉",
                "14": "其名爲鵬",
                "15": "背若太山",
                "16": "翼若垂天之雲",
                "17": "摶扶搖羊角而上者九萬里",
                "18": "絕雲氣",
                "19": "負青天",
                "20": "然後圖南",
                "21": "斥鴳笑之曰",
                "22": "彼且奚適也",
                "23": "我騰躍而上",
                "24": "不過數仞而下",
                "25": "翱翔蓬蒿之間",
                "26": "此亦飛之至也",
                "27": "而彼且奚適也",
                "28": "此小大之辯也"
            }
        },
        "7": {
            "15": {
                "1": "故夫知效一官",
                "2": "行比一鄕",
                "3": "德合一君而徴一國者",
                "4": "其自視也亦若此矣",
                "5": "而宋榮子猶然笑之",
                "6": "且舉世而譽之而不加勸",
                "7": "舉世而非之而不加沮",
                "8": "定乎內外之分",
                "9": "辯乎榮辱之境",
                "10": "斯已矣",
                "11": "彼其於世未數數然也",
                "12": "雖然",
                "13": "猶有未樹也",
                "14": "夫列子御風而行",
                "15": "泠然善也",
                "16": "旬有五日而後反",
                "17": "彼於致福者",
                "18": "未數數然也",
                "19": "此雖免乎行",
                "20": "猶有所待者也"
            }
        },
        "8": {
            "17": {
                "1": "若夫乘天地之正",
                "2": "而御六氣之辯",
                "3": "以遊無窮者",
                "4": "彼且惡乎待哉"
            }
        },
        "9": {
            "19": {
                "1": "故曰",
                "2": "至人無己",
                "3": "神人無功",
                "4": "聖人無名"
            }
        },
        "10": {
            "21": {
                "1": "堯讓天下於許由",
                "2": "曰",
                "3": "日月出矣",
                "4": "而爝火不息",
                "5": "其於光也",
                "6": "不亦難乎",
                "7": "時雨降矣",
                "8": "而猶浸灌",
                "9": "其於澤也",
                "10": "不亦勞乎",
                "11": "夫子立",
                "12": "而天下治",
                "13": "而我猶尸之",
                "14": "吾自視缺然",
                "15": "請致天下",
                "16": "許由曰",
                "17": "子治天下",
                "18": "天下旣已治也",
                "19": "而我猶代子",
                "20": "吾將爲名乎",
                "21": "名者實之賓也",
                "22": "吾將爲賓乎",
                "23": "鷦鷯巢於深林",
                "24": "不過一枝",
                "25": "偃鼠飮河",
                "26": "不過滿腹",
                "27": "歸休乎君",
                "28": "予無所用天下爲",
                "29": "庖人雖不治庖",
                "30": "尸祝不越樽俎而代之矣"
            }
        },
        "11": {
            "23": {
                "1": "肩吾問於連叔曰",
                "2": "吾聞言於接輿",
                "3": "大而無當",
                "4": "往而不反",
                "5": "吾驚怖其言",
                "6": "猶河漢而無極也",
                "7": "大有逕庭",
                "8": "不近人情焉",
                "9": "連叔曰",
                "10": "其言謂何哉",
                "11": "曰",
                "12": "藐姑射之山",
                "13": "有神人居焉",
                "14": "肌膚若冰雪",
                "15": "綽約若處子",
                "16": "不食五榖",
                "17": "吸風飮露",
                "18": "乘雲氣",
                "19": "御飛龍",
                "20": "而遊乎四海之外",
                "21": "其神凝",
                "22": "使物不疵癘而年榖熟",
                "23": "吾以是狂而不信也",
                "24": "連叔曰",
                "25": "然",
                "26": "瞽者無以與乎文章之觀",
                "27": "聾者無以與乎鐘鼓之聲",
                "28": "豈唯形骸有聾盲哉",
                "29": "夫知亦有之",
                "30": "是其言也",
                "31": "猶時女也",
                "32": "之人也",
                "33": "之德也",
                "34": "將旁礴萬物以爲一",
                "35": "世蘄乎亂",
                "36": "孰弊弊焉以天下爲事",
                "37": "之人也",
                "38": "物莫之傷",
                "39": "大浸稽天而不溺",
                "40": "大旱金石流",
                "41": "土山焦而不熱",
                "42": "是其塵垢粃穅",
                "43": "將猶陶鑄堯舜者也",
                "44": "孰肯分分然以物爲事"
            }
        },
        "12": {
            "25": {
                "1": "宋人資章甫而適諸越",
                "2": "越人斷髮文身",
                "3": "無所用之",
                "4": "堯治天下之民",
                "5": "平海內之政",
                "6": "往見四子藐姑射之山",
                "7": "汾水之陽",
                "8": "窅然喪其天下焉"
            }
        },
        "13": {
            "27": {
                "1": "惠子謂莊子曰",
                "2": "魏王貽我大瓠之種",
                "3": "我樹之成而實五石",
                "4": "以盛水漿",
                "5": "其堅不能自舉也",
                "6": "剖之以爲瓢",
                "7": "則瓠落無所容",
                "8": "非不呺然大也",
                "9": "吾爲其無用而掊之",
                "10": "莊子曰",
                "11": "夫子固拙於用大矣",
                "12": "宋人有善爲不龜手之藥者",
                "13": "世世以洴澼絖爲事",
                "14": "客聞之",
                "15": "請買其方以百金",
                "16": "聚族而謀曰",
                "17": "我世世爲洴澼絖",
                "18": "不過數金",
                "19": "今一朝而鬻技百金",
                "20": "請與之",
                "21": "客得之",
                "22": "以說吳王",
                "23": "越有難",
                "24": "吳王使之將",
                "25": "冬與越人水戰",
                "26": "大敗越人",
                "27": "裂地而封之",
                "28": "能不龜手",
                "29": "一也",
                "30": "或以封",
                "31": "或不免於洴澼絖",
                "32": "則所用之異也",
                "33": "今子有五石之瓠",
                "34": "何不慮以爲大樽而浮乎江湖",
                "35": "而憂其瓠落無所容",
                "36": "則夫子猶有蓬之心也夫"
            }
        },
        "14": {
            "29": {
                "1": "惠子謂莊子曰",
                "2": "吾有大樹",
                "3": "人謂之樗",
                "4": "其大本擁腫而不中繩墨",
                "5": "其小枝卷曲而不中規矩",
                "6": "立之塗",
                "7": "匠者不顧",
                "8": "今子之言",
                "9": "大而無用",
                "10": "衆所同去也",
                "11": "莊子曰",
                "12": "子獨不見狸狌乎",
                "13": "卑身而伏",
                "14": "以候敖者",
                "15": "東西跳梁",
                "16": "不辟高下",
                "17": "中於機辟",
                "18": "死於罔罟",
                "19": "今夫斄牛",
                "20": "其大若垂天之雲",
                "21": "此能爲大矣",
                "22": "而不能執鼠",
                "23": "今子有大樹",
                "24": "患其無用",
                "25": "何不樹之於無何有之鄕",
                "26": "廣莫之野",
                "27": "彷徨乎無爲其側",
                "28": "逍遥乎寢臥其下",
                "29": "不夭斤斧",
                "30": "物無害者",
                "31": "無所可用",
                "32": "安所困苦哉"
            }
        }
    }
}