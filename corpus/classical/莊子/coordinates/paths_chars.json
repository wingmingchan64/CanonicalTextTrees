{
    "ZHUANGZI,01,篇名": "內篇·逍遙遊第一",
    "ZHUANGZI,01,1,3,1": "北冥有魚",
    "ZHUANGZI,01,1,3,2": "其名爲鯤",
    "ZHUANGZI,01,1,3,3": "鯤之大",
    "ZHUANGZI,01,1,3,4": "不知其幾千里也",
    "ZHUANGZI,01,1,3,5": "化而爲鳥",
    "ZHUANGZI,01,1,3,6": "其名爲鵬",
    "ZHUANGZI,01,1,3,7": "鵬之背",
    "ZHUANGZI,01,1,3,8": "不知其幾千里也",
    "ZHUANGZI,01,1,3,9": "怒而飛",
    "ZHUANGZI,01,1,3,10": "其翼若垂天之雲",
    "ZHUANGZI,01,1,3,11": "是鳥也",
    "ZHUANGZI,01,1,3,12": "海運則將徙於南冥",
    "ZHUANGZI,01,1,3,13": "南冥者",
    "ZHUANGZI,01,1,3,14": "天池也",
    "ZHUANGZI,01,2,5,1": "齊諧者",
    "ZHUANGZI,01,2,5,2": "志怪者也",
    "ZHUANGZI,01,2,5,3": "諧之言曰",
    "ZHUANGZI,01,2,5,4": "鵬之徙於南冥也",
    "ZHUANGZI,01,2,5,5": "水擊三千里",
    "ZHUANGZI,01,2,5,6": "摶扶搖而上者九萬里",
    "ZHUANGZI,01,2,5,7": "去以六月息者也",
    "ZHUANGZI,01,2,5,8": "野馬也",
    "ZHUANGZI,01,2,5,9": "塵埃也",
    "ZHUANGZI,01,2,5,10": "生物之以息相吹也",
    "ZHUANGZI,01,2,5,11": "天之蒼蒼",
    "ZHUANGZI,01,2,5,12": "其正色邪",
    "ZHUANGZI,01,2,5,13": "其遠而無所至極邪",
    "ZHUANGZI,01,2,5,14": "其視下也",
    "ZHUANGZI,01,2,5,15": "亦若是則已矣",
    "ZHUANGZI,01,3,7,1": "且夫水之積也不厚",
    "ZHUANGZI,01,3,7,2": "則負大舟也無力",
    "ZHUANGZI,01,3,7,3": "覆杯水於坳堂之上",
    "ZHUANGZI,01,3,7,4": "則芥爲之舟",
    "ZHUANGZI,01,3,7,5": "置杯焉則膠",
    "ZHUANGZI,01,3,7,6": "水淺而舟大也",
    "ZHUANGZI,01,3,7,7": "風之積也不厚",
    "ZHUANGZI,01,3,7,8": "則其負大翼也無力",
    "ZHUANGZI,01,3,7,9": "故九萬里",
    "ZHUANGZI,01,3,7,10": "則風斯在下矣",
    "ZHUANGZI,01,3,7,11": "而後乃今培風",
    "ZHUANGZI,01,3,7,12": "背負青天而莫之夭閼者",
    "ZHUANGZI,01,3,7,13": "而後乃今將圖南",
    "ZHUANGZI,01,4,9,1": "蜩與學鳩笑之曰",
    "ZHUANGZI,01,4,9,2": "我決起而飛",
    "ZHUANGZI,01,4,9,3": "槍榆枋",
    "ZHUANGZI,01,4,9,4": "時則不至",
    "ZHUANGZI,01,4,9,5": "而控於地而已矣",
    "ZHUANGZI,01,4,9,6": "奚以之九萬里而南爲",
    "ZHUANGZI,01,4,9,7": "適莽蒼者",
    "ZHUANGZI,01,4,9,8": "三飡而反",
    "ZHUANGZI,01,4,9,9": "腹猶果然",
    "ZHUANGZI,01,4,9,10": "適百里者",
    "ZHUANGZI,01,4,9,11": "宿舂糧",
    "ZHUANGZI,01,4,9,12": "適千里者",
    "ZHUANGZI,01,4,9,13": "三月聚糧",
    "ZHUANGZI,01,4,9,14": "之二蟲又何知",
    "ZHUANGZI,01,5,11,1": "小知不及大知",
    "ZHUANGZI,01,5,11,2": "小年不及大年",
    "ZHUANGZI,01,5,11,3": "奚以知其然也",
    "ZHUANGZI,01,5,11,4": "朝菌不知晦朔",
    "ZHUANGZI,01,5,11,5": "蟪蛄不知春秋",
    "ZHUANGZI,01,5,11,6": "此小年也",
    "ZHUANGZI,01,5,11,7": "楚之南有冥靈者",
    "ZHUANGZI,01,5,11,8": "以五百歲爲春",
    "ZHUANGZI,01,5,11,9": "五百歲爲秋",
    "ZHUANGZI,01,5,11,10": "上古有大椿者",
    "ZHUANGZI,01,5,11,11": "以八千歲爲春",
    "ZHUANGZI,01,5,11,12": "八千歲爲秋",
    "ZHUANGZI,01,5,11,13": "此大年也",
    "ZHUANGZI,01,5,11,14": "而彭祖乃今以久特聞",
    "ZHUANGZI,01,5,11,15": "眾人匹之",
    "ZHUANGZI,01,5,11,16": "不亦悲乎",
    "ZHUANGZI,01,6,13,1": "湯之問棘也是已",
    "ZHUANGZI,01,6,13,2": "湯問棘曰",
    "ZHUANGZI,01,6,13,3": "上下四方有極乎",
    "ZHUANGZI,01,6,13,4": "棘曰",
    "ZHUANGZI,01,6,13,5": "無極之外",
    "ZHUANGZI,01,6,13,6": "復無極也",
    "ZHUANGZI,01,6,13,7": "窮髮之北有冥海者",
    "ZHUANGZI,01,6,13,8": "天池也",
    "ZHUANGZI,01,6,13,9": "有魚焉",
    "ZHUANGZI,01,6,13,10": "其廣數千里",
    "ZHUANGZI,01,6,13,11": "未有知其修者",
    "ZHUANGZI,01,6,13,12": "其名爲鯤",
    "ZHUANGZI,01,6,13,13": "有鳥焉",
    "ZHUANGZI,01,6,13,14": "其名爲鵬",
    "ZHUANGZI,01,6,13,15": "背若太山",
    "ZHUANGZI,01,6,13,16": "翼若垂天之雲",
    "ZHUANGZI,01,6,13,17": "摶扶搖羊角而上者九萬里",
    "ZHUANGZI,01,6,13,18": "絕雲氣",
    "ZHUANGZI,01,6,13,19": "負青天",
    "ZHUANGZI,01,6,13,20": "然後圖南",
    "ZHUANGZI,01,6,13,21": "斥鴳笑之曰",
    "ZHUANGZI,01,6,13,22": "彼且奚適也",
    "ZHUANGZI,01,6,13,23": "我騰躍而上",
    "ZHUANGZI,01,6,13,24": "不過數仞而下",
    "ZHUANGZI,01,6,13,25": "翱翔蓬蒿之間",
    "ZHUANGZI,01,6,13,26": "此亦飛之至也",
    "ZHUANGZI,01,6,13,27": "而彼且奚適也",
    "ZHUANGZI,01,6,13,28": "此小大之辯也",
    "ZHUANGZI,01,7,15,1": "故夫知效一官",
    "ZHUANGZI,01,7,15,2": "行比一鄕",
    "ZHUANGZI,01,7,15,3": "德合一君而徴一國者",
    "ZHUANGZI,01,7,15,4": "其自視也亦若此矣",
    "ZHUANGZI,01,7,15,5": "而宋榮子猶然笑之",
    "ZHUANGZI,01,7,15,6": "且舉世而譽之而不加勸",
    "ZHUANGZI,01,7,15,7": "舉世而非之而不加沮",
    "ZHUANGZI,01,7,15,8": "定乎內外之分",
    "ZHUANGZI,01,7,15,9": "辯乎榮辱之境",
    "ZHUANGZI,01,7,15,10": "斯已矣",
    "ZHUANGZI,01,7,15,11": "彼其於世未數數然也",
    "ZHUANGZI,01,7,15,12": "雖然",
    "ZHUANGZI,01,7,15,13": "猶有未樹也",
    "ZHUANGZI,01,7,15,14": "夫列子御風而行",
    "ZHUANGZI,01,7,15,15": "泠然善也",
    "ZHUANGZI,01,7,15,16": "旬有五日而後反",
    "ZHUANGZI,01,7,15,17": "彼於致福者",
    "ZHUANGZI,01,7,15,18": "未數數然也",
    "ZHUANGZI,01,7,15,19": "此雖免乎行",
    "ZHUANGZI,01,7,15,20": "猶有所待者也",
    "ZHUANGZI,01,8,17,1": "若夫乘天地之正",
    "ZHUANGZI,01,8,17,2": "而御六氣之辯",
    "ZHUANGZI,01,8,17,3": "以遊無窮者",
    "ZHUANGZI,01,8,17,4": "彼且惡乎待哉",
    "ZHUANGZI,01,9,19,1": "故曰",
    "ZHUANGZI,01,9,19,2": "至人無己",
    "ZHUANGZI,01,9,19,3": "神人無功",
    "ZHUANGZI,01,9,19,4": "聖人無名",
    "ZHUANGZI,01,10,21,1": "堯讓天下於許由",
    "ZHUANGZI,01,10,21,2": "曰",
    "ZHUANGZI,01,10,21,3": "日月出矣",
    "ZHUANGZI,01,10,21,4": "而爝火不息",
    "ZHUANGZI,01,10,21,5": "其於光也",
    "ZHUANGZI,01,10,21,6": "不亦難乎",
    "ZHUANGZI,01,10,21,7": "時雨降矣",
    "ZHUANGZI,01,10,21,8": "而猶浸灌",
    "ZHUANGZI,01,10,21,9": "其於澤也",
    "ZHUANGZI,01,10,21,10": "不亦勞乎",
    "ZHUANGZI,01,10,21,11": "夫子立",
    "ZHUANGZI,01,10,21,12": "而天下治",
    "ZHUANGZI,01,10,21,13": "而我猶尸之",
    "ZHUANGZI,01,10,21,14": "吾自視缺然",
    "ZHUANGZI,01,10,21,15": "請致天下",
    "ZHUANGZI,01,10,21,16": "許由曰",
    "ZHUANGZI,01,10,21,17": "子治天下",
    "ZHUANGZI,01,10,21,18": "天下旣已治也",
    "ZHUANGZI,01,10,21,19": "而我猶代子",
    "ZHUANGZI,01,10,21,20": "吾將爲名乎",
    "ZHUANGZI,01,10,21,21": "名者實之賓也",
    "ZHUANGZI,01,10,21,22": "吾將爲賓乎",
    "ZHUANGZI,01,10,21,23": "鷦鷯巢於深林",
    "ZHUANGZI,01,10,21,24": "不過一枝",
    "ZHUANGZI,01,10,21,25": "偃鼠飮河",
    "ZHUANGZI,01,10,21,26": "不過滿腹",
    "ZHUANGZI,01,10,21,27": "歸休乎君",
    "ZHUANGZI,01,10,21,28": "予無所用天下爲",
    "ZHUANGZI,01,10,21,29": "庖人雖不治庖",
    "ZHUANGZI,01,10,21,30": "尸祝不越樽俎而代之矣",
    "ZHUANGZI,01,11,23,1": "肩吾問於連叔曰",
    "ZHUANGZI,01,11,23,2": "吾聞言於接輿",
    "ZHUANGZI,01,11,23,3": "大而無當",
    "ZHUANGZI,01,11,23,4": "往而不反",
    "ZHUANGZI,01,11,23,5": "吾驚怖其言",
    "ZHUANGZI,01,11,23,6": "猶河漢而無極也",
    "ZHUANGZI,01,11,23,7": "大有逕庭",
    "ZHUANGZI,01,11,23,8": "不近人情焉",
    "ZHUANGZI,01,11,23,9": "連叔曰",
    "ZHUANGZI,01,11,23,10": "其言謂何哉",
    "ZHUANGZI,01,11,23,11": "曰",
    "ZHUANGZI,01,11,23,12": "藐姑射之山",
    "ZHUANGZI,01,11,23,13": "有神人居焉",
    "ZHUANGZI,01,11,23,14": "肌膚若冰雪",
    "ZHUANGZI,01,11,23,15": "綽約若處子",
    "ZHUANGZI,01,11,23,16": "不食五榖",
    "ZHUANGZI,01,11,23,17": "吸風飮露",
    "ZHUANGZI,01,11,23,18": "乘雲氣",
    "ZHUANGZI,01,11,23,19": "御飛龍",
    "ZHUANGZI,01,11,23,20": "而遊乎四海之外",
    "ZHUANGZI,01,11,23,21": "其神凝",
    "ZHUANGZI,01,11,23,22": "使物不疵癘而年榖熟",
    "ZHUANGZI,01,11,23,23": "吾以是狂而不信也",
    "ZHUANGZI,01,11,23,24": "連叔曰",
    "ZHUANGZI,01,11,23,25": "然",
    "ZHUANGZI,01,11,23,26": "瞽者無以與乎文章之觀",
    "ZHUANGZI,01,11,23,27": "聾者無以與乎鐘鼓之聲",
    "ZHUANGZI,01,11,23,28": "豈唯形骸有聾盲哉",
    "ZHUANGZI,01,11,23,29": "夫知亦有之",
    "ZHUANGZI,01,11,23,30": "是其言也",
    "ZHUANGZI,01,11,23,31": "猶時女也",
    "ZHUANGZI,01,11,23,32": "之人也",
    "ZHUANGZI,01,11,23,33": "之德也",
    "ZHUANGZI,01,11,23,34": "將旁礴萬物以爲一",
    "ZHUANGZI,01,11,23,35": "世蘄乎亂",
    "ZHUANGZI,01,11,23,36": "孰弊弊焉以天下爲事",
    "ZHUANGZI,01,11,23,37": "之人也",
    "ZHUANGZI,01,11,23,38": "物莫之傷",
    "ZHUANGZI,01,11,23,39": "大浸稽天而不溺",
    "ZHUANGZI,01,11,23,40": "大旱金石流",
    "ZHUANGZI,01,11,23,41": "土山焦而不熱",
    "ZHUANGZI,01,11,23,42": "是其塵垢粃穅",
    "ZHUANGZI,01,11,23,43": "將猶陶鑄堯舜者也",
    "ZHUANGZI,01,11,23,44": "孰肯分分然以物爲事",
    "ZHUANGZI,01,12,25,1": "宋人資章甫而適諸越",
    "ZHUANGZI,01,12,25,2": "越人斷髮文身",
    "ZHUANGZI,01,12,25,3": "無所用之",
    "ZHUANGZI,01,12,25,4": "堯治天下之民",
    "ZHUANGZI,01,12,25,5": "平海內之政",
    "ZHUANGZI,01,12,25,6": "往見四子藐姑射之山",
    "ZHUANGZI,01,12,25,7": "汾水之陽",
    "ZHUANGZI,01,12,25,8": "窅然喪其天下焉",
    "ZHUANGZI,01,13,27,1": "惠子謂莊子曰",
    "ZHUANGZI,01,13,27,2": "魏王貽我大瓠之種",
    "ZHUANGZI,01,13,27,3": "我樹之成而實五石",
    "ZHUANGZI,01,13,27,4": "以盛水漿",
    "ZHUANGZI,01,13,27,5": "其堅不能自舉也",
    "ZHUANGZI,01,13,27,6": "剖之以爲瓢",
    "ZHUANGZI,01,13,27,7": "則瓠落無所容",
    "ZHUANGZI,01,13,27,8": "非不呺然大也",
    "ZHUANGZI,01,13,27,9": "吾爲其無用而掊之",
    "ZHUANGZI,01,13,27,10": "莊子曰",
    "ZHUANGZI,01,13,27,11": "夫子固拙於用大矣",
    "ZHUANGZI,01,13,27,12": "宋人有善爲不龜手之藥者",
    "ZHUANGZI,01,13,27,13": "世世以洴澼絖爲事",
    "ZHUANGZI,01,13,27,14": "客聞之",
    "ZHUANGZI,01,13,27,15": "請買其方以百金",
    "ZHUANGZI,01,13,27,16": "聚族而謀曰",
    "ZHUANGZI,01,13,27,17": "我世世爲洴澼絖",
    "ZHUANGZI,01,13,27,18": "不過數金",
    "ZHUANGZI,01,13,27,19": "今一朝而鬻技百金",
    "ZHUANGZI,01,13,27,20": "請與之",
    "ZHUANGZI,01,13,27,21": "客得之",
    "ZHUANGZI,01,13,27,22": "以說吳王",
    "ZHUANGZI,01,13,27,23": "越有難",
    "ZHUANGZI,01,13,27,24": "吳王使之將",
    "ZHUANGZI,01,13,27,25": "冬與越人水戰",
    "ZHUANGZI,01,13,27,26": "大敗越人",
    "ZHUANGZI,01,13,27,27": "裂地而封之",
    "ZHUANGZI,01,13,27,28": "能不龜手",
    "ZHUANGZI,01,13,27,29": "一也",
    "ZHUANGZI,01,13,27,30": "或以封",
    "ZHUANGZI,01,13,27,31": "或不免於洴澼絖",
    "ZHUANGZI,01,13,27,32": "則所用之異也",
    "ZHUANGZI,01,13,27,33": "今子有五石之瓠",
    "ZHUANGZI,01,13,27,34": "何不慮以爲大樽而浮乎江湖",
    "ZHUANGZI,01,13,27,35": "而憂其瓠落無所容",
    "ZHUANGZI,01,13,27,36": "則夫子猶有蓬之心也夫",
    "ZHUANGZI,01,14,29,1": "惠子謂莊子曰",
    "ZHUANGZI,01,14,29,2": "吾有大樹",
    "ZHUANGZI,01,14,29,3": "人謂之樗",
    "ZHUANGZI,01,14,29,4": "其大本擁腫而不中繩墨",
    "ZHUANGZI,01,14,29,5": "其小枝卷曲而不中規矩",
    "ZHUANGZI,01,14,29,6": "立之塗",
    "ZHUANGZI,01,14,29,7": "匠者不顧",
    "ZHUANGZI,01,14,29,8": "今子之言",
    "ZHUANGZI,01,14,29,9": "大而無用",
    "ZHUANGZI,01,14,29,10": "衆所同去也",
    "ZHUANGZI,01,14,29,11": "莊子曰",
    "ZHUANGZI,01,14,29,12": "子獨不見狸狌乎",
    "ZHUANGZI,01,14,29,13": "卑身而伏",
    "ZHUANGZI,01,14,29,14": "以候敖者",
    "ZHUANGZI,01,14,29,15": "東西跳梁",
    "ZHUANGZI,01,14,29,16": "不辟高下",
    "ZHUANGZI,01,14,29,17": "中於機辟",
    "ZHUANGZI,01,14,29,18": "死於罔罟",
    "ZHUANGZI,01,14,29,19": "今夫斄牛",
    "ZHUANGZI,01,14,29,20": "其大若垂天之雲",
    "ZHUANGZI,01,14,29,21": "此能爲大矣",
    "ZHUANGZI,01,14,29,22": "而不能執鼠",
    "ZHUANGZI,01,14,29,23": "今子有大樹",
    "ZHUANGZI,01,14,29,24": "患其無用",
    "ZHUANGZI,01,14,29,25": "何不樹之於無何有之鄕",
    "ZHUANGZI,01,14,29,26": "廣莫之野",
    "ZHUANGZI,01,14,29,27": "彷徨乎無爲其側",
    "ZHUANGZI,01,14,29,28": "逍遥乎寢臥其下",
    "ZHUANGZI,01,14,29,29": "不夭斤斧",
    "ZHUANGZI,01,14,29,30": "物無害者",
    "ZHUANGZI,01,14,29,31": "無所可用",
    "ZHUANGZI,01,14,29,32": "安所困苦哉",
    "ZHUANGZI,21,篇名": "外篇·田子方第二十一",
    "ZHUANGZI,21,1,3,1": "田子方侍坐於魏文侯",
    "ZHUANGZI,21,1,3,2": "數稱谿工",
    "ZHUANGZI,21,1,4,1": "文侯曰",
    "ZHUANGZI,21,1,4,2": "谿工",
    "ZHUANGZI,21,1,4,3": "子之師邪",
    "ZHUANGZI,21,1,5,1": "子方曰",
    "ZHUANGZI,21,1,5,2": "非也",
    "ZHUANGZI,21,1,5,3": "無擇之里人也",
    "ZHUANGZI,21,1,5,4": "稱道數當",
    "ZHUANGZI,21,1,5,5": "故無擇稱之",
    "ZHUANGZI,21,1,6,1": "文侯曰",
    "ZHUANGZI,21,1,6,2": "然則子無師邪",
    "ZHUANGZI,21,1,7,1": "子方曰",
    "ZHUANGZI,21,1,7,2": "有",
    "ZHUANGZI,21,1,8,1": "曰",
    "ZHUANGZI,21,1,8,2": "子之師誰邪",
    "ZHUANGZI,21,1,9,1": "子方曰",
    "ZHUANGZI,21,1,9,2": "東郭順子",
    "ZHUANGZI,21,1,10,1": "文侯曰",
    "ZHUANGZI,21,1,10,2": "然則夫子何故未嘗稱之",
    "ZHUANGZI,21,1,11,1": "子方曰",
    "ZHUANGZI,21,1,11,2": "其爲人也眞",
    "ZHUANGZI,21,1,11,3": "人貌而天虛",
    "ZHUANGZI,21,1,11,4": "緣而葆眞",
    "ZHUANGZI,21,1,11,5": "清而容物",
    "ZHUANGZI,21,1,11,6": "物無道",
    "ZHUANGZI,21,1,11,7": "正容以悟之",
    "ZHUANGZI,21,1,11,8": "使人之意也消",
    "ZHUANGZI,21,1,11,9": "無擇何足以稱之",
    "ZHUANGZI,21,1,12,1": "子方出",
    "ZHUANGZI,21,1,12,2": "文侯儻然終日不言",
    "ZHUANGZI,21,1,12,3": "召前立臣而語之曰",
    "ZHUANGZI,21,1,12,4": "遠矣",
    "ZHUANGZI,21,1,12,5": "全德之君子",
    "ZHUANGZI,21,1,12,6": "始吾以聖知之言仁義之行爲至矣",
    "ZHUANGZI,21,1,12,7": "吾聞子方之師",
    "ZHUANGZI,21,1,12,8": "吾形解而不欲動",
    "ZHUANGZI,21,1,12,9": "口鉗而不欲言",
    "ZHUANGZI,21,1,12,10": "吾所學者直土梗耳",
    "ZHUANGZI,21,1,12,11": "夫魏眞爲我累耳",
    "ZHUANGZI,21,2,14,1": "溫伯雪子適齊",
    "ZHUANGZI,21,2,14,2": "舍於魯",
    "ZHUANGZI,21,2,14,3": "魯人有請見之者",
    "ZHUANGZI,21,2,14,4": "溫伯雪子曰",
    "ZHUANGZI,21,2,14,5": "不可",
    "ZHUANGZI,21,2,14,6": "吾聞中國之君子",
    "ZHUANGZI,21,2,14,7": "明乎禮義而陋於知人心",
    "ZHUANGZI,21,2,14,8": "吾不欲見也",
    "ZHUANGZI,21,2,15,1": "至於齊",
    "ZHUANGZI,21,2,15,2": "反舍於魯",
    "ZHUANGZI,21,2,15,3": "是人也又請見",
    "ZHUANGZI,21,2,15,4": "溫伯雪子曰",
    "ZHUANGZI,21,2,15,5": "往也蘄見我",
    "ZHUANGZI,21,2,15,6": "今也又蘄見我",
    "ZHUANGZI,21,2,15,7": "是必有以振我也",
    "ZHUANGZI,21,2,16,1": "出而見客",
    "ZHUANGZI,21,2,16,2": "入而歎",
    "ZHUANGZI,21,2,16,3": "明日見客",
    "ZHUANGZI,21,2,16,4": "又入而歎",
    "ZHUANGZI,21,2,16,5": "其僕曰",
    "ZHUANGZI,21,2,16,6": "每見之客也",
    "ZHUANGZI,21,2,16,7": "必入而歎",
    "ZHUANGZI,21,2,16,8": "何耶",
    "ZHUANGZI,21,2,17,1": "曰",
    "ZHUANGZI,21,2,17,2": "吾固告子矣",
    "ZHUANGZI,21,2,17,3": "中國之民",
    "ZHUANGZI,21,2,17,4": "明乎禮義而陋乎知人心",
    "ZHUANGZI,21,2,17,5": "昔之見我者",
    "ZHUANGZI,21,2,17,6": "進退一成規一成矩",
    "ZHUANGZI,21,2,17,7": "從容一若龍一若虎",
    "ZHUANGZI,21,2,17,8": "其諫我也似子",
    "ZHUANGZI,21,2,17,9": "其道我也似父",
    "ZHUANGZI,21,2,17,10": "是以歎也",
    "ZHUANGZI,21,2,18,1": "仲尼見之而不言",
    "ZHUANGZI,21,2,18,2": "子路曰",
    "ZHUANGZI,21,2,18,3": "吾子欲見溫伯雪子久矣",
    "ZHUANGZI,21,2,18,4": "見之而不言",
    "ZHUANGZI,21,2,18,5": "何邪",
    "ZHUANGZI,21,2,19,1": "仲尼曰",
    "ZHUANGZI,21,2,19,2": "若夫人者",
    "ZHUANGZI,21,2,19,3": "目擊而道存矣",
    "ZHUANGZI,21,2,19,4": "亦不可以容聲矣",
    "ZHUANGZI,21,3,21,1": "顏淵問於仲尼曰",
    "ZHUANGZI,21,3,21,2": "夫子步亦步",
    "ZHUANGZI,21,3,21,3": "夫子趨亦趨",
    "ZHUANGZI,21,3,21,4": "夫子馳亦馳",
    "ZHUANGZI,21,3,21,5": "夫子奔逸絕塵",
    "ZHUANGZI,21,3,21,6": "而回瞠若乎後矣",
    "ZHUANGZI,21,3,22,1": "夫子曰",
    "ZHUANGZI,21,3,22,2": "回",
    "ZHUANGZI,21,3,22,3": "何謂邪",
    "ZHUANGZI,21,3,23,1": "曰",
    "ZHUANGZI,21,3,23,2": "夫子步",
    "ZHUANGZI,21,3,23,3": "亦步也",
    "ZHUANGZI,21,3,23,4": "夫子言",
    "ZHUANGZI,21,3,23,5": "亦言也",
    "ZHUANGZI,21,3,23,6": "夫子趨",
    "ZHUANGZI,21,3,23,7": "亦趨也",
    "ZHUANGZI,21,3,23,8": "夫子辯",
    "ZHUANGZI,21,3,23,9": "亦辯也",
    "ZHUANGZI,21,3,23,10": "夫子馳",
    "ZHUANGZI,21,3,23,11": "亦馳也",
    "ZHUANGZI,21,3,23,12": "夫子言道",
    "ZHUANGZI,21,3,23,13": "回亦言道也",
    "ZHUANGZI,21,3,23,14": "及奔逸絕塵而回瞠若乎後者",
    "ZHUANGZI,21,3,23,15": "夫子不言而信",
    "ZHUANGZI,21,3,23,16": "不比而周",
    "ZHUANGZI,21,3,23,17": "無器而民滔乎前",
    "ZHUANGZI,21,3,23,18": "而不知所以然而已矣",
    "ZHUANGZI,21,3,24,1": "仲尼曰",
    "ZHUANGZI,21,3,24,2": "惡",
    "ZHUANGZI,21,3,24,3": "可不察與",
    "ZHUANGZI,21,3,24,4": "夫哀",
    "ZHUANGZI,21,3,24,5": "莫大於心死",
    "ZHUANGZI,21,3,24,6": "而人死亦次之",
    "ZHUANGZI,21,3,24,7": "日出東方而入於西極",
    "ZHUANGZI,21,3,24,8": "萬物莫不比方",
    "ZHUANGZI,21,3,24,9": "有首有趾者",
    "ZHUANGZI,21,3,24,10": "待是而後成功",
    "ZHUANGZI,21,3,24,11": "是出則存",
    "ZHUANGZI,21,3,24,12": "是入則亡",
    "ZHUANGZI,21,3,24,13": "萬物亦然",
    "ZHUANGZI,21,3,24,14": "有待也而死",
    "ZHUANGZI,21,3,24,15": "有待也而生",
    "ZHUANGZI,21,3,24,16": "吾一受其成形",
    "ZHUANGZI,21,3,24,17": "而不化以待盡",
    "ZHUANGZI,21,3,24,18": "效物而動",
    "ZHUANGZI,21,3,24,19": "日夜無隙",
    "ZHUANGZI,21,3,24,20": "而不知其所終",
    "ZHUANGZI,21,3,24,21": "薰然其成形",
    "ZHUANGZI,21,3,24,22": "知命不能規乎其前",
    "ZHUANGZI,21,3,24,23": "丘以是日徂",
    "ZHUANGZI,21,3,25,1": "吾終身與汝交一臂而失之",
    "ZHUANGZI,21,3,25,2": "可不哀與",
    "ZHUANGZI,21,3,25,3": "女殆著乎吾所以著也",
    "ZHUANGZI,21,3,25,4": "彼已盡矣",
    "ZHUANGZI,21,3,25,5": "而女求之以爲有",
    "ZHUANGZI,21,3,25,6": "是求馬於唐肆也",
    "ZHUANGZI,21,3,25,7": "吾服女也甚忘",
    "ZHUANGZI,21,3,25,8": "女服吾也亦甚忘",
    "ZHUANGZI,21,3,25,9": "雖然",
    "ZHUANGZI,21,3,25,10": "女奚患焉",
    "ZHUANGZI,21,3,25,11": "雖忘乎故吾",
    "ZHUANGZI,21,3,25,12": "吾有不忘者存",
    "ZHUANGZI,21,4,27,1": "孔子見老聃",
    "ZHUANGZI,21,4,27,2": "老聃新沐",
    "ZHUANGZI,21,4,27,3": "方將被髮而乾",
    "ZHUANGZI,21,4,27,4": "慹然似非人",
    "ZHUANGZI,21,4,27,5": "孔子便而待之",
    "ZHUANGZI,21,4,27,6": "少焉見",
    "ZHUANGZI,21,4,27,7": "曰",
    "ZHUANGZI,21,4,27,8": "丘也眩與",
    "ZHUANGZI,21,4,27,9": "其信然與",
    "ZHUANGZI,21,4,27,10": "向者先生形體掘若槁木",
    "ZHUANGZI,21,4,27,11": "似遺物離人而立於獨也",
    "ZHUANGZI,21,4,28,1": "老聃曰",
    "ZHUANGZI,21,4,28,2": "吾遊心於物之初",
    "ZHUANGZI,21,4,29,1": "孔子曰",
    "ZHUANGZI,21,4,29,2": "何謂邪",
    "ZHUANGZI,21,4,30,1": "曰",
    "ZHUANGZI,21,4,30,2": "心困焉而不能知",
    "ZHUANGZI,21,4,30,3": "口辟焉而不能言",
    "ZHUANGZI,21,4,30,4": "嘗爲汝議乎其將",
    "ZHUANGZI,21,4,30,5": "至陰肅肅",
    "ZHUANGZI,21,4,30,6": "至陽赫赫",
    "ZHUANGZI,21,4,30,7": "肅肅出乎天",
    "ZHUANGZI,21,4,30,8": "赫赫發乎地",
    "ZHUANGZI,21,4,30,9": "兩者交通成和而物生焉",
    "ZHUANGZI,21,4,30,10": "或爲之紀而莫見其形",
    "ZHUANGZI,21,4,30,11": "消息滿虛",
    "ZHUANGZI,21,4,30,12": "一晦一明",
    "ZHUANGZI,21,4,30,13": "日改月化",
    "ZHUANGZI,21,4,30,14": "日有所爲",
    "ZHUANGZI,21,4,30,15": "而莫見其功",
    "ZHUANGZI,21,4,30,16": "生有所乎萌",
    "ZHUANGZI,21,4,30,17": "死有所乎歸",
    "ZHUANGZI,21,4,30,18": "始終相反乎無端而莫知乎其所窮",
    "ZHUANGZI,21,4,30,19": "非是也",
    "ZHUANGZI,21,4,30,20": "且孰爲之宗",
    "ZHUANGZI,21,4,31,1": "孔子曰",
    "ZHUANGZI,21,4,31,2": "請問遊是",
    "ZHUANGZI,21,4,32,1": "老聃曰",
    "ZHUANGZI,21,4,32,2": "夫得是",
    "ZHUANGZI,21,4,32,3": "至美至樂也",
    "ZHUANGZI,21,4,32,4": "得至美而遊乎至樂",
    "ZHUANGZI,21,4,32,5": "謂之至人",
    "ZHUANGZI,21,4,33,1": "孔子曰",
    "ZHUANGZI,21,4,33,2": "願聞其方",
    "ZHUANGZI,21,4,34,1": "曰",
    "ZHUANGZI,21,4,34,2": "草食之獸不疾易藪",
    "ZHUANGZI,21,4,34,3": "水生之蟲不疾易水",
    "ZHUANGZI,21,4,34,4": "行小變而不失其大常也",
    "ZHUANGZI,21,4,34,5": "喜怒哀樂不入於胸次",
    "ZHUANGZI,21,4,34,6": "夫天下也者",
    "ZHUANGZI,21,4,34,7": "萬物之所一也",
    "ZHUANGZI,21,4,34,8": "得其所一而同焉",
    "ZHUANGZI,21,4,34,9": "則四支百體將爲塵垢",
    "ZHUANGZI,21,4,34,10": "而死生終始將爲晝夜而莫之能滑",
    "ZHUANGZI,21,4,34,11": "而況得喪禍福之所介乎",
    "ZHUANGZI,21,4,34,12": "棄隸者若棄泥塗",
    "ZHUANGZI,21,4,34,13": "知身貴於隸也",
    "ZHUANGZI,21,4,34,14": "貴在於我而不失於變",
    "ZHUANGZI,21,4,34,15": "且萬化而未始有極也",
    "ZHUANGZI,21,4,34,16": "夫孰足以患心",
    "ZHUANGZI,21,4,34,17": "已爲道者解乎此",
    "ZHUANGZI,21,4,35,1": "孔子曰",
    "ZHUANGZI,21,4,35,2": "夫子德配天地",
    "ZHUANGZI,21,4,35,3": "而猶假至言以修心",
    "ZHUANGZI,21,4,35,4": "古之君子",
    "ZHUANGZI,21,4,35,5": "孰能脫焉",
    "ZHUANGZI,21,4,36,1": "老聃曰",
    "ZHUANGZI,21,4,36,2": "不然",
    "ZHUANGZI,21,4,36,3": "夫水之於汋也",
    "ZHUANGZI,21,4,36,4": "無爲而才自然矣",
    "ZHUANGZI,21,4,36,5": "至人之於德也",
    "ZHUANGZI,21,4,36,6": "不修而物不能離焉",
    "ZHUANGZI,21,4,36,7": "若天之自高",
    "ZHUANGZI,21,4,36,8": "地之自厚",
    "ZHUANGZI,21,4,36,9": "日月之自明",
    "ZHUANGZI,21,4,36,10": "夫何修焉",
    "ZHUANGZI,21,4,37,1": "孔子出",
    "ZHUANGZI,21,4,37,2": "以告顏回曰",
    "ZHUANGZI,21,4,37,3": "丘之於道也",
    "ZHUANGZI,21,4,37,4": "其猶醯雞與",
    "ZHUANGZI,21,4,37,5": "微夫子之發吾覆也",
    "ZHUANGZI,21,4,37,6": "吾不知天地之大全也",
    "ZHUANGZI,21,5,39,1": "莊子見魯哀公",
    "ZHUANGZI,21,5,39,2": "哀公曰",
    "ZHUANGZI,21,5,39,3": "魯多儒士",
    "ZHUANGZI,21,5,39,4": "少爲先生方者",
    "ZHUANGZI,21,5,40,1": "莊子曰",
    "ZHUANGZI,21,5,40,2": "魯少儒",
    "ZHUANGZI,21,5,41,1": "哀公曰",
    "ZHUANGZI,21,5,41,2": "舉魯國而儒服",
    "ZHUANGZI,21,5,41,3": "何謂少乎",
    "ZHUANGZI,21,5,42,1": "莊子曰",
    "ZHUANGZI,21,5,42,2": "周聞之",
    "ZHUANGZI,21,5,42,3": "儒者冠圜冠者",
    "ZHUANGZI,21,5,42,4": "知天時",
    "ZHUANGZI,21,5,42,5": "履句屨者",
    "ZHUANGZI,21,5,42,6": "知地形",
    "ZHUANGZI,21,5,42,7": "緩佩玦者",
    "ZHUANGZI,21,5,42,8": "事至而斷",
    "ZHUANGZI,21,5,42,9": "君子有其道者",
    "ZHUANGZI,21,5,42,10": "未必爲其服也",
    "ZHUANGZI,21,5,42,11": "爲其服者",
    "ZHUANGZI,21,5,42,12": "未必知其道也",
    "ZHUANGZI,21,5,42,13": "公固以爲不然",
    "ZHUANGZI,21,5,42,14": "何不號於國中曰",
    "ZHUANGZI,21,5,42,15": "無此道而爲此服者",
    "ZHUANGZI,21,5,42,16": "其罪死",
    "ZHUANGZI,21,5,43,1": "於是哀公號之五日",
    "ZHUANGZI,21,5,43,2": "而魯國無敢儒服者",
    "ZHUANGZI,21,5,43,3": "獨有一丈夫儒服而立乎公門",
    "ZHUANGZI,21,5,43,4": "公卽召而問以國事",
    "ZHUANGZI,21,5,43,5": "千轉萬變而不窮",
    "ZHUANGZI,21,5,44,1": "莊子曰",
    "ZHUANGZI,21,5,44,2": "以魯國而儒者一人耳",
    "ZHUANGZI,21,5,44,3": "可謂多乎",
    "ZHUANGZI,21,6,46,1": "百里奚爵祿不入於心",
    "ZHUANGZI,21,6,46,2": "故飯牛而牛肥",
    "ZHUANGZI,21,6,46,3": "使秦穆公忘其賤",
    "ZHUANGZI,21,6,46,4": "與之政也",
    "ZHUANGZI,21,6,46,5": "有虞氏死生不入於心",
    "ZHUANGZI,21,6,46,6": "故足以動人",
    "ZHUANGZI,21,7,48,1": "宋元君將畫圖",
    "ZHUANGZI,21,7,48,2": "眾史皆至",
    "ZHUANGZI,21,7,48,3": "受揖而立",
    "ZHUANGZI,21,7,48,4": "舐筆和墨",
    "ZHUANGZI,21,7,48,5": "在外者半",
    "ZHUANGZI,21,7,48,6": "有一史後至者",
    "ZHUANGZI,21,7,48,7": "儃儃然不趨",
    "ZHUANGZI,21,7,48,8": "受揖不立",
    "ZHUANGZI,21,7,48,9": "因之舍",
    "ZHUANGZI,21,7,48,10": "公使人視之",
    "ZHUANGZI,21,7,48,11": "則解衣槃礴臝",
    "ZHUANGZI,21,7,48,12": "君曰",
    "ZHUANGZI,21,7,48,13": "可矣",
    "ZHUANGZI,21,7,48,14": "是眞畫者也",
    "ZHUANGZI,21,8,50,1": "文王觀於臧",
    "ZHUANGZI,21,8,50,2": "見一丈人釣",
    "ZHUANGZI,21,8,50,3": "而其釣莫釣",
    "ZHUANGZI,21,8,50,4": "非持其釣有釣者也",
    "ZHUANGZI,21,8,50,5": "常釣也",
    "ZHUANGZI,21,8,51,1": "文王欲舉而授之政",
    "ZHUANGZI,21,8,51,2": "而恐大臣父兄之弗安也",
    "ZHUANGZI,21,8,51,3": "欲終而釋之",
    "ZHUANGZI,21,8,51,4": "而不忍百姓之無天也",
    "ZHUANGZI,21,8,51,5": "於是旦而屬之大夫曰",
    "ZHUANGZI,21,8,51,6": "昔者寡人夢見良人",
    "ZHUANGZI,21,8,51,7": "黑色而髯",
    "ZHUANGZI,21,8,51,8": "乘駁馬而偏朱蹄",
    "ZHUANGZI,21,8,51,9": "號曰",
    "ZHUANGZI,21,8,51,10": "寓而政於臧丈人",
    "ZHUANGZI,21,8,51,11": "庶幾乎民有瘳乎",
    "ZHUANGZI,21,8,52,1": "諸大夫蹴然曰",
    "ZHUANGZI,21,8,52,2": "先君王也",
    "ZHUANGZI,21,8,53,1": "文王曰",
    "ZHUANGZI,21,8,53,2": "然則卜之",
    "ZHUANGZI,21,8,54,1": "諸大夫曰",
    "ZHUANGZI,21,8,54,2": "先君之命",
    "ZHUANGZI,21,8,54,3": "王其無它",
    "ZHUANGZI,21,8,54,4": "又何卜焉",
    "ZHUANGZI,21,8,55,1": "遂迎臧丈人而授之政",
    "ZHUANGZI,21,8,55,2": "典法無更",
    "ZHUANGZI,21,8,55,3": "偏令無出",
    "ZHUANGZI,21,8,55,4": "三年",
    "ZHUANGZI,21,8,55,5": "文王觀於國",
    "ZHUANGZI,21,8,55,6": "則列士壞植散羣",
    "ZHUANGZI,21,8,55,7": "長官者不成德",
    "ZHUANGZI,21,8,55,8": "斔斛不敢入於四竟",
    "ZHUANGZI,21,8,55,9": "列士壞植散羣",
    "ZHUANGZI,21,8,55,10": "則尙同也",
    "ZHUANGZI,21,8,55,11": "長官者不成德",
    "ZHUANGZI,21,8,55,12": "則同務也",
    "ZHUANGZI,21,8,55,13": "斔斛不敢入於四竟",
    "ZHUANGZI,21,8,55,14": "則諸侯無二心也",
    "ZHUANGZI,21,8,56,1": "文王於是焉以爲大師",
    "ZHUANGZI,21,8,56,2": "北面而問曰",
    "ZHUANGZI,21,8,56,3": "政可以及天下乎",
    "ZHUANGZI,21,8,56,4": "臧丈人昧然而不應",
    "ZHUANGZI,21,8,56,5": "泛然而辭",
    "ZHUANGZI,21,8,56,6": "朝令而夜遁",
    "ZHUANGZI,21,8,56,7": "終身無聞",
    "ZHUANGZI,21,8,57,1": "顏淵問於仲尼曰",
    "ZHUANGZI,21,8,57,2": "文王其猶未邪",
    "ZHUANGZI,21,8,57,3": "又何以夢爲乎",
    "ZHUANGZI,21,8,58,1": "仲尼曰",
    "ZHUANGZI,21,8,58,2": "默",
    "ZHUANGZI,21,8,58,3": "汝無言",
    "ZHUANGZI,21,8,58,4": "夫文王盡之也",
    "ZHUANGZI,21,8,58,5": "而又何論剌焉",
    "ZHUANGZI,21,8,58,6": "彼直以循斯須也",
    "ZHUANGZI,21,9,60,1": "列禦寇爲伯昏無人射",
    "ZHUANGZI,21,9,60,2": "引之盈貫",
    "ZHUANGZI,21,9,60,3": "措杯水其肘上",
    "ZHUANGZI,21,9,60,4": "發之",
    "ZHUANGZI,21,9,60,5": "適矢復沓",
    "ZHUANGZI,21,9,60,6": "方矢復寓",
    "ZHUANGZI,21,9,60,7": "當是時",
    "ZHUANGZI,21,9,60,8": "猶象人也",
    "ZHUANGZI,21,9,61,1": "伯昏無人曰",
    "ZHUANGZI,21,9,61,2": "是射之射",
    "ZHUANGZI,21,9,61,3": "非不射之射也",
    "ZHUANGZI,21,9,61,4": "嘗與汝登高山",
    "ZHUANGZI,21,9,61,5": "履危石",
    "ZHUANGZI,21,9,61,6": "臨百仞之淵",
    "ZHUANGZI,21,9,61,7": "若能射乎",
    "ZHUANGZI,21,9,62,1": "於是無人遂登高山",
    "ZHUANGZI,21,9,62,2": "履危石",
    "ZHUANGZI,21,9,62,3": "臨百仞之淵",
    "ZHUANGZI,21,9,62,4": "背逡巡",
    "ZHUANGZI,21,9,62,5": "足二分垂在外",
    "ZHUANGZI,21,9,62,6": "揖禦寇而進之",
    "ZHUANGZI,21,9,62,7": "禦寇伏地",
    "ZHUANGZI,21,9,62,8": "汗流至踵",
    "ZHUANGZI,21,9,63,1": "伯昏無人曰",
    "ZHUANGZI,21,9,63,2": "夫至人者",
    "ZHUANGZI,21,9,63,3": "上闚青天",
    "ZHUANGZI,21,9,63,4": "下潛黃泉",
    "ZHUANGZI,21,9,63,5": "揮斥八極",
    "ZHUANGZI,21,9,63,6": "神氣不變",
    "ZHUANGZI,21,9,63,7": "今汝怵然有恂目之志",
    "ZHUANGZI,21,9,63,8": "爾於中也殆矣夫",
    "ZHUANGZI,21,10,65,1": "肩吾問於孫叔敖曰",
    "ZHUANGZI,21,10,65,2": "子三爲令尹而不榮華",
    "ZHUANGZI,21,10,65,3": "三去之而無憂色",
    "ZHUANGZI,21,10,65,4": "吾始也疑子",
    "ZHUANGZI,21,10,65,5": "今視子之鼻間栩栩然",
    "ZHUANGZI,21,10,65,6": "子之用心獨柰何",
    "ZHUANGZI,21,10,66,1": "孫叔敖曰",
    "ZHUANGZI,21,10,66,2": "吾何以過人哉",
    "ZHUANGZI,21,10,66,3": "吾以其來不可卻也",
    "ZHUANGZI,21,10,66,4": "其去不可止也",
    "ZHUANGZI,21,10,66,5": "吾以爲得失之非我也",
    "ZHUANGZI,21,10,66,6": "而無憂色而已矣",
    "ZHUANGZI,21,10,66,7": "我何以過人哉",
    "ZHUANGZI,21,10,66,8": "且不知其在彼乎",
    "ZHUANGZI,21,10,66,9": "其在我乎",
    "ZHUANGZI,21,10,66,10": "其在彼邪",
    "ZHUANGZI,21,10,66,11": "亡乎我",
    "ZHUANGZI,21,10,66,12": "在我邪",
    "ZHUANGZI,21,10,66,13": "亡乎彼",
    "ZHUANGZI,21,10,66,14": "方將躊躇",
    "ZHUANGZI,21,10,66,15": "方將四顧",
    "ZHUANGZI,21,10,66,16": "何暇至乎人貴人賤哉",
    "ZHUANGZI,21,10,67,1": "仲尼聞之曰",
    "ZHUANGZI,21,10,67,2": "古之眞人",
    "ZHUANGZI,21,10,67,3": "知者不得說",
    "ZHUANGZI,21,10,67,4": "美人不得濫",
    "ZHUANGZI,21,10,67,5": "盜人不得劫",
    "ZHUANGZI,21,10,67,6": "伏戲",
    "ZHUANGZI,21,10,67,7": "黃帝不得友",
    "ZHUANGZI,21,10,67,8": "死生亦大矣",
    "ZHUANGZI,21,10,67,9": "而無變乎己",
    "ZHUANGZI,21,10,67,10": "況爵祿乎",
    "ZHUANGZI,21,10,67,11": "若然者",
    "ZHUANGZI,21,10,67,12": "其神經乎大山而無介",
    "ZHUANGZI,21,10,67,13": "入乎淵泉而不濡",
    "ZHUANGZI,21,10,67,14": "處卑細而不憊",
    "ZHUANGZI,21,10,67,15": "充滿天地",
    "ZHUANGZI,21,10,67,16": "旣以與人",
    "ZHUANGZI,21,10,67,17": "己愈有",
    "ZHUANGZI,21,11,69,1": "楚王與凡君坐",
    "ZHUANGZI,21,11,69,2": "少焉",
    "ZHUANGZI,21,11,69,3": "楚王左右曰凡亡者三",
    "ZHUANGZI,21,11,69,4": "凡君曰",
    "ZHUANGZI,21,11,69,5": "凡之亡也",
    "ZHUANGZI,21,11,69,6": "不足以喪吾存",
    "ZHUANGZI,21,11,69,7": "夫凡之亡不足以喪吾存",
    "ZHUANGZI,21,11,69,8": "則楚之存不足以存存",
    "ZHUANGZI,21,11,69,9": "由是觀之",
    "ZHUANGZI,21,11,69,10": "則凡未始亡而楚未始存也"
}