{
    "100-1": {
        "篇名": "敍傳第七十上",
        "1": {
            "3": {
                "1": "班氏之先",
                "2": "與楚同姓",
                "3": "令尹子文之後也",
                "4": "子文初生",
                "5": "棄於瞢中",
                "6": "而虎乳之",
                "7": "楚人謂乳穀",
                "8": "謂虎於檡",
                "9": "故名穀於檡",
                "10": "字子文",
                "11": "楚人謂虎班",
                "12": "其子以爲號",
                "13": "秦之滅楚",
                "14": "遷晉",
                "15": "代之間",
                "16": "因氏焉"
            }
        },
        "2": {
            "5": {
                "1": "始皇之末",
                "2": "班壹避墬於樓煩",
                "3": "致馬牛羊數千羣",
                "4": "値漢初定",
                "5": "與民無禁",
                "6": "當孝惠",
                "7": "高后時",
                "8": "以財雄邊",
                "9": "出入弋獵",
                "10": "旌旗鼓吹",
                "11": "年百餘歲",
                "12": "以壽終",
                "13": "故北方多以壹爲字者"
            }
        },
        "3": {
            "7": {
                "1": "壹生孺",
                "2": "孺爲任俠",
                "3": "州郡歌之",
                "4": "孺生長",
                "5": "官至上谷守",
                "6": "長生回",
                "7": "以茂材爲長子令",
                "8": "回生況",
                "9": "舉孝廉爲郎",
                "10": "積功勞",
                "11": "至上河農都尉",
                "12": "大司農奏課連最",
                "13": "入爲左曹越騎校尉",
                "14": "成帝之初",
                "15": "女爲婕妤",
                "16": "致仕就第",
                "17": "貲累千金",
                "18": "徙昌陵",
                "19": "昌陵後罷",
                "20": "大臣名家皆占數於長安"
            }
        },
        "4": {
            "9": {
                "1": "況生三子",
                "2": "伯",
                "3": "斿",
                "4": "稚",
                "5": "伯少受詩於師丹",
                "6": "大將軍王鳳薦伯宜勸學",
                "7": "召見宴昵殿",
                "8": "容貌甚麗",
                "9": "誦說有法",
                "10": "拜爲中常侍",
                "11": "時上方鄕學",
                "12": "鄭寬中",
                "13": "張禹朝夕入說尙書",
                "14": "論語於金華殿中",
                "15": "詔伯受焉",
                "16": "旣通大義",
                "17": "又講異同於許商",
                "18": "遷奉車都尉",
                "19": "數年",
                "20": "金華之業絕",
                "21": "出與王",
                "22": "許子弟爲羣",
                "23": "在於綺襦紈褲之間",
                "24": "非其好也"
            }
        },
        "5": {
            "11": {
                "1": "家本北邊",
                "2": "志節忼慨",
                "3": "數求使匈奴",
                "4": "河平中",
                "5": "單於來朝",
                "6": "上使伯持節迎於塞下",
                "7": "會定襄大姓石",
                "8": "李羣輩報怨",
                "9": "殺追捕吏",
                "10": "伯上狀",
                "11": "因自請願試守期月",
                "12": "上遣侍中中郎將王舜馳傳代伯護單於",
                "13": "幷奉璽書印綬",
                "14": "卽拜伯爲定襄太守",
                "15": "定襄聞伯素貴",
                "16": "年少",
                "17": "自請治劇",
                "18": "畏其下車作威",
                "19": "吏民竦息",
                "20": "伯至",
                "21": "請問耆老父祖故人有舊恩者",
                "22": "迎延滿堂",
                "23": "日爲供具",
                "24": "執子孫禮",
                "25": "郡中益弛",
                "26": "諸所賓禮皆名豪",
                "27": "懷恩醉酒",
                "28": "共諫伯宜頗攝錄盜賊",
                "29": "具言本謀亡匿處",
                "30": "伯曰",
                "31": "是所望於父師矣",
                "32": "乃召屬縣長吏",
                "33": "選精進掾史",
                "34": "分部收捕",
                "35": "及它隱伏",
                "36": "旬日盡得",
                "37": "郡中震栗",
                "38": "咸稱神明",
                "39": "歲餘",
                "40": "上徵伯",
                "41": "伯上書願過故郡上父祖冢",
                "42": "有詔",
                "43": "太守都尉以下會",
                "44": "因召宗族",
                "45": "各以親疏加恩施",
                "46": "散數百金",
                "47": "北州以爲榮",
                "48": "長老紀焉",
                "49": "道病中風",
                "50": "旣至",
                "51": "以侍中光祿大夫養病",
                "52": "賞賜甚厚",
                "53": "數年未能起"
            }
        },
        "6": {
            "13": {
                "1": "會許皇后廢",
                "2": "班婕妤供養東宮",
                "3": "進侍者李平爲婕妤",
                "4": "而趙飛燕爲皇后",
                "5": "伯遂稱篤",
                "6": "久之",
                "7": "上出過臨候伯",
                "8": "伯惶恐",
                "9": "起視事"
            }
        },
        "7": {
            "15": {
                "1": "自大將軍薨後",
                "2": "富平",
                "3": "定陵侯張放",
                "4": "淳於長等始愛幸",
                "5": "出爲微行",
                "6": "行則同輿執轡",
                "7": "入侍禁中",
                "8": "設宴飲之會",
                "9": "及趙",
                "10": "李諸侍中皆引滿舉白",
                "11": "談笑大噱",
                "12": "時乘輿幄坐張畫屛風",
                "13": "畫紂醉踞妲己作長夜之樂",
                "14": "上以伯新起",
                "15": "數目禮之",
                "16": "因顧指畫而問伯",
                "17": "紂爲無道",
                "18": "至於是虖",
                "19": "伯對曰",
                "20": "書云乃用婦人之言",
                "21": "何有踞肆於朝",
                "22": "所謂眾惡歸之",
                "23": "不如是之甚者也",
                "24": "上曰",
                "25": "苟不若此",
                "26": "此圖何戒",
                "27": "伯曰",
                "28": "沈湎於酒",
                "29": "微子所以告去也",
                "30": "式號式謼",
                "31": "大雅所以流連也",
                "32": "詩書淫亂之戒",
                "33": "其原皆在於酒",
                "34": "上乃謂然歎曰",
                "35": "吾久不見班生",
                "36": "今日復聞讜言",
                "37": "放等不懌",
                "38": "稍自引起更衣",
                "39": "因罷出",
                "40": "時長信庭林表適使來",
                "41": "聞見之"
            }
        },
        "8": {
            "17": {
                "1": "後上朝東宮",
                "2": "太后泣曰",
                "3": "帝間顏色瘦黑",
                "4": "班侍中本大將軍所舉",
                "5": "宜寵異之",
                "6": "益求其比",
                "7": "以輔聖德",
                "8": "宜遣富平侯且就國",
                "9": "上曰",
                "10": "諾",
                "11": "車騎將軍王音聞之",
                "12": "以風丞相御史奏富平侯罪過",
                "13": "上乃出放爲邊都尉",
                "14": "後復徵入",
                "15": "太后與上書曰",
                "16": "前所道尙未效",
                "17": "富平侯反復來",
                "18": "其能默虖",
                "19": "上謝曰",
                "20": "請今奉詔",
                "21": "是時許商爲少府",
                "22": "師丹爲光祿勳",
                "23": "上於是引商",
                "24": "丹入爲光祿大夫",
                "25": "伯遷水衡都尉",
                "26": "與兩師並侍中",
                "27": "皆秩中二千石",
                "28": "每朝東宮",
                "29": "常從",
                "30": "及有大政",
                "31": "俱使諭指於公卿",
                "32": "上亦稍厭遊宴",
                "33": "復修經書之業",
                "34": "太后甚悅",
                "35": "丞相方進復奏",
                "36": "富平侯竟就國",
                "37": "會伯病卒",
                "38": "年三十八",
                "39": "朝廷愍惜焉"
            }
        },
        "9": {
            "19": {
                "1": "斿博學有俊材",
                "2": "左將軍師丹舉賢良方正",
                "3": "以對策爲議郎",
                "4": "遷諫大夫",
                "5": "右曹中郎將",
                "6": "與劉向校祕書",
                "7": "每奏事",
                "8": "斿以選受詔進讀羣書",
                "9": "上器其能",
                "10": "賜以祕書之副",
                "11": "時書不布",
                "12": "自東平思王以叔父求太史公",
                "13": "諸子書",
                "14": "大將軍白不許",
                "15": "語在東平王傳",
                "16": "斿亦早卒",
                "17": "有子曰嗣",
                "18": "顯名當世"
            }
        },
        "10": {
            "21": {
                "1": "稚少爲黃門郎中常侍",
                "2": "方直自守",
                "3": "成帝季年",
                "4": "立定陶王爲太子",
                "5": "數遣中盾請問近臣",
                "6": "稚獨不敢答",
                "7": "哀帝卽位",
                "8": "出稚爲西河屬國都尉",
                "9": "遷廣平相"
            }
        },
        "11": {
            "23": {
                "1": "王莽少與稚兄弟同列友善",
                "2": "兄事斿而弟畜稚",
                "3": "斿之卒也",
                "4": "修緦麻",
                "5": "賻賵甚厚",
                "6": "平帝卽位",
                "7": "太后臨朝",
                "8": "莽秉政",
                "9": "方欲文致太平",
                "10": "使使者分行風俗",
                "11": "采頌聲",
                "12": "而稚無所上",
                "13": "琅邪太守公孫閎言災害於公府",
                "14": "大司空甄豐遣屬馳至兩郡諷吏民",
                "15": "而劾閎空造不祥",
                "16": "稚絕嘉應",
                "17": "嫉害聖政",
                "18": "皆不道",
                "19": "太后曰",
                "20": "不宣德美",
                "21": "宜與言災害者異罰",
                "22": "且後宮賢家",
                "23": "我所哀也",
                "24": "閎獨下獄誅",
                "25": "稚懼",
                "26": "上書陳恩謝罪",
                "27": "願歸相印",
                "28": "入補延陵園郎",
                "29": "太后許焉",
                "30": "食故祿終身",
                "31": "由是班氏不顯莽朝",
                "32": "亦不罹咎"
            }
        },
        "12": {
            "25": {
                "1": "初",
                "2": "成帝性寬",
                "3": "進入直言",
                "4": "是以王音",
                "5": "翟方進等繩法舉過",
                "6": "而劉向",
                "7": "杜鄴",
                "8": "王章",
                "9": "朱雲之徒肆意犯上",
                "10": "故自帝師安昌侯",
                "11": "諸舅大將軍兄弟及公卿大夫",
                "12": "後宮外屬史許之家有貴寵者",
                "13": "莫不被文傷詆",
                "14": "唯谷永嘗言建始",
                "15": "河平之際",
                "16": "許",
                "17": "班之貴",
                "18": "傾動前朝",
                "19": "熏灼四方",
                "20": "賞賜無量",
                "21": "空虛內臧",
                "22": "女寵至極",
                "23": "不可尙矣",
                "24": "今之後起",
                "25": "天所不饗",
                "26": "什倍於前",
                "27": "永指以駮譏趙",
                "28": "李",
                "29": "亦無間云"
            }
        },
        "13": {
            "27": {
                "1": "稚生彪",
                "2": "彪字叔皮",
                "3": "幼與從兄嗣共遊學",
                "4": "家有賜書",
                "5": "內足於財",
                "6": "好古之士自遠方至",
                "7": "父黨揚子雲以下莫不造門"
            }
        },
        "14": {
            "29": {
                "1": "嗣雖修儒學",
                "2": "然貴老嚴之術",
                "3": "桓生欲借其書",
                "4": "嗣報曰",
                "5": "若夫嚴子者",
                "6": "絕聖棄智",
                "7": "修生保眞",
                "8": "清虛澹泊",
                "9": "歸之自然",
                "10": "獨師友造化",
                "11": "而不爲世俗所役者也",
                "12": "漁釣於一壑",
                "13": "則萬物不奸其志",
                "14": "栖遲於一丘",
                "15": "則天下不易其樂",
                "16": "不絓聖人之罔",
                "17": "不齅驕君之餌",
                "18": "蕩然肆志",
                "19": "談者不得而名焉",
                "20": "故可貴也",
                "21": "今吾子已貫仁誼之羈絆",
                "22": "繫名聲之韁鎖",
                "23": "伏周",
                "24": "孔之軌躅",
                "25": "馳顏",
                "26": "閔之極摯",
                "27": "旣繫攣於世教矣",
                "28": "何用大道爲自眩曜",
                "29": "昔有學步於邯鄲者",
                "30": "曾未得其髣彿",
                "31": "又復失其故步",
                "32": "遂匍匐而歸耳",
                "33": "恐似此類",
                "34": "故不進",
                "35": "嗣之行己持論如此"
            }
        },
        "15": {
            "31": {
                "1": "叔皮唯聖人之道然後盡心焉",
                "2": "年二十",
                "3": "遭王莽敗",
                "4": "世祖卽位於冀州",
                "5": "時隗囂據壟擁眾",
                "6": "招輯英俊",
                "7": "而公孫述稱帝於蜀漢",
                "8": "天下雲擾",
                "9": "大者連州郡",
                "10": "小者據縣邑",
                "11": "囂問彪曰",
                "12": "往者周亡",
                "13": "戰國並爭",
                "14": "天下分裂",
                "15": "數世然後乃定",
                "16": "其抑者從橫之事復起於今乎",
                "17": "將承運迭興在於一人也",
                "18": "願先生論之",
                "19": "對曰",
                "20": "周之廢興與漢異",
                "21": "昔周立爵五等",
                "22": "諸侯從政",
                "23": "本根旣微",
                "24": "枝葉強大",
                "25": "故其末流有從橫之事",
                "26": "其勢然也",
                "27": "漢家承秦之制",
                "28": "並立郡縣",
                "29": "主有專己之威",
                "30": "臣無百年之柄",
                "31": "至於成帝",
                "32": "假借外家",
                "33": "哀",
                "34": "平短祚",
                "35": "國嗣三絕",
                "36": "危自上起",
                "37": "傷不及下",
                "38": "故王氏之貴",
                "39": "傾擅朝廷",
                "40": "能竊號位",
                "41": "而不根於民",
                "42": "是以卽眞之後",
                "43": "天下莫不引領而歎",
                "44": "十餘年間",
                "45": "外內騷擾",
                "46": "遠近俱發",
                "47": "假號雲合",
                "48": "咸稱劉氏",
                "49": "不謀而同辭",
                "50": "方今雄桀帶州城者",
                "51": "皆無七國世業之資",
                "52": "詩云",
                "53": "皇矣上帝",
                "54": "臨下有赫",
                "55": "鑒觀四方",
                "56": "求民之莫",
                "57": "今民皆謳吟思漢",
                "58": "鄕仰劉氏",
                "59": "已可知矣",
                "60": "囂曰",
                "61": "先生言周",
                "62": "漢之勢",
                "63": "可也",
                "64": "至於但見愚民習識劉氏姓號之故",
                "65": "而謂漢家復興",
                "66": "疏矣",
                "67": "昔秦失其鹿",
                "68": "劉季逐而掎之",
                "69": "時民復知漢虖",
                "70": "旣感囂言",
                "71": "又愍狂狡之不息",
                "72": "乃著王命論以救時難",
                "73": "其辭曰"
            }
        },
        "16": {
            "33": {
                "1": "昔在帝堯之禪曰",
                "2": "咨爾舜",
                "3": "天之曆數在爾躬",
                "4": "舜亦以命禹",
                "5": "臮於稷𢍆",
                "6": "咸佐唐虞",
                "7": "光濟四海",
                "8": "奕世載德",
                "9": "至於湯武",
                "10": "而有天下",
                "11": "雖其遭遇異時",
                "12": "禪代不同",
                "13": "至於應天順民",
                "14": "其揆一也",
                "15": "是故劉氏承堯之祚",
                "16": "氏族之世",
                "17": "著乎春秋",
                "18": "唐據火德",
                "19": "而漢紹之",
                "20": "始起沛澤",
                "21": "則神母夜號",
                "22": "以章赤帝之符",
                "23": "由是言之",
                "24": "帝王之祚",
                "25": "必有明聖顯懿之德",
                "26": "豐功厚利積絫之業",
                "27": "然後精誠通於神明",
                "28": "流澤加於生民",
                "29": "故能爲鬼神所福饗",
                "30": "天下所歸往",
                "31": "未見運世無本",
                "32": "功德不紀",
                "33": "而得屈起在此位者也",
                "34": "世俗見高祖興於布衣",
                "35": "不達其故",
                "36": "以爲適遭暴亂",
                "37": "得奮其劍",
                "38": "遊說之士至比天下於逐鹿",
                "39": "幸捷而得之",
                "40": "不知神器有命",
                "41": "不可以智力求也",
                "42": "悲夫",
                "43": "此世所以多亂臣賊子者也",
                "44": "若然者",
                "45": "豈徒闇於天道哉",
                "46": "又不睹之於人事矣"
            }
        },
        "17": {
            "35": {
                "1": "夫餓饉流隸",
                "2": "飢寒道路",
                "3": "思有裋褐之褻",
                "4": "儋石之畜",
                "5": "所願不過一金",
                "6": "然終於轉死溝壑",
                "7": "何則",
                "8": "貧窮亦有命也",
                "9": "況虖天子之貴",
                "10": "四海之富",
                "11": "神明之祚",
                "12": "可得而妄處哉",
                "13": "故雖遭罹阨會",
                "14": "竊其權柄",
                "15": "勇如信",
                "16": "布",
                "17": "彊如梁",
                "18": "籍",
                "19": "成如王莽",
                "20": "然卒潤鑊伏質",
                "21": "亨醢分裂",
                "22": "又況幺䯢",
                "23": "尙不及數子",
                "24": "而欲闇奸天位者虖",
                "25": "是故駑蹇之乘不騁千里之塗",
                "26": "燕雀之疇不奮六翮之用",
                "27": "楶梲之材不荷棟梁之任",
                "28": "斗筲之子不秉帝王之重",
                "29": "易曰鼎折足",
                "30": "覆公餗",
                "31": "不勝其任也"
            }
        },
        "18": {
            "37": {
                "1": "當秦之末",
                "2": "豪桀共推陳嬰而王之",
                "3": "嬰母止之曰",
                "4": "自吾爲子家婦",
                "5": "而世貧賤",
                "6": "卒富貴不祥",
                "7": "不如以兵屬人",
                "8": "事成少受其利",
                "9": "不成禍有所歸",
                "10": "嬰從其言",
                "11": "而陳氏以寧",
                "12": "王陵之母亦見項氏之必亡",
                "13": "而劉氏之將興也",
                "14": "是時陵爲漢將",
                "15": "而母獲於楚",
                "16": "有漢使來",
                "17": "陵母見之",
                "18": "謂曰",
                "19": "願告吾子",
                "20": "漢王長者",
                "21": "必得天下",
                "22": "子謹事之",
                "23": "無有二心",
                "24": "遂對漢使伏劍而死",
                "25": "以固勉陵",
                "26": "其後果定於漢",
                "27": "陵爲宰相封侯",
                "28": "夫以匹婦之明",
                "29": "猶能推事理之致",
                "30": "探禍福之機",
                "31": "而全宗祀於無窮",
                "32": "垂策書於春秋",
                "33": "而況大丈夫之事虖",
                "34": "是故窮達有命",
                "35": "吉凶由人",
                "36": "嬰母知廢",
                "37": "陵母知興",
                "38": "審此四者",
                "39": "帝王之分決矣"
            }
        },
        "19": {
            "39": {
                "1": "蓋在高祖",
                "2": "其興也有五",
                "3": "一曰帝堯之苗裔",
                "4": "二曰體貌多奇異",
                "5": "三曰神武有徵應",
                "6": "四曰寬明而仁恕",
                "7": "五曰知人善任使",
                "8": "加之以信誠好謀",
                "9": "達於聽受",
                "10": "見善如不及",
                "11": "用人如由己",
                "12": "從諫如順流",
                "13": "趣時如嚮赴",
                "14": "當食吐哺",
                "15": "納子房之策",
                "16": "拔足揮洗",
                "17": "揖酈生之說",
                "18": "寤戍卒之言",
                "19": "斷懷土之情",
                "20": "高四皓之名",
                "21": "割肌膚之愛",
                "22": "舉韓信於行陳",
                "23": "收陳平於亡命",
                "24": "英雄陳力",
                "25": "羣策畢舉",
                "26": "此高祖之大略",
                "27": "所以成帝業也",
                "28": "若乃靈瑞符應",
                "29": "又可略聞矣",
                "30": "初劉媼任高祖而夢與神遇",
                "31": "震電晦冥",
                "32": "有龍蛇之怪",
                "33": "及其長而多靈",
                "34": "有異於眾",
                "35": "是以王",
                "36": "武感物而折券",
                "37": "呂公睹形而進女",
                "38": "秦皇東遊以厭其氣",
                "39": "呂后望雲而知所處",
                "40": "始受命則白蛇分",
                "41": "西入關則五星聚",
                "42": "故淮陰",
                "43": "留侯謂之天授",
                "44": "非人力也"
            }
        },
        "20": {
            "41": {
                "1": "歷古今之得失",
                "2": "驗行事之成敗",
                "3": "稽帝王之世運",
                "4": "考五者之所謂",
                "5": "取舍不厭斯位",
                "6": "符瑞不同斯度",
                "7": "而苟昧於權利",
                "8": "越次妄據",
                "9": "外不量力",
                "10": "內不知命",
                "11": "則必喪保家之主",
                "12": "失天年之壽",
                "13": "遇折足之凶",
                "14": "伏鈇鉞之誅",
                "15": "英雄誠知覺寤",
                "16": "畏若禍戒",
                "17": "超然遠覽",
                "18": "淵然深識",
                "19": "收陵",
                "20": "嬰之明分",
                "21": "絕信",
                "22": "布之覬覦",
                "23": "距逐鹿之瞽說",
                "24": "審神器之有授",
                "25": "毋貪不可幾",
                "26": "爲二母之所咲",
                "27": "則福祚流於子孫",
                "28": "天祿其永終矣"
            }
        },
        "21": {
            "43": {
                "1": "知隗囂終不寤",
                "2": "乃避墬於河西",
                "3": "河西大將軍竇融嘉其美德",
                "4": "訪問焉",
                "5": "舉茂材",
                "6": "爲徐令",
                "7": "以病去官",
                "8": "後數應三公之召",
                "9": "仕不爲祿",
                "10": "所如不合",
                "11": "學不爲人",
                "12": "博而不俗",
                "13": "言不爲華",
                "14": "述而不作"
            }
        },
        "22": {
            "45": {
                "1": "有子曰固",
                "2": "弱冠而孤",
                "3": "作幽通之賦",
                "4": "以致命遂志",
                "5": "其辭曰"
            }
        },
        "23": {
            "47": {
                "1": "系高頊之玄冑兮",
                "2": "氏中葉之炳靈"
            },
            "48": {
                "1": "繇凱風而蟬蛻兮",
                "2": "雄朔野以颺聲"
            },
            "49": {
                "1": "皇十紀而鴻漸兮",
                "2": "有羽儀於上京"
            },
            "50": {
                "1": "巨滔天而泯夏兮",
                "2": "考遘愍以行謠"
            },
            "51": {
                "1": "終保己而貽則兮",
                "2": "里上仁之所廬"
            },
            "52": {
                "1": "懿前烈之純淑兮",
                "2": "窮與達其必濟"
            },
            "53": {
                "1": "咨孤矇之眇眇兮",
                "2": "將圮絕而罔階"
            },
            "54": {
                "1": "豈余身之足殉兮",
                "2": "愇世業之可懷"
            }
        },
        "24": {
            "56": {
                "1": "靖潛處以永思兮",
                "2": "經日月而彌遠"
            },
            "57": {
                "1": "匪黨人之敢拾兮",
                "2": "庶斯言之不玷"
            },
            "58": {
                "1": "魂煢煢與神交兮",
                "2": "精誠發於宵寐"
            },
            "59": {
                "1": "夢登山而迥眺兮",
                "2": "覿幽人之髣彿"
            },
            "60": {
                "1": "㩜葛藟而授余兮",
                "2": "眷峻谷曰勿隧"
            },
            "61": {
                "1": "昒昕寤而仰思兮",
                "2": "心蒙蒙猶未察"
            },
            "62": {
                "1": "黃神邈而靡質兮",
                "2": "儀遺讖以臆對"
            },
            "63": {
                "1": "曰乘高而遌神兮",
                "2": "道遐通而不迷"
            },
            "64": {
                "1": "葛綿綿於樛木兮",
                "2": "詠南風以爲綏"
            },
            "65": {
                "1": "蓋惴惴之臨深兮",
                "2": "乃二雅之所祇"
            },
            "66": {
                "1": "旣誶爾以吉象兮",
                "2": "又申之以炯戒"
            },
            "67": {
                "1": "盍孟晉以迨羣兮",
                "2": "辰焂忽其不再"
            }
        },
        "25": {
            "69": {
                "1": "承靈訓其虛徐兮",
                "2": "竚盤桓而且俟"
            },
            "70": {
                "1": "惟天墬之無窮兮",
                "2": "鱻生民之脢在"
            },
            "71": {
                "1": "紛屯亶與蹇連兮",
                "2": "何艱多而智寡"
            },
            "72": {
                "1": "上聖寤而後拔兮",
                "2": "豈羣黎之所御"
            },
            "73": {
                "1": "昔衞叔之御昆兮",
                "2": "昆爲寇而喪予"
            },
            "74": {
                "1": "管彎弧欲斃讎兮",
                "2": "讎作后而成己"
            },
            "75": {
                "1": "變化故而相詭兮",
                "2": "孰云豫其終始"
            },
            "76": {
                "1": "雍造怨而先賞兮",
                "2": "丁繇惠而被戮"
            },
            "77": {
                "1": "㮚取弔於逌吉兮",
                "2": "王膺慶於所慼"
            },
            "78": {
                "1": "畔回宂其若茲兮",
                "2": "北叟頗識其倚伏"
            },
            "79": {
                "1": "單治裏而外凋兮",
                "2": "張修襮而內逼"
            },
            "80": {
                "1": "欥中龢爲庶幾兮",
                "2": "顏與冉又不得"
            },
            "81": {
                "1": "溺招路以從己兮",
                "2": "謂孔氏猶未可"
            },
            "82": {
                "1": "安慆慆而不萉兮",
                "2": "卒隕身虖世禍"
            },
            "83": {
                "1": "遊聖門而靡救兮",
                "2": "顧覆醢其何補"
            },
            "84": {
                "1": "固行行其必凶兮",
                "2": "免盜亂爲賴道"
            },
            "85": {
                "1": "形氣發於根柢兮",
                "2": "柯葉彙而靈茂"
            },
            "86": {
                "1": "恐网蜽之責景兮",
                "2": "慶未得其云已"
            }
        },
        "26": {
            "88": {
                "1": "黎淳耀於高辛兮",
                "2": "羋彊大於南汜"
            },
            "89": {
                "1": "嬴取威於百儀兮",
                "2": "姜本支虖三止"
            },
            "90": {
                "1": "旣仁得其信然兮",
                "2": "卬天路而同軌"
            },
            "91": {
                "1": "東厸虐而殲仁兮",
                "2": "王合位虖三五"
            },
            "92": {
                "1": "戎女烈而喪孝兮",
                "2": "伯徂歸於龍虎"
            },
            "93": {
                "1": "發還師以成性兮",
                "2": "重醉行而自耦"
            },
            "94": {
                "1": "震鱗漦於夏庭兮",
                "2": "匝三正而滅周"
            },
            "95": {
                "1": "巽羽化於宣宮兮",
                "2": "彌五辟而成災"
            }
        },
        "27": {
            "97": {
                "1": "道悠長而世短兮",
                "2": "敻冥默而不周"
            },
            "98": {
                "1": "胥仍物而鬼諏兮",
                "2": "乃窮宙而達幽"
            },
            "99": {
                "1": "媯巢姜於孺筮兮",
                "2": "旦算祀於挈龜"
            },
            "100": {
                "1": "宣",
                "2": "曹興敗於下夢兮",
                "3": "魯",
                "4": "衞名諡於銘謠"
            },
            "101": {
                "1": "妣聆呱而刻石兮",
                "2": "許相理而鞠條"
            },
            "102": {
                "1": "道混成而自然兮",
                "2": "術同原而分流"
            },
            "103": {
                "1": "神先心以定命兮",
                "2": "命隨行以消息"
            },
            "104": {
                "1": "斡流遷其不濟兮",
                "2": "故遭罹而贏縮"
            },
            "105": {
                "1": "三欒同於一體兮",
                "2": "雖移盈然不忒"
            },
            "106": {
                "1": "洞參差其紛錯兮",
                "2": "斯眾兆之所惑"
            },
            "107": {
                "1": "周",
                "2": "賈盪而貢憤兮",
                "3": "齊死生與禍福"
            },
            "108": {
                "1": "抗爽言以矯情兮",
                "2": "信畏犧而忌服"
            }
        },
        "28": {
            "110": {
                "1": "所貴聖人之至論兮",
                "2": "順天性而斷誼"
            },
            "111": {
                "1": "物有欲而不居兮",
                "2": "亦有惡而不避"
            },
            "112": {
                "1": "守孔約而不貳兮",
                "2": "乃輶德而無累"
            },
            "113": {
                "1": "三仁殊而一致兮",
                "2": "夷",
                "3": "惠舛而齊聲"
            },
            "114": {
                "1": "木偃息以蕃魏兮",
                "2": "申重繭以存荊"
            },
            "115": {
                "1": "紀焚躬以衞上兮",
                "2": "皓頤志而弗營"
            },
            "116": {
                "1": "侯屮木之區別兮",
                "2": "苟能實而必榮"
            },
            "117": {
                "1": "要沒世而不朽兮",
                "2": "乃先民之所程"
            }
        },
        "29": {
            "119": {
                "1": "觀天罔之紘覆兮",
                "2": "實棐諶而相順"
            },
            "120": {
                "1": "謨先聖之大繇兮",
                "2": "亦厸德而助信"
            },
            "121": {
                "1": "虞韶美而儀鳳兮",
                "2": "孔忘味於千載"
            },
            "122": {
                "1": "素文信而底麟兮",
                "2": "漢賓祚於異代"
            },
            "123": {
                "1": "精通靈而感物兮",
                "2": "神動氣而入微"
            },
            "124": {
                "1": "養遊睇而猿號兮",
                "2": "李虎發而石開"
            },
            "125": {
                "1": "非精誠其焉通兮",
                "2": "苟無實其孰信"
            },
            "126": {
                "1": "操末技猶必然兮",
                "2": "矧湛躬於道眞"
            },
            "127": {
                "1": "登孔",
                "2": "顥而上下兮",
                "3": "緯羣龍之所經"
            },
            "128": {
                "1": "朝貞觀而夕化兮",
                "2": "猶諠己而遺形"
            },
            "129": {
                "1": "若胤彭而偕老兮",
                "2": "訴來哲以通情"
            }
        },
        "30": {
            "131": {
                "1": "亂曰",
                "2": "天造屮昧",
                "3": "立性命兮",
                "4": "復心弘道",
                "5": "惟賢聖兮",
                "6": "渾元運物",
                "7": "流不處兮",
                "8": "保身遺名",
                "9": "民之表兮",
                "10": "舍生取誼",
                "11": "亦道用兮",
                "12": "憂傷夭物",
                "13": "忝莫痛兮",
                "14": "昊爾太素",
                "15": "曷渝色兮",
                "16": "尙粵其幾",
                "17": "淪神域兮"
            }
        },
        "31": {
            "133": {
                "1": "永平中爲郎",
                "2": "典校祕書",
                "3": "專篤志於博學",
                "4": "以著述爲業",
                "5": "或譏以無功",
                "6": "又感東方朔",
                "7": "揚雄自諭以不遭蘇",
                "8": "張",
                "9": "范",
                "10": "蔡之時",
                "11": "曾不折之以正道",
                "12": "明君子之所守",
                "13": "故聊復應焉",
                "14": "其辭曰"
            }
        },
        "32": {
            "135": {
                "1": "賓戲主人曰",
                "2": "蓋聞聖人有壹定之論",
                "3": "列士有不易之分",
                "4": "亦云名而已矣",
                "5": "故太上有立德",
                "6": "其次有立功",
                "7": "夫德不得後身而特盛",
                "8": "功不得背時而獨章",
                "9": "是以聖喆之治",
                "10": "栖栖皇皇",
                "11": "孔席不煗",
                "12": "墨突不黔",
                "13": "由此言之",
                "14": "取舍者昔人之上務",
                "15": "著作者前列之餘事耳",
                "16": "今吾子幸遊帝王之世",
                "17": "躬帶冕之服",
                "18": "浮英華",
                "19": "湛道德",
                "20": "矕龍虎之文",
                "21": "舊矣",
                "22": "卒不能攄首尾",
                "23": "奮翼鱗",
                "24": "振拔洿塗",
                "25": "跨騰風雲",
                "26": "使見之者景駭",
                "27": "聞之者嚮震",
                "28": "徒樂枕經籍書",
                "29": "紆體衡門",
                "30": "上無所蔕",
                "31": "下無所根",
                "32": "獨攄意虖宇宙之外",
                "33": "銳思於豪芒之內",
                "34": "潛神默記",
                "35": "恆以年歲",
                "36": "然而器不賈於當己",
                "37": "用不效於一世",
                "38": "雖馳辯如濤波",
                "39": "摛藻如春華",
                "40": "猶無益於殿最",
                "41": "意者",
                "42": "且運朝夕之策",
                "43": "定合會之計",
                "44": "使存有顯號",
                "45": "亡有美諡",
                "46": "不亦優虖"
            }
        },
        "33": {
            "137": {
                "1": "主人逌爾而咲曰",
                "2": "若賓之言",
                "3": "斯所謂見勢利之華",
                "4": "闇道德之實",
                "5": "守穾奧之熒燭",
                "6": "未卬天庭而睹白日也",
                "7": "曩者王塗蕪穢",
                "8": "周失其御",
                "9": "侯伯方軌",
                "10": "戰國橫騖",
                "11": "於是七雄虓闞",
                "12": "分裂諸夏",
                "13": "龍戰而虎爭",
                "14": "遊說之徒",
                "15": "風颺電激",
                "16": "並起而救之",
                "17": "其餘猋飛景附",
                "18": "煜霅其間者",
                "19": "蓋不可勝載",
                "20": "當此之時",
                "21": "搦朽摩鈍",
                "22": "鈆刀皆能壹斷",
                "23": "是故魯連飛一矢而蹶千金",
                "24": "虞卿以顧眄而捐相印也",
                "25": "夫啾發投曲",
                "26": "感耳之聲",
                "27": "合之律度",
                "28": "淫䵷而不可聽者",
                "29": "非韶",
                "30": "夏之樂也",
                "31": "因勢合變",
                "32": "偶時之會",
                "33": "風移俗易",
                "34": "乖忤而不可通者",
                "35": "非君子之法也",
                "36": "及至從人合之",
                "37": "衡人散之",
                "38": "亡命漂說",
                "39": "羈旅騁辭",
                "40": "商鞅挾三術以鑽孝公",
                "41": "李斯奮時務而要始皇",
                "42": "彼皆躡風雲之會",
                "43": "履顚沛之勢",
                "44": "據徼乘邪以求一日之富貴",
                "45": "朝爲榮華",
                "46": "夕而焦瘁",
                "47": "福不盈眥",
                "48": "禍益於世",
                "49": "凶人且以自悔",
                "50": "況吉士而是賴虖",
                "51": "且功不可以虛成",
                "52": "名不可以僞立",
                "53": "韓設辯以徼君",
                "54": "呂行詐以賈國",
                "55": "說難旣酋",
                "56": "其身乃囚",
                "57": "秦貨旣貴",
                "58": "厥宗亦隧",
                "59": "是故仲尼抗浮雲之志",
                "60": "孟軻養浩然之氣",
                "61": "彼豈樂爲迂闊哉",
                "62": "道不可以貳也",
                "63": "方今大漢灑埽羣穢",
                "64": "夷險芟荒",
                "65": "廓帝紘",
                "66": "恢皇綱",
                "67": "基隆於羲",
                "68": "農",
                "69": "規廣於黃",
                "70": "唐",
                "71": "其君天下也",
                "72": "炎之如日",
                "73": "威之如神",
                "74": "函之如海",
                "75": "養之如春",
                "76": "是以六合之內",
                "77": "莫不同原共流",
                "78": "沐浴玄德",
                "79": "稟卬太和",
                "80": "枝附葉著",
                "81": "譬猶屮木之殖山林",
                "82": "鳥魚之毓川澤",
                "83": "得氣者蕃滋",
                "84": "失時者苓落",
                "85": "參天墬而施化",
                "86": "豈云人事之厚薄哉",
                "87": "今子處皇世而論戰國",
                "88": "耀所聞而疑所覿",
                "89": "欲從旄敦而度高虖泰山",
                "90": "懷氿濫而測深虖重淵",
                "91": "亦未至也"
            }
        },
        "34": {
            "139": {
                "1": "賓曰",
                "2": "若夫鞅",
                "3": "斯之倫",
                "4": "衰周之凶人",
                "5": "旣聞命矣",
                "6": "敢問上古之士",
                "7": "處身行道",
                "8": "輔世成名",
                "9": "可述於後者",
                "10": "默而已虖"
            }
        },
        "35": {
            "141": {
                "1": "主人曰",
                "2": "何爲其然也",
                "3": "昔咎繇謨虞",
                "4": "箕子訪周",
                "5": "言通帝王",
                "6": "謀合聖神",
                "7": "殷說夢發於傅巖",
                "8": "周望兆動於渭濱",
                "9": "齊甯激聲於康衢",
                "10": "漢良受書於邳沂",
                "11": "皆俟命而神交",
                "12": "匪詞言之所信",
                "13": "故能建必然之策",
                "14": "展無窮之勳也",
                "15": "近者陸子優繇",
                "16": "新語以興",
                "17": "董生下帷",
                "18": "發藻儒林",
                "19": "劉向司籍",
                "20": "辯章舊聞",
                "21": "揚雄覃思",
                "22": "法言",
                "23": "大玄",
                "24": "皆及時君之門闈",
                "25": "究先聖之壼奧",
                "26": "婆娑虖術藝之場",
                "27": "休息虖篇籍之囿",
                "28": "以全其質而發其文",
                "29": "用納虖聖聽",
                "30": "列炳於後人",
                "31": "斯非其亞與",
                "32": "若乃夷抗行於首陽",
                "33": "惠降志於辱仕",
                "34": "顏耽樂於簞瓢",
                "35": "孔終篇於西狩",
                "36": "聲盈塞於天淵",
                "37": "眞吾徒之師表也",
                "38": "且吾聞之",
                "39": "壹陰壹陽",
                "40": "天墬之方",
                "41": "乃文乃質",
                "42": "王道之綱",
                "43": "有同有異",
                "44": "聖喆之常",
                "45": "故曰",
                "46": "愼修所志",
                "47": "守爾天符",
                "48": "委命共己",
                "49": "味道之腴",
                "50": "神之聽之",
                "51": "名其舍諸",
                "52": "賓又不聞龢氏之璧韞於荊石",
                "53": "隨侯之珠藏於蜯蛤虖",
                "54": "歷世莫眡",
                "55": "不知其將含景耀",
                "56": "吐英精",
                "57": "曠千載而流夜光也",
                "58": "應龍潛於潢汙",
                "59": "魚黿媟之",
                "60": "不睹其能奮靈德",
                "61": "合風雲",
                "62": "超忽荒",
                "63": "而躆顥蒼也",
                "64": "故夫泥蟠而天飛者",
                "65": "應龍之神也",
                "66": "先賤而後貴者",
                "67": "龢",
                "68": "隨之珍也",
                "69": "時闇而久章者",
                "70": "君子之眞也",
                "71": "若乃牙",
                "72": "曠清耳於管絃",
                "73": "離婁眇目於豪分",
                "74": "逢蒙絕技於弧矢",
                "75": "班輸榷巧於斧斤",
                "76": "良樂軼能於相馭",
                "77": "烏獲抗力於千鈞",
                "78": "龢",
                "79": "鵲發精於鍼石",
                "80": "硏",
                "81": "桑心計於無垠",
                "82": "僕亦不任廁技於彼列",
                "83": "故密爾自娛於斯文"
            }
        }
    }
}