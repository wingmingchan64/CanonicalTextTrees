    "HANSHU,100-1,11,23,31": "由是班氏不顯莽朝",
    "HANSHU,100-1,11,23,32": "亦不罹咎",
    "HANSHU,100-1,12,25,1": "初",
    "HANSHU,100-1,12,25,2": "成帝性寬",
    "HANSHU,100-1,12,25,3": "進入直言",
    "HANSHU,100-1,12,25,4": "是以王音",
    "HANSHU,100-1,12,25,5": "翟方進等繩法舉過",
    "HANSHU,100-1,12,25,6": "而劉向",
    "HANSHU,100-1,12,25,7": "杜鄴",
    "HANSHU,100-1,12,25,8": "王章",
    "HANSHU,100-1,12,25,9": "朱雲之徒肆意犯上",
    "HANSHU,100-1,12,25,10": "故自帝師安昌侯",
    "HANSHU,100-1,12,25,11": "諸舅大將軍兄弟及公卿大夫",
    "HANSHU,100-1,12,25,12": "後宮外屬史許之家有貴寵者",
    "HANSHU,100-1,12,25,13": "莫不被文傷詆",
    "HANSHU,100-1,12,25,14": "唯谷永嘗言建始",
    "HANSHU,100-1,12,25,15": "河平之際",
    "HANSHU,100-1,12,25,16": "許",
    "HANSHU,100-1,12,25,17": "班之貴",
    "HANSHU,100-1,12,25,18": "傾動前朝",
    "HANSHU,100-1,12,25,19": "熏灼四方",
    "HANSHU,100-1,12,25,20": "賞賜無量",
    "HANSHU,100-1,12,25,21": "空虛內臧",
    "HANSHU,100-1,12,25,22": "女寵至極",
    "HANSHU,100-1,12,25,23": "不可尙矣",
    "HANSHU,100-1,12,25,24": "今之後起",
    "HANSHU,100-1,12,25,25": "天所不饗",
    "HANSHU,100-1,12,25,26": "什倍於前",
    "HANSHU,100-1,12,25,27": "永指以駮譏趙",
    "HANSHU,100-1,12,25,28": "李",
    "HANSHU,100-1,12,25,29": "亦無間云",
    "HANSHU,100-1,13,27,1": "稚生彪",
    "HANSHU,100-1,13,27,2": "彪字叔皮",
    "HANSHU,100-1,13,27,3": "幼與從兄嗣共遊學",
    "HANSHU,100-1,13,27,4": "家有賜書",
    "HANSHU,100-1,13,27,5": "內足於財",
    "HANSHU,100-1,13,27,6": "好古之士自遠方至",
    "HANSHU,100-1,13,27,7": "父黨揚子雲以下莫不造門",
    "HANSHU,100-1,14,29,1": "嗣雖修儒學",
    "HANSHU,100-1,14,29,2": "然貴老嚴之術",
    "HANSHU,100-1,14,29,3": "桓生欲借其書",
    "HANSHU,100-1,14,29,4": "嗣報曰",
    "HANSHU,100-1,14,29,5": "若夫嚴子者",
    "HANSHU,100-1,14,29,6": "絕聖棄智",
    "HANSHU,100-1,14,29,7": "修生保眞",
    "HANSHU,100-1,14,29,8": "清虛澹泊",
    "HANSHU,100-1,14,29,9": "歸之自然",
    "HANSHU,100-1,14,29,10": "獨師友造化",
    "HANSHU,100-1,14,29,11": "而不爲世俗所役者也",
    "HANSHU,100-1,14,29,12": "漁釣於一壑",
    "HANSHU,100-1,14,29,13": "則萬物不奸其志",
    "HANSHU,100-1,14,29,14": "栖遲於一丘",
    "HANSHU,100-1,14,29,15": "則天下不易其樂",
    "HANSHU,100-1,14,29,16": "不絓聖人之罔",
    "HANSHU,100-1,14,29,17": "不齅驕君之餌",
    "HANSHU,100-1,14,29,18": "蕩然肆志",
    "HANSHU,100-1,14,29,19": "談者不得而名焉",
    "HANSHU,100-1,14,29,20": "故可貴也",
    "HANSHU,100-1,14,29,21": "今吾子已貫仁誼之羈絆",
    "HANSHU,100-1,14,29,22": "繫名聲之韁鎖",
    "HANSHU,100-1,14,29,23": "伏周",
    "HANSHU,100-1,14,29,24": "孔之軌躅",
    "HANSHU,100-1,14,29,25": "馳顏",
    "HANSHU,100-1,14,29,26": "閔之極摯",
    "HANSHU,100-1,14,29,27": "旣繫攣於世教矣",
    "HANSHU,100-1,14,29,28": "何用大道爲自眩曜",
    "HANSHU,100-1,14,29,29": "昔有學步於邯鄲者",
    "HANSHU,100-1,14,29,30": "曾未得其髣彿",
    "HANSHU,100-1,14,29,31": "又復失其故步",
    "HANSHU,100-1,14,29,32": "遂匍匐而歸耳",
    "HANSHU,100-1,14,29,33": "恐似此類",
    "HANSHU,100-1,14,29,34": "故不進",
    "HANSHU,100-1,14,29,35": "嗣之行己持論如此",
    "HANSHU,100-1,15,31,1": "叔皮唯聖人之道然後盡心焉",
    "HANSHU,100-1,15,31,2": "年二十",
    "HANSHU,100-1,15,31,3": "遭王莽敗",
    "HANSHU,100-1,15,31,4": "世祖卽位於冀州",
    "HANSHU,100-1,15,31,5": "時隗囂據壟擁眾",
    "HANSHU,100-1,15,31,6": "招輯英俊",
    "HANSHU,100-1,15,31,7": "而公孫述稱帝於蜀漢",
    "HANSHU,100-1,15,31,8": "天下雲擾",
    "HANSHU,100-1,15,31,9": "大者連州郡",
    "HANSHU,100-1,15,31,10": "小者據縣邑",
    "HANSHU,100-1,15,31,11": "囂問彪曰",
    "HANSHU,100-1,15,31,12": "往者周亡",
    "HANSHU,100-1,15,31,13": "戰國並爭",
    "HANSHU,100-1,15,31,14": "天下分裂",
    "HANSHU,100-1,15,31,15": "數世然後乃定",
    "HANSHU,100-1,15,31,16": "其抑者從橫之事復起於今乎",
    "HANSHU,100-1,15,31,17": "將承運迭興在於一人也",
    "HANSHU,100-1,15,31,18": "願先生論之",
    "HANSHU,100-1,15,31,19": "對曰",
    "HANSHU,100-1,15,31,20": "周之廢興與漢異",
    "HANSHU,100-1,15,31,21": "昔周立爵五等",
    "HANSHU,100-1,15,31,22": "諸侯從政",
    "HANSHU,100-1,15,31,23": "本根旣微",
    "HANSHU,100-1,15,31,24": "枝葉強大",
    "HANSHU,100-1,15,31,25": "故其末流有從橫之事",
    "HANSHU,100-1,15,31,26": "其勢然也",
    "HANSHU,100-1,15,31,27": "漢家承秦之制",
    "HANSHU,100-1,15,31,28": "並立郡縣",
    "HANSHU,100-1,15,31,29": "主有專己之威",
    "HANSHU,100-1,15,31,30": "臣無百年之柄",
    "HANSHU,100-1,15,31,31": "至於成帝",
    "HANSHU,100-1,15,31,32": "假借外家",
    "HANSHU,100-1,15,31,33": "哀",
    "HANSHU,100-1,15,31,34": "平短祚",
    "HANSHU,100-1,15,31,35": "國嗣三絕",
    "HANSHU,100-1,15,31,36": "危自上起",
    "HANSHU,100-1,15,31,37": "傷不及下",
    "HANSHU,100-1,15,31,38": "故王氏之貴",
    "HANSHU,100-1,15,31,39": "傾擅朝廷",
    "HANSHU,100-1,15,31,40": "能竊號位",
    "HANSHU,100-1,15,31,41": "而不根於民",
    "HANSHU,100-1,15,31,42": "是以卽眞之後",
    "HANSHU,100-1,15,31,43": "天下莫不引領而歎",
    "HANSHU,100-1,15,31,44": "十餘年間",
    "HANSHU,100-1,15,31,45": "外內騷擾",
    "HANSHU,100-1,15,31,46": "遠近俱發",
    "HANSHU,100-1,15,31,47": "假號雲合",
    "HANSHU,100-1,15,31,48": "咸稱劉氏",
    "HANSHU,100-1,15,31,49": "不謀而同辭",
    "HANSHU,100-1,15,31,50": "方今雄桀帶州城者",
    "HANSHU,100-1,15,31,51": "皆無七國世業之資",
    "HANSHU,100-1,15,31,52": "詩云",
    "HANSHU,100-1,15,31,53": "皇矣上帝",
    "HANSHU,100-1,15,31,54": "臨下有赫",
    "HANSHU,100-1,15,31,55": "鑒觀四方",
    "HANSHU,100-1,15,31,56": "求民之莫",
    "HANSHU,100-1,15,31,57": "今民皆謳吟思漢",
    "HANSHU,100-1,15,31,58": "鄕仰劉氏",
    "HANSHU,100-1,15,31,59": "已可知矣",
    "HANSHU,100-1,15,31,60": "囂曰",
    "HANSHU,100-1,15,31,61": "先生言周",
    "HANSHU,100-1,15,31,62": "漢之勢",
    "HANSHU,100-1,15,31,63": "可也",
    "HANSHU,100-1,15,31,64": "至於但見愚民習識劉氏姓號之故",
    "HANSHU,100-1,15,31,65": "而謂漢家復興",
    "HANSHU,100-1,15,31,66": "疏矣",
    "HANSHU,100-1,15,31,67": "昔秦失其鹿",
    "HANSHU,100-1,15,31,68": "劉季逐而掎之",
    "HANSHU,100-1,15,31,69": "時民復知漢虖",
    "HANSHU,100-1,15,31,70": "旣感囂言",
    "HANSHU,100-1,15,31,71": "又愍狂狡之不息",
    "HANSHU,100-1,15,31,72": "乃著王命論以救時難",
    "HANSHU,100-1,15,31,73": "其辭曰",
    "HANSHU,100-1,16,33,1": "昔在帝堯之禪曰",
    "HANSHU,100-1,16,33,2": "咨爾舜",
    "HANSHU,100-1,16,33,3": "天之曆數在爾躬",
    "HANSHU,100-1,16,33,4": "舜亦以命禹",
    "HANSHU,100-1,16,33,5": "臮於稷𢍆",
    "HANSHU,100-1,16,33,6": "咸佐唐虞",
    "HANSHU,100-1,16,33,7": "光濟四海",
    "HANSHU,100-1,16,33,8": "奕世載德",
    "HANSHU,100-1,16,33,9": "至於湯武",
    "HANSHU,100-1,16,33,10": "而有天下",
    "HANSHU,100-1,16,33,11": "雖其遭遇異時",
    "HANSHU,100-1,16,33,12": "禪代不同",
    "HANSHU,100-1,16,33,13": "至於應天順民",
    "HANSHU,100-1,16,33,14": "其揆一也",
    "HANSHU,100-1,16,33,15": "是故劉氏承堯之祚",
    "HANSHU,100-1,16,33,16": "氏族之世",
    "HANSHU,100-1,16,33,17": "著乎春秋",
    "HANSHU,100-1,16,33,18": "唐據火德",
    "HANSHU,100-1,16,33,19": "而漢紹之",
    "HANSHU,100-1,16,33,20": "始起沛澤",
    "HANSHU,100-1,16,33,21": "則神母夜號",
    "HANSHU,100-1,16,33,22": "以章赤帝之符",
    "HANSHU,100-1,16,33,23": "由是言之",
    "HANSHU,100-1,16,33,24": "帝王之祚",
    "HANSHU,100-1,16,33,25": "必有明聖顯懿之德",
    "HANSHU,100-1,16,33,26": "豐功厚利積絫之業",
    "HANSHU,100-1,16,33,27": "然後精誠通於神明",
    "HANSHU,100-1,16,33,28": "流澤加於生民",
    "HANSHU,100-1,16,33,29": "故能爲鬼神所福饗",
    "HANSHU,100-1,16,33,30": "天下所歸往",
    "HANSHU,100-1,16,33,31": "未見運世無本",
    "HANSHU,100-1,16,33,32": "功德不紀",
    "HANSHU,100-1,16,33,33": "而得屈起在此位者也",
    "HANSHU,100-1,16,33,34": "世俗見高祖興於布衣",
    "HANSHU,100-1,16,33,35": "不達其故",
    "HANSHU,100-1,16,33,36": "以爲適遭暴亂",
    "HANSHU,100-1,16,33,37": "得奮其劍",
    "HANSHU,100-1,16,33,38": "遊說之士至比天下於逐鹿",
    "HANSHU,100-1,16,33,39": "幸捷而得之",
    "HANSHU,100-1,16,33,40": "不知神器有命",
    "HANSHU,100-1,16,33,41": "不可以智力求也",
    "HANSHU,100-1,16,33,42": "悲夫",
    "HANSHU,100-1,16,33,43": "此世所以多亂臣賊子者也",
    "HANSHU,100-1,16,33,44": "若然者",
    "HANSHU,100-1,16,33,45": "豈徒闇於天道哉",
    "HANSHU,100-1,16,33,46": "又不睹之於人事矣",
    "HANSHU,100-1,17,35,1": "夫餓饉流隸",
    "HANSHU,100-1,17,35,2": "飢寒道路",
    "HANSHU,100-1,17,35,3": "思有裋褐之褻",
    "HANSHU,100-1,17,35,4": "儋石之畜",
    "HANSHU,100-1,17,35,5": "所願不過一金",
    "HANSHU,100-1,17,35,6": "然終於轉死溝壑",
    "HANSHU,100-1,17,35,7": "何則",
    "HANSHU,100-1,17,35,8": "貧窮亦有命也",
    "HANSHU,100-1,17,35,9": "況虖天子之貴",
    "HANSHU,100-1,17,35,10": "四海之富",
    "HANSHU,100-1,17,35,11": "神明之祚",
    "HANSHU,100-1,17,35,12": "可得而妄處哉",
    "HANSHU,100-1,17,35,13": "故雖遭罹阨會",
    "HANSHU,100-1,17,35,14": "竊其權柄",
    "HANSHU,100-1,17,35,15": "勇如信",
    "HANSHU,100-1,17,35,16": "布",
    "HANSHU,100-1,17,35,17": "彊如梁",
    "HANSHU,100-1,17,35,18": "籍",
    "HANSHU,100-1,17,35,19": "成如王莽",
    "HANSHU,100-1,17,35,20": "然卒潤鑊伏質",
    "HANSHU,100-1,17,35,21": "亨醢分裂",
    "HANSHU,100-1,17,35,22": "又況幺䯢",
    "HANSHU,100-1,17,35,23": "尙不及數子",
    "HANSHU,100-1,17,35,24": "而欲闇奸天位者虖",
    "HANSHU,100-1,17,35,25": "是故駑蹇之乘不騁千里之塗",
    "HANSHU,100-1,17,35,26": "燕雀之疇不奮六翮之用",
    "HANSHU,100-1,17,35,27": "楶梲之材不荷棟梁之任",
    "HANSHU,100-1,17,35,28": "斗筲之子不秉帝王之重",
    "HANSHU,100-1,17,35,29": "易曰鼎折足",
    "HANSHU,100-1,17,35,30": "覆公餗",
    "HANSHU,100-1,17,35,31": "不勝其任也",
    "HANSHU,100-1,18,37,1": "當秦之末",
    "HANSHU,100-1,18,37,2": "豪桀共推陳嬰而王之",
    "HANSHU,100-1,18,37,3": "嬰母止之曰",
    "HANSHU,100-1,18,37,4": "自吾爲子家婦",
    "HANSHU,100-1,18,37,5": "而世貧賤",
    "HANSHU,100-1,18,37,6": "卒富貴不祥",
    "HANSHU,100-1,18,37,7": "不如以兵屬人",
    "HANSHU,100-1,18,37,8": "事成少受其利",
    "HANSHU,100-1,18,37,9": "不成禍有所歸",
    "HANSHU,100-1,18,37,10": "嬰從其言",
    "HANSHU,100-1,18,37,11": "而陳氏以寧",
    "HANSHU,100-1,18,37,12": "王陵之母亦見項氏之必亡",
    "HANSHU,100-1,18,37,13": "而劉氏之將興也",
    "HANSHU,100-1,18,37,14": "是時陵爲漢將",
    "HANSHU,100-1,18,37,15": "而母獲於楚",
    "HANSHU,100-1,18,37,16": "有漢使來",
    "HANSHU,100-1,18,37,17": "陵母見之",
    "HANSHU,100-1,18,37,18": "謂曰",
    "HANSHU,100-1,18,37,19": "願告吾子",
    "HANSHU,100-1,18,37,20": "漢王長者",
    "HANSHU,100-1,18,37,21": "必得天下",
    "HANSHU,100-1,18,37,22": "子謹事之",
    "HANSHU,100-1,18,37,23": "無有二心",
    "HANSHU,100-1,18,37,24": "遂對漢使伏劍而死",
    "HANSHU,100-1,18,37,25": "以固勉陵",
    "HANSHU,100-1,18,37,26": "其後果定於漢",
    "HANSHU,100-1,18,37,27": "陵爲宰相封侯",
    "HANSHU,100-1,18,37,28": "夫以匹婦之明",
    "HANSHU,100-1,18,37,29": "猶能推事理之致",
    "HANSHU,100-1,18,37,30": "探禍福之機",
    "HANSHU,100-1,18,37,31": "而全宗祀於無窮",
    "HANSHU,100-1,18,37,32": "垂策書於春秋",
    "HANSHU,100-1,18,37,33": "而況大丈夫之事虖",
    "HANSHU,100-1,18,37,34": "是故窮達有命",
    "HANSHU,100-1,18,37,35": "吉凶由人",
    "HANSHU,100-1,18,37,36": "嬰母知廢",
    "HANSHU,100-1,18,37,37": "陵母知興",
    "HANSHU,100-1,18,37,38": "審此四者",
    "HANSHU,100-1,18,37,39": "帝王之分決矣",
    "HANSHU,100-1,19,39,1": "蓋在高祖",
    "HANSHU,100-1,19,39,2": "其興也有五",
    "HANSHU,100-1,19,39,3": "一曰帝堯之苗裔",
    "HANSHU,100-1,19,39,4": "二曰體貌多奇異",
    "HANSHU,100-1,19,39,5": "三曰神武有徵應",
    "HANSHU,100-1,19,39,6": "四曰寬明而仁恕",
    "HANSHU,100-1,19,39,7": "五曰知人善任使",
    "HANSHU,100-1,19,39,8": "加之以信誠好謀",
    "HANSHU,100-1,19,39,9": "達於聽受",
    "HANSHU,100-1,19,39,10": "見善如不及",
    "HANSHU,100-1,19,39,11": "用人如由己",
    "HANSHU,100-1,19,39,12": "從諫如順流",
    "HANSHU,100-1,19,39,13": "趣時如嚮赴",
    "HANSHU,100-1,19,39,14": "當食吐哺",
    "HANSHU,100-1,19,39,15": "納子房之策",
    "HANSHU,100-1,19,39,16": "拔足揮洗",
    "HANSHU,100-1,19,39,17": "揖酈生之說",
    "HANSHU,100-1,19,39,18": "寤戍卒之言",
    "HANSHU,100-1,19,39,19": "斷懷土之情",
    "HANSHU,100-1,19,39,20": "高四皓之名",
    "HANSHU,100-1,19,39,21": "割肌膚之愛",
    "HANSHU,100-1,19,39,22": "舉韓信於行陳",
    "HANSHU,100-1,19,39,23": "收陳平於亡命",
    "HANSHU,100-1,19,39,24": "英雄陳力",
    "HANSHU,100-1,19,39,25": "羣策畢舉",
    "HANSHU,100-1,19,39,26": "此高祖之大略",
    "HANSHU,100-1,19,39,27": "所以成帝業也",
    "HANSHU,100-1,19,39,28": "若乃靈瑞符應",
    "HANSHU,100-1,19,39,29": "又可略聞矣",
    "HANSHU,100-1,19,39,30": "初劉媼任高祖而夢與神遇",
    "HANSHU,100-1,19,39,31": "震電晦冥",
    "HANSHU,100-1,19,39,32": "有龍蛇之怪",
    "HANSHU,100-1,19,39,33": "及其長而多靈",
    "HANSHU,100-1,19,39,34": "有異於眾",
    "HANSHU,100-1,19,39,35": "是以王",
    "HANSHU,100-1,19,39,36": "武感物而折券",
    "HANSHU,100-1,19,39,37": "呂公睹形而進女",
    "HANSHU,100-1,19,39,38": "秦皇東遊以厭其氣",
    "HANSHU,100-1,19,39,39": "呂后望雲而知所處",
    "HANSHU,100-1,19,39,40": "始受命則白蛇分",
    "HANSHU,100-1,19,39,41": "西入關則五星聚",
    "HANSHU,100-1,19,39,42": "故淮陰",
    "HANSHU,100-1,19,39,43": "留侯謂之天授",
    "HANSHU,100-1,19,39,44": "非人力也",
    "HANSHU,100-1,20,41,1": "歷古今之得失",
    "HANSHU,100-1,20,41,2": "驗行事之成敗",
    "HANSHU,100-1,20,41,3": "稽帝王之世運",
    "HANSHU,100-1,20,41,4": "考五者之所謂",
    "HANSHU,100-1,20,41,5": "取舍不厭斯位",
    "HANSHU,100-1,20,41,6": "符瑞不同斯度",
    "HANSHU,100-1,20,41,7": "而苟昧於權利",
    "HANSHU,100-1,20,41,8": "越次妄據",
    "HANSHU,100-1,20,41,9": "外不量力",
    "HANSHU,100-1,20,41,10": "內不知命",
    "HANSHU,100-1,20,41,11": "則必喪保家之主",
    "HANSHU,100-1,20,41,12": "失天年之壽",
    "HANSHU,100-1,20,41,13": "遇折足之凶",
    "HANSHU,100-1,20,41,14": "伏鈇鉞之誅",
    "HANSHU,100-1,20,41,15": "英雄誠知覺寤",
    "HANSHU,100-1,20,41,16": "畏若禍戒",
    "HANSHU,100-1,20,41,17": "超然遠覽",
    "HANSHU,100-1,20,41,18": "淵然深識",
    "HANSHU,100-1,20,41,19": "收陵",
    "HANSHU,100-1,20,41,20": "嬰之明分",
    "HANSHU,100-1,20,41,21": "絕信",
    "HANSHU,100-1,20,41,22": "布之覬覦",
    "HANSHU,100-1,20,41,23": "距逐鹿之瞽說",
    "HANSHU,100-1,20,41,24": "審神器之有授",
    "HANSHU,100-1,20,41,25": "毋貪不可幾",
    "HANSHU,100-1,20,41,26": "爲二母之所咲",
    "HANSHU,100-1,20,41,27": "則福祚流於子孫",
    "HANSHU,100-1,20,41,28": "天祿其永終矣",
    "HANSHU,100-1,21,43,1": "知隗囂終不寤",
    "HANSHU,100-1,21,43,2": "乃避墬於河西",
    "HANSHU,100-1,21,43,3": "河西大將軍竇融嘉其美德",
    "HANSHU,100-1,21,43,4": "訪問焉",
    "HANSHU,100-1,21,43,5": "舉茂材",
    "HANSHU,100-1,21,43,6": "爲徐令",
    "HANSHU,100-1,21,43,7": "以病去官",
    "HANSHU,100-1,21,43,8": "後數應三公之召",
    "HANSHU,100-1,21,43,9": "仕不爲祿",
    "HANSHU,100-1,21,43,10": "所如不合",
    "HANSHU,100-1,21,43,11": "學不爲人",
    "HANSHU,100-1,21,43,12": "博而不俗",
    "HANSHU,100-1,21,43,13": "言不爲華",
    "HANSHU,100-1,21,43,14": "述而不作",
    "HANSHU,100-1,22,45,1": "有子曰固",
    "HANSHU,100-1,22,45,2": "弱冠而孤",
    "HANSHU,100-1,22,45,3": "作幽通之賦",
    "HANSHU,100-1,22,45,4": "以致命遂志",
    "HANSHU,100-1,22,45,5": "其辭曰",
    "HANSHU,100-1,23,47,1": "系高頊之玄冑兮",
    "HANSHU,100-1,23,47,2": "氏中葉之炳靈",
    "HANSHU,100-1,23,48,1": "繇凱風而蟬蛻兮",
    "HANSHU,100-1,23,48,2": "雄朔野以颺聲",
    "HANSHU,100-1,23,49,1": "皇十紀而鴻漸兮",
    "HANSHU,100-1,23,49,2": "有羽儀於上京",
    "HANSHU,100-1,23,50,1": "巨滔天而泯夏兮",
    "HANSHU,100-1,23,50,2": "考遘愍以行謠",
    "HANSHU,100-1,23,51,1": "終保己而貽則兮",
    "HANSHU,100-1,23,51,2": "里上仁之所廬",
    "HANSHU,100-1,23,52,1": "懿前烈之純淑兮",
    "HANSHU,100-1,23,52,2": "窮與達其必濟",
    "HANSHU,100-1,23,53,1": "咨孤矇之眇眇兮",
    "HANSHU,100-1,23,53,2": "將圮絕而罔階",
    "HANSHU,100-1,23,54,1": "豈余身之足殉兮",
    "HANSHU,100-1,23,54,2": "愇世業之可懷",
    "HANSHU,100-1,24,56,1": "靖潛處以永思兮",
    "HANSHU,100-1,24,56,2": "經日月而彌遠",
    "HANSHU,100-1,24,57,1": "匪黨人之敢拾兮",
    "HANSHU,100-1,24,57,2": "庶斯言之不玷",
    "HANSHU,100-1,24,58,1": "魂煢煢與神交兮",
    "HANSHU,100-1,24,58,2": "精誠發於宵寐",
    "HANSHU,100-1,24,59,1": "夢登山而迥眺兮",
    "HANSHU,100-1,24,59,2": "覿幽人之髣彿",
    "HANSHU,100-1,24,60,1": "㩜葛藟而授余兮",
    "HANSHU,100-1,24,60,2": "眷峻谷曰勿隧",
    "HANSHU,100-1,24,61,1": "昒昕寤而仰思兮",
    "HANSHU,100-1,24,61,2": "心蒙蒙猶未察",
    "HANSHU,100-1,24,62,1": "黃神邈而靡質兮",
    "HANSHU,100-1,24,62,2": "儀遺讖以臆對",
    "HANSHU,100-1,24,63,1": "曰乘高而遌神兮",
    "HANSHU,100-1,24,63,2": "道遐通而不迷",
    "HANSHU,100-1,24,64,1": "葛綿綿於樛木兮",
    "HANSHU,100-1,24,64,2": "詠南風以爲綏",
    "HANSHU,100-1,24,65,1": "蓋惴惴之臨深兮",
    "HANSHU,100-1,24,65,2": "乃二雅之所祇",
    "HANSHU,100-1,24,66,1": "旣誶爾以吉象兮",
    "HANSHU,100-1,24,66,2": "又申之以炯戒",
    "HANSHU,100-1,24,67,1": "盍孟晉以迨羣兮",
    "HANSHU,100-1,24,67,2": "辰焂忽其不再",
    "HANSHU,100-1,25,69,1": "承靈訓其虛徐兮",
    "HANSHU,100-1,25,69,2": "竚盤桓而且俟",
    "HANSHU,100-1,25,70,1": "惟天墬之無窮兮",
    "HANSHU,100-1,25,70,2": "鱻生民之脢在",
    "HANSHU,100-1,25,71,1": "紛屯亶與蹇連兮",
    "HANSHU,100-1,25,71,2": "何艱多而智寡",
    "HANSHU,100-1,25,72,1": "上聖寤而後拔兮",
    "HANSHU,100-1,25,72,2": "豈羣黎之所御",
    "HANSHU,100-1,25,73,1": "昔衞叔之御昆兮",
    "HANSHU,100-1,25,73,2": "昆爲寇而喪予",
    "HANSHU,100-1,25,74,1": "管彎弧欲斃讎兮",
    "HANSHU,100-1,25,74,2": "讎作后而成己",
    "HANSHU,100-1,25,75,1": "變化故而相詭兮",
    "HANSHU,100-1,25,75,2": "孰云豫其終始",
    "HANSHU,100-1,25,76,1": "雍造怨而先賞兮",
    "HANSHU,100-1,25,76,2": "丁繇惠而被戮",
    "HANSHU,100-1,25,77,1": "㮚取弔於逌吉兮",
    "HANSHU,100-1,25,77,2": "王膺慶於所慼",
    "HANSHU,100-1,25,78,1": "畔回宂其若茲兮",
    "HANSHU,100-1,25,78,2": "北叟頗識其倚伏",
    "HANSHU,100-1,25,79,1": "單治裏而外凋兮",
    "HANSHU,100-1,25,79,2": "張修襮而內逼",
    "HANSHU,100-1,25,80,1": "欥中龢爲庶幾兮",
    "HANSHU,100-1,25,80,2": "顏與冉又不得",
    "HANSHU,100-1,25,81,1": "溺招路以從己兮",
    "HANSHU,100-1,25,81,2": "謂孔氏猶未可",
    "HANSHU,100-1,25,82,1": "安慆慆而不萉兮",
    "HANSHU,100-1,25,82,2": "卒隕身虖世禍",
    "HANSHU,100-1,25,83,1": "遊聖門而靡救兮",
    "HANSHU,100-1,25,83,2": "顧覆醢其何補",
    "HANSHU,100-1,25,84,1": "固行行其必凶兮",
    "HANSHU,100-1,25,84,2": "免盜亂爲賴道",
    "HANSHU,100-1,25,85,1": "形氣發於根柢兮",
    "HANSHU,100-1,25,85,2": "柯葉彙而靈茂",
    "HANSHU,100-1,25,86,1": "恐网蜽之責景兮",
    "HANSHU,100-1,25,86,2": "慶未得其云已",
    "HANSHU,100-1,26,88,1": "黎淳耀於高辛兮",
    "HANSHU,100-1,26,88,2": "羋彊大於南汜",
    "HANSHU,100-1,26,89,1": "嬴取威於百儀兮",
    "HANSHU,100-1,26,89,2": "姜本支虖三止",
    "HANSHU,100-1,26,90,1": "旣仁得其信然兮",
    "HANSHU,100-1,26,90,2": "卬天路而同軌",
    "HANSHU,100-1,26,91,1": "東厸虐而殲仁兮",
    "HANSHU,100-1,26,91,2": "王合位虖三五",
    "HANSHU,100-1,26,92,1": "戎女烈而喪孝兮",
    "HANSHU,100-1,26,92,2": "伯徂歸於龍虎",
    "HANSHU,100-1,26,93,1": "發還師以成性兮",
    "HANSHU,100-1,26,93,2": "重醉行而自耦",
    "HANSHU,100-1,26,94,1": "震鱗漦於夏庭兮",
    "HANSHU,100-1,26,94,2": "匝三正而滅周",
    "HANSHU,100-1,26,95,1": "巽羽化於宣宮兮",
    "HANSHU,100-1,26,95,2": "彌五辟而成災",
    "HANSHU,100-1,27,97,1": "道悠長而世短兮",
    "HANSHU,100-1,27,97,2": "敻冥默而不周",
    "HANSHU,100-1,27,98,1": "胥仍物而鬼諏兮",
    "HANSHU,100-1,27,98,2": "乃窮宙而達幽",
    "HANSHU,100-1,27,99,1": "媯巢姜於孺筮兮",
    "HANSHU,100-1,27,99,2": "旦算祀於挈龜",
    "HANSHU,100-1,27,100,1": "宣",
    "HANSHU,100-1,27,100,2": "曹興敗於下夢兮",
    "HANSHU,100-1,27,100,3": "魯",
    "HANSHU,100-1,27,100,4": "衞名諡於銘謠",
    "HANSHU,100-1,27,101,1": "妣聆呱而刻石兮",
    "HANSHU,100-1,27,101,2": "許相理而鞠條",
    "HANSHU,100-1,27,102,1": "道混成而自然兮",
    "HANSHU,100-1,27,102,2": "術同原而分流",
    "HANSHU,100-1,27,103,1": "神先心以定命兮",
    "HANSHU,100-1,27,103,2": "命隨行以消息",
    "HANSHU,100-1,27,104,1": "斡流遷其不濟兮",
    "HANSHU,100-1,27,104,2": "故遭罹而贏縮",
    "HANSHU,100-1,27,105,1": "三欒同於一體兮",
    "HANSHU,100-1,27,105,2": "雖移盈然不忒",
    "HANSHU,100-1,27,106,1": "洞參差其紛錯兮",
    "HANSHU,100-1,27,106,2": "斯眾兆之所惑",
    "HANSHU,100-1,27,107,1": "周",
    "HANSHU,100-1,27,107,2": "賈盪而貢憤兮",
    "HANSHU,100-1,27,107,3": "齊死生與禍福",
    "HANSHU,100-1,27,108,1": "抗爽言以矯情兮",
    "HANSHU,100-1,27,108,2": "信畏犧而忌服",
    "HANSHU,100-1,28,110,1": "所貴聖人之至論兮",
    "HANSHU,100-1,28,110,2": "順天性而斷誼",
    "HANSHU,100-1,28,111,1": "物有欲而不居兮",
    "HANSHU,100-1,28,111,2": "亦有惡而不避",
    "HANSHU,100-1,28,112,1": "守孔約而不貳兮",
    "HANSHU,100-1,28,112,2": "乃輶德而無累",
    "HANSHU,100-1,28,113,1": "三仁殊而一致兮",
    "HANSHU,100-1,28,113,2": "夷",
    "HANSHU,100-1,28,113,3": "惠舛而齊聲",
    "HANSHU,100-1,28,114,1": "木偃息以蕃魏兮",
    "HANSHU,100-1,28,114,2": "申重繭以存荊",
    "HANSHU,100-1,28,115,1": "紀焚躬以衞上兮",
    "HANSHU,100-1,28,115,2": "皓頤志而弗營",
    "HANSHU,100-1,28,116,1": "侯屮木之區別兮",
    "HANSHU,100-1,28,116,2": "苟能實而必榮",
    "HANSHU,100-1,28,117,1": "要沒世而不朽兮",
    "HANSHU,100-1,28,117,2": "乃先民之所程",
    "HANSHU,100-1,29,119,1": "觀天罔之紘覆兮",
    "HANSHU,100-1,29,119,2": "實棐諶而相順",
    "HANSHU,100-1,29,120,1": "謨先聖之大繇兮",
    "HANSHU,100-1,29,120,2": "亦厸德而助信",
    "HANSHU,100-1,29,121,1": "虞韶美而儀鳳兮",
    "HANSHU,100-1,29,121,2": "孔忘味於千載",
    "HANSHU,100-1,29,122,1": "素文信而底麟兮",
    "HANSHU,100-1,29,122,2": "漢賓祚於異代",
    "HANSHU,100-1,29,123,1": "精通靈而感物兮",
    "HANSHU,100-1,29,123,2": "神動氣而入微",
    "HANSHU,100-1,29,124,1": "養遊睇而猿號兮",
    "HANSHU,100-1,29,124,2": "李虎發而石開",
    "HANSHU,100-1,29,125,1": "非精誠其焉通兮",
    "HANSHU,100-1,29,125,2": "苟無實其孰信",
    "HANSHU,100-1,29,126,1": "操末技猶必然兮",
    "HANSHU,100-1,29,126,2": "矧湛躬於道眞",
    "HANSHU,100-1,29,127,1": "登孔",
    "HANSHU,100-1,29,127,2": "顥而上下兮",
    "HANSHU,100-1,29,127,3": "緯羣龍之所經",
    "HANSHU,100-1,29,128,1": "朝貞觀而夕化兮",
    "HANSHU,100-1,29,128,2": "猶諠己而遺形",
    "HANSHU,100-1,29,129,1": "若胤彭而偕老兮",
    "HANSHU,100-1,29,129,2": "訴來哲以通情",
    "HANSHU,100-1,30,131,1": "亂曰",
    "HANSHU,100-1,30,131,2": "天造屮昧",
    "HANSHU,100-1,30,131,3": "立性命兮",
    "HANSHU,100-1,30,131,4": "復心弘道",
    "HANSHU,100-1,30,131,5": "惟賢聖兮",
    "HANSHU,100-1,30,131,6": "渾元運物",
    "HANSHU,100-1,30,131,7": "流不處兮",
    "HANSHU,100-1,30,131,8": "保身遺名",
    "HANSHU,100-1,30,131,9": "民之表兮",
    "HANSHU,100-1,30,131,10": "舍生取誼",
    "HANSHU,100-1,30,131,11": "亦道用兮",
    "HANSHU,100-1,30,131,12": "憂傷夭物",
    "HANSHU,100-1,30,131,13": "忝莫痛兮",
    "HANSHU,100-1,30,131,14": "昊爾太素",
    "HANSHU,100-1,30,131,15": "曷渝色兮",
    "HANSHU,100-1,30,131,16": "尙粵其幾",
    "HANSHU,100-1,30,131,17": "淪神域兮",
    "HANSHU,100-1,31,133,1": "永平中爲郎",
    "HANSHU,100-1,31,133,2": "典校祕書",
    "HANSHU,100-1,31,133,3": "專篤志於博學",
    "HANSHU,100-1,31,133,4": "以著述爲業",
    "HANSHU,100-1,31,133,5": "或譏以無功",
    "HANSHU,100-1,31,133,6": "又感東方朔",
    "HANSHU,100-1,31,133,7": "揚雄自諭以不遭蘇",
    "HANSHU,100-1,31,133,8": "張",
    "HANSHU,100-1,31,133,9": "范",
    "HANSHU,100-1,31,133,10": "蔡之時",
    "HANSHU,100-1,31,133,11": "曾不折之以正道",
    "HANSHU,100-1,31,133,12": "明君子之所守",
    "HANSHU,100-1,31,133,13": "故聊復應焉",
    "HANSHU,100-1,31,133,14": "其辭曰",
    "HANSHU,100-1,32,135,1": "賓戲主人曰",
    "HANSHU,100-1,32,135,2": "蓋聞聖人有壹定之論",
    "HANSHU,100-1,32,135,3": "列士有不易之分",
    "HANSHU,100-1,32,135,4": "亦云名而已矣",
    "HANSHU,100-1,32,135,5": "故太上有立德",
    "HANSHU,100-1,32,135,6": "其次有立功",
    "HANSHU,100-1,32,135,7": "夫德不得後身而特盛",
    "HANSHU,100-1,32,135,8": "功不得背時而獨章",
    "HANSHU,100-1,32,135,9": "是以聖喆之治",
    "HANSHU,100-1,32,135,10": "栖栖皇皇",
    "HANSHU,100-1,32,135,11": "孔席不煗",
    "HANSHU,100-1,32,135,12": "墨突不黔",
    "HANSHU,100-1,32,135,13": "由此言之",
    "HANSHU,100-1,32,135,14": "取舍者昔人之上務",
    "HANSHU,100-1,32,135,15": "著作者前列之餘事耳",
    "HANSHU,100-1,32,135,16": "今吾子幸遊帝王之世",
    "HANSHU,100-1,32,135,17": "躬帶冕之服",
    "HANSHU,100-1,32,135,18": "浮英華",
    "HANSHU,100-1,32,135,19": "湛道德",
    "HANSHU,100-1,32,135,20": "矕龍虎之文",
    "HANSHU,100-1,32,135,21": "舊矣",
    "HANSHU,100-1,32,135,22": "卒不能攄首尾",
    "HANSHU,100-1,32,135,23": "奮翼鱗",
    "HANSHU,100-1,32,135,24": "振拔洿塗",
    "HANSHU,100-1,32,135,25": "跨騰風雲",
    "HANSHU,100-1,32,135,26": "使見之者景駭",
    "HANSHU,100-1,32,135,27": "聞之者嚮震",
    "HANSHU,100-1,32,135,28": "徒樂枕經籍書",
    "HANSHU,100-1,32,135,29": "紆體衡門",
    "HANSHU,100-1,32,135,30": "上無所蔕",
    "HANSHU,100-1,32,135,31": "下無所根",
    "HANSHU,100-1,32,135,32": "獨攄意虖宇宙之外",
    "HANSHU,100-1,32,135,33": "銳思於豪芒之內",
    "HANSHU,100-1,32,135,34": "潛神默記",
    "HANSHU,100-1,32,135,35": "恆以年歲",
    "HANSHU,100-1,32,135,36": "然而器不賈於當己",
    "HANSHU,100-1,32,135,37": "用不效於一世",
    "HANSHU,100-1,32,135,38": "雖馳辯如濤波",
    "HANSHU,100-1,32,135,39": "摛藻如春華",
    "HANSHU,100-1,32,135,40": "猶無益於殿最",
    "HANSHU,100-1,32,135,41": "意者",
    "HANSHU,100-1,32,135,42": "且運朝夕之策",
    "HANSHU,100-1,32,135,43": "定合會之計",
    "HANSHU,100-1,32,135,44": "使存有顯號",
    "HANSHU,100-1,32,135,45": "亡有美諡",
    "HANSHU,100-1,32,135,46": "不亦優虖",
    "HANSHU,100-1,33,137,1": "主人逌爾而咲曰",
    "HANSHU,100-1,33,137,2": "若賓之言",
    "HANSHU,100-1,33,137,3": "斯所謂見勢利之華",
    "HANSHU,100-1,33,137,4": "闇道德之實",
    "HANSHU,100-1,33,137,5": "守穾奧之熒燭",
    "HANSHU,100-1,33,137,6": "未卬天庭而睹白日也",
    "HANSHU,100-1,33,137,7": "曩者王塗蕪穢",
    "HANSHU,100-1,33,137,8": "周失其御",
    "HANSHU,100-1,33,137,9": "侯伯方軌",
    "HANSHU,100-1,33,137,10": "戰國橫騖",
    "HANSHU,100-1,33,137,11": "於是七雄虓闞",
    "HANSHU,100-1,33,137,12": "分裂諸夏",
    "HANSHU,100-1,33,137,13": "龍戰而虎爭",
    "HANSHU,100-1,33,137,14": "遊說之徒",
    "HANSHU,100-1,33,137,15": "風颺電激",
    "HANSHU,100-1,33,137,16": "並起而救之",
    "HANSHU,100-1,33,137,17": "其餘猋飛景附",
    "HANSHU,100-1,33,137,18": "煜霅其間者",
    "HANSHU,100-1,33,137,19": "蓋不可勝載",
    "HANSHU,100-1,33,137,20": "當此之時",
    "HANSHU,100-1,33,137,21": "搦朽摩鈍",
    "HANSHU,100-1,33,137,22": "鈆刀皆能壹斷",
    "HANSHU,100-1,33,137,23": "是故魯連飛一矢而蹶千金",
    "HANSHU,100-1,33,137,24": "虞卿以顧眄而捐相印也",
    "HANSHU,100-1,33,137,25": "夫啾發投曲",
    "HANSHU,100-1,33,137,26": "感耳之聲",
    "HANSHU,100-1,33,137,27": "合之律度",
    "HANSHU,100-1,33,137,28": "淫䵷而不可聽者",
    "HANSHU,100-1,33,137,29": "非韶",
    "HANSHU,100-1,33,137,30": "夏之樂也",
    "HANSHU,100-1,33,137,31": "因勢合變",
    "HANSHU,100-1,33,137,32": "偶時之會",
    "HANSHU,100-1,33,137,33": "風移俗易",
    "HANSHU,100-1,33,137,34": "乖忤而不可通者",
    "HANSHU,100-1,33,137,35": "非君子之法也",
    "HANSHU,100-1,33,137,36": "及至從人合之",
    "HANSHU,100-1,33,137,37": "衡人散之",
    "HANSHU,100-1,33,137,38": "亡命漂說",
    "HANSHU,100-1,33,137,39": "羈旅騁辭",
    "HANSHU,100-1,33,137,40": "商鞅挾三術以鑽孝公",
    "HANSHU,100-1,33,137,41": "李斯奮時務而要始皇",
    "HANSHU,100-1,33,137,42": "彼皆躡風雲之會",
    "HANSHU,100-1,33,137,43": "履顚沛之勢",
    "HANSHU,100-1,33,137,44": "據徼乘邪以求一日之富貴",
    "HANSHU,100-1,33,137,45": "朝爲榮華",
    "HANSHU,100-1,33,137,46": "夕而焦瘁",
    "HANSHU,100-1,33,137,47": "福不盈眥",
    "HANSHU,100-1,33,137,48": "禍益於世",
    "HANSHU,100-1,33,137,49": "凶人且以自悔",
    "HANSHU,100-1,33,137,50": "況吉士而是賴虖",
    "HANSHU,100-1,33,137,51": "且功不可以虛成",
    "HANSHU,100-1,33,137,52": "名不可以僞立",
    "HANSHU,100-1,33,137,53": "韓設辯以徼君",
    "HANSHU,100-1,33,137,54": "呂行詐以賈國",
    "HANSHU,100-1,33,137,55": "說難旣酋",
    "HANSHU,100-1,33,137,56": "其身乃囚",
    "HANSHU,100-1,33,137,57": "秦貨旣貴",
    "HANSHU,100-1,33,137,58": "厥宗亦隧",
    "HANSHU,100-1,33,137,59": "是故仲尼抗浮雲之志",
    "HANSHU,100-1,33,137,60": "孟軻養浩然之氣",
    "HANSHU,100-1,33,137,61": "彼豈樂爲迂闊哉",
    "HANSHU,100-1,33,137,62": "道不可以貳也",
    "HANSHU,100-1,33,137,63": "方今大漢灑埽羣穢",
    "HANSHU,100-1,33,137,64": "夷險芟荒",
    "HANSHU,100-1,33,137,65": "廓帝紘",
    "HANSHU,100-1,33,137,66": "恢皇綱",
    "HANSHU,100-1,33,137,67": "基隆於羲",
    "HANSHU,100-1,33,137,68": "農",
    "HANSHU,100-1,33,137,69": "規廣於黃",
    "HANSHU,100-1,33,137,70": "唐",
    "HANSHU,100-1,33,137,71": "其君天下也",
    "HANSHU,100-1,33,137,72": "炎之如日",
    "HANSHU,100-1,33,137,73": "威之如神",
    "HANSHU,100-1,33,137,74": "函之如海",
    "HANSHU,100-1,33,137,75": "養之如春",
    "HANSHU,100-1,33,137,76": "是以六合之內",
    "HANSHU,100-1,33,137,77": "莫不同原共流",
    "HANSHU,100-1,33,137,78": "沐浴玄德",
    "HANSHU,100-1,33,137,79": "稟卬太和",
    "HANSHU,100-1,33,137,80": "枝附葉著",
    "HANSHU,100-1,33,137,81": "譬猶屮木之殖山林",
    "HANSHU,100-1,33,137,82": "鳥魚之毓川澤",
    "HANSHU,100-1,33,137,83": "得氣者蕃滋",
    "HANSHU,100-1,33,137,84": "失時者苓落",
    "HANSHU,100-1,33,137,85": "參天墬而施化",
    "HANSHU,100-1,33,137,86": "豈云人事之厚薄哉",
    "HANSHU,100-1,33,137,87": "今子處皇世而論戰國",
    "HANSHU,100-1,33,137,88": "耀所聞而疑所覿",
    "HANSHU,100-1,33,137,89": "欲從旄敦而度高虖泰山",
    "HANSHU,100-1,33,137,90": "懷氿濫而測深虖重淵",
    "HANSHU,100-1,33,137,91": "亦未至也",
    "HANSHU,100-1,34,139,1": "賓曰",
    "HANSHU,100-1,34,139,2": "若夫鞅",
    "HANSHU,100-1,34,139,3": "斯之倫",
    "HANSHU,100-1,34,139,4": "衰周之凶人",
    "HANSHU,100-1,34,139,5": "旣聞命矣",
    "HANSHU,100-1,34,139,6": "敢問上古之士",
    "HANSHU,100-1,34,139,7": "處身行道",
    "HANSHU,100-1,34,139,8": "輔世成名",
    "HANSHU,100-1,34,139,9": "可述於後者",
    "HANSHU,100-1,34,139,10": "默而已虖",
    "HANSHU,100-1,35,141,1": "主人曰",
    "HANSHU,100-1,35,141,2": "何爲其然也",
    "HANSHU,100-1,35,141,3": "昔咎繇謨虞",
    "HANSHU,100-1,35,141,4": "箕子訪周",
    "HANSHU,100-1,35,141,5": "言通帝王",
    "HANSHU,100-1,35,141,6": "謀合聖神",
    "HANSHU,100-1,35,141,7": "殷說夢發於傅巖",
    "HANSHU,100-1,35,141,8": "周望兆動於渭濱",
    "HANSHU,100-1,35,141,9": "齊甯激聲於康衢",
    "HANSHU,100-1,35,141,10": "漢良受書於邳沂",
    "HANSHU,100-1,35,141,11": "皆俟命而神交",
    "HANSHU,100-1,35,141,12": "匪詞言之所信",
    "HANSHU,100-1,35,141,13": "故能建必然之策",
    "HANSHU,100-1,35,141,14": "展無窮之勳也",
    "HANSHU,100-1,35,141,15": "近者陸子優繇",
    "HANSHU,100-1,35,141,16": "新語以興",
    "HANSHU,100-1,35,141,17": "董生下帷",
    "HANSHU,100-1,35,141,18": "發藻儒林",
    "HANSHU,100-1,35,141,19": "劉向司籍",
    "HANSHU,100-1,35,141,20": "辯章舊聞",
    "HANSHU,100-1,35,141,21": "揚雄覃思",
    "HANSHU,100-1,35,141,22": "法言",
    "HANSHU,100-1,35,141,23": "大玄",
    "HANSHU,100-1,35,141,24": "皆及時君之門闈",
    "HANSHU,100-1,35,141,25": "究先聖之壼奧",
    "HANSHU,100-1,35,141,26": "婆娑虖術藝之場",
    "HANSHU,100-1,35,141,27": "休息虖篇籍之囿",
    "HANSHU,100-1,35,141,28": "以全其質而發其文",
    "HANSHU,100-1,35,141,29": "用納虖聖聽",
    "HANSHU,100-1,35,141,30": "列炳於後人",
    "HANSHU,100-1,35,141,31": "斯非其亞與",
    "HANSHU,100-1,35,141,32": "若乃夷抗行於首陽",
    "HANSHU,100-1,35,141,33": "惠降志於辱仕",
    "HANSHU,100-1,35,141,34": "顏耽樂於簞瓢",
    "HANSHU,100-1,35,141,35": "孔終篇於西狩",
    "HANSHU,100-1,35,141,36": "聲盈塞於天淵",
    "HANSHU,100-1,35,141,37": "眞吾徒之師表也",
    "HANSHU,100-1,35,141,38": "且吾聞之",
    "HANSHU,100-1,35,141,39": "壹陰壹陽",
    "HANSHU,100-1,35,141,40": "天墬之方",
    "HANSHU,100-1,35,141,41": "乃文乃質",
    "HANSHU,100-1,35,141,42": "王道之綱",
    "HANSHU,100-1,35,141,43": "有同有異",
    "HANSHU,100-1,35,141,44": "聖喆之常",
    "HANSHU,100-1,35,141,45": "故曰",
    "HANSHU,100-1,35,141,46": "愼修所志",
    "HANSHU,100-1,35,141,47": "守爾天符",
    "HANSHU,100-1,35,141,48": "委命共己",
    "HANSHU,100-1,35,141,49": "味道之腴",
    "HANSHU,100-1,35,141,50": "神之聽之",
    "HANSHU,100-1,35,141,51": "名其舍諸",
    "HANSHU,100-1,35,141,52": "賓又不聞龢氏之璧韞於荊石",
    "HANSHU,100-1,35,141,53": "隨侯之珠藏於蜯蛤虖",
    "HANSHU,100-1,35,141,54": "歷世莫眡",
    "HANSHU,100-1,35,141,55": "不知其將含景耀",
    "HANSHU,100-1,35,141,56": "吐英精",
    "HANSHU,100-1,35,141,57": "曠千載而流夜光也",
    "HANSHU,100-1,35,141,58": "應龍潛於潢汙",
    "HANSHU,100-1,35,141,59": "魚黿媟之",
    "HANSHU,100-1,35,141,60": "不睹其能奮靈德",
    "HANSHU,100-1,35,141,61": "合風雲",
    "HANSHU,100-1,35,141,62": "超忽荒",
    "HANSHU,100-1,35,141,63": "而躆顥蒼也",
    "HANSHU,100-1,35,141,64": "故夫泥蟠而天飛者",
    "HANSHU,100-1,35,141,65": "應龍之神也",
    "HANSHU,100-1,35,141,66": "先賤而後貴者",
    "HANSHU,100-1,35,141,67": "龢",
    "HANSHU,100-1,35,141,68": "隨之珍也",
    "HANSHU,100-1,35,141,69": "時闇而久章者",
    "HANSHU,100-1,35,141,70": "君子之眞也",
    "HANSHU,100-1,35,141,71": "若乃牙",
    "HANSHU,100-1,35,141,72": "曠清耳於管絃",
    "HANSHU,100-1,35,141,73": "離婁眇目於豪分",
    "HANSHU,100-1,35,141,74": "逢蒙絕技於弧矢",
    "HANSHU,100-1,35,141,75": "班輸榷巧於斧斤",
    "HANSHU,100-1,35,141,76": "良樂軼能於相馭",
    "HANSHU,100-1,35,141,77": "烏獲抗力於千鈞",
    "HANSHU,100-1,35,141,78": "龢",
    "HANSHU,100-1,35,141,79": "鵲發精於鍼石",
    "HANSHU,100-1,35,141,80": "硏",
    "HANSHU,100-1,35,141,81": "桑心計於無垠",
    "HANSHU,100-1,35,141,82": "僕亦不任廁技於彼列",
    "HANSHU,100-1,35,141,83": "故密爾自娛於斯文"
}