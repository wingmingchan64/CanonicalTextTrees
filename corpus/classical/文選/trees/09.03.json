{
    "09.03": {
        "篇名": "班叔皮 北征賦",
        "1": {
            "3": {
                "1": "余遭世之顚覆兮",
                "2": "罹塡塞之阨災",
                "3": "舊室滅以丘墟兮",
                "4": "曾不得乎少留",
                "5": "遂奮袂以北征兮",
                "6": "超絕迹而遠遊"
            }
        },
        "2": {
            "5": {
                "1": "朝發軔於長都兮",
                "2": "夕宿瓠谷之玄宮",
                "3": "歷雲門而反顧",
                "4": "望通天之崇崇",
                "5": "乘陵崗以登降",
                "6": "息郇邠之邑鄕",
                "7": "慕公劉之遺德",
                "8": "及行葦之不傷",
                "9": "彼何生之優渥",
                "10": "我獨罹此百殃",
                "11": "故時會之變化兮",
                "12": "非天命之靡常"
            }
        },
        "3": {
            "7": {
                "1": "登赤須之長阪",
                "2": "入義渠之舊城",
                "3": "忿戎王之淫狡",
                "4": "穢宣后之失貞",
                "5": "嘉秦昭之討賊",
                "6": "赫斯怒以北征"
            }
        },
        "4": {
            "9": {
                "1": "紛吾去此舊都兮",
                "2": "騑遲遲以歷茲",
                "3": "遂舒節以遠逝兮",
                "4": "指安定以爲期",
                "5": "涉長路之綿綿兮",
                "6": "遠紆回以樛流",
                "7": "過泥陽而太息兮",
                "8": "悲祖廟之不修",
                "9": "釋余馬於彭陽兮",
                "10": "且弭節而自思",
                "11": "日晻晻其將暮兮",
                "12": "睹牛羊之下來",
                "13": "寤曠怨之傷情兮",
                "14": "哀詩人之歎時"
            }
        },
        "5": {
            "11": {
                "1": "越安定以容與兮",
                "2": "遵長城之漫漫",
                "3": "劇蒙公之疲民兮",
                "4": "爲彊秦乎築怨",
                "5": "舍高亥之切憂兮",
                "6": "事蠻狄之遼患",
                "7": "不耀德以綏遠",
                "8": "顧厚固而繕藩",
                "9": "首身分而不寤兮",
                "10": "猶數功而辭諐",
                "11": "何夫子之妄說兮",
                "12": "孰云地脈而生殘"
            }
        },
        "6": {
            "13": {
                "1": "登鄣隧而遙望兮",
                "2": "聊須臾以婆娑",
                "3": "閔獯鬻之猾夏兮",
                "4": "弔尉邛於朝那",
                "5": "從聖文之克讓兮",
                "6": "不勞師而幣加",
                "7": "惠父兄於南越兮",
                "8": "黜帝號於尉他",
                "9": "降几杖於藩國兮",
                "10": "折吳濞之逆邪",
                "11": "惟太宗之蕩蕩兮",
                "12": "豈曩秦之所圖"
            }
        },
        "7": {
            "15": {
                "1": "隮高平而周覽",
                "2": "望山谷之嵯峨",
                "3": "野蕭條以莽蕩",
                "4": "迥千里而無家",
                "5": "風猋發以漂遙兮",
                "6": "谷水灌以揚波",
                "7": "飛雲霧之杳杳",
                "8": "涉積雪之皚皚",
                "9": "雁邕邕以羣翔兮",
                "10": "鵾雞鳴以嚌嚌"
            }
        },
        "8": {
            "17": {
                "1": "遊子悲其故鄕",
                "2": "心愴悢以傷懷",
                "3": "撫長劍而慨息",
                "4": "泣漣落而霑衣",
                "5": "攬余涕以於邑兮",
                "6": "哀生民之多故",
                "7": "夫何陰曀之不陽兮",
                "8": "嗟久失其平度",
                "9": "諒時運之所爲兮",
                "10": "永伊鬱其誰愬"
            }
        },
        "9": {
            "19": {
                "1": "亂曰",
                "2": "夫子固窮",
                "3": "遊藝文兮",
                "4": "樂以忘憂",
                "5": "惟聖賢兮",
                "6": "達人從事",
                "7": "有儀則兮",
                "8": "行止屈申",
                "9": "與時息兮",
                "10": "君子履信",
                "11": "無不居兮",
                "12": "雖之蠻貊",
                "13": "何憂懼兮"
            }
        }
    }
}