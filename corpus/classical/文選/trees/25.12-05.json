{
    "25.12-05": {
        "篇名": "謝宣遠 於安城答靈運·其五",
        "1": {
            "3": {
                "1": "跬行安步武",
                "2": "鎩翮周數仞",
                "3": "豈不識高遠",
                "4": "違方往有吝",
                "5": "歲寒霜雪嚴",
                "6": "過半路愈峻",
                "7": "量己畏友朋",
                "8": "勇退不敢進",
                "9": "行矣勵令猷",
                "10": "寫誠詶來訊"
            }
        }
    }
}