{
    "16.07": {
        "篇名": "江文通 恨賦",
        "1": {
            "3": {
                "1": "試望平原",
                "2": "蔓草縈骨",
                "3": "拱木斂魂",
                "4": "人生到此",
                "5": "天道寧論"
            }
        },
        "2": {
            "5": {
                "1": "於是僕本恨人",
                "2": "心驚不已",
                "3": "直念古者",
                "4": "伏恨而死",
                "5": "至如秦帝按劍",
                "6": "諸侯西馳",
                "7": "削平天下",
                "8": "同文共規",
                "9": "華山爲城",
                "10": "紫淵爲池",
                "11": "雄圖旣溢",
                "12": "武力未畢",
                "13": "方架黿鼉以爲梁",
                "14": "巡海右以送日",
                "15": "一旦魂斷",
                "16": "宮車晚出",
                "17": "若乃趙王旣虜",
                "18": "遷於房陵",
                "19": "薄暮心動",
                "20": "昧旦神興",
                "21": "別豔姬與美女",
                "22": "喪金輿及玉乘",
                "23": "置酒欲飲",
                "24": "悲來塡膺",
                "25": "千秋萬歲",
                "26": "爲怨難勝"
            }
        },
        "3": {
            "7": {
                "1": "至如李君降北",
                "2": "名辱身冤",
                "3": "拔劍擊柱",
                "4": "弔影慚魂",
                "5": "情往上郡",
                "6": "心留雁門",
                "7": "裂帛繫書",
                "8": "誓還漢恩",
                "9": "朝露溘至",
                "10": "握手何言",
                "11": "若夫明妃去時",
                "12": "仰天太息",
                "13": "紫臺稍遠",
                "14": "關山無極",
                "15": "搖風忽起",
                "16": "白日西匿",
                "17": "隴雁少飛",
                "18": "代雲寡色",
                "19": "望君王兮何期",
                "20": "終蕪絕兮異域"
            }
        },
        "4": {
            "9": {
                "1": "至乃敬通見抵",
                "2": "罷歸田里",
                "3": "閉關卻掃",
                "4": "塞門不仕",
                "5": "左對孺人",
                "6": "顧弄稚子",
                "7": "脫略公卿",
                "8": "跌宕文史",
                "9": "齎志沒地",
                "10": "長懷無已",
                "11": "及夫中散下獄",
                "12": "神氣激揚",
                "13": "濁醪夕引",
                "14": "素琴晨張",
                "15": "秋日蕭索",
                "16": "浮雲無光",
                "17": "鬱青霞之奇意",
                "18": "入修夜之不暘"
            }
        },
        "5": {
            "11": {
                "1": "或有孤臣危涕",
                "2": "孼子墜心",
                "3": "遷客海上",
                "4": "流戍隴陰",
                "5": "此人但聞悲風汩起",
                "6": "血下霑衿",
                "7": "亦復含酸茹歎",
                "8": "銷落湮沈",
                "9": "若迺騎疊迹",
                "10": "車屯軌",
                "11": "黃塵帀地",
                "12": "歌吹四起",
                "13": "無不煙斷火絕",
                "14": "閉骨泉裏"
            }
        },
        "6": {
            "13": {
                "1": "已矣哉",
                "2": "春草暮兮秋風驚",
                "3": "秋風罷兮春草生",
                "4": "綺羅畢兮池館盡",
                "5": "琴瑟滅兮丘壟平",
                "6": "自古皆有死",
                "7": "莫不飲恨而吞聲"
            }
        }
    }
}