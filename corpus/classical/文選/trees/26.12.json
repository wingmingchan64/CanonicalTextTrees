{
    "26.12": {
        "篇名": "范彥龍 古意贈王中書",
        "1": {
            "3": {
                "1": "攝官青瑣闥",
                "2": "遙望鳳皇池",
                "3": "誰云相去遠",
                "4": "脈脈阻光儀",
                "5": "岱山饒靈異",
                "6": "沂水富英奇",
                "7": "逸翮凌北海",
                "8": "摶飛出南皮",
                "9": "遭逢聖明后",
                "10": "來栖桐樹枝",
                "11": "竹花何莫莫",
                "12": "桐葉何離離",
                "13": "可栖復可食",
                "14": "此外亦何爲",
                "15": "豈如鷦鷯者",
                "16": "一粒有餘貲"
            }
        }
    }
}