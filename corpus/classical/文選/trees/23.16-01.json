{
    "23.16-01": {
        "篇名": "劉公幹 贈五官中郎將四首·其一",
        "1": {
            "3": {
                "1": "昔我從元后",
                "2": "整駕至南鄕",
                "3": "過彼豐沛都",
                "4": "與君共翱翔",
                "5": "四節相推斥",
                "6": "季冬風且涼",
                "7": "眾賓會廣坐",
                "8": "明鐙熺炎光",
                "9": "清歌製妙聲",
                "10": "萬舞在中堂",
                "11": "金罍含甘醴",
                "12": "羽觴行無方",
                "13": "長夜忘歸來",
                "14": "聊且爲大康",
                "15": "四牡向路馳",
                "16": "歡悅誠未央"
            }
        }
    }
}