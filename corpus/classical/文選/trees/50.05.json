{
    "50.05": {
        "篇名": "沈休文 恩倖傳論",
        "1": {
            "3": {
                "1": "夫君子小人",
                "2": "類物之通稱",
                "3": "蹈道則爲君子",
                "4": "違之則爲小人",
                "5": "屠釣",
                "6": "卑事也",
                "7": "板築",
                "8": "賤役也",
                "9": "太公起爲周師",
                "10": "傅說去爲殷相",
                "11": "非論公侯之世",
                "12": "鼎食之資",
                "13": "明揚幽仄",
                "14": "唯才是與"
            }
        },
        "2": {
            "5": {
                "1": "逮於二漢",
                "2": "茲道未革",
                "3": "胡廣累世農夫",
                "4": "伯始致位公相",
                "5": "黃憲牛毉之子",
                "6": "叔度名動京師",
                "7": "且士子居朝",
                "8": "咸有職業",
                "9": "雖七葉珥貂",
                "10": "見崇西漢",
                "11": "而侍中身奉奏事",
                "12": "又分掌御服",
                "13": "東方朔爲黃門侍郎",
                "14": "執戟殿下",
                "15": "郡縣掾吏",
                "16": "並出豪家",
                "17": "負戈宿衞",
                "18": "皆由勢族",
                "19": "非若晚代分爲二塗者也"
            }
        },
        "3": {
            "7": {
                "1": "漢末喪亂",
                "2": "魏武始基",
                "3": "軍中倉卒",
                "4": "權立九品",
                "5": "蓋以論人才優劣",
                "6": "非謂世族高卑",
                "7": "因此相沿",
                "8": "遂爲成法",
                "9": "自魏至晉",
                "10": "莫之能改",
                "11": "州都郡正",
                "12": "以才品人",
                "13": "而舉世人才",
                "14": "升降蓋寡",
                "15": "徒以憑籍世資",
                "16": "用相陵駕",
                "17": "都正俗士",
                "18": "斟酌時宜",
                "19": "品目少多",
                "20": "隨事俯仰",
                "21": "劉毅所云下品無高門",
                "22": "上品無賤族者也",
                "23": "歲月遷訛",
                "24": "斯風漸篤",
                "25": "凡厥衣冠",
                "26": "莫非二品",
                "27": "自此以還",
                "28": "遂成卑庶",
                "29": "周漢之道",
                "30": "以智役愚",
                "31": "臺隸參差",
                "32": "用成等級",
                "33": "魏晉以來",
                "34": "以貴役賤",
                "35": "士庶之科",
                "36": "較然有辨",
                "37": "夫人君南面",
                "38": "九重奧絕",
                "39": "陪奉朝夕",
                "40": "義隔卿士",
                "41": "階闥之任",
                "42": "宜有司存",
                "43": "旣而恩以狎生",
                "44": "信由恩固",
                "45": "無可憚之姿",
                "46": "有易親之色",
                "47": "孝建泰始",
                "48": "主威獨運",
                "49": "空置百司",
                "50": "權不外假",
                "51": "而刑政糾雜",
                "52": "理難遍通",
                "53": "耳目所寄",
                "54": "事歸近習",
                "55": "賞罰之要",
                "56": "是謂國權",
                "57": "出納王命",
                "58": "由其掌握",
                "59": "於是方塗結軌",
                "60": "輻湊同奔",
                "61": "人主謂其身卑位薄",
                "62": "以爲權不得重",
                "63": "曾不知鼠憑社貴",
                "64": "狐藉虎威",
                "65": "外無逼主之嫌",
                "66": "內有專用之功",
                "67": "勢傾天下",
                "68": "未之或悟",
                "69": "挾朋樹黨",
                "70": "政以賄成",
                "71": "鈇鉞瘡痏",
                "72": "搆於牀笫之曲",
                "73": "服冕乘軒",
                "74": "出於言笑之下",
                "75": "南金北毳",
                "76": "來悉方艚",
                "77": "素縑丹魄",
                "78": "至皆兼兩音亮",
                "79": "北毳",
                "80": "𤟤貂之屬",
                "81": "艚",
                "82": "船也",
                "83": "丹魄",
                "84": "虎魄也",
                "85": "色赤",
                "86": "故曰丹",
                "87": "孔安國尙書傳曰",
                "88": "車稱兩",
                "89": "西京許史",
                "90": "蓋不足云",
                "91": "晉朝王石",
                "92": "未或能比",
                "93": "及太宗晚運",
                "94": "慮經盛衰",
                "95": "權倖之徒",
                "96": "慴憚宗戚",
                "97": "欲使幼主孤立",
                "98": "永竊國權",
                "99": "搆造同異",
                "100": "興樹禍隙",
                "101": "帝弟宗王",
                "102": "相繼屠勦",
                "103": "民忘宋德",
                "104": "雖非一塗",
                "105": "寶祚夙傾",
                "106": "實由於此",
                "107": "嗚呼",
                "108": "漢書有恩澤侯表",
                "109": "又有佞倖傳",
                "110": "今采其名",
                "111": "列以爲恩倖篇云"
            }
        }
    }
}