{
    "11.02": {
        "篇名": "孫興公 遊天台山賦[幷序]",
        "1": {
            "3": {
                "1": "天台山者",
                "2": "蓋山嶽之神秀者也",
                "3": "涉海則有方丈蓬萊",
                "4": "登陸則有四明天台",
                "5": "皆玄聖之所遊化",
                "6": "靈仙之所窟宅",
                "7": "夫其峻極之狀",
                "8": "嘉祥之美",
                "9": "窮山海之瑰富",
                "10": "盡人神之壯麗矣",
                "11": "所以不列於五嶽",
                "12": "闕載於常典者",
                "13": "豈不以所立冥奧",
                "14": "其路幽迥",
                "15": "或倒景於重溟",
                "16": "或匿峯於千嶺",
                "17": "始經魑魅之塗",
                "18": "卒踐無人之境",
                "19": "舉世罕能登陟",
                "20": "王者莫由禋祀",
                "21": "故事絕於常篇",
                "22": "名標於奇紀"
            }
        },
        "2": {
            "5": {
                "1": "然圖像之興",
                "2": "豈虛也哉",
                "3": "非夫遺世翫道",
                "4": "絕粒茹芝者",
                "5": "烏能輕舉而宅之",
                "6": "非夫遠寄冥搜",
                "7": "篤信通神者",
                "8": "何肯遙想而存之",
                "9": "余所以馳神運思",
                "10": "晝詠宵興",
                "11": "俛仰之間",
                "12": "若已再升者也",
                "13": "方解纓絡",
                "14": "永託茲嶺",
                "15": "不任吟想之至",
                "16": "聊奮藻以散懷"
            }
        },
        "3": {
            "7": {
                "1": "太虛遼廓而無閡",
                "2": "運自然之妙有",
                "3": "融而爲川瀆",
                "4": "結而爲山阜",
                "5": "嗟台嶽之所奇挺",
                "6": "寔神明之所扶持",
                "7": "蔭牛宿以曜峯",
                "8": "託靈越以正基",
                "9": "結根彌於華岱",
                "10": "直指高於九疑",
                "11": "應配天於唐典",
                "12": "齊峻極於周詩"
            }
        },
        "4": {
            "9": {
                "1": "邈彼絕域",
                "2": "幽邃窈窕",
                "3": "近智以守見而不之",
                "4": "之者以路絕而莫曉",
                "5": "哂夏蟲之疑冰",
                "6": "整輕翮而思矯",
                "7": "理無隱而不彰",
                "8": "啟二奇以示兆",
                "9": "赤城霞起而建標",
                "10": "瀑布飛流以界道"
            }
        },
        "5": {
            "11": {
                "1": "睹靈驗而遂徂",
                "2": "忽乎吾之將行",
                "3": "仍羽人於丹丘",
                "4": "尋不死之福庭",
                "5": "苟台嶺之可攀",
                "6": "亦何羨於層城",
                "7": "釋域中之常戀",
                "8": "暢超然之高情",
                "9": "被毛褐之森森",
                "10": "振金策之鈴鈴",
                "11": "披荒榛之蒙蘢",
                "12": "陟峭崿之崢嶸",
                "13": "濟楢溪而直進",
                "14": "落五界而迅征",
                "15": "跨穹隆之懸磴",
                "16": "臨萬丈之絕冥",
                "17": "踐莓苔之滑石",
                "18": "搏壁立之翠屛",
                "19": "攬樛木之長蘿",
                "20": "援葛藟之飛莖",
                "21": "雖一冒於垂堂",
                "22": "乃永存乎長生",
                "23": "必契誠於幽昧",
                "24": "履重嶮而逾平"
            }
        },
        "6": {
            "13": {
                "1": "旣克隮於九折",
                "2": "路威夷而修通",
                "3": "恣心目之寥朗",
                "4": "任緩步之從容",
                "5": "藉萋萋之纖草",
                "6": "蔭落落之長松",
                "7": "覿翔鸞之裔裔",
                "8": "聽鳴鳳之嗈嗈",
                "9": "過靈溪而一濯",
                "10": "疏煩想於心胸",
                "11": "蕩遺塵於旋流",
                "12": "發五蓋之遊蒙",
                "13": "追羲農之絕軌",
                "14": "躡二老之玄蹤"
            }
        },
        "7": {
            "15": {
                "1": "陟降信宿",
                "2": "迄於仙都",
                "3": "雙闕雲竦以夾路",
                "4": "瓊臺中天而懸居",
                "5": "朱闕玲瓏於林間",
                "6": "玉堂陰映於高隅",
                "7": "彤雲斐亹以翼櫺",
                "8": "曒日炯晃於綺疏",
                "9": "八桂森挺以凌霜",
                "10": "五芝含秀而晨敷",
                "11": "惠風佇芳於陽林",
                "12": "醴泉涌溜於陰渠",
                "13": "建木滅景於千尋",
                "14": "琪樹璀璨而垂珠",
                "15": "王喬控鶴以沖天",
                "16": "應眞飛錫以躡虛",
                "17": "騁神變之揮霍",
                "18": "忽出有而入無"
            }
        },
        "8": {
            "17": {
                "1": "於是遊覽旣周",
                "2": "體靜心閑",
                "3": "害馬已去",
                "4": "世事都捐",
                "5": "投刃皆虛",
                "6": "目牛無全",
                "7": "凝思幽巖",
                "8": "朗詠長川",
                "9": "爾乃羲和亭午",
                "10": "遊氣高褰",
                "11": "法鼓琅以振響",
                "12": "眾香馥以揚煙",
                "13": "肆覲天宗",
                "14": "爰集通仙",
                "15": "挹以玄玉之膏",
                "16": "嗽以華池之泉",
                "17": "散以象外之說",
                "18": "暢以無生之篇",
                "19": "悟遣有之不盡",
                "20": "覺涉無之有間",
                "21": "泯色空以合迹",
                "22": "忽卽有而得玄",
                "23": "釋二名之同出",
                "24": "消一無於三幡",
                "25": "恣語樂以終日",
                "26": "等寂默於不言",
                "27": "渾萬象以冥觀",
                "28": "兀同體於自然"
            }
        }
    }
}