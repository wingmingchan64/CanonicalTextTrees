{
    "38.11": {
        "篇名": "任彥升 爲范始興作求立太宰碑表",
        "1": {
            "3": {
                "1": "臣雲言",
                "2": "原夫存樹風猷",
                "3": "沒著徽烈",
                "4": "旣絕故老之口",
                "5": "必資不刊之書",
                "6": "而藏諸名山",
                "7": "則陵谷遷貿",
                "8": "府之延閣",
                "9": "則青編落簡",
                "10": "然則配天之迹",
                "11": "存乎泗水之上",
                "12": "素王之道",
                "13": "紀於沂川之側",
                "14": "由是崇師之義",
                "15": "擬迹於西河",
                "16": "尊主之情",
                "17": "致之於堯禹",
                "18": "故精廬妄啟",
                "19": "必窮鐫勒之盛",
                "20": "君長一城",
                "21": "亦盡刊刻之美",
                "22": "況乎甄陶周召",
                "23": "孕育伊顏"
            }
        },
        "2": {
            "5": {
                "1": "故太宰竟陵文宣王臣某",
                "2": "與存與亡",
                "3": "則義刑社稷",
                "4": "嚴天配帝",
                "5": "則周公其人",
                "6": "體國端朝",
                "7": "出藩入守",
                "8": "進思必告之道",
                "9": "退無苟利之專",
                "10": "五教以倫",
                "11": "百揆時序",
                "12": "若夫一言一行",
                "13": "盛德之風",
                "14": "琴書藝業",
                "15": "述作之茂",
                "16": "道非兼濟",
                "17": "事止樂善",
                "18": "亦無得而稱焉"
            }
        },
        "3": {
            "7": {
                "1": "人之云亡",
                "2": "忽移歲序",
                "3": "鴟鴞東徙",
                "4": "松檟成行",
                "5": "六府臣僚",
                "6": "三藩士女",
                "7": "人蓄油素",
                "8": "家懷鈆筆",
                "9": "瞻彼景山",
                "10": "徒然望慕",
                "11": "昔晉氏初禁立碑",
                "12": "魏舒之亡",
                "13": "亦從班列",
                "14": "而阮略旣泯",
                "15": "故首冒嚴科",
                "16": "爲之者竟免刑戮",
                "17": "致之者反蒙嘉歎",
                "18": "至於道被如仁",
                "19": "功參微管",
                "20": "本宜在常均之外",
                "21": "故太宰淵",
                "22": "丞相嶷",
                "23": "親賢並軌",
                "24": "卽爲成規",
                "25": "乞依二公前例",
                "26": "賜許刊立",
                "27": "寧容使長想九原",
                "28": "樵蘇罔識其禁",
                "29": "駐驆長陵",
                "30": "輶軒不知所適"
            }
        },
        "4": {
            "9": {
                "1": "臣里閭孤賤",
                "2": "才無可甄",
                "3": "値齊網之弘",
                "4": "弛賓客之禁",
                "5": "策名委質",
                "6": "忽焉二紀",
                "7": "慮先犬馬",
                "8": "厚恩不答",
                "9": "而敝帷毀蓋",
                "10": "未蓐螻蟻",
                "11": "珠襦玉匣",
                "12": "遽飾幽泉",
                "13": "陛下弘獎名教",
                "14": "不隔微物",
                "15": "使臣得駿奔南浦",
                "16": "長號北陵",
                "17": "旣曲逢前施",
                "18": "實仰覬後澤",
                "19": "儻驗杜預山頂之言",
                "20": "庶存馬駿必拜之感",
                "21": "臨表悲懼",
                "22": "言不自宣",
                "23": "臣誠惶已下"
            }
        }
    }
}