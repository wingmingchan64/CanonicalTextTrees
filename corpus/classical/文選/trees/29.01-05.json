{
    "29.01-05": {
        "篇名": "古詩一十九首·西北有高樓",
        "1": {
            "3": {
                "1": "西北有高樓",
                "2": "上與浮雲齊",
                "3": "交疏結綺牎",
                "4": "阿閣三重階",
                "5": "上有絃歌聲",
                "6": "音響一何悲",
                "7": "誰能爲此曲",
                "8": "無乃杞梁妻",
                "9": "清商隨風發",
                "10": "中曲正徘徊",
                "11": "一彈再三歎",
                "12": "慷慨有餘哀",
                "13": "不惜歌者苦",
                "14": "但傷知音稀",
                "15": "願爲雙鳴鶴",
                "16": "奮翅起高飛"
            }
        }
    }
}