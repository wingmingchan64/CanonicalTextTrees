        },
        "19": {
            "39": {
                "1": "據開陽而頫盼兮",
                "2": "臨舊鄕之暗藹",
                "3": "悲離居之勞心兮",
                "4": "情悁悁而思歸",
                "5": "魂眷眷而屢顧兮",
                "6": "馬倚輈而徘回",
                "7": "雖遨遊以媮樂兮",
                "8": "豈愁慕之可懷",
                "9": "出閶闔兮降天塗",
                "10": "乘飇忽兮馳虛無",
                "11": "雲霏霏兮繞余輪",
                "12": "風眇眇兮震余旟",
                "13": "繽連翩兮紛暗曖",
                "14": "倏眩眃兮反常閭"
            }
        },
        "20": {
            "41": {
                "1": "收疇昔之逸豫兮",
                "2": "卷淫放之遐心",
                "3": "修初服之娑娑兮",
                "4": "長余珮之參參",
                "5": "文章煥以粲爛兮",
                "6": "美紛紜以從風",
                "7": "御六蓺之珍駕兮",
                "8": "遊道德之平林",
                "9": "結典籍而爲罟兮",
                "10": "敺儒墨以爲禽",
                "11": "玩陰陽之變化兮",
                "12": "詠雅頌之徽音",
                "13": "嘉曾氏之歸耕兮",
                "14": "慕歷陵之欽崟",
                "15": "恭夙夜而不貳兮",
                "16": "固終始之所服",
                "17": "夕惕若厲以省諐兮",
                "18": "懼余身之未敕也",
                "19": "苟中情之端直兮",
                "20": "莫吾知而不恧",
                "21": "墨無爲以凝志兮",
                "22": "與仁義乎消遙",
                "23": "不出戶而知天下兮",
                "24": "何必歷遠以劬勞"
            }
        },
        "21": {
            "43": {
                "1": "系曰",
                "2": "天長地久歲不留",
                "3": "俟河之清祇懷憂",
                "4": "願得遠渡以自娛",
                "5": "上下無常窮六區",
                "6": "超踰騰躍絕世俗",
                "7": "飄颻神舉逞所欲",
                "8": "天不可階仙夫希",
                "9": "柏舟悄悄吝不飛",
                "10": "松喬高跱孰能離",
                "11": "結精遠遊使心攜",
                "12": "回志朅來從玄諆",
                "13": "獲我所求夫何思"
            }
        }
    }
