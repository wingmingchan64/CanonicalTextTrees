{
    "15.01": {
        "篇名": "張平子 思玄賦",
        "1": {
            "3": {
                "1": "衡常思圖身之事",
                "2": "以爲吉凶倚伏",
                "3": "幽微難明",
                "4": "乃作思玄賦",
                "5": "以宣寄情志",
                "6": "其辭曰︰"
            }
        },
        "2": {
            "5": {
                "1": "仰先哲之玄訓兮",
                "2": "雖彌高而弗違",
                "3": "匪仁里其焉宅兮",
                "4": "匪義迹其焉追",
                "5": "潛服膺以永靚兮",
                "6": "綿日月而不衰",
                "7": "伊中情之信修兮",
                "8": "慕古人之貞節",
                "9": "竦余身而順止兮",
                "10": "遵繩墨而不跌",
                "11": "志團團以應懸兮",
                "12": "誠心固其如結",
                "13": "旌性行以製珮兮",
                "14": "佩夜光與瓊枝",
                "15": "𦆈幽蘭之秋華兮",
                "16": "又綴之以江蘺",
                "17": "美襞積以酷烈兮",
                "18": "允塵邈而難虧",
                "19": "旣姱麗而鮮雙兮",
                "20": "非是時之攸珍",
                "21": "奮余榮而莫見兮",
                "22": "播余香而莫聞",
                "23": "幽獨守此庂陋兮",
                "24": "敢怠遑而舍勤",
                "25": "幸二八之遌虞兮",
                "26": "嘉傅說之生殷",
                "27": "尙前良之遺風兮",
                "28": "恫後辰而無及",
                "29": "何孤行之煢煢兮",
                "30": "孑不羣而介立",
                "31": "感鸞鷖之特栖兮",
                "32": "悲淑人之稀合"
            }
        },
        "3": {
            "7": {
                "1": "彼無合而何傷兮",
                "2": "患眾僞之冒眞",
                "3": "旦獲讟於羣弟兮",
                "4": "啟金縢而後信",
                "5": "覽蒸民之多僻兮",
                "6": "畏立辟以危身",
                "7": "增煩毒以迷或兮",
                "8": "羌孰可爲言己",
                "9": "私湛憂而深懷兮",
                "10": "思繽紛而不理",
                "11": "願竭力以守誼兮",
                "12": "雖貧窮而不改",
                "13": "執雕虎而試象兮",
                "14": "阽焦原而跟止",
                "15": "庶斯奉以周旋兮",
                "16": "要旣死而後已",
                "17": "俗遷渝而事化兮",
                "18": "泯規矩之圜方",
                "19": "珍蕭艾於重笥兮",
                "20": "謂蕙芷之不香",
                "21": "斥西施而弗御兮",
                "22": "羈要裊以服箱",
                "23": "行陂僻而獲志兮",
                "24": "循法度而離殃",
                "25": "惟天地之無窮兮",
                "26": "何遭遇之無常"
            }
        },
        "4": {
            "9": {
                "1": "不抑操而苟容兮",
                "2": "譬臨河而無航",
                "3": "欲巧笑以干媚兮",
                "4": "非余心之所嘗",
                "5": "襲溫恭之黻衣兮",
                "6": "披禮義之繡裳",
                "7": "辮貞亮以爲鞶兮",
                "8": "雜技藝以爲珩",
                "9": "昭綵藻與雕琢兮",
                "10": "璜聲遠而彌長",
                "11": "淹栖遲以恣欲兮",
                "12": "耀靈忽其西藏",
                "13": "恃己知而華予兮",
                "14": "鶗鴂鳴而不芳",
                "15": "冀一年之三秀兮",
                "16": "遒白露之爲霜",
                "17": "時亹亹而代序兮",
                "18": "疇可與乎比伉",
                "19": "咨姤嫮之難並兮",
                "20": "想依韓以流亡",
                "21": "恐漸染而無成兮",
                "22": "留則蔽而不章"
            }
        },
        "5": {
            "11": {
                "1": "心猶豫而狐疑兮",
                "2": "卽岐阯而攄情",
                "3": "文君爲我端蓍兮",
                "4": "利飛遁以保名",
                "5": "歷眾山以周流兮",
                "6": "翼迅風以揚聲",
                "7": "二女感於崇岳兮",
                "8": "或冰折而不營",
                "9": "天蓋高而爲澤兮",
                "10": "誰云路之不平",
                "11": "勔自強而不息兮",
                "12": "蹈玉階之嶢崢",
                "13": "懼筮氏之長短兮",
                "14": "鑽東龜以觀禎",
                "15": "遇九皋之介鳥兮",
                "16": "怨素意之不逞",
                "17": "遊塵外而瞥天兮",
                "18": "據冥翳而哀鳴",
                "19": "雕鶚競於貪婪兮",
                "20": "我修絜以益榮",
                "21": "子有故於玄鳥兮",
                "22": "歸母氏而後寧"
            }
        },
        "6": {
            "13": {
                "1": "占旣吉而無悔兮",
                "2": "簡元辰而俶裝",
                "3": "旦余沐於清源兮",
                "4": "晞余髮於朝陽",
                "5": "漱飛泉之瀝液兮",
                "6": "咀石菌之流英",
                "7": "翾鳥舉而魚躍兮",
                "8": "將往走乎八荒",
                "9": "過少皥之窮野兮",
                "10": "問三丘於句芒",
                "11": "何道眞之淳粹兮",
                "12": "去穢累而票輕",
                "13": "登蓬萊而容與兮",
                "14": "鼇雖抃而不傾",
                "15": "留瀛洲而采芝兮",
                "16": "聊且以乎長生",
                "17": "馮歸雲而遐逝兮",
                "18": "夕余宿乎扶桑",
                "19": "噏青岑之玉醴兮",
                "20": "餐沆瀣以爲糧",
                "21": "發昔夢於木禾兮",
                "22": "穀崑崙之高岡",
                "23": "朝吾行於湯谷兮",
                "24": "從伯禹乎稽山",
                "25": "嘉羣神之執玉兮",
                "26": "疾防風之食言"
            }
        },
        "7": {
            "15": {
                "1": "指長沙之邪徑兮",
                "2": "存重華乎南鄰",
                "3": "哀二妃之未從兮",
                "4": "翩儐處彼湘濱",
                "5": "流目覜夫衡阿兮",
                "6": "睹有黎之圮墳",
                "7": "痛火正之無懷兮",
                "8": "託山陂以孤魂",
                "9": "愁蔚蔚以慕遠兮",
                "10": "越卬州而愉遨",
                "11": "躋日中於昆吾兮",
                "12": "憩炎天之所陶",
                "13": "揚芒熛而絳天兮",
                "14": "水泫沄而涌濤",
                "15": "溫風翕其增熱兮",
                "16": "惄鬱悒其難聊",
                "17": "顝羈旅而無友兮",
                "18": "余安能乎留茲"
            }
        },
        "8": {
            "17": {
                "1": "顧金天而歎息兮",
                "2": "吾欲往乎西嬉",
                "3": "前祝融使舉麾兮",
                "4": "纚朱鳥以承旗",
                "5": "躔建木於廣都兮",
                "6": "拓若華而躊躇",
                "7": "超軒轅於西海兮",
                "8": "跨汪氏之龍魚",
                "9": "聞此國之千歲兮",
                "10": "曾焉足以娛余"
            }
        },
        "9": {
            "19": {
                "1": "思九土之殊風兮",
                "2": "從蓐收而遂徂",
                "3": "欻神化而蟬蛻兮",
                "4": "朋精粹而爲徒",
                "5": "蹶白門而東馳兮",
                "6": "云台行乎中野",
                "7": "亂弱水之潺湲兮",
                "8": "逗華陰之湍渚",
                "9": "號馮夷俾清津兮",
                "10": "櫂龍舟以濟予",
                "11": "會帝軒之未歸兮",
                "12": "悵相佯而延佇",
                "13": "呬河林之蓁蓁兮",
                "14": "偉關雎之戒女"
            }
        },
        "10": {
            "21": {
                "1": "黃靈詹而訪命兮",
                "2": "摎天道其焉如",
                "3": "曰︰近信而遠疑兮",
                "4": "六籍闕而不書",
                "5": "神逵昧其難覆兮",
                "6": "疇克謨而從諸",
                "7": "牛哀病而成虎兮",
                "8": "雖逢昆其必噬",
                "9": "鼈令殪而尸亡兮",
                "10": "取蜀禪而引世",
                "11": "死生錯其不齊兮",
                "12": "雖司命其不晰",
                "13": "竇號行於代路兮",
                "14": "後膺祚而繁廡",
                "15": "王肆侈於漢庭兮",
                "16": "卒銜卹而絕緒",
                "17": "尉尨眉而郎潛兮",
                "18": "逮三葉而遘武",
                "19": "董弱冠而司衮兮",
                "20": "設王隧而弗處",
                "21": "夫吉凶之相仍兮",
                "22": "恆反側而靡所"
            }
        },
        "11": {
            "23": {
                "1": "穆屆天以悅牛兮",
                "2": "豎亂叔而幽主",
                "3": "文斷袪而忌伯兮",
                "4": "閹謁賊而寧后",
                "5": "通人闇於好惡兮",
                "6": "豈愛惑而能剖",
                "7": "嬴擿讖而戒胡兮",
                "8": "備諸外而發內",
                "9": "或輦賄而違車兮",
                "10": "孕行產而爲對",
                "11": "愼竈顯以言天兮",
                "12": "占水火而妄誶",
                "13": "梁叟患夫黎丘兮",
                "14": "丁厥子而事刃",
                "15": "親所睇而弗識兮",
                "16": "矧幽冥之可信",
                "17": "毋綿攣以涬己兮",
                "18": "思百憂以自疢"
            }
        },
        "12": {
            "25": {
                "1": "彼天監之孔明兮",
                "2": "用棐忱而祐仁",
                "3": "湯蠲體以禱祈兮",
                "4": "蒙厖禠以拯人",
                "5": "景三慮以營國兮",
                "6": "熒惑次於它辰",
                "7": "魏顆亮以從理兮",
                "8": "鬼亢回以敝秦",
                "9": "咎繇邁而種德兮",
                "10": "樹德茂乎英",
                "11": "六",
                "12": "桑末寄夫根生兮",
                "13": "卉旣彫而己毓",
                "14": "有無言而不讎兮",
                "15": "又何往而不復",
                "16": "盍遠迹以飛聲兮",
                "17": "孰謂時之可蓄"
            }
        },
        "13": {
            "27": {
                "1": "仰矯首以遙望兮",
                "2": "魂𢠵惘而無疇",
                "3": "偪區中之隘陋兮",
                "4": "將北度而宣遊",
                "5": "行積冰之磑磑兮",
                "6": "清泉沍而不流",
                "7": "寒風淒其永至兮",
                "8": "拂穹岫之騷騷",
                "9": "玄武縮於殼中兮",
                "10": "螣蛇蜿而自糾",
                "11": "魚矜鱗而幷凌兮",
                "12": "鳥登木而失條",
                "13": "坐太陰之屛室兮",
                "14": "慨含欷而增愁",
                "15": "怨高陽之相寓兮",
                "16": "㑋顓頊之宅幽",
                "17": "庸織絡於四裔兮",
                "18": "斯與彼其何瘳",
                "19": "望寒門之絕垠兮",
                "20": "縱余緤乎不周",
                "21": "迅飇潚其媵我兮",
                "22": "騖翩飄而不禁",
                "23": "越谽𠽫之洞穴兮",
                "24": "標通川之碄碄",
                "25": "經重陰乎寂寞兮",
                "26": "愍墳羊之深潛"
            }
        },
        "14": {
            "29": {
                "1": "追慌忽於地底兮",
                "2": "軼無形而上浮",
                "3": "出石密之闇野兮",
                "4": "不識蹊之所由",
                "5": "速燭龍令執炬兮",
                "6": "過鍾山而中休",
                "7": "瞰瑤谿之赤岸兮",
                "8": "弔祖江之見劉",
                "9": "聘王母於銀臺兮",
                "10": "羞玉芝以療飢",
                "11": "戴勝憖其旣歡兮",
                "12": "又誚余之行遲",
                "13": "載太華之玉女兮",
                "14": "召洛浦之宓妃",
                "15": "咸姣麗以蠱媚兮",
                "16": "增嫮眼而蛾眉",
                "17": "舒妙婧之纖腰兮",
                "18": "揚雜錯之袿徽",
                "19": "離朱脣而微笑兮",
                "20": "顏的礰以遺光",
                "21": "獻環琨與璵縭兮",
                "22": "申厥好以玄黃",
                "23": "雖色豔而賂美兮",
                "24": "志浩蕩而不嘉",
                "25": "雙材悲於不納兮",
                "26": "並詠詩而清歌",
                "27": "歌曰",
                "28": "天地煙熅",
                "29": "百卉含蘤",
                "30": "鳴鶴交頸",
                "31": "雎鳩相和",
                "32": "處子懷春",
                "33": "精魂回移",
                "34": "如何淑明",
                "35": "忘我實多"
            }
        },
        "15": {
            "31": {
                "1": "將答賦而不暇兮",
                "2": "爰整駕而亟行",
                "3": "瞻崑崙之巍巍兮",
                "4": "臨縈河之洋洋",
                "5": "伏靈龜以負坻兮",
                "6": "亙螭龍之飛梁",
                "7": "登閬風之層城兮",
                "8": "搆不死而爲牀",
                "9": "屑瑤橤以爲糇兮",
                "10": "𣂏白水以爲漿",
                "11": "抨巫咸以占夢兮",
                "12": "乃貞吉之元符",
                "13": "滋令德於正中兮",
                "14": "含嘉禾以爲敷",
                "15": "旣垂穎而顧本兮",
                "16": "爾要思乎故居",
                "17": "安和靜而隨時兮",
                "18": "結純懿之所廬"
            }
        },
        "16": {
            "33": {
                "1": "戒庶僚以夙會兮",
                "2": "僉恭職而並迓",
                "3": "豐隆軯其震霆兮",
                "4": "列缺曄其照夜",
                "5": "雲師𩅾以交集兮",
                "6": "涷雨沛其灑塗",
                "7": "轙琱輿而樹葩兮",
                "8": "擾應龍以服輅",
                "9": "百神森其備從兮",
                "10": "屯騎羅而星布"
            }
        },
        "17": {
            "35": {
                "1": "振余袂而就車兮",
                "2": "修劍揭以低昂",
                "3": "冠咢咢其映蓋兮",
                "4": "佩綝纚以煇煌",
                "5": "僕夫儼其正策兮",
                "6": "八乘攄而超驤",
                "7": "氛旄溶以天旋兮",
                "8": "蜺旌飄以飛揚",
                "9": "撫軨軹而還睨兮",
                "10": "心灼藥其若湯",
                "11": "羨上都之赫戲兮",
                "12": "何迷故而不忘",
                "13": "左青琱之揵芝兮",
                "14": "右素威以司鉦",
                "15": "前長離使拂羽兮",
                "16": "委水衡乎玄冥",
                "17": "屬箕伯以函風兮",
                "18": "懲淟涊而爲清",
                "19": "曳雲旗之離離兮",
                "20": "鳴玉鸞之譻譻",
                "21": "涉清霄而升遐兮",
                "22": "浮蔑蒙而上征",
                "23": "紛翼翼以徐戾兮",
                "24": "焱回回其揚靈",
                "25": "叫帝閽使闢扉兮",
                "26": "覿天皇於瓊宮",
                "27": "聆廣樂之九奏兮",
                "28": "展泄泄以肜肜",
                "29": "考理亂於律均兮",
                "30": "意建始而思終",
                "31": "惟盤逸之無斁兮",
                "32": "懼樂往而哀來",
                "33": "素撫弦而餘音兮",
                "34": "太容吟曰念哉",
                "35": "旣防溢而靜志兮",
                "36": "迨我暇以翱翔"
            }
        },
        "18": {
            "37": {
                "1": "出紫宮之肅肅兮",
                "2": "集太微之閬閬",
                "3": "命王良掌策駟兮",
                "4": "踰高閣之鏘鏘",
                "5": "建罔車之幕幕兮",
                "6": "獵青林之芒芒",
                "7": "彎威弧之撥剌兮",
                "8": "射嶓冢之封狼",
                "9": "觀壁壘於北落兮",
                "10": "伐河鼓之磅硠",
                "11": "乘天潢之泛泛兮",
                "12": "浮雲漢之湯湯",
                "13": "倚招搖攝提以低回剹流兮",
                "14": "察二紀五緯之綢繆遹皇",
                "15": "偃蹇夭矯㛯以連卷兮",
                "16": "雜沓叢顇颯以方驤",
                "17": "戫汨飂淚沛以罔象兮",
                "18": "爛漫麗靡藐以迭逿",
                "19": "凌驚雷之砊礚兮",
                "20": "弄狂電之淫裔",
                "21": "踰痝澒於宕冥兮",
                "22": "貫倒景而高厲",
                "23": "廓盪盪其無涯兮",
                "24": "乃今窺乎天外"
