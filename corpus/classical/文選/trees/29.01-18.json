{
    "29.01-18": {
        "篇名": "古詩一十九首·客從遠方來",
        "1": {
            "3": {
                "1": "客從遠方來",
                "2": "遺我一端綺",
                "3": "相去萬餘里",
                "4": "故人心尙爾",
                "5": "文綵雙鴛鴦",
                "6": "裁爲合歡被",
                "7": "著以長相思",
                "8": "緣以結不解",
                "9": "以膠投漆中",
                "10": "誰能別離此"
            }
        }
    }
}