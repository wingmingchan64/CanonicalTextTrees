{
    "13.05": {
        "篇名": "賈誼 鵩鳥賦[幷序]",
        "1": {
            "3": {
                "1": "誼爲長沙王傅三年",
                "2": "有鵩鳥飛入誼舍",
                "3": "止於坐隅",
                "4": "鵩似鴞",
                "5": "不祥鳥也",
                "6": "誼旣以謫居長沙",
                "7": "長沙卑濕",
                "8": "誼自傷悼",
                "9": "以爲壽不得長",
                "10": "迺爲賦以自廣",
                "11": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "單閼之歲",
                "2": "四月孟夏",
                "3": "庚子日斜",
                "4": "鵩集余舍",
                "5": "止於坐隅",
                "6": "貌甚間暇",
                "7": "異物來崒",
                "8": "私怪其故",
                "9": "發書占之",
                "10": "讖言其度",
                "11": "曰野鳥入室",
                "12": "主人將去",
                "13": "問於子鵩",
                "14": "余去何之",
                "15": "吉虖告我",
                "16": "凶言其災",
                "17": "淹速之度",
                "18": "語余其期"
            }
        },
        "3": {
            "7": {
                "1": "鵩乃太息",
                "2": "舉首奮翼",
                "3": "口不能言",
                "4": "請對以意",
                "5": "萬物變化",
                "6": "固亡休息",
                "7": "斡流而遷",
                "8": "或推而還",
                "9": "形氣轉續",
                "10": "變化而嬗",
                "11": "沕穆亡間",
                "12": "胡可勝言",
                "13": "禍兮福所倚",
                "14": "福兮禍所伏",
                "15": "憂喜聚門",
                "16": "吉凶同域",
                "17": "彼吳彊大",
                "18": "夫差以敗",
                "19": "粵栖會稽",
                "20": "句踐伯世",
                "21": "斯遊遂成",
                "22": "卒被五刑",
                "23": "傅說胥靡",
                "24": "乃相武丁",
                "25": "夫禍之與福",
                "26": "何異糾纆",
                "27": "命不可說",
                "28": "孰知其極",
                "29": "水激則旱",
                "30": "矢激則遠",
                "31": "萬物回薄",
                "32": "震蕩相轉",
                "33": "雲烝雨降",
                "34": "糾錯相紛",
                "35": "大鈞播物",
                "36": "坱圠無垠",
                "37": "天不可與慮",
                "38": "道不可與謀",
                "39": "遲速有命",
                "40": "烏識其時"
            }
        },
        "4": {
            "9": {
                "1": "且夫天地爲爐",
                "2": "造化爲工",
                "3": "陰陽爲炭",
                "4": "萬物爲銅",
                "5": "合散消息",
                "6": "安有常則",
                "7": "千變萬化",
                "8": "未始有極",
                "9": "忽然爲人",
                "10": "何足控揣",
                "11": "化爲異物",
                "12": "又何足患",
                "13": "小智自私",
                "14": "賤彼貴我",
                "15": "達人大觀",
                "16": "物亡不可",
                "17": "貪夫徇財",
                "18": "列士徇名",
                "19": "夸者死權",
                "20": "品庶每生",
                "21": "怵迫之徒",
                "22": "或趨西東",
                "23": "大人不曲",
                "24": "意變齊同",
                "25": "愚士繫俗",
                "26": "時若囚拘",
                "27": "至人遺物",
                "28": "獨與道俱",
                "29": "眾人惑惑",
                "30": "好惡積意",
                "31": "眞人恬漠",
                "32": "獨與道息",
                "33": "釋智遺形",
                "34": "超然自喪",
                "35": "寥廓忽荒",
                "36": "與道翱翔",
                "37": "乘流則逝",
                "38": "得坎則止",
                "39": "縱軀委命",
                "40": "不私與己",
                "41": "其生兮若浮",
                "42": "其死兮若休",
                "43": "澹虖若深淵之靚",
                "44": "泛虖若不繫之舟",
                "45": "不以生故自保",
                "46": "養空而浮",
                "47": "德人無累",
                "48": "知命不憂",
                "49": "細故蔕芥",
                "50": "何足以疑"
            }
        }
    }
}