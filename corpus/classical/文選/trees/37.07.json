{
    "37.07": {
        "篇名": "陸士衡 謝平原內史表",
        "1": {
            "3": {
                "1": "陪臣陸機言",
                "2": "今月九日",
                "3": "魏郡太守遣兼丞張含",
                "4": "齎板詔書印綬",
                "5": "假臣爲平原內史",
                "6": "拜受祇竦",
                "7": "不知所裁",
                "8": "臣機頓首頓首",
                "9": "死罪死罪"
            }
        },
        "2": {
            "5": {
                "1": "臣本吳人",
                "2": "出自敵國",
                "3": "世無先臣宣力之效",
                "4": "才非丘園耿介之秀",
                "5": "皇澤廣被",
                "6": "惠濟無遠",
                "7": "擢自羣萃",
                "8": "累蒙榮進",
                "9": "入朝九載",
                "10": "歷官有六",
                "11": "身登三閣",
                "12": "官成兩宮",
                "13": "服冕乘軒",
                "14": "仰齒貴遊",
                "15": "振景拔迹",
                "16": "顧邈同列",
                "17": "施重山岳",
                "18": "義足灰沒",
                "19": "遭國顚沛",
                "20": "無節可紀",
                "21": "雖蒙曠盪",
                "22": "臣獨何顏",
                "23": "俛首頓膝",
                "24": "憂愧若厲",
                "25": "而橫爲故齊王冏所見枉陷",
                "26": "誣臣與眾人共作禪文",
                "27": "幽執囹圄",
                "28": "當爲誅始",
                "29": "臣之微誠",
                "30": "不負天地",
                "31": "倉卒之際",
                "32": "慮有逼迫",
                "33": "乃與弟雲及散騎侍郎袁瑜",
                "34": "中書侍郎馮熊",
                "35": "尙書右丞崔基",
                "36": "廷尉正顧榮",
                "37": "汝陰太守曹武",
                "38": "思所以獲免",
                "39": "陰蒙避迴",
                "40": "岐嶇自列",
                "41": "片言隻字",
                "42": "不關其間",
                "43": "事蹤筆迹",
                "44": "皆可推校",
                "45": "而一朝翻然",
                "46": "更以爲罪",
                "47": "蕞爾之生",
                "48": "尙不足吝",
                "49": "區區本懷",
                "50": "實有可悲",
                "51": "畏逼天威",
                "52": "卽罪惟謹",
                "53": "鉗口結舌",
                "54": "不敢上訴所天",
                "55": "莫大之釁",
                "56": "日經聖聽",
                "57": "肝血之誠",
                "58": "終不一聞",
                "59": "所以臨難慷慨",
                "60": "而不能不恨恨者",
                "61": "惟此而已"
            }
        },
        "3": {
            "7": {
                "1": "重蒙陛下愷悌之宥",
                "2": "迴霜收電",
                "3": "使不隕越",
                "4": "復得扶老攜幼",
                "5": "生出獄戶",
                "6": "懷金拖紫",
                "7": "退就散輩",
                "8": "感恩惟咎",
                "9": "五情震悼",
                "10": "跼天蹐地",
                "11": "若無所容",
                "12": "不悟日月之明",
                "13": "遂垂曲照",
                "14": "雲雨之澤",
                "15": "播及朽瘁",
                "16": "忘臣弱才",
                "17": "身無足采",
                "18": "哀臣零落",
                "19": "罪有可察",
                "20": "苟削丹書",
                "21": "得夷平民",
                "22": "則塵洗天波",
                "23": "謗絕眾口",
                "24": "臣之始望",
                "25": "尙未至是"
            }
        },
        "4": {
            "9": {
                "1": "猥辱大命",
                "2": "顯授符虎",
                "3": "使春枯之條",
                "4": "更與秋蘭垂芳",
                "5": "陸沈之羽",
                "6": "復與翔鴻撫翼",
                "7": "雖安國免徒",
                "8": "起紆青組",
                "9": "張敞亡命",
                "10": "坐致朱軒",
                "11": "方臣所荷",
                "12": "未足爲泰",
                "13": "豈臣蒙垢含吝",
                "14": "所宜忝竊",
                "15": "非臣毀宗夷族",
                "16": "所能上報",
                "17": "喜懼參幷",
                "18": "悲慚哽結",
                "19": "拘守常憲",
                "20": "當便道之官",
                "21": "不得束身奔走",
                "22": "稽顙城闕",
                "23": "瞻係天衢",
                "24": "馳心輦轂",
                "25": "臣不勝屛營延仰",
                "26": "謹拜表以聞"
            }
        }
    }
}