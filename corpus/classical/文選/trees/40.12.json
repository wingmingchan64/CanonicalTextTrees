{
    "40.12": {
        "篇名": "任彥升 百辟勸進今上牋",
        "1": {
            "3": {
                "1": "近以朝命蘊策",
                "2": "冒奏丹誠",
                "3": "奉被還命",
                "4": "未蒙虛受",
                "5": "搢紳顒顒",
                "6": "深所未達",
                "7": "司馬相如封禪書曰",
                "8": "因雜搢紳先生之略術",
                "9": "李奇曰",
                "10": "搢",
                "11": "插笏於紳",
                "12": "紳",
                "13": "大帶",
                "14": "薛君韓詩章句曰",
                "15": "萬人顒顒",
                "16": "仰天告愬",
                "17": "論語",
                "18": "子曰",
                "19": "丘未達也",
                "20": "蓋聞受金於府",
                "21": "通人之弘致",
                "22": "高蹈海隅",
                "23": "匹夫之小節",
                "24": "是以履乘石而周公不以爲疑",
                "25": "增玉璜而太公不以爲讓",
                "26": "況世哲繼軌",
                "27": "先德在民",
                "28": "經綸草昧",
                "29": "歎深微管",
                "30": "加以朱方之役",
                "31": "荊河是依",
                "32": "班師振旅",
                "33": "大造王室",
                "34": "雖累繭救宋",
                "35": "重胝存楚",
                "36": "說文曰",
                "37": "䵤",
                "38": "黑皺也",
                "39": "古典切",
                "40": "戰國策曰",
                "41": "公輸般爲楚設機械",
                "42": "將以攻宋",
                "43": "墨子聞之",
                "44": "百舍重繭",
                "45": "往見公輸般",
                "46": "輸般服焉",
                "47": "請見之王",
                "48": "王曰",
                "49": "善哉",
                "50": "請無攻宋",
                "51": "高誘曰",
                "52": "公輸般",
                "53": "魯班之子",
                "54": "百舍",
                "55": "百里一舍也",
                "56": "重繭",
                "57": "累胝也",
                "58": "淮南子曰",
                "59": "申包胥累繭重胝",
                "60": "七日七夜至於秦庭",
                "61": "以見秦王",
                "62": "曰",
                "63": "使下臣告急",
                "64": "秦王乃發軍擊吳",
                "65": "果大破之",
                "66": "以存楚國",
                "67": "胝",
                "68": "竹尼切"
            }
        },
        "2": {
            "5": {
                "1": "居今觀古",
                "2": "曾何足云",
                "3": "而惑甚盜鍾",
                "4": "功疑不賞",
                "5": "皇天后土",
                "6": "不勝其酷",
                "7": "是以玉馬駿奔",
                "8": "表微子之去",
                "9": "金版出地",
                "10": "告龍逄之怨",
                "11": "明公據鞍輟哭",
                "12": "厲三軍之志",
                "13": "獨居掩涕",
                "14": "激義士之心",
                "15": "故能使海若登祇",
                "16": "罄圖效祉",
                "17": "山戎孤竹",
                "18": "束馬景從",
                "19": "伐罪弔民",
                "20": "一匡靖亂",
                "21": "匪叨天功",
                "22": "實勤濡足",
                "23": "且明公本自諸生",
                "24": "取樂名教",
                "25": "道風素論",
                "26": "坐鎭雅俗",
                "27": "不習孫吳",
                "28": "遘茲神武",
                "29": "驅盡誅之氓",
                "30": "濟必封之俗",
                "31": "龜玉不毀",
                "32": "誰之功歟",
                "33": "獨爲君子",
                "34": "將使伊周何地",
                "35": "某等不達通變",
                "36": "實有愚誠",
                "37": "不任悾款",
                "38": "悉心重謁",
                "39": "伏願時膺典冊",
                "40": "式副民望"
            }
        }
    }
}