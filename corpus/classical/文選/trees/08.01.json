{
    "08.01": {
        "篇名": "司馬長卿 上林賦",
        "1": {
            "3": {
                "1": "亡是公听然而笑曰",
                "2": "楚則失矣",
                "3": "齊亦未爲得也",
                "4": "夫使諸侯納貢者",
                "5": "非爲財幣",
                "6": "所以述職也",
                "7": "封疆畫界者",
                "8": "非爲守禦",
                "9": "所以禁淫也",
                "10": "今齊列爲東藩",
                "11": "而外私肅愼",
                "12": "捐國踰限",
                "13": "越海而田",
                "14": "其於義固未可也",
                "15": "且二君之論",
                "16": "不務明君臣之義",
                "17": "正諸侯之禮",
                "18": "徒事爭於遊戲之樂",
                "19": "苑囿之大",
                "20": "欲以奢侈相勝",
                "21": "荒淫相越",
                "22": "此不可以揚名發譽",
                "23": "而適足以貶君自損也"
            }
        },
        "2": {
            "5": {
                "1": "且夫齊楚之事又烏足道乎",
                "2": "君未覩夫巨麗也",
                "3": "獨不聞天子之上林乎",
                "4": "左蒼梧",
                "5": "右西極",
                "6": "丹水更其南",
                "7": "紫淵徑其北",
                "8": "終始灞滻",
                "9": "出入涇渭",
                "10": "酆鎬潦潏",
                "11": "紆餘委蛇",
                "12": "經營乎其內",
                "13": "蕩蕩乎八川分流",
                "14": "相背而異態",
                "15": "東西南北",
                "16": "馳騖往來",
                "17": "出乎椒丘之闕",
                "18": "行乎洲淤之浦",
                "19": "經乎桂林之中",
                "20": "過乎泱漭之野",
                "21": "汨乎混流",
                "22": "順阿而下",
                "23": "赴隘陝之口",
                "24": "觸穹石",
                "25": "激堆埼",
                "26": "怫乎暴怒",
                "27": "洶涌滂湃",
                "28": "滭弗滵汨",
                "29": "偪側泌瀄",
                "30": "橫流逆折",
                "31": "轉騰潎洌",
                "32": "滂濞沆漑",
                "33": "穹隆雲橈",
                "34": "宛潬膠盭",
                "35": "踰波趨浥",
                "36": "莅莅下瀨",
                "37": "批巖衝擁",
                "38": "犇揚滯沛",
                "39": "臨坻注壑",
                "40": "瀺灂霣墜",
                "41": "沈沈隱隱",
                "42": "砰磅訇磕",
                "43": "潏潏淈淈",
                "44": "湁潗鼎沸",
                "45": "馳波跳沫",
                "46": "汨㴔漂疾",
                "47": "悠遠長懷",
                "48": "寂漻無聲",
                "49": "肆乎永歸",
                "50": "然後灝溔潢漾",
                "51": "安翔徐徊",
                "52": "翯乎滈滈",
                "53": "東注太湖",
                "54": "衍溢陂池"
            }
        },
        "3": {
            "7": {
                "1": "於是乎蛟龍赤螭",
                "2": "䱎䲛漸離",
                "3": "鰅鱅鳍鮀",
                "4": "禺禺魼鰨",
                "5": "揵鰭掉尾",
                "6": "振鱗奮翼",
                "7": "潛處乎深巖",
                "8": "魚鱉讙聲",
                "9": "萬物眾夥",
                "10": "明月珠子",
                "11": "的皪江靡",
                "12": "蜀石黃碝",
                "13": "水玉磊砢",
                "14": "磷磷爛爛",
                "15": "采色澔汗",
                "16": "藂積乎其中",
                "17": "鴻鷫鵠鴇",
                "18": "鴐鵞屬玉",
                "19": "交精旋目",
                "20": "煩鶩庸渠",
                "21": "箴疵鵁盧",
                "22": "羣浮乎其上",
                "23": "泛淫泛濫",
                "24": "隨風澹淡",
                "25": "與波搖蕩",
                "26": "掩薄水渚",
                "27": "唼喋菁藻",
                "28": "咀嚼菱藕"
            }
        },
        "4": {
            "9": {
                "1": "於是乎崇山矗矗",
                "2": "巃嵸崔嵬",
                "3": "深林巨木",
                "4": "嶄巖嵾嵳",
                "5": "九嵕嶻嶭",
                "6": "南山峩峩",
                "7": "巖阤甗錡",
                "8": "嶊崣崛崎",
                "9": "振溪通谷",
                "10": "蹇產溝瀆",
                "11": "谽呀豁閕",
                "12": "阜陵別隝",
                "13": "崴嵬嵔廆",
                "14": "丘虛堀礨",
                "15": "隱轔鬱㠥",
                "16": "登降陀靡",
                "17": "陂池貏豸",
                "18": "沇溶淫鬻",
                "19": "散渙夷陸",
                "20": "亭皋千里",
                "21": "靡不被築",
                "22": "掩以綠蕙",
                "23": "被以江蘺",
                "24": "糅以蘪蕪",
                "25": "雜以留夷",
                "26": "布結縷",
                "27": "攢戾莎",
                "28": "揭車蘅蘭",
                "29": "槀本射干",
                "30": "茈薑蘘荷",
                "31": "葴持若蓀",
                "32": "鮮支黃礫",
                "33": "蔣芧青薠",
                "34": "布濩閎澤",
                "35": "延蔓太原",
                "36": "離靡廣衍",
                "37": "應風披靡",
                "38": "吐芳揚烈",
                "39": "郁郁菲菲",
                "40": "眾香發越",
                "41": "肸蠁布寫",
                "42": "晻薆咇茀"
            }
        },
        "5": {
            "11": {
                "1": "於是乎周覽泛觀",
                "2": "縝紛軋芴",
                "3": "芒芒怳忽",
                "4": "視之無端",
                "5": "察之無涯",
                "6": "日出東沼",
                "7": "入乎西陂",
                "8": "其南則隆冬生長",
                "9": "涌水躍波",
                "10": "其獸則㺎旄貘犛",
                "11": "沈牛麈麋",
                "12": "赤首圜題",
                "13": "窮奇象犀",
                "14": "其北則盛夏含凍裂地",
                "15": "涉冰揭河",
                "16": "其獸則麒麟角端",
                "17": "騊駼橐駝",
                "18": "蛩蛩驒騱",
                "19": "駃騠驢騾"
            }
        },
        "6": {
            "13": {
                "1": "於是乎離宮別館",
                "2": "彌山跨谷",
                "3": "高廊四注",
                "4": "重坐曲閣",
                "5": "華榱璧璫",
                "6": "輦道纚屬",
                "7": "步櫩周流",
                "8": "長途中宿",
                "9": "夷嵕築堂",
                "10": "累臺增成",
                "11": "巖窔洞房",
                "12": "俯杳眇而無見",
                "13": "仰攀橑而捫天",
                "14": "奔星更於閨闥",
                "15": "宛虹拖於楯軒",
                "16": "青龍蚴蟉於東廂",
                "17": "象輿婉蟬於西清",
                "18": "靈圉燕於間館",
                "19": "偓佺之倫暴於南榮",
                "20": "醴泉涌於清室",
                "21": "通川過於中庭",
                "22": "盤石振崖",
                "23": "嶔巖倚傾",
                "24": "嵯峨㠎嶫",
                "25": "刻削崢嶸",
                "26": "玫瑰碧琳",
                "27": "珊瑚叢生",
                "28": "瑉玉旁唐",
                "29": "玢豳文鱗",
                "30": "赤瑕駮犖",
                "31": "雜插其間",
                "32": "鼂采琬琰",
                "33": "和氏出焉"
            }
        },
        "7": {
            "15": {
                "1": "於是乎盧橘夏熟",
                "2": "黃甘橙楱",
                "3": "枇杷橪柿",
                "4": "楟柰厚朴",
                "5": "梬棗楊梅",
                "6": "櫻桃蒲陶",
                "7": "隱夫薁棣",
                "8": "答遝離支",
                "9": "羅乎後宮",
                "10": "列乎北園",
                "11": "䝯丘陵",
                "12": "下平原",
                "13": "揚翠葉",
                "14": "扤紫莖",
                "15": "發紅華",
                "16": "垂朱榮",
                "17": "煌煌扈扈",
                "18": "照曜鉅野",
                "19": "沙棠櫟櫧",
                "20": "華楓枰櫨",
                "21": "留落胥邪",
                "22": "仁頻幷閭",
                "23": "欃檀木蘭",
                "24": "豫章女貞",
                "25": "長千仞",
                "26": "大連抱",
                "27": "夸條直暢",
                "28": "實葉葰楙",
                "29": "攢立叢倚",
                "30": "連卷欐佹",
                "31": "崔錯癹骪",
                "32": "坑衡閜砢",
                "33": "垂條扶疏",
                "34": "落英幡纚",
                "35": "紛溶箾蔘",
                "36": "猗柅從風",
                "37": "瀏莅芔歙",
                "38": "蓋象金石之聲",
                "39": "管籥之音",
                "40": "偨池茈虒",
                "41": "旋還乎後宮",
                "42": "雜襲纍輯",
                "43": "被山緣谷",
                "44": "循坂下隰",
                "45": "視之無端",
                "46": "究之無窮"
            }
        },
        "8": {
            "17": {
                "1": "於是乎玄猿素雌",
                "2": "蜼玃飛鸓",
                "3": "蛭蜩蠼猱",
                "4": "獑胡豰蛫",
                "5": "栖息乎其間",
                "6": "長嘯哀鳴",
                "7": "翩幡互經",
                "8": "夭蟜枝格",
                "9": "偃蹇杪顚",
                "10": "隃絕梁",
                "11": "騰殊榛",
                "12": "捷垂條",
                "13": "掉希間",
                "14": "牢落陸離",
                "15": "爛漫遠遷",
                "16": "若此輩者",
                "17": "數百千處",
                "18": "娛遊往來",
                "19": "宮宿館舍",
                "20": "庖廚不徙",
                "21": "後宮不移",
                "22": "百官備具"
            }
        },
        "9": {
            "19": {
                "1": "於是乎背秋涉冬",
                "2": "天子校獵",
                "3": "乘鏤象",
                "4": "六玉虯",
                "5": "拖蜺旌",
                "6": "靡雲旗",
                "7": "前皮軒",
                "8": "後道遊",
                "9": "孫叔奉轡",
                "10": "衞公參乘",
                "11": "扈從橫行",
                "12": "出乎四校之中",
                "13": "鼓嚴簿",
                "14": "縱獵者",
                "15": "江江爲阹",
                "16": "泰山爲櫓",
                "17": "車騎雷起",
                "18": "殷天動地",
                "19": "先後陸離",
                "20": "離散別追",
                "21": "淫淫裔裔",
                "22": "緣陵流澤",
                "23": "雲布雨施",
                "24": "生貔豹",
                "25": "搏豺狼",
                "26": "手熊羆",
                "27": "足野羊",
                "28": "蒙鶡蘇",
                "29": "絝白虎",
                "30": "被班文",
                "31": "跨野馬",
                "32": "陵三嵕之危",
                "33": "下磧歷之坻",
                "34": "徑峻赴險",
                "35": "越壑厲水",
                "36": "推飛廉",
                "37": "弄獬豸格蝦蛤",
                "38": "鋋猛氏",
                "39": "羂騕褭",
                "40": "射封豕",
                "41": "箭不苟害",
                "42": "解脰陷腦",
                "43": "弓不虛發",
                "44": "應聲而倒"
            }
        },
        "10": {
            "21": {
                "1": "於是乘輿弭節徘徊",
                "2": "翱翔往來",
                "3": "睨部曲之進退",
                "4": "覽將帥之變態",
                "5": "然後侵淫促節",
                "6": "倏敻遠去",
                "7": "流離輕禽",
                "8": "蹴履狡獸",
                "9": "轊白鹿",
                "10": "捷狡兔",
                "11": "軼赤電",
                "12": "遺光耀",
                "13": "追怪物",
                "14": "出宇宙",
                "15": "彎蕃弱",
                "16": "滿白羽",
                "17": "射遊梟",
                "18": "櫟蜚遽",
                "19": "擇肉而後發",
                "20": "先中而命處",
                "21": "弦矢分",
                "22": "藝殪仆",
                "23": "然後揚節而上浮",
                "24": "凌驚風",
                "25": "歷駭猋",
                "26": "乘虛無",
                "27": "與神俱",
                "28": "藺玄鶴",
                "29": "亂昆雞",
                "30": "遒孔鸞",
                "31": "促鵕䴊",
                "32": "拂翳鳥",
                "33": "捎鳳凰",
                "34": "捷鵷雛",
                "35": "揜焦明",
                "36": "道盡塗殫",
                "37": "迴車而還",
                "38": "招搖乎襄羊",
                "39": "降集乎北紘",
                "40": "率乎直指",
                "41": "晻乎反鄕",
                "42": "蹶石闕",
                "43": "歷封巒",
                "44": "過鳷鵲",
                "45": "望露寒",
                "46": "下棠梨",
                "47": "息宜春",
                "48": "西馳宣曲",
                "49": "濯鷁牛首",
                "50": "登龍臺",
                "51": "掩細柳",
                "52": "觀士大夫之勤略",
                "53": "鈞獵者之所得獲",
                "54": "徒車之所轥轢",
                "55": "步騎之所蹂蹃",
                "56": "人臣之所蹈藉",
                "57": "與其窮極倦谻",
                "58": "驚憚讋伏",
                "59": "不被創刃而死者",
                "60": "佗佗藉藉",
                "61": "塡阬滿谷",
                "62": "揜平彌澤"
            }
        },
        "11": {
            "23": {
                "1": "於是乎遊戲懈怠",
                "2": "置酒乎顥天之臺",
                "3": "張樂乎膠葛之㝢",
                "4": "撞千石之鐘",
                "5": "立萬石之虡",
                "6": "建翠華之旗",
                "7": "樹靈鼉之鼓",
                "8": "奏陶唐氏之舞",
                "9": "聽葛天氏之歌",
                "10": "千人唱",
                "11": "萬人和",
                "12": "山陵爲之震動",
                "13": "川谷爲之蕩波",
                "14": "巴兪",
                "15": "宋",
                "16": "蔡",
                "17": "淮南",
                "18": "干遮",
                "19": "文成",
                "20": "顚歌",
                "21": "族居遞奏",
                "22": "金鼓迭起",
                "23": "鏗鎗闛鞈",
                "24": "洞心駭耳",
                "25": "荊",
                "26": "吳",
                "27": "鄭",
                "28": "衞之聲",
                "29": "韶",
                "30": "濩",
                "31": "武",
                "32": "象之樂",
                "33": "陰淫案衍之音",
                "34": "鄢",
                "35": "郢繽紛",
                "36": "激楚結風",
                "37": "俳優侏儒",
                "38": "狄鞮之倡",
                "39": "所以娛耳目",
                "40": "樂心意者",
                "41": "麗靡爛漫於前",
                "42": "靡曼美色於後",
                "43": "若夫青琴",
                "44": "宓妃之徒",
                "45": "絕殊離俗",
                "46": "妖冶閑都",
                "47": "靚莊刻飾",
                "48": "便嬛綽約",
                "49": "柔橈嫚嫚",
                "50": "嫵媚孅弱",
                "51": "曳獨繭之褕袣",
                "52": "眇閻易以戌削",
                "53": "便姍嫳屑",
                "54": "與俗殊服",
                "55": "芬芳漚鬱",
                "56": "酷烈淑郁",
                "57": "皓齒粲爛",
                "58": "宜笑的皪",
                "59": "長眉連娟",
                "60": "微睇緜藐",
                "61": "色授魂與",
                "62": "心愉於側"
            }
        },
        "12": {
            "25": {
                "1": "於是酒中樂酣",
                "2": "天子芒然而思",
                "3": "似若有亡曰",
                "4": "嗟乎",
                "5": "此大奢侈",
                "6": "朕以覽聽餘間",
                "7": "無事棄日",
                "8": "順天道以殺伐",
                "9": "時休息於此",
                "10": "恐後世靡麗",
                "11": "遂往而不返",
                "12": "非所以爲繼嗣創業垂統也",
                "13": "於是乎乃解酒罷獵",
                "14": "而命有司曰",
                "15": "地可墾闢",
                "16": "悉爲農郊",
                "17": "以贍氓隸",
                "18": "隤牆塡塹",
                "19": "使山澤之人得至焉",
                "20": "實陂池而勿禁",
                "21": "虛宮館而勿仞",
                "22": "發倉廩以救貧窮",
                "23": "補不足",
                "24": "卹鰥寡",
                "25": "存孤獨",
                "26": "出德號",
                "27": "省刑罰",
                "28": "改制度",
                "29": "易服色",
                "30": "革正朔",
                "31": "與天下爲始"
            }
        },
        "13": {
            "27": {
                "1": "於是歷吉日以齋戒",
                "2": "襲朝服",
                "3": "乘法駕",
                "4": "建華旗",
                "5": "鳴玉鸞",
                "6": "遊乎六藝之囿",
                "7": "馳騖乎仁義之塗",
                "8": "覽觀春秋之林",
                "9": "射貍首",
                "10": "兼騶虞",
                "11": "弋玄鶴",
                "12": "舞干戚",
                "13": "載雲䍐",
                "14": "揜羣雅",
                "15": "悲伐檀",
                "16": "樂樂胥",
                "17": "修容乎禮園",
                "18": "翱翔乎書圃",
                "19": "述易道",
                "20": "放怪獸",
                "21": "登明堂",
                "22": "坐清廟",
                "23": "恣羣臣",
                "24": "奏得失",
                "25": "四海之內",
                "26": "靡不受獲",
                "27": "於斯之時",
                "28": "天下大說",
                "29": "向風而聽",
                "30": "隨流而化",
                "31": "芔然興道而遷義",
                "32": "刑錯而不用",
                "33": "德隆於三皇",
                "34": "而功羨於五帝",
                "35": "若此",
                "36": "故獵乃可喜也",
                "37": "若夫終日馳騁",
                "38": "勞神苦形",
                "39": "疲車馬之用",
                "40": "抏士卒之精",
                "41": "費府庫之財",
                "42": "而無德厚之恩",
                "43": "務在獨樂",
                "44": "不顧眾庶",
                "45": "忘國家之政",
                "46": "貪雉兔之獲",
                "47": "則仁者不由也",
                "48": "從此觀之",
                "49": "齊",
                "50": "楚之事",
                "51": "豈不哀哉",
                "52": "地方不過千里",
                "53": "而囿居九百",
                "54": "是草木不得墾辟",
                "55": "而人無所食也",
                "56": "夫以諸侯之細",
                "57": "而樂萬乘之侈",
                "58": "僕恐百姓被其尤也"
            }
        },
        "14": {
            "29": {
                "1": "於是二子愀然改容",
                "2": "超若自失",
                "3": "逡巡避席曰",
                "4": "鄙人固陋",
                "5": "不知忌諱",
                "6": "乃今日見教",
                "7": "謹受命矣"
            }
        }
    }
}