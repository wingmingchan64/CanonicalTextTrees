{
    "39.06": {
        "篇名": "枚叔 上書重諫吳王",
        "1": {
            "3": {
                "1": "昔秦西舉胡戎之難",
                "2": "北備楡中之關",
                "3": "南距羌筰之塞",
                "4": "東當六國之從",
                "5": "六國乘信陵之籍",
                "6": "明蘇秦之約",
                "7": "厲荊軻之威",
                "8": "幷力一心以備秦",
                "9": "然秦卒禽六國",
                "10": "滅其社稷",
                "11": "而幷天下",
                "12": "是何也",
                "13": "則地利不同",
                "14": "而民輕重不等也",
                "15": "今漢據全秦之地",
                "16": "兼六國之眾",
                "17": "修戎狄之義",
                "18": "而南朝羌筰",
                "19": "此其與秦",
                "20": "地相什而民相百",
                "21": "大王之所明知也",
                "22": "今夫讒諛之臣爲大王計者",
                "23": "不論骨肉之義",
                "24": "民之輕重",
                "25": "國之大小",
                "26": "以爲吳禍",
                "27": "此臣所以爲大王患也"
            }
        },
        "2": {
            "5": {
                "1": "夫舉吳兵以訾於漢",
                "2": "譬猶蠅蚋之附羣牛",
                "3": "腐肉之齒利劍",
                "4": "鋒接必無事矣",
                "5": "天下聞吳率失職諸侯",
                "6": "願責先帝之遺約",
                "7": "今漢親誅其三公",
                "8": "以謝前過",
                "9": "是大王威加於天下",
                "10": "而功越於湯武也",
                "11": "夫吳有諸侯之位",
                "12": "而富實於天子",
                "13": "有隱匿之名",
                "14": "而居過於中國",
                "15": "夫漢幷二十四郡",
                "16": "十七諸侯",
                "17": "方輸錯出",
                "18": "軍行數千里不絕於郊",
                "19": "其珍怪不如山東之府",
                "20": "轉粟西鄕",
                "21": "陸行不絕",
                "22": "水行滿河",
                "23": "不如海陵之倉",
                "24": "修治上林",
                "25": "雜以離宮",
                "26": "積聚玩好",
                "27": "圈守禽獸",
                "28": "不如長洲之苑",
                "29": "遊曲臺",
                "30": "臨上路",
                "31": "不如朝夕之池",
                "32": "深壁高壘",
                "33": "副以關城",
                "34": "不如江淮之險",
                "35": "此臣之所爲大王樂也"
            }
        },
        "3": {
            "7": {
                "1": "今大王還兵疾歸",
                "2": "尙得十半",
                "3": "不然",
                "4": "漢知吳有吞天下之心",
                "5": "赫然加怒",
                "6": "遣羽林黃頭循江而下",
                "7": "襲大王之都",
                "8": "魯東海絕吳之饟道",
                "9": "梁王飾車騎",
                "10": "習戰射",
                "11": "積粟固守",
                "12": "以偪滎陽",
                "13": "待吳之飢",
                "14": "大王雖欲反都",
                "15": "亦不得已",
                "16": "夫三淮南之計不負其約",
                "17": "齊王殺身以滅其迹",
                "18": "四國不得出兵其郡",
                "19": "趙囚邯鄲",
                "20": "此不可掩",
                "21": "亦已明矣",
                "22": "今大王已去千里之國",
                "23": "而制於十里之內矣",
                "24": "張韓將北地",
                "25": "弓高宿左右",
                "26": "兵不得下壁",
                "27": "軍不得太息",
                "28": "臣竊哀之",
                "29": "願大王熟察焉"
            }
        }
    }
}