{
    "18.01": {
        "篇名": "馬季長 長笛賦[幷序]",
        "1": {
            "3": {
                "1": "融旣博覽典雅",
                "2": "精核數術",
                "3": "又性好音",
                "4": "能鼓琴吹笛",
                "5": "而爲督郵",
                "6": "無留事",
                "7": "獨臥郿平陽鄔中",
                "8": "有雒客舍逆旅",
                "9": "吹笛爲氣出精列相和",
                "10": "融去京師",
                "11": "踰年",
                "12": "暫聞",
                "13": "甚悲而樂之",
                "14": "追慕王子淵枚乘劉伯康傅武仲等簫琴笙頌",
                "15": "唯笛獨無",
                "16": "故聊復備數",
                "17": "作長笛賦",
                "18": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "惟籦籠之奇生兮",
                "2": "於終南之陰崖",
                "3": "託九成之孤岑兮",
                "4": "臨萬仞之石磎",
                "5": "特箭槁而莖立兮",
                "6": "獨聆風於極危",
                "7": "秋潦漱其下趾兮",
                "8": "冬雪揣封乎其枝",
                "9": "巓根跱之𣙗刖兮",
                "10": "感迴飇而將頹",
                "11": "夫其面旁則重巘增石",
                "12": "簡積頵砡",
                "13": "兀㟺狋𦡼",
                "14": "傾𣅳倚伏",
                "15": "庨窌巧老",
                "16": "港洞坑谷",
                "17": "嶰壑澮𡷋",
                "18": "𡸞窞巖𥨍",
                "19": "運裛窏洝",
                "20": "岡連嶺屬",
                "21": "林簫蔓荊",
                "22": "森槮柞樸"
            }
        },
        "3": {
            "7": {
                "1": "於是山水猥至",
                "2": "渟涔障潰",
                "3": "顄淡滂流",
                "4": "碓投瀺穴",
                "5": "爭湍苹縈",
                "6": "汩活澎濞",
                "7": "波瀾鱗淪",
                "8": "窊隆詭戾",
                "9": "𤀰瀑噴沫",
                "10": "奔遯碭突",
                "11": "搖演其山",
                "12": "動杌其根者",
                "13": "歲五六而至焉",
                "14": "是以間介無蹊",
                "15": "人迹罕到",
                "16": "猿蜼晝吟",
                "17": "鼯鼠夜叫",
                "18": "寒熊振頷",
                "19": "特麚昏髟",
                "20": "山雞晨羣",
                "21": "壄雉晁雊",
                "22": "求偶鳴子",
                "23": "悲號長嘯",
                "24": "由衍識道",
                "25": "噍噍讙譟",
                "26": "經涉其左右",
                "27": "哤聒其前後者",
                "28": "無晝夜而息焉",
                "29": "夫固危殆險巇之所迫也",
                "30": "眾哀集悲之所積也",
                "31": "故其應清風也",
                "32": "纖末奮蕱",
                "33": "錚鐄謍嗃",
                "34": "若絙瑟促柱",
                "35": "號鍾高調"
            }
        },
        "4": {
            "9": {
                "1": "於是放臣逐子",
                "2": "棄妻離友",
                "3": "彭胥伯奇",
                "4": "哀姜孝己",
                "5": "攢乎下風",
                "6": "收精注耳",
                "7": "靁歎頹息",
                "8": "掐膺擗摽",
                "9": "泣血泫流",
                "10": "交橫而下",
                "11": "通旦忘寐",
                "12": "不能自禦"
            }
        },
        "5": {
            "11": {
                "1": "於是乃使魯般宋翟",
                "2": "構雲梯",
                "3": "抗浮柱",
                "4": "蹉纖根",
                "5": "跋𮆘縷",
                "6": "膺陗阤",
                "7": "腹陘阻",
                "8": "逮乎其上",
                "9": "匍匐伐取",
                "10": "挑截本末",
                "11": "規摹彠矩",
                "12": "夔襄比律",
                "13": "子壄協呂",
                "14": "十二畢具",
                "15": "黃鍾爲主",
                "16": "撟揉斤械",
                "17": "剸掞度擬",
                "18": "鏓硐隤墜",
                "19": "程表朱裏",
                "20": "定名曰笛",
                "21": "以觀賢士",
                "22": "陳於東階",
                "23": "八音俱起",
                "24": "食舉雍徹",
                "25": "勸侑君子",
                "26": "然後退理乎黃門之高廊",
                "27": "重丘宋灌",
                "28": "名師郭張",
                "29": "工人巧士",
                "30": "肄業修聲"
            }
        },
        "6": {
            "13": {
                "1": "於是遊間公子",
                "2": "暇豫王孫",
                "3": "心樂五聲之和",
                "4": "耳比八音之調",
                "5": "乃相與集乎其庭",
                "6": "詳觀夫曲胤之繁會叢雜",
                "7": "何其富也",
                "8": "紛葩爛漫",
                "9": "誠可喜也",
                "10": "波散廣衍",
                "11": "實可異也",
                "12": "牚距劫遌",
                "13": "又足怪也",
                "14": "啾咋嘈啐",
                "15": "似華羽兮",
                "16": "絞灼激以轉切",
                "17": "震鬱怫以憑怒兮",
                "18": "耾碭駭以奮肆",
                "19": "氣噴勃以布覆兮",
                "20": "乍跱蹠以狼戾",
                "21": "靁叩鍛之岌峇兮",
                "22": "正瀏溧以風冽",
                "23": "薄湊會而凌節兮",
                "24": "馳趣期而赴躓"
            }
        },
        "7": {
            "15": {
                "1": "爾乃聽聲類形",
                "2": "狀似流水",
                "3": "又象飛鴻",
                "4": "泛濫溥漠",
                "5": "浩浩洋洋",
                "6": "長矕遠引",
                "7": "旋復迴皇",
                "8": "充屈鬱律",
                "9": "瞋菌碨抰",
                "10": "酆琅磊落",
                "11": "騈田磅唐",
                "12": "取予時適",
                "13": "去就有方",
                "14": "洪殺衰序",
                "15": "希數必當",
                "16": "微風纖妙",
                "17": "若存若亡",
                "18": "藎滯抗絕",
                "19": "中息更裝",
                "20": "奄忽滅沒",
                "21": "曄然復揚",
                "22": "或乃聊慮固護",
                "23": "專美擅工",
                "24": "漂凌絲簧",
                "25": "覆冒鼓鍾",
                "26": "或乃植持縼纆",
                "27": "佁儗寬容",
                "28": "簫管備舉",
                "29": "金石並隆",
                "30": "無相奪倫",
                "31": "以宣八風",
                "32": "律呂旣和",
                "33": "哀聲五降",
                "34": "曲終闋盡",
                "35": "餘絃更興",
                "36": "繁手累發",
                "37": "密櫛疊重",
                "38": "踾踧攢仄",
                "39": "蜂聚蟻同",
                "40": "眾音猥積",
                "41": "以送厥終"
            }
        },
        "8": {
            "17": {
                "1": "然後少息暫怠",
                "2": "雜弄間奏",
                "3": "易聽駭耳",
                "4": "有所搖演",
                "5": "安翔駘蕩",
                "6": "從容闡緩",
                "7": "惆悵怨懟",
                "8": "窳圔窴赧",
                "9": "聿皇求索",
                "10": "乍近乍遠",
                "11": "臨危自放",
                "12": "若頹復反",
                "13": "蚡縕繙紆",
                "14": "緸冤蜿蟺",
                "15": "笢笏抑隱",
                "16": "行入諸變",
                "17": "絞槪汨湟",
                "18": "五音代轉",
                "19": "挼拏捘臧",
                "20": "遞相乘邅",
                "21": "反商下徵",
                "22": "每各異善"
            }
        },
        "9": {
            "19": {
                "1": "故聆曲引者",
                "2": "觀法於節奏",
                "3": "察變於句投",
                "4": "以知禮制之不可踰越焉",
                "5": "聽簉弄者",
                "6": "遙思於古昔",
                "7": "虞志於怛惕",
                "8": "以知長戚之不能間居焉",
                "9": "故論記其義",
                "10": "協比其象",
                "11": "徬徨縱肆",
                "12": "曠𤄾敞罔",
                "13": "老莊之槪也",
                "14": "溫直擾毅",
                "15": "孔孟之方也",
                "16": "激朗清厲",
                "17": "隨光之介也",
                "18": "牢剌拂戾",
                "19": "諸",
                "20": "賁之氣也",
                "21": "節解句斷",
                "22": "管商之制也",
                "23": "條決繽紛",
                "24": "申韓之察也",
                "25": "繁縟駱驛",
                "26": "范蔡之說也",
                "27": "剺櫟銚㦎",
                "28": "晳龍之惠也",
                "29": "上擬法於韶箾南籥",
                "30": "中取度於白雪淥水",
                "31": "下釆制於延露巴人"
            }
        },
        "10": {
            "21": {
                "1": "是以尊卑都鄙",
                "2": "賢愚勇懼",
                "3": "魚鼈禽獸",
                "4": "聞之者莫不張耳鹿駭",
                "5": "熊經鳥申",
                "6": "鴟視狼顧",
                "7": "拊譟踴躍",
                "8": "各得其齊",
                "9": "人盈所欲",
                "10": "皆反中和",
                "11": "以美風俗",
                "12": "屈平適樂國",
                "13": "介推還受祿",
                "14": "澹臺載尸歸",
                "15": "皋魚節其哭",
                "16": "長萬輟逆謀",
                "17": "渠彌不復惡",
                "18": "蒯聵能退敵",
                "19": "不占成節鄂",
                "20": "王公保其位",
                "21": "隱處安林薄",
                "22": "宦夫樂其業",
                "23": "士子世其宅",
                "24": "鱏魚喁於水裔",
                "25": "仰駟馬而舞玄鶴"
            }
        },
        "11": {
            "23": {
                "1": "於時也",
                "2": "綿駒吞聲",
                "3": "伯牙毀絃",
                "4": "瓠巴聑柱",
                "5": "磬襄弛懸",
                "6": "留視𥊲眙",
                "7": "累稱屢讚",
                "8": "失容墜席",
                "9": "搏拊雷抃",
                "10": "僬眇睢維",
                "11": "涕洟流漫",
                "12": "是故可以通靈感物",
                "13": "寫神喩意",
                "14": "致誠效志",
                "15": "率作興事",
                "16": "漑盥汙濊",
                "17": "澡雪垢滓矣"
            }
        },
        "12": {
            "25": {
                "1": "昔庖羲作琴",
                "2": "神農造瑟",
                "3": "女媧制簧",
                "4": "暴辛爲塤",
                "5": "倕之和鐘",
                "6": "叔之離磬",
                "7": "或鑠金礱石",
                "8": "華睆切錯",
                "9": "丸挻彫琢",
                "10": "刻鏤鑽笮",
                "11": "窮妙極巧",
                "12": "曠以日月",
                "13": "然後成器",
                "14": "其音如彼",
                "15": "唯笛因其天姿",
                "16": "不變其材",
                "17": "伐而吹之",
                "18": "其聲如此",
                "19": "蓋亦簡易之義",
                "20": "賢人之業也",
                "21": "若然",
                "22": "六器者",
                "23": "猶以二皇聖哲黈益",
                "24": "況笛生乎大漢",
                "25": "而學者不識其可以裨助盛美",
                "26": "忽而不讚",
                "27": "悲夫"
            }
        },
        "13": {
            "27": {
                "1": "有庶士丘仲言其所由出",
                "2": "而不知其弘妙",
                "3": "其辭曰"
            }
        },
        "14": {
            "29": {
                "1": "近世雙笛從羌起",
                "2": "羌人伐竹未及已",
                "3": "龍鳴水中不見己",
                "4": "截竹吹之聲相似",
                "5": "剡其上孔通洞之",
                "6": "裁以當簻便易持",
                "7": "易京君明識音律",
                "8": "故本四孔加以一",
                "9": "君明所加孔後出",
                "10": "是謂商聲五音畢"
            }
        }
    }
}