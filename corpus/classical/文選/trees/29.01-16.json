{
    "29.01-16": {
        "篇名": "古詩一十九首·凜凜歲云暮",
        "1": {
            "3": {
                "1": "凜凜歲云暮",
                "2": "螻蛄夕鳴悲",
                "3": "涼風率已厲",
                "4": "遊子寒無衣",
                "5": "錦衾遺洛浦",
                "6": "同袍與我違",
                "7": "獨宿累長夜",
                "8": "夢想見容輝",
                "9": "良人惟古歡",
                "10": "枉駕惠前綏",
                "11": "願得常巧笑",
                "12": "攜手同車歸",
                "13": "旣來不須臾",
                "14": "又不處重闈",
                "15": "亮無晨風翼",
                "16": "焉能凌風飛",
                "17": "眄睞以適意",
                "18": "引領遙相睎",
                "19": "徙倚懷感傷",
                "20": "垂涕霑雙扉"
            }
        }
    }
}