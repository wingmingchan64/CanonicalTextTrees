{
    "20.03-12": {
        "篇名": "潘安仁 關中詩·其十二",
        "1": {
            "3": {
                "1": "情固萬端",
                "2": "於何不有",
                "3": "紛紜齊萬",
                "4": "亦孔之醜",
                "5": "曰納其降",
                "6": "曰梟其首",
                "7": "疇眞可掩",
                "8": "孰僞可久"
            }
        }
    }
}