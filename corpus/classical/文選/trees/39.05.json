{
    "39.05": {
        "篇名": "枚叔 上書諫吳王",
        "1": {
            "3": {
                "1": "臣聞得全者昌",
                "2": "失全者亡",
                "3": "舜無立錐之地",
                "4": "以有天下",
                "5": "禹無十戶之聚",
                "6": "以王諸侯",
                "7": "湯武之土不過百里",
                "8": "上不絕三光之明",
                "9": "下不傷百姓之心者",
                "10": "有王術也",
                "11": "故父子之道",
                "12": "天性也",
                "13": "忠臣不避重誅以直諫",
                "14": "則事無遺策",
                "15": "功流萬世",
                "16": "臣乘願披腹心而效愚忠",
                "17": "惟大王少加意念惻怛之心於臣乘言"
            }
        },
        "2": {
            "5": {
                "1": "夫以一縷之任係千鈞之重",
                "2": "上懸之無極之高",
                "3": "下垂之不測之淵",
                "4": "雖甚愚之人猶知哀其將絕也",
                "5": "馬方駭鼓而驚之",
                "6": "係方絕又重鎭之",
                "7": "係絕於天不可復結",
                "8": "墜入深淵難以復出",
                "9": "其出不出",
                "10": "間不容髮",
                "11": "能聽忠臣之言",
                "12": "百舉必脫",
                "13": "必若所欲爲",
                "14": "危於累卵",
                "15": "難於上天",
                "16": "變所欲爲",
                "17": "易於反掌",
                "18": "安於泰山",
                "19": "今欲極天命之上壽",
                "20": "敝無窮之極樂",
                "21": "究萬乘之勢",
                "22": "不出反掌之易",
                "23": "居泰山之安",
                "24": "而欲乘累卵之危",
                "25": "走上天之難",
                "26": "此愚臣之所大惑也"
            }
        },
        "3": {
            "7": {
                "1": "人性有畏其影而惡其迹",
                "2": "卻背而走",
                "3": "迹逾多",
                "4": "影逾疾",
                "5": "不如就陰而止",
                "6": "影滅迹絕",
                "7": "欲人勿聞",
                "8": "莫若勿言",
                "9": "欲人勿知",
                "10": "莫若勿爲",
                "11": "欲湯之滄",
                "12": "一人炊之",
                "13": "百人揚之",
                "14": "無益也",
                "15": "不如絕薪止火而已",
                "16": "不絕之於彼",
                "17": "而救之於此",
                "18": "譬由抱薪而救火也",
                "19": "養由基",
                "20": "楚之善射者也",
                "21": "去楊葉百步",
                "22": "百發百中",
                "23": "楊葉之大",
                "24": "加百中焉",
                "25": "可謂善射矣",
                "26": "然其所止",
                "27": "百步之內耳",
                "28": "比於臣乘",
                "29": "未知操弓持矢也"
            }
        },
        "4": {
            "9": {
                "1": "福生有基",
                "2": "禍生有胎",
                "3": "納其基",
                "4": "絕其胎",
                "5": "禍何自來",
                "6": "太山之霤穿石",
                "7": "殫極之𥾚斷幹",
                "8": "晉灼曰",
                "9": "𥾚",
                "10": "古綆字",
                "11": "殫",
                "12": "盡也",
                "13": "極之綆幹",
                "14": "幹",
                "15": "井上四交之幹",
                "16": "常爲汲者所契傷也",
                "17": "水非石之鑽",
                "18": "索非木之鋸",
                "19": "漸靡使之然也",
                "20": "夫銖銖而稱之",
                "21": "至石必差",
                "22": "寸寸而度之",
                "23": "至丈必過",
                "24": "石稱丈量",
                "25": "徑而寡失",
                "26": "夫十圍之木",
                "27": "始生而蘗",
                "28": "足可搔而絕",
                "29": "手可擢而抓",
                "30": "據其未生",
                "31": "先其未形",
                "32": "磨皲砥礪",
                "33": "不見其損",
                "34": "有時而盡",
                "35": "種樹畜養",
                "36": "不見其益",
                "37": "有時而大",
                "38": "積德累行",
                "39": "不知其善",
                "40": "有時而用",
                "41": "棄義背理",
                "42": "不知其惡",
                "43": "有時而亡",
                "44": "臣願大王熟計而身行之",
                "45": "此百世不易之道也"
            }
        }
    }
}