{
    "41.02": {
        "篇名": "司馬子長 報任少卿書",
        "1": {
            "3": {
                "1": "太史公牛馬走司馬遷再拜言",
                "2": "少卿足下",
                "3": "曩者辱賜書",
                "4": "教以順於接物",
                "5": "推賢進士爲務",
                "6": "意氣懃懃懇懇",
                "7": "若望僕不相師",
                "8": "而用流俗人之言",
                "9": "僕非敢如此也",
                "10": "僕雖罷駑",
                "11": "亦嘗側聞長者之遺風矣",
                "12": "顧自以爲身殘處穢",
                "13": "動而見尤",
                "14": "欲益反損",
                "15": "是以獨鬱悒而與誰語",
                "16": "諺曰",
                "17": "誰爲爲之",
                "18": "孰令聽之",
                "19": "蓋鍾子期死",
                "20": "伯牙終身不復鼓琴",
                "21": "何則",
                "22": "士爲知己者用",
                "23": "女爲說己者容",
                "24": "若僕大質已虧缺矣",
                "25": "雖才懷隨和",
                "26": "行若由夷",
                "27": "終不可以爲榮",
                "28": "適足以見笑而自點耳",
                "29": "書辭宜答",
                "30": "會東從上來",
                "31": "又迫賤事",
                "32": "相見日淺",
                "33": "卒卒無須臾之間",
                "34": "得竭至意",
                "35": "今少卿抱不測之罪",
                "36": "涉旬月",
                "37": "迫季冬",
                "38": "僕又薄從上雍",
                "39": "恐卒然不可爲諱",
                "40": "是僕終己不得舒憤懣以曉左右",
                "41": "則長逝者魂魄私恨無窮",
                "42": "請略陳固陋",
                "43": "闕然久不報",
                "44": "幸勿爲過"
            }
        },
        "2": {
            "5": {
                "1": "僕聞之",
                "2": "修身者",
                "3": "智之符也",
                "4": "愛施者",
                "5": "仁之端也",
                "6": "取與者",
                "7": "義之表也",
                "8": "恥辱者",
                "9": "勇之決也",
                "10": "立名者",
                "11": "行之極也",
                "12": "士有此五者",
                "13": "然後可以託於世",
                "14": "而列於君子之林矣",
                "15": "故禍莫憯於欲利",
                "16": "悲莫痛於傷心",
                "17": "行莫醜於辱先",
                "18": "詬莫大於宮刑",
                "19": "刑餘之人",
                "20": "無所比數",
                "21": "非一世也",
                "22": "所從來遠矣",
                "23": "昔衞靈公與雍渠同載",
                "24": "孔子適陳",
                "25": "商鞅因景監見",
                "26": "趙良寒心",
                "27": "同子參乘",
                "28": "袁絲變色",
                "29": "自古而恥之",
                "30": "夫以中才之人",
                "31": "事有關於宦豎",
                "32": "莫不傷氣",
                "33": "而況於慷慨之士乎",
                "34": "如今朝廷雖乏人",
                "35": "柰何令刀鋸之餘",
                "36": "薦天下豪俊哉"
            }
        },
        "3": {
            "7": {
                "1": "僕賴先人緒業",
                "2": "得待罪輦轂下",
                "3": "二十餘年矣",
                "4": "所以自惟",
                "5": "上之不能納忠效信",
                "6": "有奇策才力之譽",
                "7": "自結明主",
                "8": "次之又不能拾遺補闕",
                "9": "招賢進能",
                "10": "顯巖穴之士",
                "11": "外之又不能備行伍",
                "12": "攻城野戰",
                "13": "有斬將搴旗之功",
                "14": "下之不能積日累勞",
                "15": "取尊官厚祿",
                "16": "以爲宗族交遊光寵",
                "17": "四者無一遂",
                "18": "苟合取容",
                "19": "無所短長之效",
                "20": "可見如此矣",
                "21": "嚮者",
                "22": "僕常廁下大夫之列",
                "23": "陪外廷末議",
                "24": "不以此時引維綱",
                "25": "盡思慮",
                "26": "今以虧形爲掃除之隸",
                "27": "在闒茸之中",
                "28": "乃欲仰首伸眉",
                "29": "論列是非",
                "30": "不亦輕朝廷羞當世之士邪",
                "31": "嗟乎",
                "32": "嗟呼",
                "33": "如僕尙何言哉",
                "34": "尙何言哉"
            }
        },
        "4": {
            "9": {
                "1": "且事本末未易明也",
                "2": "僕少負不羈之行",
                "3": "長無鄕曲之譽",
                "4": "主上幸以先人之故",
                "5": "使得奏薄伎",
                "6": "出入周衞之中",
                "7": "僕以爲戴盆何以望天",
                "8": "故絕賓客之知",
                "9": "亡室家之業",
                "10": "日夜思竭其不肖之才力",
                "11": "務一心營職",
                "12": "以求親媚於主上",
                "13": "而事乃有大謬不然者夫"
            }
        },
        "5": {
            "11": {
                "1": "僕與李陵",
                "2": "俱居門下",
                "3": "素非能相善也",
                "4": "趣舍異路",
                "5": "未嘗銜杯酒",
                "6": "接慇懃之餘歡",
                "7": "然僕觀其爲人",
                "8": "自守奇士",
                "9": "事親孝",
                "10": "與士信",
                "11": "臨財廉",
                "12": "取與義",
                "13": "分別有讓",
                "14": "恭儉下人",
                "15": "常思奮不顧身",
                "16": "以徇國家之急",
                "17": "其素所蓄積也",
                "18": "僕以爲有國士之風",
                "19": "夫人臣出萬死不顧一生之計",
                "20": "赴公家之難",
                "21": "斯以奇矣",
                "22": "今舉事一不當",
                "23": "而全驅保妻子之臣",
                "24": "隨而媒㜸其短",
                "25": "僕誠私心痛之",
                "26": "且李陵提步卒不滿五千",
                "27": "深踐戎馬之地",
                "28": "足歷王庭",
                "29": "垂餌虎口",
                "30": "橫挑彊胡",
                "31": "仰億萬之師",
                "32": "與單於連戰十有餘日",
                "33": "所殺過半當",
                "34": "虜救死扶傷不給",
                "35": "旃裘之君長咸震怖",
                "36": "乃悉徵其左右賢王",
                "37": "舉引弓之人",
                "38": "一國共攻而圍之",
                "39": "轉鬭千里",
                "40": "矢盡道窮",
                "41": "救兵不至",
                "42": "士卒死傷如積然陵一呼勞",
                "43": "軍士無不起",
                "44": "躬自流涕",
                "45": "沬血飲泣",
                "46": "更張空拳",
                "47": "冒白刃",
                "48": "北嚮爭死敵者",
                "49": "陵未沒時",
                "50": "使有來報",
                "51": "漢公卿王侯",
                "52": "皆奉觴上壽",
                "53": "後數日",
                "54": "陵敗書聞",
                "55": "主上爲之食不甘味",
                "56": "聽朝不怡",
                "57": "大臣憂懼",
                "58": "不知所出",
                "59": "僕竊不自料其卑賤",
                "60": "見主上慘愴怛悼",
                "61": "誠欲效其款款之愚",
                "62": "以爲李陵素與士大夫絕甘分少",
                "63": "能得人死力",
                "64": "雖古之名將",
                "65": "不能過也",
                "66": "身雖陷敗",
                "67": "彼觀其意",
                "68": "且欲得其當而報於漢",
                "69": "事已無可柰何",
                "70": "其所摧敗",
                "71": "功亦足以暴於天下矣",
                "72": "僕懷欲陳之",
                "73": "而未有路",
                "74": "適會召問",
                "75": "卽以此指推言陵之功",
                "76": "欲以廣主上之意",
                "77": "塞睚眥之辭",
                "78": "未能盡明",
                "79": "明主不曉",
                "80": "以爲僕沮貳師",
                "81": "而爲李陵遊說",
                "82": "遂下於理",
                "83": "拳拳之忠",
                "84": "終不能自列",
                "85": "因爲誣上",
                "86": "卒從吏議",
                "87": "家貧",
                "88": "貨賂不足以自贖",
                "89": "交遊莫救",
                "90": "左右親近",
                "91": "不爲一言",
                "92": "身非木石",
                "93": "獨與法吏爲伍",
                "94": "深幽囹圄之中",
                "95": "誰可告愬者",
                "96": "此眞少卿所親見",
                "97": "僕行事豈不然乎",
                "98": "李陵旣生降",
                "99": "隤其家聲",
                "100": "而僕又佴之蠶室",
                "101": "重爲天下觀笑",
                "102": "悲夫",
                "103": "悲夫",
                "104": "事未易一二爲俗人言也"
            }
        },
        "6": {
            "13": {
                "1": "僕之先",
                "2": "非有剖符丹書之功",
                "3": "文史星曆",
                "4": "近乎卜祝之間",
                "5": "固主上所戲弄",
                "6": "倡優所畜",
                "7": "流俗之所輕也",
                "8": "假令僕伏法受誅",
                "9": "若九牛亡一毛",
                "10": "與螻蟻何以異",
                "11": "而世又不與能死節者",
                "12": "特以爲智窮罪極",
                "13": "不能自免",
                "14": "卒就死耳",
                "15": "何也",
                "16": "素所自樹立使然也",
                "17": "人固有一死",
                "18": "或重於太山",
                "19": "或輕於鴻毛",
                "20": "用之所趨異也",
                "21": "太上不辱先",
                "22": "其次不辱身",
                "23": "其次不辱理色",
                "24": "其次不辱辭令",
                "25": "其次詘體受辱",
                "26": "其次易服受辱",
                "27": "其次關木索被箠楚受辱",
                "28": "其次剔毛髮嬰金鐵受辱",
                "29": "其次毀肌膚斷肢體受辱",
                "30": "最下腐刑",
                "31": "極矣",
                "32": "傳曰",
                "33": "刑不上大夫",
                "34": "此言士節不可不勉勵也",
                "35": "猛虎在深山",
                "36": "百獸震恐",
                "37": "及在檻穽之中",
                "38": "搖尾而求食",
                "39": "積威約之漸也",
                "40": "故有畫地爲牢勢不可入",
                "41": "削木爲吏議不可對",
                "42": "定計於鮮也",
                "43": "今交手足",
                "44": "受木索",
                "45": "暴肌膚",
                "46": "受榜箠",
                "47": "幽於圜牆之中",
                "48": "當此之時",
                "49": "見獄吏則頭槍地",
                "50": "視徒隸則正惕息",
                "51": "何者",
                "52": "積威約之勢也",
                "53": "及以至是言不辱者",
                "54": "所謂強顏耳",
                "55": "曷足貴乎",
                "56": "且西伯",
                "57": "伯也",
                "58": "拘於羑里",
                "59": "李斯",
                "60": "相也",
                "61": "具於五刑",
                "62": "淮陰",
                "63": "王也",
                "64": "受械於陳",
                "65": "彭越張敖",
                "66": "南面稱孤",
                "67": "繫獄抵罪",
                "68": "絳侯誅諸呂",
                "69": "權傾五伯",
                "70": "囚於請室",
                "71": "魏其",
                "72": "大將也",
                "73": "衣赭衣",
                "74": "關三木",
                "75": "季布爲朱家鉗奴",
                "76": "灌夫受辱於居室",
                "77": "此人皆身至王侯將相",
                "78": "聲聞鄰國",
                "79": "及罪至罔加",
                "80": "不能引決自裁",
                "81": "在塵埃之中",
                "82": "古今一體",
                "83": "安在其不辱也",
                "84": "由此言之",
                "85": "勇怯",
                "86": "勢也",
                "87": "強弱",
                "88": "形也",
                "89": "審矣",
                "90": "何足怪乎",
                "91": "夫人不能早自裁繩墨之外",
                "92": "以稍陵遲至於鞭箠之間",
                "93": "乃欲引節",
                "94": "斯不亦遠乎",
                "95": "古人所以重施刑於大夫者",
                "96": "殆爲此也"
            }
        },
        "7": {
            "15": {
                "1": "夫人情莫不貪生惡死",
                "2": "念父母",
                "3": "顧妻子",
                "4": "至激於義理者不然",
                "5": "乃有所不得已也",
                "6": "今僕不幸",
                "7": "早失父母",
                "8": "無兄弟之親",
                "9": "獨身孤立",
                "10": "少卿視僕於妻子何如哉",
                "11": "且勇者不必死節",
                "12": "怯夫慕義",
                "13": "何處不勉焉",
                "14": "僕雖怯懦欲苟活",
                "15": "亦頗識去就之分矣",
                "16": "何至自沈溺縲紲之辱哉",
                "17": "且夫臧獲婢妾",
                "18": "由能引決",
                "19": "況僕之不得已乎",
                "20": "所以隱忍苟活",
                "21": "幽於糞土之中而不辭者",
                "22": "恨私心有所不盡",
                "23": "鄙陋沒世",
                "24": "而文彩不表於後世也"
            }
        },
        "8": {
            "17": {
                "1": "古者富貴而名摩滅",
                "2": "不可勝記",
                "3": "唯倜儻非常之人稱焉",
                "4": "蓋文王拘而演周易",
                "5": "仲尼厄而作春秋",
                "6": "屈原放逐",
                "7": "乃賦離騷",
                "8": "左丘失明",
                "9": "厥有國語",
                "10": "孫子臏腳",
                "11": "兵法修列",
                "12": "不韋遷蜀",
                "13": "世傳呂覽",
                "14": "韓非囚秦",
                "15": "說難孤憤",
                "16": "詩三百篇",
                "17": "大底聖賢發憤之所爲作也",
                "18": "此人皆意有鬱結",
                "19": "不得通其道",
                "20": "故述往事",
                "21": "思來者",
                "22": "乃如左丘無目",
                "23": "孫子斷足",
                "24": "終不可用",
                "25": "退而論書策",
                "26": "以舒其憤",
                "27": "思垂空文以自見"
            }
        },
        "9": {
            "19": {
                "1": "僕竊不遜",
                "2": "近自託於無能之辭",
                "3": "網羅天下放失舊聞",
                "4": "略考其行事",
                "5": "綜其終始",
                "6": "稽其成敗興壞之紀",
                "7": "上計軒轅",
                "8": "下至於茲",
                "9": "爲十表",
                "10": "本紀十二",
                "11": "書八章",
                "12": "世家三十",
                "13": "列傳七十",
                "14": "凡百三十篇",
                "15": "亦欲以究天人之際",
                "16": "通古今之變",
                "17": "成一家之言",
                "18": "草創未就",
                "19": "會遭此禍",
                "20": "惜其不成",
                "21": "已就極刑而無慍色",
                "22": "僕誠以著此書藏諸名山",
                "23": "傳之其人",
                "24": "通邑大都",
                "25": "則僕償前辱之責",
                "26": "雖萬被戮",
                "27": "豈有悔哉",
                "28": "然此可爲智者道",
                "29": "難爲俗人言也"
            }
        },
        "10": {
            "21": {
                "1": "且負下未易居",
                "2": "下流多謗議",
                "3": "僕以口語遇此禍",
                "4": "重爲鄕黨所笑",
                "5": "以汙辱先人",
                "6": "亦何面目復上父母丘墓乎",
                "7": "雖累百世",
                "8": "垢彌甚耳",
                "9": "是以腸一日而九迴",
                "10": "居則忽忽若有所亡",
                "11": "出則不知其所往",
                "12": "每念斯恥",
                "13": "汗未嘗不發背霑衣也",
                "14": "身直爲閨閤之臣",
                "15": "寧得自引於深藏巖穴邪",
                "16": "故且從俗浮沈",
                "17": "與時俯仰",
                "18": "以通其狂惑",
                "19": "今少卿乃教以推賢進士",
                "20": "無乃與僕私心剌謬乎",
                "21": "今雖欲自雕琢",
                "22": "曼辭以自飾",
                "23": "無益於俗不信",
                "24": "適足取辱耳",
                "25": "要之死日",
                "26": "然後是非乃定",
                "27": "書不能悉意",
                "28": "略陳固陋",
                "29": "謹再拜"
            }
        }
    }
}