{
    "19.03": {
        "篇名": "宋玉登徒子好色賦[幷序]",
        "1": {
            "3": {
                "1": "大夫登徒子侍於楚王",
                "2": "短宋玉曰",
                "3": "玉爲人",
                "4": "體貌閑麗",
                "5": "口多微辭",
                "6": "又性好色",
                "7": "願王勿與出入後宮",
                "8": "王以登徒子之言問宋玉",
                "9": "玉曰",
                "10": "體貌閑麗",
                "11": "所受於天也",
                "12": "口多微辭",
                "13": "所學於師也",
                "14": "至於好色",
                "15": "臣無有也",
                "16": "王曰",
                "17": "子不好色",
                "18": "亦有說乎",
                "19": "有說則止",
                "20": "無說則退",
                "21": "玉曰",
                "22": "天下之佳人莫若楚國",
                "23": "楚國之麗者莫若臣里",
                "24": "臣里之美者莫若臣東家之子",
                "25": "東家之子",
                "26": "增之一分則太長",
                "27": "減之一分則太短",
                "28": "著粉則太白",
                "29": "施朱則太赤",
                "30": "眉如翠羽",
                "31": "肌如白雪",
                "32": "腰如束素",
                "33": "齒如含貝",
                "34": "嫣然一笑",
                "35": "惑陽城",
                "36": "迷下蔡",
                "37": "然此女登牆闚臣三年",
                "38": "至今未許也",
                "39": "登徒子則不然",
                "40": "其妻蓬頭攣耳",
                "41": "齞脣歷齒",
                "42": "旁行踽僂",
                "43": "又疥且痔",
                "44": "登徒子悅之",
                "45": "使有五子",
                "46": "王孰察之",
                "47": "誰爲好色者矣",
                "48": "是時",
                "49": "秦章華大夫在側",
                "50": "因進而稱曰",
                "51": "今夫宋玉盛稱鄰之女",
                "52": "以爲美色",
                "53": "愚亂之邪",
                "54": "臣自以爲守德",
                "55": "謂不如彼矣",
                "56": "且夫南楚窮巷之妾",
                "57": "焉足爲大王言乎",
                "58": "若臣之陋",
                "59": "目所曾睹者",
                "60": "未敢云也",
                "61": "王曰",
                "62": "試爲寡人說之",
                "63": "大夫曰",
                "64": "唯唯"
            }
        },
        "2": {
            "5": {
                "1": "臣少曾遠遊",
                "2": "周覽九土",
                "3": "足歷五都",
                "4": "出咸陽",
                "5": "熙邯鄲",
                "6": "從容鄭衞溱洧之間",
                "7": "是時向春之末",
                "8": "迎夏之陽",
                "9": "鶬鶊喈喈",
                "10": "羣女出桑",
                "11": "此郊之姝",
                "12": "華色含光",
                "13": "體美容冶",
                "14": "不待飾裝",
                "15": "臣觀其麗者",
                "16": "因稱詩曰",
                "17": "遵大路兮攬子袪",
                "18": "贈以芳華辭甚妙",
                "19": "於是處子怳若有望而不來",
                "20": "忽若有來而不見",
                "21": "意密體疏",
                "22": "俯仰異觀",
                "23": "含喜微笑",
                "24": "竊視流眄",
                "25": "復稱詩曰",
                "26": "寤春風兮發鮮榮",
                "27": "絜齋俟兮惠音聲",
                "28": "贈我如此兮不如無生",
                "29": "因遷延而辭避",
                "30": "蓋徒以微辭相感動",
                "31": "精神相依憑",
                "32": "目欲其顏",
                "33": "心顧其義",
                "34": "揚詩守禮",
                "35": "終不過差",
                "36": "故足稱也"
            }
        },
        "3": {
            "7": {
                "1": "於是楚王稱善",
                "2": "宋玉遂不退"
            }
        }
    }
}