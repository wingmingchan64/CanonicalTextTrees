{
    "56.05": {
        "篇名": "陸佐公 石闕銘",
        "1": {
            "3": {
                "1": "昔在舜格文祖",
                "2": "禹至神宗",
                "3": "周變商俗",
                "4": "湯黜夏政",
                "5": "雖革命殊乎因襲",
                "6": "揖讓異於干戈",
                "7": "而晷緯冥合",
                "8": "天人啟惎",
                "9": "克明俊德",
                "10": "大庇生民",
                "11": "其揆一也"
            }
        },
        "2": {
            "5": {
                "1": "在齊之季",
                "2": "昏虐君臨",
                "3": "威侮五行",
                "4": "怠棄三正",
                "5": "刑酷然炭",
                "6": "暴踰膏柱",
                "7": "民怨神怒",
                "8": "眾叛親離",
                "9": "蹐地無歸",
                "10": "瞻烏靡託",
                "11": "於是我皇帝拯之",
                "12": "乃操斗極",
                "13": "把鉤陳",
                "14": "翼百神",
                "15": "禔萬福",
                "16": "龍飛黑水",
                "17": "虎步西河",
                "18": "電動風驅",
                "19": "天行地止",
                "20": "命旅致屯雲之應",
                "21": "登壇有降火之祥",
                "22": "龜筮協從",
                "23": "人祇響附",
                "24": "穿胸露頂之豪",
                "25": "箕坐椎髻之長",
                "26": "莫不援旗請奮",
                "27": "執銳爭先",
                "28": "夏首憑固",
                "29": "庸岷負阻",
                "30": "協彼離心",
                "31": "抗茲同德",
                "32": "帝赫斯怒",
                "33": "秣馬訓兵",
                "34": "嚴鼓未通",
                "35": "兇渠泥首",
                "36": "弘舸連軸",
                "37": "巨檻接艫",
                "38": "鐵馬千羣",
                "39": "朱旗萬里",
                "40": "折簡而禽廬九",
                "41": "傳檄以下湘羅",
                "42": "兵不血刃",
                "43": "士無遺鏃",
                "44": "而樊鄧威懷",
                "45": "巴黔底定"
            }
        },
        "3": {
            "7": {
                "1": "於是流湯之黨",
                "2": "握炭之徒",
                "3": "守似藩籬",
                "4": "戰同枯朽",
                "5": "革車近次",
                "6": "師營商牧",
                "7": "華夷士女",
                "8": "冠蓋相望",
                "9": "扶老攜幼",
                "10": "一旦雲集",
                "11": "壺漿塞野",
                "12": "簞食盈塗",
                "13": "似夏民之附成湯",
                "14": "殷士之窺周武",
                "15": "安老懷少",
                "16": "伐罪弔民",
                "17": "農不遷業",
                "18": "市無易賈",
                "19": "八方入計",
                "20": "四隩奉圖",
                "21": "羽檄交馳",
                "22": "軍書狎至",
                "23": "一日二日",
                "24": "非止萬穖",
                "25": "而尊嚴之度",
                "26": "不諐於師旅",
                "27": "淵默之容",
                "28": "無改於行陣",
                "29": "計如投水",
                "30": "思若轉規",
                "31": "策定帷幄",
                "32": "謀成几案",
                "33": "曾未浹辰",
                "34": "獨夫授首",
                "35": "乃焚其綺席",
                "36": "棄彼寶衣",
                "37": "歸琁臺之珠",
                "38": "反諸侯之玉",
                "39": "指麾而四海隆平",
                "40": "下車而天下大定",
                "41": "拯茲塗炭",
                "42": "救此橫流",
                "43": "功均天地",
                "44": "明並日月"
            }
        },
        "4": {
            "9": {
                "1": "於是仰協三靈",
                "2": "俯從億兆",
                "3": "受昭華之玉",
                "4": "納龍敍之圖",
                "5": "類帝禋宗",
                "6": "光有神器",
                "7": "升中以祀羣望",
                "8": "攝袂而朝諸夏",
                "9": "布教都畿",
                "10": "班政方外",
                "11": "謀協上策",
                "12": "刑從中典",
                "13": "南服緩耳",
                "14": "西羈反舌",
                "15": "劍騎穹廬之國",
                "16": "同川共穴之人",
                "17": "莫不屈膝交臂",
                "18": "厥角稽顙",
                "19": "鑿空萬里",
                "20": "攘地千都",
                "21": "幕南罷鄣",
                "22": "河西無警",
                "23": "喩巴蜀文曰",
                "24": "交臂受事",
                "25": "屈膝請和",
                "26": "孟子曰",
                "27": "武王之伐殷也",
                "28": "百姓若崩厥角",
                "29": "趙岐曰",
                "30": "厥角",
                "31": "叩頭以額𧢻厥地",
                "32": "禮記",
                "33": "孔子曰",
                "34": "拜而後稽顙",
                "35": "漢書曰",
                "36": "通西北國",
                "37": "張騫鑿空",
                "38": "蘇林曰",
                "39": "鑿",
                "40": "開",
                "41": "空",
                "42": "通也",
                "43": "戰國策",
                "44": "蔡澤謂應侯曰",
                "45": "公孫鞅爲秦攘地千里",
                "46": "漢書曰",
                "47": "驃騎封於狼居胥山",
                "48": "匈奴遠逃",
                "49": "而漠南無王庭",
                "50": "漢書",
                "51": "武帝謂狄山曰",
                "52": "使居一障間",
                "53": "蒼頡曰",
                "54": "障",
                "55": "小城也",
                "56": "漢書",
                "57": "晉文公攘戎狄",
                "58": "居於西河圁",
                "59": "洛之間",
                "60": "圁音銀",
                "61": "謝承後漢書曰",
                "62": "祝良爲梁州刺史",
                "63": "歷年無警"
            }
        },
        "5": {
            "11": {
                "1": "於是治定功成",
                "2": "邇安遠肅",
                "3": "忘茲鹿駭",
                "4": "息此狼顧",
                "5": "乃正六樂",
                "6": "治五禮",
                "7": "改章程",
                "8": "創法律",
                "9": "置博士之職",
                "10": "而著錄之生若雲",
                "11": "開集雅之館",
                "12": "而款關之學如市",
                "13": "興建庠序",
                "14": "啟設郊丘",
                "15": "一介之才必記",
                "16": "無文之典咸秩"
            }
        },
        "6": {
            "13": {
                "1": "於是天下學士",
                "2": "靡然向風",
                "3": "人識廉隅",
                "4": "家知禮讓",
                "5": "教臻侍子",
                "6": "化洽期門",
                "7": "區宇乂安",
                "8": "方面靜息",
                "9": "役休務簡",
                "10": "歲阜民和",
                "11": "歷代規謩",
                "12": "前王典故",
                "13": "莫不芟夷剪截",
                "14": "允執厥中",
                "15": "以爲象闕之制",
                "16": "其來已遠",
                "17": "春秋設舊章之教",
                "18": "經禮垂布憲之文",
                "19": "戴記顯遊觀之言",
                "20": "周史書樹闕之夢",
                "21": "北荒明月",
                "22": "西極流精",
                "23": "海岳黃金",
                "24": "河庭紫貝",
                "25": "蒼龍玄武之製",
                "26": "銅雀鐵鳳之工",
                "27": "或以聽窮省冤",
                "28": "或以布化懸法",
                "29": "或以表正王居",
                "30": "或以光崇帝里",
                "31": "晉氏浸弱",
                "32": "宋歷威夷",
                "33": "禮經舊典",
                "34": "寂寥無記",
                "35": "鴻規盛烈",
                "36": "湮沒罕稱",
                "37": "乃假天闕於牛頭",
                "38": "託遠圖於博望",
                "39": "有欺耳目",
                "40": "無補憲章",
                "41": "乃命審曲之官",
                "42": "選明中之士",
                "43": "陳圭置臬",
                "44": "瞻星揆地",
                "45": "興復表門",
                "46": "草創華闕"
            }
        },
        "7": {
            "15": {
                "1": "於是歲次天紀",
                "2": "月旅太簇",
                "3": "皇帝御天下之七載也",
                "4": "搆茲盛則",
                "5": "興此崇麗",
                "6": "方且趨以表敬",
                "7": "觀而知法",
                "8": "物睹雙碣之容",
                "9": "人識百重之典",
                "10": "作範垂訓",
                "11": "赫矣壯乎",
                "12": "爰命下臣",
                "13": "式銘盤石",
                "14": "其辭曰"
            }
        },
        "8": {
            "17": {
                "1": "惟帝建國",
                "2": "正位辨方",
                "3": "周營洛涘",
                "4": "漢啟岐梁",
                "5": "居因業盛",
                "6": "文以化光",
                "7": "爰有象闕",
                "8": "是惟舊章",
                "9": "青蓋南洎",
                "10": "黃旗東指",
                "11": "懸法無聞",
                "12": "藏書弗紀",
                "13": "大人造物",
                "14": "龍德休否",
                "15": "建此百常",
                "16": "興茲雙起",
                "17": "偉哉偃蹇",
                "18": "壯矣巍巍",
                "19": "旁映重疊",
                "20": "上連翠微",
                "21": "布教方顯",
                "22": "浹日初輝",
                "23": "懸書有附",
                "24": "委篋知歸",
                "25": "鬱崫重軒",
                "26": "穹隆反宇",
                "27": "形聳飛棟",
                "28": "勢超浮柱",
                "29": "色法上圓",
                "30": "製模下矩",
                "31": "周望原隰",
                "32": "俛臨煙雨",
                "33": "前賓四會",
                "34": "卻背九房",
                "35": "北通二轍",
                "36": "南湊五方",
                "37": "暑來寒往",
                "38": "地久天長",
                "39": "神哉華觀",
                "40": "永配無疆"
            }
        }
    }
}