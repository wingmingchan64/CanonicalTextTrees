{
    "25.01": {
        "篇名": "傅長虞 贈何劭王濟[幷序]",
        "1": {
            "3": {
                "1": "朗陵公何敬祖",
                "2": "咸之從內兄",
                "3": "國子祭酒王武子",
                "4": "咸從姑之外孫也",
                "5": "並以明德見重於世",
                "6": "咸親之重之",
                "7": "情猶同生",
                "8": "義則師友",
                "9": "何公旣登侍中",
                "10": "武子俄而亦作",
                "11": "二賢相得甚歡",
                "12": "咸亦慶之",
                "13": "然自恨闇劣",
                "14": "雖願其繾綣",
                "15": "而從之末由",
                "16": "歷試無效",
                "17": "且有家艱",
                "18": "賦詩申懷",
                "19": "以貽之云爾"
            }
        },
        "2": {
            "5": {
                "1": "日月光太清",
                "2": "列宿曜紫微",
                "3": "赫赫大晉朝",
                "4": "明明闢皇闈",
                "5": "吾兄旣鳳翔",
                "6": "王子亦龍飛",
                "7": "雙鸞遊蘭渚",
                "8": "二雞揚清暉",
                "9": "攜手升玉階",
                "10": "並坐侍丹帷",
                "11": "金璫綴惠文",
                "12": "煌煌發令姿",
                "13": "斯榮非悠庶",
                "14": "繾綣情所希",
                "15": "豈不企高蹤",
                "16": "麟趾邈難追",
                "17": "臨川靡芳餌",
                "18": "何爲守空坻",
                "19": "槁葉待風飄",
                "20": "逝將與君違",
                "21": "違君能無戀",
                "22": "尺素當言歸",
                "23": "歸身蓬蓽廬",
                "24": "樂道以忘饑",
                "25": "進則無云補",
                "26": "退則卹其私",
                "27": "但願隆弘美",
                "28": "王度日清夷"
            }
        }
    }
}