{
    "25.14": {
        "篇名": "謝惠連 還舊園作見顏范二中書",
        "1": {
            "3": {
                "1": "辭滿豈多秩",
                "2": "謝病不待年",
                "3": "偶與張邴合",
                "4": "久欲還東山",
                "5": "聖靈昔迴眷",
                "6": "微尙不及宣",
                "7": "何意衝飆激",
                "8": "烈火縱炎煙",
