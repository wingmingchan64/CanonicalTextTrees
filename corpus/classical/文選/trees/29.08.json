{
    "29.08": {
        "篇名": "曹子建 朔風詩",
        "1": {
            "3": {
                "1": "仰彼朔風",
                "2": "用懷魏都",
                "3": "願騁代馬",
                "4": "倏忽北徂",
                "5": "凱風永至",
                "6": "思彼蠻方",
                "7": "願隨越鳥",
                "8": "翻飛南翔",
                "9": "四氣代謝",
                "10": "懸景運周",
                "11": "別如俯仰",
                "12": "脫若三秋",
                "13": "昔我初遷",
                "14": "朱華未希",
                "15": "今我旋止",
                "16": "素雪雲飛",
                "17": "俯降千仞",
                "18": "仰登天阻",
                "19": "風飄蓬飛",
                "20": "載離寒暑",
                "21": "千仞易陟",
                "22": "天阻可越",
                "23": "昔我同袍",
                "24": "今永乖別",
                "25": "子好芳草",
                "26": "豈忘爾貽",
                "27": "繁華將茂",
                "28": "秋霜悴之",
                "29": "君不垂眷",
                "30": "豈云其誠",
                "31": "秋蘭可喩",
                "32": "桂樹冬榮",
                "33": "絃歌蕩思",
                "34": "誰與消憂",
                "35": "臨川暮思",
                "36": "何爲泛舟",
                "37": "豈無和樂",
                "38": "遊非我鄰",
                "39": "誰忘泛舟",
                "40": "愧無榜人"
