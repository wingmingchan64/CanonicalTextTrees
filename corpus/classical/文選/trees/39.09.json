{
    "39.09": {
        "篇名": "任彥升 爲卞彬謝修卞忠貞墓啟",
        "1": {
            "3": {
                "1": "臣彬啟",
                "2": "伏見詔書幷鄭義泰宣敕",
                "3": "當賜修理臣亡高祖晉故驃騎大將軍建興忠貞公壼墳塋",
                "4": "臣門緒不昌",
                "5": "天道所昧",
                "6": "忠遘身危",
                "7": "孝積家禍",
                "8": "名教同悲",
                "9": "隱淪惆悵",
                "10": "而年世伛遷",
                "11": "孤裔淪塞",
                "12": "遂使碑表蕪滅",
                "13": "丘樹荒毀",
                "14": "狐兔成穴",
                "15": "童牧哀歌",
                "16": "感慨自哀",
                "17": "日月纏迫"
            }
        },
        "2": {
            "5": {
                "1": "陸下弘宣教義",
                "2": "非求效於方今",
                "3": "壼餘烈不泯",
                "4": "固陳力於異世",
                "5": "但加等之渥",
                "6": "近闕於晉典",
                "7": "樵蘇之刑",
                "8": "遠流於皇代",
                "9": "臣亦何人",
                "10": "敢謝斯幸",
                "11": "不任悲荷之至",
                "12": "謹奉啟事以聞",
                "13": "謹啟"
            }
        }
    }
