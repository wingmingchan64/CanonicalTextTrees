{
    "29.14-02": {
        "篇名": "張茂先 情詩二首·其二",
        "1": {
            "3": {
                "1": "遊目四野外",
                "2": "逍遙獨延佇",
                "3": "蘭蕙緣清渠",
                "4": "繁華蔭綠渚",
                "5": "佳人不在茲",
                "6": "取此欲誰與",
                "7": "巢居知風寒",
                "8": "穴處識陰雨",
                "9": "不曾遠別離",
                "10": "安知慕儔侶"
            }
        }
    }
}