{
    "42.08": {
        "篇名": "應休璉 與滿公琰書",
        "1": {
            "3": {
                "1": "璩白",
                "2": "昨者不遺",
                "3": "猥見照臨",
                "4": "雖昔侯生納顧於夷門",
                "5": "毛公受眷於逆旅",
                "6": "無以過也",
                "7": "外嘉郎君謙下之德",
                "8": "內幸頑才見誠知己",
                "9": "歡欣踴躍",
                "10": "情有無量",
                "11": "是以奔騁御僕",
                "12": "宣命周求",
                "13": "陽書喩於詹何",
                "14": "楊倩說於范武",
                "15": "故使鮮魚出於潛淵",
                "16": "芳旨發自幽巷",
                "17": "繁俎綺錯",
                "18": "羽爵飛騰",
                "19": "牙曠高徽",
                "20": "義渠哀激",
                "21": "當此之時",
                "22": "仲孺不辭同產之服",
                "23": "孟公不顧尙書之期",
                "24": "徒恨宴樂始酣",
                "25": "白日傾夕",
                "26": "驪駒就駕",
                "27": "意不宣展",
                "28": "追惟耿介",
                "29": "迄於明發"
            }
        },
        "2": {
            "5": {
                "1": "適欲遣書",
                "2": "會承來命",
                "3": "知諸君子復有漳渠之會",
                "4": "夫漳渠西有伯陽之館",
                "5": "北有曠野之望",
                "6": "高樹翳朝雲",
                "7": "文禽蔽綠水",
                "8": "沙場夷敞",
                "9": "清風肅穆",
                "10": "是京臺之樂也",
                "11": "得無流而不反乎",
                "12": "適有事務",
                "13": "須自經營",
                "14": "不獲侍坐",
                "15": "良增邑邑",
                "16": "因白不悉",
                "17": "璩白"
            }
        }
    }
}