{
    "32.01": {
        "篇名": "屈平 離騷經",
        "1": {
            "3": {
                "1": "帝高陽之苗裔兮",
                "2": "朕皇考曰伯庸",
                "3": "攝提貞於孟陬兮",
                "4": "惟庚寅吾以降",
                "5": "皇覽揆余初度兮",
                "6": "肇錫余以嘉名",
                "7": "名余曰正則兮",
                "8": "字余曰靈均"
            }
        },
        "2": {
            "5": {
                "1": "紛吾旣有此內美兮",
                "2": "又重之以修能",
                "3": "扈江離與辟芷兮",
                "4": "紐秋蘭以爲佩",
                "5": "汩余若將不及兮",
                "6": "恐年歲之不吾與",
                "7": "朝搴阰之木蘭兮",
                "8": "夕攬洲之宿莽",
                "9": "日月忽其不淹兮",
                "10": "春與秋其代序",
                "11": "惟草木之零落兮",
                "12": "恐美人之遲暮",
                "13": "不撫壯而棄穢兮",
                "14": "何不改乎此度",
                "15": "乘騏驥以馳騁兮",
                "16": "來吾道夫先路"
            }
        },
        "3": {
            "7": {
                "1": "昔三后之純粹兮",
                "2": "固眾芳之所在",
                "3": "雜申椒與菌桂兮",
                "4": "豈維紐夫蕙茝",
                "5": "彼堯舜之耿介兮",
                "6": "旣遵道而得路",
                "7": "何桀紂之猖披兮",
                "8": "夫唯捷徑以窘步",
                "9": "惟黨人之偸樂兮",
                "10": "路幽昧以險隘",
                "11": "豈余身之憚殃兮",
                "12": "恐皇輿之敗績",
                "13": "忽奔走以先後兮",
                "14": "及前王之踵武",
                "15": "荃不察余之忠情兮",
                "16": "反信讒而齌怒",
                "17": "余固知謇謇之爲患兮",
                "18": "忍而不能舍也",
                "19": "指九天以爲正兮",
                "20": "夫唯靈修之故也",
                "21": "初旣與余成言兮",
                "22": "後悔遁而有他",
                "23": "余旣不難離別兮",
                "24": "傷靈修之數化"
            }
        },
        "4": {
            "9": {
                "1": "余旣滋蘭之九畹兮",
                "2": "又樹蕙之百畝",
                "3": "畦留夷與揭車兮",
                "4": "雜杜衡與芳芷",
                "5": "冀枝葉之峻茂兮",
                "6": "願竢時乎吾將刈",
                "7": "雖萎絕其亦何傷兮",
                "8": "哀眾芳之蕪穢"
            }
        },
        "5": {
            "11": {
                "1": "眾皆競進以貪婪兮",
                "2": "憑不厭乎求索",
                "3": "羌內恕己以量人兮",
                "4": "各興心而嫉妬",
                "5": "忽馳騖以追逐兮",
                "6": "非余心之所急",
                "7": "老冉冉其將至兮",
                "8": "恐修名之不立",
                "9": "朝飲木蘭之墜露兮",
                "10": "夕餐秋菊之落英",
                "11": "苟余情其信姱以練要兮",
                "12": "長顑頷亦何傷",
                "13": "攬木根以結茝兮",
                "14": "貫薜荔之落蕊",
                "15": "矯菌桂以紉蕙兮",
                "16": "索胡繩之纚纚",
                "17": "謇吾法夫前修兮",
                "18": "非時俗之所服",
                "19": "雖不周於今之人兮",
                "20": "願依彭咸之遺則",
                "21": "長太息以掩涕兮",
                "22": "哀民生之多艱",
                "23": "余雖好修姱以鞿羈兮",
                "24": "謇朝誶而夕替",
                "25": "旣替余以蕙纕兮",
                "26": "又申之㠯攬茝",
                "27": "亦余心之所善兮",
                "28": "雖九死其猶未悔",
                "29": "怨靈修之浩蕩兮",
                "30": "終不察夫民心",
                "31": "眾女嫉余之蛾眉兮",
                "32": "謠諑謂余以善淫",
                "33": "固時俗之工巧兮",
                "34": "偭規矩而改錯",
                "35": "背繩墨以追曲兮",
                "36": "競周容以爲度",
                "37": "忳鬱邑余侘傺兮",
                "38": "吾獨窮困乎此時也",
                "39": "寧溘死以流亡兮",
                "40": "余不忍爲此態也",
                "41": "鷙鳥之不羣兮",
                "42": "自前世而固然",
                "43": "何方圜之能周兮",
                "44": "夫孰異道而相安",
                "45": "屈心而抑志兮",
                "46": "忍尤而攘詬",
                "47": "伏清白以死直兮",
                "48": "固前聖之所厚"
            }
        },
        "6": {
            "13": {
                "1": "悔相道之不察兮",
                "2": "延佇乎吾將反",
                "3": "回朕車以復路兮",
                "4": "及行迷之未遠",
                "5": "步余馬於蘭皋兮",
                "6": "馳椒丘且焉止息",
                "7": "進不入以離尤兮",
                "8": "退將復修吾初服",
                "9": "製芰荷以爲衣兮",
                "10": "集芙蓉以爲裳",
                "11": "不吾知其亦已兮",
                "12": "苟余情其信芳",
                "13": "高余冠之岌岌兮",
                "14": "長余佩之陸離",
                "15": "芳與澤其雜糅兮",
                "16": "唯昭質其猶未虧",
                "17": "忽反顧以遊目兮",
                "18": "將往觀乎四荒",
                "19": "佩繽紛其繁飾兮",
                "20": "芳菲菲其彌章",
                "21": "民生各有所樂兮",
                "22": "余獨好修以爲常",
                "23": "雖體解吾猶未變兮",
                "24": "豈余心之可懲"
            }
        },
        "7": {
            "15": {
                "1": "女嬃之嬋媛兮",
                "2": "申申其詈予",
                "3": "曰鯀婞直以亡身兮",
                "4": "終然殀乎羽之野",
                "5": "汝何博謇而好修兮",
                "6": "紛獨有此姱節",
                "7": "薋菉葹以盈室兮",
                "8": "判獨離而不服",
                "9": "眾不可戶說兮",
                "10": "孰云察余之中情",
                "11": "世並舉而好朋兮",
                "12": "夫何煢獨而不予聽"
            }
        },
        "8": {
            "17": {
                "1": "依前聖以節中兮",
                "2": "喟憑心而歷玆",
                "3": "濟沅湘以南征兮",
                "4": "就重華而敶詞",
                "5": "啟九辯與九歌兮",
                "6": "夏康娛以自縱",
                "7": "不顧難以圖後兮",
                "8": "五子用失乎家巷",
                "9": "羿淫遊以佚畋兮",
                "10": "又好射夫封狐",
                "11": "固亂流其鮮終兮",
                "12": "浞又貪夫厥家",
                "13": "澆身被服強圉兮",
                "14": "縱欲而不忍",
                "15": "日康娛而自忘兮",
                "16": "厥首用夫顚隕",
                "17": "夏桀之常違兮",
                "18": "乃遂焉而逢殃",
                "19": "后辛之菹醢兮",
                "20": "殷宗用而不長",
                "21": "湯禹儼而祇敬兮",
                "22": "周論道而莫差",
                "23": "舉賢而授能兮",
                "24": "循繩墨而不頗",
                "25": "皇天無私阿兮",
                "26": "覽民德焉錯輔",
                "27": "夫維聖哲以茂行兮",
                "28": "苟得用此下土",
                "29": "瞻前而顧後兮",
                "30": "相觀民之計極",
                "31": "夫孰非義而可用兮",
                "32": "孰非善而可服",
                "33": "阽余身而危死兮",
                "34": "覽余初其猶未悔",
                "35": "不量鑿而正枘兮",
                "36": "固前修以菹醢",
                "37": "曾歔欷余鬱邑兮",
                "38": "哀朕時之不當",
                "39": "攬茹蕙以掩涕兮",
                "40": "霑余襟之浪浪"
            }
        },
        "9": {
            "19": {
                "1": "跪敷衽以陳辭兮",
                "2": "耿吾旣得此中正",
                "3": "駟玉虯以乘鷖兮",
                "4": "溘埃風余上征",
                "5": "朝發軔於蒼梧兮",
                "6": "夕余至乎縣圃",
                "7": "欲少留此靈瑣兮",
                "8": "日忽忽其將暮",
                "9": "吾令羲和弭節兮",
                "10": "望崦嵫而勿迫",
                "11": "路曼曼其修遠兮",
                "12": "吾將上下而求索",
                "13": "飲余馬於咸池兮",
                "14": "總余轡乎扶桑",
                "15": "折若木以拂日兮",
                "16": "聊逍遙以相羊",
                "17": "前望舒使先驅兮",
                "18": "後飛廉使奔屬",
                "19": "鸞皇爲余先戒兮",
                "20": "雷師告余以未具",
                "21": "吾令鳳鳥飛騰兮",
                "22": "繼之以日夜",
                "23": "飄風屯其相離兮",
                "24": "帥雲霓而來御",
                "25": "紛總總其離合兮",
                "26": "斑陸離其上下",
                "27": "吾令帝閽開關兮",
                "28": "倚閶闔而望予",
                "29": "時曖曖其將罷兮",
                "30": "結幽蘭而延佇",
                "31": "世溷濁而不分兮",
                "32": "好蔽美而嫉妬"
            }
        },
        "10": {
            "21": {
                "1": "朝吾將濟於白水兮",
                "2": "登閬風而緤馬",
                "3": "忽反顧以流涕兮",
                "4": "哀高丘之無女",
                "5": "溘吾遊此春宮兮",
                "6": "折瓊枝以繼佩",
                "7": "及榮華之未落兮",
                "8": "相下女之可詒",
                "9": "吾令豐隆椉雲兮",
                "10": "求宓妃之所在",
                "11": "解佩纕以結言兮",
                "12": "吾令蹇修以爲理",
                "13": "紛總總其離合兮",
                "14": "忽緯繣其難遷",
                "15": "夕歸次於窮石兮",
                "16": "朝濯髮乎洧盤",
                "17": "保厥美以驕傲兮",
                "18": "日康娛以淫遊",
                "19": "雖信美而無禮兮",
                "20": "來違棄而改求",
                "21": "覽相觀於四極兮",
                "22": "周流乎天余乃下",
                "23": "望瑤臺之偃蹇兮",
                "24": "見有娀之佚女",
                "25": "吾令鴆爲媒兮",
                "26": "鴆告余以不好",
                "27": "雄鳩之鳴逝兮",
                "28": "余猶惡其佻巧",
                "29": "心猶豫而狐疑兮",
                "30": "欲自適而不可",
                "31": "鳳皇旣受詒兮",
                "32": "恐高辛之先我",
                "33": "欲遠集而無所止兮",
                "34": "聊浮遊以逍遙",
                "35": "及少康之未家兮",
                "36": "留有虞之二姚",
                "37": "理弱而媒拙兮",
                "38": "恐導言之不固",
                "39": "世溷濁而嫉賢兮",
                "40": "好蔽美而稱惡",
                "41": "閨中旣以邃遠兮",
                "42": "哲王又不寤",
                "43": "懷朕情而不發兮",
                "44": "余焉能忍與此終古"
            }
        },
        "11": {
            "23": {
                "1": "索瓊茅以筳篿兮",
                "2": "命靈氛爲余占之",
                "3": "曰",
                "4": "兩美其必合兮",
                "5": "孰信修而慕之",
                "6": "思九州之博大兮",
                "7": "豈唯是其有女",
                "8": "曰",
                "9": "勉遠逝而無狐疑兮",
                "10": "孰求美而釋女",
                "11": "何所獨無芳草兮",
                "12": "爾何懷乎故宇",
                "13": "世幽昧以昡曜兮",
                "14": "孰云察余之善惡",
                "15": "民好惡其不同兮",
                "16": "惟此黨人其獨異",
                "17": "戶服艾以盈要兮",
                "18": "謂幽蘭其不可佩",
                "19": "覽察草木其猶未得兮",
                "20": "豈珵美之能當",
                "21": "蘇糞壤㠯充幃兮",
                "22": "謂申椒其不芳"
            }
        },
        "12": {
            "25": {
                "1": "欲從靈氛之吉占兮",
                "2": "心猶豫而狐疑",
                "3": "巫咸將夕降兮",
                "4": "懷椒糈而要之",
                "5": "百神翳其備降兮",
                "6": "九疑繽其並迎",
                "7": "皇剡剡其揚靈兮",
                "8": "告余以吉故",
                "9": "曰",
                "10": "勉陞降以上下兮",
                "11": "求榘矱之所同",
                "12": "湯禹嚴而求合兮",
                "13": "摯咎繇而能調",
                "14": "苟中情其好修兮",
                "15": "何必用夫行媒",
                "16": "說操築於傳巖兮",
                "17": "武丁用而不疑",
                "18": "呂望之鼓刀兮",
                "19": "遭周文而得舉",
                "20": "甯戚之謳歌兮",
                "21": "齊桓聞以該輔",
                "22": "及年歲之未宴兮",
                "23": "時亦猶其未央",
                "24": "恐鵜鴃之先鳴兮",
                "25": "使百草爲之不芳"
            }
        },
        "13": {
            "27": {
                "1": "何瓊佩之偃蹇兮",
                "2": "眾薆然而蔽之",
                "3": "惟此黨人之不諒兮",
                "4": "恐嫉妬而折之",
                "5": "時繽紛其變易兮",
                "6": "又何可以淹留",
                "7": "蘭芷變而不芳兮",
                "8": "荃蕙化而爲茅",
                "9": "何昔日之芳草兮",
                "10": "今直爲此蕭艾也",
                "11": "豈其有他故兮",
                "12": "莫好修之害也",
                "13": "余以蘭爲可恃兮",
                "14": "羌無實而容長",
                "15": "委厥美以從俗兮",
                "16": "苟得列乎眾芳",
                "17": "椒專佞以慢慆兮",
                "18": "樧又欲充夫佩幃",
                "19": "旣干進而務入兮",
                "20": "又何芳之能祇",
                "21": "固時俗之流從兮",
                "22": "又孰能無變化",
                "23": "覽椒蘭其若玆兮",
                "24": "又況揭車與江離",
                "25": "惟玆佩之可貴兮",
                "26": "委厥美而歷玆",
                "27": "芳菲菲而難虧兮",
                "28": "芬至今猶未沬",
                "29": "和調度以自娛兮",
                "30": "聊浮遊而求女",
                "31": "及余飾之方壯兮",
                "32": "周流觀乎上下"
            }
        },
        "14": {
            "29": {
                "1": "靈氛旣告余以吉占兮",
                "2": "歷吉日乎吾將行",
                "3": "折瓊枝以爲羞兮",
                "4": "精瓊爢以爲粻",
                "5": "爲余駕飛龍兮",
                "6": "雜瑤象以爲車",
                "7": "何離心之可同兮",
                "8": "吾將遠逝以自疏",
                "9": "邅吾道夫崑崙兮",
                "10": "路修遠以周流",
                "11": "揚雲霓之晻藹兮",
                "12": "鳴玉鸞之啾啾",
                "13": "朝發軔於天津兮",
                "14": "夕余至乎西極",
                "15": "鳳皇翼其承旂兮",
                "16": "高翱翔之翼翼",
                "17": "忽吾行此流沙兮",
                "18": "遵赤水而容與",
                "19": "麾蛟龍使梁津兮",
                "20": "詔西皇使涉予",
                "21": "路修遠以多艱兮",
                "22": "騰眾車使徑待",
                "23": "路不周以左轉兮",
                "24": "指西海以爲期",
                "25": "屯余車其千乘兮",
                "26": "齊玉軑而並馳",
                "27": "駕八龍之婉婉兮",
                "28": "載雲旗之委蛇",
                "29": "抑志而弭節兮",
                "30": "神高馳之邈邈",
                "31": "奏九歌而舞韶兮",
                "32": "聊假日以媮樂",
                "33": "陟陞皇之赫戲兮",
                "34": "忽臨睨夫舊鄕",
                "35": "僕夫悲余馬懷兮",
                "36": "蜷局顧而不行"
            }
        },
        "15": {
            "31": {
                "1": "亂曰",
                "2": "已矣哉",
                "3": "國無人莫我知兮",
                "4": "又何懷乎故都",
                "5": "旣莫足與爲美政兮",
                "6": "吾將從彭咸之所居"
            }
        }
    }
}