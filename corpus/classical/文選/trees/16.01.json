{
    "16.01": {
        "篇名": "潘安仁 閑居賦[幷序]",
        "1": {
            "3": {
                "1": "岳嘗讀汲黯傳",
                "2": "至司馬安四至九卿",
                "3": "而良史書之",
                "4": "題以巧宦之目",
                "5": "未嘗不慨然廢書而歎",
                "6": "曰",
                "7": "嗟乎",
                "8": "巧誠有之",
                "9": "拙亦宜然",
                "10": "顧常以爲士之生也",
                "11": "非至聖無軌微妙玄通者",
                "12": "則必立功立事",
                "13": "效當年之用",
                "14": "是以資忠履信以進德",
                "15": "修辭立誠以居業"
            }
        },
        "2": {
            "5": {
                "1": "僕少竊鄕曲之譽",
                "2": "忝司空太尉之命",
                "3": "所奉之主",
                "4": "卽太宰魯武公其人也",
                "5": "舉秀才爲郎",
                "6": "逮事世祖武皇帝",
                "7": "爲河陽懷令",
                "8": "尙書郎",
                "9": "廷尉平",
                "10": "今天子諒闇之際",
                "11": "領太傅主簿",
                "12": "府主誅",
                "13": "除名爲民",
                "14": "俄而復官",
                "15": "除長安令",
                "16": "遷博士",
                "17": "未召拜",
                "18": "親疾",
                "19": "輒去官免",
                "20": "自弱冠涉乎知命之年",
                "21": "八徙官而一進階",
                "22": "再免",
                "23": "一除名",
                "24": "一不拜職",
                "25": "遷者三而已矣",
                "26": "雖通塞有遇",
                "27": "抑亦拙者之效也"
            }
        },
        "3": {
            "7": {
                "1": "昔通人和長輿之論余也",
                "2": "固謂拙於用多",
                "3": "稱多則吾豈敢",
                "4": "言拙信而有徵",
                "5": "方今俊乂在官",
                "6": "百工惟時",
                "7": "拙者可以絕意乎寵榮之事矣",
                "8": "太夫人在堂",
                "9": "有羸老之疾",
                "10": "尙何能違膝下色養",
                "11": "而屑屑從斗筲之役乎"
            }
        },
        "4": {
            "9": {
                "1": "於是覽止足之分",
                "2": "庶浮雲之志",
                "3": "築室種樹",
                "4": "逍遙自得",
                "5": "池沼足以漁釣",
                "6": "舂稅足以代耕",
                "7": "灌園粥蔬",
                "8": "以供朝夕之膳",
                "9": "牧羊酤酪",
                "10": "以俟伏臘之費",
                "11": "孝乎惟孝",
                "12": "友於兄弟",
                "13": "此亦拙者之爲政也",
                "14": "乃作閑居賦",
                "15": "以歌事遂情焉",
                "16": "其辭曰"
            }
        },
        "5": {
            "11": {
                "1": "傲墳素之長圃",
                "2": "步先哲之高衢",
                "3": "雖吾顏之云厚",
                "4": "猶內愧於寗蘧",
                "5": "有道吾不仕",
                "6": "無道吾不愚",
                "7": "何巧智之不足",
                "8": "而拙艱之有餘也"
            }
        },
        "6": {
            "13": {
                "1": "於是退而閑居",
                "2": "於洛之涘",
                "3": "身齊逸民",
                "4": "名綴下士",
                "5": "陪京泝伊",
                "6": "面郊後市",
                "7": "浮梁黝以徑度",
                "8": "靈臺傑其高峙",
                "9": "闚天文之祕奧",
                "10": "究人事之終始",
                "11": "其西則有元戎禁營",
                "12": "玄幙綠徽",
                "13": "谿子巨黍",
                "14": "異絭同機",
                "15": "礮石雷駭",
                "16": "激矢蝱飛",
                "17": "以先啟行",
                "18": "耀我皇威",
                "19": "其東則有明堂辟廱",
                "20": "清穆敞閑",
                "21": "環林縈映",
                "22": "圓海迴淵",
                "23": "聿追孝以嚴父",
                "24": "宗文考以配天",
                "25": "祇聖敬以明順",
                "26": "養更老以崇年"
            }
        },
        "7": {
            "15": {
                "1": "若乃背冬涉春",
                "2": "陰謝陽施",
                "3": "天子有事於柴燎",
                "4": "以郊祖而展義",
                "5": "張鈞天之廣樂",
                "6": "備千乘之萬騎",
                "7": "服振振以齊玄",
                "8": "管啾啾而並吹",
                "9": "煌煌乎",
                "10": "隱隱乎",
                "11": "茲禮容之壯觀",
                "12": "而王制之巨麗也",
                "13": "兩學齊列",
                "14": "雙宇如一",
                "15": "右延國冑",
                "16": "左納良逸",
                "17": "祁祁生徒",
                "18": "濟濟儒術",
                "19": "或升之堂",
                "20": "或入之室",
                "21": "教無常師",
                "22": "道在則是",
                "23": "故髦士投紱",
                "24": "名王懷璽",
                "25": "訓若風行",
                "26": "應如草靡",
                "27": "此里仁所以爲美",
                "28": "孟母所以三徙也"
            }
        },
        "8": {
            "17": {
                "1": "爰定我居",
                "2": "築室穿池",
                "3": "長楊映沼",
                "4": "芳枳樹籬",
                "5": "遊鱗瀺灂",
                "6": "菡萏敷披",
                "7": "竹木蓊藹",
                "8": "靈果參差",
                "9": "張公大谷之梨",
                "10": "梁侯烏椑之柿",
                "11": "周文弱枝之棗",
                "12": "房陵朱仲之李",
                "13": "靡不畢殖",
                "14": "三桃表櫻胡之別",
                "15": "二柰曜丹白之色",
                "16": "石榴蒲陶之珍",
                "17": "磊落蔓衍乎其側",
                "18": "梅杏郁棣之屬",
                "19": "繁榮麗藻之飾",
                "20": "華實照爛",
                "21": "言所不能極也",
                "22": "菜則蔥韭蒜芋",
                "23": "青筍紫薑",
                "24": "蓳薺甘旨",
                "25": "蓼荾芬芳",
                "26": "蘘荷依陰",
                "27": "時藿向陽",
                "28": "綠葵含露",
                "29": "白䪥負霜"
            }
        },
        "9": {
            "19": {
                "1": "於是凜秋暑退",
                "2": "熙春寒往",
                "3": "微雨新晴",
                "4": "六合清朗",
                "5": "太夫人乃御版輿",
                "6": "升輕軒",
                "7": "遠覽王畿",
                "8": "近周家園",
                "9": "體以行和",
                "10": "藥以勞宣",
                "11": "常膳載加",
                "12": "舊痾有痊",
                "13": "席長筵",
                "14": "列孫子",
                "15": "柳垂陰",
                "16": "車結軌",
                "17": "陸擿紫房",
                "18": "水挂赬鯉",
                "19": "或宴於林",
                "20": "或禊於汜",
                "21": "昆弟班白",
                "22": "兒童稚齒",
                "23": "稱萬壽以獻觴",
                "24": "咸一懼而一喜",
                "25": "壽觴舉",
                "26": "慈顏和",
                "27": "浮杯樂飲",
                "28": "絲竹騈羅",
                "29": "頓足起舞",
                "30": "抗音高歌",
                "31": "人生安樂",
                "32": "孰知其佗"
            }
        },
        "10": {
            "21": {
                "1": "退求己而自省",
                "2": "信用薄而才劣",
                "3": "奉周任之格言",
                "4": "敢陳力而就列",
                "5": "幾陋身之不保",
                "6": "尙奚擬於明哲",
                "7": "仰眾妙而絕思",
                "8": "終優遊以養拙"
            }
        }
    }
}