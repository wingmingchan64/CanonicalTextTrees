{
    "30.31-01": {
        "篇名": "謝靈運 擬魏太子鄴中集詩八首[幷序]·魏太子",
        "1": {
            "3": {
                "1": "建安末",
                "2": "余時在鄴宮",
                "3": "朝遊夕讌",
                "4": "究歡愉之極",
                "5": "天下良辰美景",
                "6": "賞心樂事",
                "7": "四者難幷",
                "8": "今昆弟友朋",
                "9": "二三諸彥",
                "10": "共盡之矣",
                "11": "古來此娛",
                "12": "書籍未見",
                "13": "何者",
                "14": "楚襄王時有宋玉",
                "15": "唐景",
                "16": "梁孝王時有鄒",
                "17": "枚",
                "18": "嚴",
                "19": "馬",
                "20": "遊者美矣",
                "21": "而其主不文",
                "22": "漢武帝徐樂諸才",
                "23": "備應對之能",
                "24": "而雄猜多忌",
                "25": "豈獲晤言之適",
                "26": "不誣方將",
                "27": "庶必賢於今日爾",
                "28": "歲月如流",
                "29": "零落將盡",
                "30": "撰文懷人",
                "31": "感往增愴",
                "32": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "百川赴巨海",
                "2": "眾星環北辰",
                "3": "照灼爛霄漢",
                "4": "遙裔起長津",
                "5": "天地中橫潰",
                "6": "家王拯生民",
                "7": "區㝢旣滌蕩",
                "8": "羣英必來臻",
                "9": "東京賦曰",
                "10": "區㝢乂寧",
                "11": "謝承後漢書曰",
                "12": "黃向對策爲羣英之表",
                "13": "忝此欽賢性",
                "14": "由來常懷仁",
                "15": "況値眾君子",
                "16": "傾心隆日新",
                "17": "論物靡浮說",
                "18": "析理實敷陳",
                "19": "羅縷豈闕辭",
                "20": "窈窕究天人",
                "21": "澄觴滿金罍",
                "22": "連榻設華茵",
                "23": "急絃動飛聽",
                "24": "清歌拂梁塵",
                "25": "何言相遇易",
                "26": "此歡信可珍"
            }
        }
    }
}