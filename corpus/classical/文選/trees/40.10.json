{
    "40.10": {
        "篇名": "謝玄暉 拜中軍記室辭隋王牋",
        "1": {
            "3": {
                "1": "故吏文學謝朓死罪死罪",
                "2": "卽日被尙書召",
                "3": "以眺補中軍新安王記室參軍",
                "4": "眺聞潢汙之水",
                "5": "願朝宗而每竭",
                "6": "駑蹇之乘",
                "7": "希沃若而中疲",
                "8": "何則",
                "9": "皋壤搖落",
                "10": "對之惆悵",
                "11": "歧路西東",
                "12": "或以歍唈況迺服義徒擁",
                "13": "歸志莫從",
                "14": "邈若墜雨",
                "15": "翩似秋蔕",
                "16": "眺實庸流",
                "17": "行能無算",
                "18": "屬天地休明",
                "19": "山川受納",
                "20": "襃采一介",
                "21": "抽揚小善",
                "22": "故捨耒場圃",
                "23": "奉筆兔園",
                "24": "東亂三江",
                "25": "西浮七澤",
                "26": "契闊戎旃",
                "27": "從容讌語",
                "28": "長裾日曳",
                "29": "後乘載脂",
                "30": "榮立府庭",
                "31": "恩加顏色",
                "32": "沐髮晞陽",
                "33": "未測涯涘",
                "34": "撫臆論報",
                "35": "早誓肌骨",
                "36": "不悟滄溟未運",
                "37": "波臣自蕩",
                "38": "渤澥方春",
                "39": "旅翮先謝",
                "40": "清切藩房",
                "41": "寂寥舊蓽",
                "42": "輕舟反溯",
                "43": "弔影獨留",
                "44": "白雲在天",
                "45": "龍門不見",
                "46": "去德滋永",
                "47": "思德滋深",
                "48": "唯待青江可望",
                "49": "候歸艎於春渚",
                "50": "朱邸方開",
                "51": "效蓬心於秋實",
                "52": "如其簪履或存",
                "53": "衽席無改",
                "54": "雖復身塡溝壑",
                "55": "猶望妻子知歸",
                "56": "攬涕告辭",
