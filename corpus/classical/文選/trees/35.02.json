{
    "35.02": {
        "篇名": "漢武帝 詔",
        "1": {
            "3": {
                "1": "詔曰",
                "2": "蓋有非常之功",
                "3": "必待非常之人",
                "4": "故馬或奔踶而致千里",
                "5": "士或有負俗之累而立功名",
                "6": "夫泛駕之馬",
                "7": "跅弛之士",
                "8": "亦在御之而已",
                "9": "其令州縣察吏民有茂才異等",
                "10": "可爲將相及使絕國者"
            }
        }
    }
}