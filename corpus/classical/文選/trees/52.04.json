{
    "52.04": {
        "篇名": "韋弘嗣 博弈論",
        "1": {
            "3": {
                "1": "蓋君子恥當年而功不立",
                "2": "疾沒世而名不稱",
                "3": "故曰",
                "4": "學如不及",
                "5": "猶恐失之",
                "6": "是以古之志士",
                "7": "悼年齒之流邁",
                "8": "而懼名稱之不建也",
                "9": "勉精厲操",
                "10": "晨興夜寐",
                "11": "不遑寧息",
                "12": "經之以歲月",
                "13": "累之以日力",
                "14": "若寗越之勤",
                "15": "董生之篤",
                "16": "漸漬德義之淵",
                "17": "栖遲道藝之域",
                "18": "且以西伯之聖",
                "19": "姬公之才",
                "20": "猶有日昃待旦之勞",
                "21": "故能隆興周道",
                "22": "垂名億載",
                "23": "況在臣庶",
                "24": "而可以已乎"
            }
        },
        "2": {
            "5": {
                "1": "歷觀古今功名之士",
                "2": "皆有積累殊異之迹",
                "3": "勞神苦體",
                "4": "契闊勤思",
                "5": "平居不惰其業",
                "6": "窮困不易其素",
                "7": "是以卜式立志於耕牧",
                "8": "而黃霸受道於囹圄",
                "9": "終有榮顯之福",
                "10": "以成不朽之名",
                "11": "故山甫勤於夙夜",
                "12": "而吳漢不離公門",
                "13": "豈有遊惰哉"
            }
        },
        "3": {
            "7": {
                "1": "今世之人",
                "2": "多不務經術",
                "3": "好翫博弈",
                "4": "廢事棄業",
                "5": "忘寢與食",
                "6": "窮日盡明",
                "7": "繼以脂燭",
                "8": "當其臨局交爭",
                "9": "雌雄未決",
                "10": "專精銳意",
                "11": "神迷體倦",
                "12": "人事曠而不修",
                "13": "賓旅闕而不接",
                "14": "雖有太牢之饌",
                "15": "韶夏之樂",
                "16": "不暇存也",
                "17": "至或賭及衣物",
                "18": "徙棋易行",
                "19": "埤蒼",
                "20": "賭",
                "21": "䞈也",
                "22": "賭",
                "23": "丁古切",
                "24": "䞈",
                "25": "記被切",
                "26": "廉恥之意弛",
                "27": "而忿戾之色發",
                "28": "然其所志不出一枰之上",
                "29": "所務不過方罫之間",
                "30": "勝敵無封爵之賞",
                "31": "獲地無兼土之實",
                "32": "技非六藝",
                "33": "用非經國",
                "34": "立身者不階其術",
                "35": "徵選者不由其道",
                "36": "求之於戰陣",
                "37": "則非孫吳之倫也",
                "38": "考之於道藝",
                "39": "則非孔氏之門也",
                "40": "以變詐爲務",
                "41": "則非忠信之事也",
                "42": "以劫殺爲名",
                "43": "則非仁者之意也",
                "44": "而空妨日廢業",
                "45": "終無補益",
                "46": "是何異設木而擊之",
                "47": "置石而投之哉",
                "48": "且君子之居室也",
                "49": "勤身以致養",
                "50": "其在朝也",
                "51": "竭命以納忠",
                "52": "臨事且猶旰食",
                "53": "而何暇博弈之足躭",
                "54": "夫然",
                "55": "故孝友之行立",
                "56": "貞純之名章也"
            }
        },
        "4": {
            "9": {
                "1": "方今大吳受命",
                "2": "海內未平",
                "3": "聖朝乾乾",
                "4": "務在得人",
                "5": "勇略之士",
                "6": "則受熊虎之任",
                "7": "儒雅之徒",
                "8": "則處龍鳳之署",
                "9": "百行兼苞",
                "10": "文武並騖",
                "11": "博選良才",
                "12": "旌簡髦俊",
                "13": "設程試之科",
                "14": "垂金爵之賞",
                "15": "誠千載之嘉會",
                "16": "百世之良遇也",
                "17": "當世之士",
                "18": "宜勉思至道",
                "19": "愛功惜力",
                "20": "以佐明時",
                "21": "使名書史籍",
                "22": "勳在盟府",
                "23": "乃君子之務",
                "24": "當今之先急也"
            }
        },
        "5": {
            "11": {
                "1": "夫一木之枰",
                "2": "孰與方國之封",
                "3": "枯棋三百",
                "4": "孰與萬人之將",
                "5": "衮龍之服",
                "6": "金石之樂",
                "7": "足以兼棋局而貿博弈矣",
                "8": "假令世士",
                "9": "移博弈之力用之於詩書",
                "10": "是有顏閔之志也",
                "11": "用之於智計",
                "12": "是有良平之思也",
                "13": "用之於資貨",
                "14": "是有猗頓之富也",
                "15": "用之於射御",
                "16": "是有將帥之備也",
                "17": "如此",
                "18": "則功名立而鄙賤遠矣"
            }
        }
    }
}