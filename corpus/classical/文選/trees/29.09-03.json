{
    "29.09-03": {
        "篇名": "曹子建 雜詩六首·其三",
        "1": {
            "3": {
                "1": "西北有織婦",
                "2": "綺縞何繽紛",
                "3": "明晨秉機杼",
                "4": "日昃不成文",
                "5": "太息終長夜",
                "6": "悲嘯入青雲",
                "7": "妾身守空閨",
                "8": "良人行從軍",
                "9": "自期三年歸",
                "10": "今已歷九春",
                "11": "飛鳥繞樹翔",
                "12": "噭噭鳴索羣",
                "13": "願爲南流景",
                "14": "馳光見我君"
            }
        }
    }
