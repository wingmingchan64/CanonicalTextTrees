                "47": "對曰",
                "48": "嬰聞佯問者佯對也",
                "49": "寧可以軌物字民",
                "50": "作範垂訓者乎",
                "51": "且今之官漏",
                "52": "出自會稽",
                "53": "積水違方",
                "54": "導流乖則",
                "55": "六日無辨",
                "56": "五夜不分",
                "57": "歲躔閹茂",
                "58": "月次姑洗",
                "59": "皇帝有天下之五載也",
                "60": "樂遷夏諺",
                "61": "禮變商俗",
                "62": "業類補天",
                "63": "功均柱地",
                "64": "河海夷晏",
                "65": "風雲律呂",
                "66": "坐朝晏罷",
                "67": "每旦晨興",
                "68": "屬傳漏之音",
                "69": "聽雞人之響",
                "70": "以爲星火謬中",
                "71": "金水違用",
                "72": "時乖啟閉",
                "73": "箭異錙銖",
                "74": "爰命日官",
                "75": "草創新器"
