        },
        "2": {
            "5": {
                "1": "於是俯察旁羅",
                "2": "登臺升庫",
                "3": "則於地四",
                "4": "參以天一",
                "5": "建武遺蠹",
                "6": "咸和餘舛",
                "7": "金筒方員之制",
                "8": "飛流吐納之規",
                "9": "變律改經",
                "10": "一皆懲革",
                "11": "天監六年",
                "12": "太歲丁亥",
                "13": "十月丁亥朔",
                "14": "十六日壬寅",
                "15": "漏成進御",
