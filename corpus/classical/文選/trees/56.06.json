{
    "56.06": {
        "篇名": "陸佐公 新刻漏銘[幷序]",
        "1": {
            "3": {
                "1": "夫自天觀象",
                "2": "昏旦之刻未分",
                "3": "治歷明時",
                "4": "盈縮之度無準",
                "5": "挈壺命氏",
                "6": "遠哉義用",
                "7": "揆景測辰",
                "8": "徼宮戒井",
                "9": "守以水火",
                "10": "分茲日夜",
                "11": "而司歷亡官",
                "12": "疇人廢業",
                "13": "孟陬殄滅",
                "14": "攝提無紀",
                "15": "衞宏載傳呼之節",
                "16": "較而未詳",
                "17": "霍融敍分至之差",
                "18": "詳而不密",
                "19": "陸機之賦",
                "20": "虛握靈珠",
                "21": "孫綽之銘",
                "22": "空擅崑玉",
                "23": "弘度遺篇",
                "24": "承天垂旨",
                "25": "布在方冊",
                "26": "無彰器用",
                "27": "譬彼春華",
