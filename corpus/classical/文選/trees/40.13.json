{
    "40.13": {
        "篇名": "阮嗣宗 詣蔣公",
        "1": {
            "3": {
                "1": "籍死罪死罪",
                "2": "伏惟明公",
                "3": "以含一之德",
                "4": "據上台之位",
                "5": "羣英翹首",
                "6": "俊賢抗足",
                "7": "開府之日",
                "8": "人人自以爲掾屬",
                "9": "辟書始下",
                "10": "下走爲首",
                "11": "子夏處西河之上",
                "12": "而文侯擁篲",
                "13": "鄒子居黍谷之陰",
                "14": "而昭王陪乘",
                "15": "夫布衣窮居韋帶之士",
                "16": "王公大人所以屈體而下之者",
                "17": "爲道存也",
                "18": "籍無鄒卜之德而有其陋",
                "19": "猥見采擢",
                "20": "無以稱當",
                "21": "方將耕於東皋之陽",
                "22": "輸黍稷之稅",
                "23": "以避當塗者之路",
                "24": "負薪疲病",
                "25": "足力不強",
                "26": "補吏之召",
                "27": "非所克堪",
                "28": "乞迴謬恩",
                "29": "以光清舉"
            }
        }
    }
}