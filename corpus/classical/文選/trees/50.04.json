{
    "50.04": {
        "篇名": "沈休文 宋書·謝靈運傳論",
        "1": {
            "3": {
                "1": "史臣曰",
                "2": "民稟天地之靈",
                "3": "含五常之德",
                "4": "剛柔迭用",
                "5": "喜慍分情",
                "6": "夫志動於中",
                "7": "則歌詠外發",
                "8": "六義所因",
                "9": "四始攸繫",
                "10": "升降謳謠",
                "11": "紛披風什",
                "12": "雖虞夏以前",
                "13": "遺文不睹",
                "14": "稟氣懷靈",
                "15": "理或無異",
                "16": "然則歌詠所興",
                "17": "宜自生民始也"
            }
        },
        "2": {
            "5": {
                "1": "周室旣衰",
                "2": "風流彌著",
                "3": "屈平宋玉導清源於前",
                "4": "賈誼相如振芳塵於後",
                "5": "英辭潤金石",
                "6": "高義薄雲天",
                "7": "自茲以降",
                "8": "情志愈廣",
                "9": "王襃劉向楊班崔蔡之徒",
                "10": "異軌同奔",
                "11": "遞相師祖",
                "12": "然清辭麗曲",
                "13": "時發乎篇",
                "14": "而蕪音累氣",
                "15": "固亦多矣",
                "16": "若夫平子豔發",
                "17": "文以情變",
                "18": "絕唱高蹤",
                "19": "久無嗣響",
                "20": "至於建安",
                "21": "曹氏基命",
                "22": "三祖陳王",
                "23": "咸蓄盛藻",
                "24": "甫乃以情緯文",
                "25": "以文被質"
            }
        },
        "3": {
            "7": {
                "1": "自漢至魏",
                "2": "四百餘年",
                "3": "辭人才子",
                "4": "文體三變",
                "5": "相如工爲形似之言",
                "6": "二班長於情理之說",
                "7": "子建仲宣以氣質爲體",
                "8": "並摽能擅美",
                "9": "獨映當時",
                "10": "是以一世之士",
                "11": "各相慕習",
                "12": "源其飆流所始",
                "13": "莫不同祖風騷",
                "14": "徒以賞好異情",
                "15": "故意製相詭"
            }
        },
        "4": {
            "9": {
                "1": "降及元康",
                "2": "潘陸特秀",
                "3": "律異班賈",
                "4": "體變曹王",
                "5": "縟旨星稠",
                "6": "繁文綺合",
                "7": "綴平臺之逸響",
                "8": "采南皮之高韻",
                "9": "遺風餘烈",
                "10": "事極江右",
                "11": "在晉中興",
                "12": "玄風獨扇",
                "13": "爲學窮於柱下",
                "14": "博物止乎七篇",
                "15": "馳騁文辭",
                "16": "義殫乎此",
                "17": "自建武曁於義熙",
                "18": "歷載將百",
                "19": "雖比響聯辭",
                "20": "波屬雲委",
                "21": "莫不寄言上德",
                "22": "託意玄珠",
                "23": "遒麗之辭",
                "24": "無聞焉爾",
                "25": "仲文始革孫許之風",
                "26": "叔源大變太元之氣"
            }
        },
        "5": {
            "11": {
                "1": "爰逮宋氏",
                "2": "顏謝騰聲",
                "3": "靈運之興會摽舉",
                "4": "延年之體裁明密",
                "5": "並方軌前秀",
                "6": "垂範後昆",
                "7": "若夫敷衽論心",
                "8": "商搉前藻",
                "9": "工拙之數",
                "10": "如有可言",
                "11": "夫五色相宣",
                "12": "八音協暢",
                "13": "由乎玄黃律呂",
                "14": "各適物宜",
                "15": "欲使宮羽相變",
                "16": "低昂舛節",
                "17": "若前有浮聲",
                "18": "則後須切響",
                "19": "一簡之內",
                "20": "音韻盡殊",
                "21": "兩句之中",
                "22": "輕重悉異",
                "23": "妙達此旨",
                "24": "始可言文",
                "25": "至於先士茂製",
                "26": "諷高歷賞",
                "27": "子建函京之作",
                "28": "仲宣灞岸之篇",
                "29": "子荊零雨之章",
                "30": "正長朔風之句",
                "31": "並直舉胸情",
                "32": "非傍詩史",
                "33": "正以音律調韻",
                "34": "取高前式",
                "35": "自靈均以來",
                "36": "多歷年代",
                "37": "雖文體稍精",
                "38": "而此祕未睹",
                "39": "至於高言妙句",
                "40": "音韻天成",
                "41": "皆暗與理合",
                "42": "匪由思至",
                "43": "張蔡曹王",
                "44": "曾無先覺",
                "45": "潘陸顏謝",
                "46": "去之彌遠",
                "47": "世之知音者",
                "48": "有以得之",
                "49": "此言非謬",
                "50": "如曰不然",
                "51": "請待來哲"
            }
        }
    }
}