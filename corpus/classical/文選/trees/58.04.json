{
    "58.04": {
        "篇名": "蔡伯喈 陳太丘碑文[幷序]",
        "1": {
            "3": {
                "1": "先生諱寔",
                "2": "字仲弓",
                "3": "潁川許人也",
                "4": "含元精之和",
                "5": "應期運之數",
                "6": "兼資九德",
                "7": "摠修百行",
                "8": "於鄕黨則恂恂焉",
                "9": "彬彬焉",
                "10": "善誘善導",
                "11": "仁而愛人",
                "12": "使夫少長咸安懷之",
                "13": "其爲道也",
                "14": "用行舍藏",
                "15": "進退可度",
                "16": "不徼訐以干時",
                "17": "不遷貳以臨下",
                "18": "四爲郡功曹",
                "19": "五辟豫州",
                "20": "六辟三府",
                "21": "再辟大將軍",
                "22": "宰聞喜半歲",
                "23": "太丘一年",
                "24": "德務中庸",
                "25": "教敦不肅",
                "26": "政以禮成",
                "27": "化行有謐",
                "28": "會遭黨事",
                "29": "禁固二十年",
                "30": "樂天知命",
                "31": "澹然自逸",
                "32": "交不諂上",
                "33": "愛不瀆下",
                "34": "見機而作",
                "35": "不俟終日",
                "36": "及文書赦宥",
                "37": "時年已七十",
                "38": "遂隱丘山",
                "39": "懸車告老",
                "40": "四門備禮",
                "41": "閑心靜居",
                "42": "大將軍何公",
                "43": "司徒袁公",
                "44": "前後招辟",
                "45": "使人曉喩",
                "46": "云欲特表",
                "47": "便可入踐常伯",
                "48": "超補三事",
                "49": "紆佩金紫",
                "50": "光國垂勳",
                "51": "先生曰",
                "52": "絕望已久",
                "53": "飾巾待期而已",
                "54": "皆遂不至",
                "55": "弘農楊公",
                "56": "東海陳公",
                "57": "每在衮職",
                "58": "羣僚賀之",
                "59": "皆舉手曰",
                "60": "潁川陳君",
                "61": "絕世超倫",
                "62": "大位未躋",
                "63": "慚於臧文竊位之負",
                "64": "故時人高其德",
                "65": "重乎公相之位也"
            }
        },
        "2": {
            "5": {
                "1": "年八十有三",
                "2": "中平三年八月丙午",
                "3": "遭疾而終",
                "4": "臨沒顧命",
                "5": "留葬所卒",
                "6": "時服素棺",
                "7": "槨財周襯",
                "8": "喪事惟約",
                "9": "用過乎儉",
                "10": "羣公百僚",
                "11": "莫不咨嗟",
                "12": "巖藪知名",
                "13": "失聲揮涕",
                "14": "大將軍弔祠",
                "15": "錫以嘉謚",
                "16": "曰",
                "17": "徵士陳君",
                "18": "稟嶽瀆之精",
                "19": "苞靈曜之純",
                "20": "天不憖遺老",
                "21": "俾屛我王",
                "22": "梁崩哲萎",
                "23": "於時靡憲",
                "24": "搢紳儒林",
                "25": "論德謀迹",
                "26": "謚曰文範先生",
                "27": "傳曰",
                "28": "郁郁乎文哉",
                "29": "書曰",
                "30": "洪範九疇",
                "31": "彝倫攸敍",
                "32": "文爲德表",
                "33": "範爲士則",
                "34": "存誨沒號",
                "35": "不亦宜乎",
                "36": "三公遣令史祭以中牢",
                "37": "刺史敬弔",
                "38": "太守南陽曹府君命官作誄曰",
                "39": "赫矣陳君",
                "40": "命世是生",
                "41": "含光醇德",
                "42": "爲士作程",
                "43": "資始旣正",
                "44": "守終又令",
                "45": "奉禮終沒",
                "46": "休矣清聲",
                "47": "遣官屬掾吏",
                "48": "前後赴會",
                "49": "刊石作銘",
                "50": "府丞與比縣會葬",
                "51": "荀慈明韓元長等五百餘人",
                "52": "緦麻設位",
                "53": "哀以送之",
                "54": "遠近會葬",
                "55": "千人已上",
                "56": "河南尹种府君臨郡",
                "57": "追歎功德",
                "58": "述錄高行",
                "59": "以爲遠近鮮能及之",
                "60": "重部大掾",
                "61": "以時成銘",
                "62": "斯可謂存榮沒哀",
                "63": "死而不朽者已",
                "64": "乃作銘曰"
            }
        },
        "3": {
            "7": {
                "1": "峨峨崇嶽",
                "2": "吐符降神",
                "3": "於皇先生",
                "4": "抱寶懷珍",
                "5": "如何昊穹",
                "6": "旣喪斯文",
                "7": "微言圮絕",
                "8": "來者曷聞",
                "9": "交交黃鳥",
                "10": "爰集於棘",
                "11": "命不可贖",
                "12": "哀何有極"
            }
        }
    }
}