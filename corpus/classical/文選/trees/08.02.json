{
    "08.02": {
        "篇名": "楊子雲 羽獵賦[幷序]",
        "1": {
            "3": {
                "1": "月羽獵",
                "2": "雄從",
                "3": "以爲昔在二帝三王",
                "4": "宮館臺榭",
                "5": "沼池苑囿",
                "6": "林麓藪澤",
                "7": "財足以奉郊廟",
                "8": "御賓客",
                "9": "充庖廚而已",
                "10": "不奪百姓膏腴穀土桑柘之地",
                "11": "女有餘布",
                "12": "男有餘粟",
                "13": "國家殷富",
                "14": "上下交足",
                "15": "故甘露零其庭",
                "16": "醴泉流其唐",
                "17": "鳳凰巢其樹",
                "18": "黃龍遊其沼",
                "19": "麒麟臻其囿",
                "20": "神爵栖其林",
                "21": "昔者禹任益虞而上下和",
                "22": "屮木茂",
                "23": "成湯好田",
                "24": "而天下用足",
                "25": "文王囿百里",
                "26": "民以爲尙小",
                "27": "齊宣王囿四十里",
                "28": "民以爲大",
                "29": "裕民之與奪民也",
                "30": "武帝廣開上林",
                "31": "東南至宜春",
                "32": "鼎湖",
                "33": "御宿",
                "34": "昆吾",
                "35": "旁南山而西",
                "36": "至長楊",
                "37": "五柞",
                "38": "北繞黃山",
                "39": "瀕渭而東",
                "40": "周袤數百里",
                "41": "穿昆明池",
                "42": "象滇河",
                "43": "營建章",
                "44": "鳳闕",
                "45": "神明",
                "46": "馺娑",
                "47": "漸臺",
                "48": "泰液",
                "49": "象海水",
                "50": "周流方丈",
                "51": "瀛洲",
                "52": "蓬萊",
                "53": "遊觀侈靡",
                "54": "窮妙極麗",
                "55": "雖頗割垂以贍齊民",
                "56": "然至羽獵",
                "57": "田車戎馬",
                "58": "器械儲偫",
                "59": "禁禦所營",
                "60": "尙泰奢麗誇詡",
                "61": "非堯舜成湯文王三驅之意也",
                "62": "又恐後世復修前好",
                "63": "不折中以泉臺",
                "64": "故聊因校獵",
                "65": "賦以風",
                "66": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "或稱羲農",
                "2": "豈或帝王之彌文哉",
                "3": "論者雲否",
                "4": "各以並時而得宜",
                "5": "奚必同條而共貫",
                "6": "則泰山之封",
                "7": "烏得七十而有二儀",
                "8": "是以創業垂統者俱不見其爽",
                "9": "遐邇五三孰知其是非",
                "10": "遂作頌曰",
                "11": "麗哉神聖",
                "12": "處於玄宮",
                "13": "富旣與地乎侔訾",
                "14": "貴正與天虖比崇",
                "15": "齊桓曾不足使扶轂",
                "16": "楚嚴未足以爲驂乘",
                "17": "陿三王之阸薜",
                "18": "嶠高舉而大興",
                "19": "歷五帝之寥廓",
                "20": "涉三皇之登閎",
                "21": "建道德以爲師",
                "22": "友仁義與之爲朋"
            }
        },
        "3": {
            "7": {
                "1": "於是玄冬季月",
                "2": "天地隆烈",
                "3": "萬物權輿於內",
                "4": "徂落於外",
                "5": "帝將惟田於靈之囿",
                "6": "開北垠",
                "7": "受不周之制",
                "8": "以奉終始顓頊玄冥之統",
                "9": "迺詔虞人典澤",
                "10": "東延昆鄰",
                "11": "西馳闛闔",
                "12": "儲積共偫",
                "13": "戍卒夾道",
                "14": "斬叢棘",
                "15": "夷野草",
                "16": "禦自汧渭",
                "17": "經營酆鎬",
                "18": "章皇周流",
                "19": "出入日月",
                "20": "天與地沓",
                "21": "爾迺虎路三嵏以爲司馬",
                "22": "圍經百里而爲殿門",
                "23": "外則正南極海",
                "24": "邪界虞淵",
                "25": "鴻濛沆茫",
                "26": "碣以崇山",
                "27": "營合圍會",
                "28": "然後先置虖白楊之南",
                "29": "昆明靈沼之東",
                "30": "賁育之倫",
                "31": "蒙盾負羽",
                "32": "杖鏌邪而羅者以萬計",
                "33": "其餘荷垂天之畢",
                "34": "張竟壄之罘",
                "35": "靡日月之朱竿",
                "36": "曳彗星之飛旗",
                "37": "青雲爲紛",
                "38": "紅蜺爲繯",
                "39": "屬虖昆侖之虛",
                "40": "渙若天星之羅",
                "41": "浩如濤水之波",
                "42": "淫淫與與",
                "43": "前後要遮",
                "44": "欃槍爲闉",
                "45": "明月爲候",
                "46": "熒惑司命",
                "47": "天弧發射",
                "48": "鮮扁陸離",
                "49": "騈衍佖路",
                "50": "徽車輕武",
                "51": "鴻絧緁獵",
                "52": "殷殷軫軫",
                "53": "被陵緣阪",
                "54": "窮冥極遠者",
                "55": "相與迾虖高原之上",
                "56": "羽騎營營",
                "57": "昈分殊事",
                "58": "繽紛往來",
                "59": "轠轤不絕",
                "60": "若光若滅者",
                "61": "布虖青林之下"
            }
        },
        "4": {
            "9": {
                "1": "於是天子迺以陽鼂始出虖玄宮",
                "2": "撞鴻鍾",
                "3": "建九流",
                "4": "六白虎",
                "5": "載靈輿",
                "6": "蚩尤並轂",
                "7": "蒙公先驅",
                "8": "立歷天之旂",
                "9": "曳捎星之旃",
                "10": "辟歷列缺",
                "11": "吐火施鞭",
                "12": "萃傱允溶",
                "13": "淋離廓落",
                "14": "戲八鎭而開關",
                "15": "飛廉雲師",
                "16": "吸嚊潚率",
                "17": "鱗羅布列",
                "18": "攢以龍翰",
                "19": "秋秋蹌蹌",
                "20": "入西園",
                "21": "切神光",
                "22": "望平樂",
                "23": "徑竹林",
                "24": "蹂惠圃",
                "25": "踐蘭唐",
                "26": "舉㶻烈火",
                "27": "轡者施披",
                "28": "方馳千駟",
                "29": "狡騎萬帥",
                "30": "虓虎之陳",
                "31": "從橫膠輵",
                "32": "猋泣雷厲",
                "33": "驞駍駖磕",
                "34": "洶洶旭旭",
                "35": "天動地岋",
                "36": "羨漫半散",
                "37": "蕭條數千萬里外"
            }
        },
        "5": {
            "11": {
                "1": "若夫壯士忼慨",
                "2": "殊鄕別趣",
                "3": "東西南北",
                "4": "騁耆奔欲",
                "5": "拕蒼豨",
                "6": "跋犀犛",
                "7": "蹶浮麋",
                "8": "斮巨狿",
                "9": "搏玄蝯",
                "10": "騰空虛",
                "11": "距連卷",
                "12": "踔夭蟜",
                "13": "娭澗門",
                "14": "莫莫紛紛",
                "15": "山谷爲之風猋",
                "16": "林叢爲之生塵",
                "17": "及至獲夷之徒",
                "18": "蹶松柏",
                "19": "掌疾棃",
                "20": "獵蒙蘢",
                "21": "轔輕飛",
                "22": "履般首",
                "23": "帶修蛇",
                "24": "鉤赤豹",
                "25": "摼象犀",
                "26": "跇巒阬",
                "27": "超唐陂",
                "28": "車騎雲會",
                "29": "登降闇藹",
                "30": "泰華爲旒",
                "31": "熊耳爲綴",
                "32": "木仆山還",
                "33": "漫若天外",
                "34": "儲與虖大浦",
                "35": "聊浪虖宇內"
            }
        },
        "6": {
            "13": {
                "1": "於是天清日晏",
                "2": "逢蒙列眥",
                "3": "羿氏控弦",
                "4": "皇車幽輵",
                "5": "光純天地",
                "6": "望舒彌轡",
                "7": "翼乎徐至於上蘭",
                "8": "移圍徙陣",
                "9": "浸淫蹵部",
                "10": "曲隊堅重",
                "11": "各按行伍",
                "12": "壁壘天旋",
                "13": "神抶電擊",
                "14": "逢之則碎",
                "15": "近之則破",
                "16": "鳥不及飛",
                "17": "獸不得過",
                "18": "軍驚師駭",
                "19": "刮野掃地",
                "20": "及至罕車飛揚",
                "21": "武騎聿皇",
                "22": "蹈飛豹",
                "23": "絹嘄陽",
                "24": "追天寶",
                "25": "出一方",
                "26": "應駍聲",
                "27": "擊流光",
                "28": "壄盡山窮",
                "29": "囊括其雌雄",
                "30": "沈沈溶溶",
                "31": "遙噱虖紭中",
                "32": "三軍芒然",
                "33": "窮冘閼與",
                "34": "亶觀夫票禽之紲隃",
                "35": "犀兕之抵觸",
                "36": "熊羆之挐玃",
                "37": "虎豹之凌遽",
                "38": "徒角槍題注",
                "39": "䠞竦讋怖",
                "40": "魂亡魄失",
                "41": "觸輻關脰",
                "42": "妄發期中",
                "43": "進退履獲",
                "44": "創淫輪夷",
                "45": "丘累陵聚"
            }
        },
        "7": {
            "15": {
                "1": "於是禽殫中衰",
                "2": "相與集於靖冥之館",
                "3": "以臨珍池",
                "4": "灌以岐梁",
                "5": "溢以江河,東瞰目盡",
                "6": "西暢亡厓",
                "7": "隨珠和氏",
                "8": "焯爍其陂",
                "9": "玉石嶜崟",
                "10": "眩燿青熒",
                "11": "漢女水潛",
                "12": "怪物暗冥",
                "13": "不可殫形",
                "14": "玄鸞孔雀",
                "15": "翡翠垂榮",
                "16": "王雎關關",
                "17": "鴻雁嚶嚶",
                "18": "羣娛虖其中",
                "19": "噍噍昆鳴",
                "20": "鳧鷖振鷺",
                "21": "上下砰磕",
                "22": "聲若雷霆",
                "23": "乃使文身之技",
                "24": "水格鱗蟲",
                "25": "凌堅冰",
                "26": "犯嚴淵",
                "27": "探巖排碕",
                "28": "薄索蛟螭",
                "29": "蹈獱獺",
                "30": "據黿鼉",
                "31": "抾靈蠵",
                "32": "入洞穴",
                "33": "出蒼梧",
                "34": "乘巨鱗",
                "35": "騎京魚",
                "36": "浮彭蠡",
                "37": "目有虞",
                "38": "方椎夜光之流離",
                "39": "剖明月之珠胎",
                "40": "鞭洛水之虙妃",
                "41": "餉屈原與彭胥"
            }
        },
        "8": {
            "17": {
                "1": "於茲虖鴻生鉅儒",
                "2": "俄軒冕",
                "3": "雜衣裳",
                "4": "修唐典",
                "5": "匡雅頌",
                "6": "揖讓於前",
                "7": "昭光振燿",
                "8": "蠁曶如神",
                "9": "仁聲惠於北狄",
                "10": "武誼動於南鄰",
                "11": "是以旃裘之王",
                "12": "胡貉之長",
                "13": "移珍來享",
                "14": "抗手稱臣",
                "15": "前入圍口",
                "16": "後陳盧山",
                "17": "羣公常伯",
                "18": "楊朱墨翟之徒",
                "19": "喟然稱曰",
                "20": "崇哉乎德",
                "21": "雖有唐虞大夏成周之隆",
                "22": "何以侈茲",
                "23": "太古之覲東嶽",
                "24": "禪梁基",
                "25": "舍此世也",
                "26": "其誰與哉"
            }
        },
        "9": {
            "19": {
                "1": "上猶謙讓而未兪也",
                "2": "方將上獵三靈之流",
                "3": "下決醴泉之滋",
                "4": "發黃龍之穴",
                "5": "窺鳳凰之巢",
                "6": "臨麒麟之囿",
                "7": "幸神雀之林",
                "8": "奢雲夢",
                "9": "侈孟諸",
                "10": "非章華",
                "11": "是靈臺",
                "12": "罕徂離宮而輟觀遊",
                "13": "土事不飾",
                "14": "木功不雕",
                "15": "承民乎農桑",
                "16": "勸之以弗迨",
                "17": "儕男女使莫違",
                "18": "恐貧窮者不徧被洋溢之饒",
                "19": "開禁苑",
                "20": "散公儲",
                "21": "創道德之囿",
                "22": "弘仁惠之虞",
                "23": "馳弋乎神明之囿",
                "24": "覽觀乎羣臣之有亡",
                "25": "放雉兔",
                "26": "收罝罘",
                "27": "麋鹿芻蕘與百姓共之",
                "28": "蓋所以臻茲也",
                "29": "於是醇洪鬯之德",
                "30": "豐茂世之規",
                "31": "加勞三皇",
                "32": "勖勤五帝",
                "33": "不亦至乎",
                "34": "迺祇莊雍穆之徒",
                "35": "立君臣之節",
                "36": "崇賢聖之業",
                "37": "未皇苑囿之麗",
                "38": "遊獵之靡也",
                "39": "因回軫還衡",
                "40": "背阿房",
                "41": "反未央"
            }
        }
    }
}