{
    "29.23-05": {
        "篇名": "張景陽 雜詩十首·其五",
        "1": {
            "3": {
                "1": "昔我資章甫",
                "2": "聊以適諸越",
                "3": "行行入幽荒",
                "4": "歐駱從祝髮",
                "5": "窮年非所用",
                "6": "此貨將安設",
                "7": "瓴甋夸璵璠",
                "8": "魚目笑明月",
                "9": "不見郢中歌",
                "10": "能否居然別",
                "11": "陽春無和者",
                "12": "巴人皆下節",
                "13": "流俗多昏迷",
                "14": "此理誰能察"
            }
        }
    }
}