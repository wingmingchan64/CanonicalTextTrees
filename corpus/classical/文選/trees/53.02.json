{
    "53.02": {
        "篇名": "李蕭遠 運命論",
        "1": {
            "3": {
                "1": "夫治亂",
                "2": "運也",
                "3": "窮達",
                "4": "命也",
                "5": "貴賤",
                "6": "時也",
                "7": "故運之將隆",
                "8": "必生聖明之君",
                "9": "聖明之君",
                "10": "必有忠賢之臣",
                "11": "其所以相遇也",
                "12": "不求而自合",
                "13": "其所以相親也",
                "14": "不介而自親",
                "15": "唱之而必和",
                "16": "謀之而必從",
                "17": "道德玄同",
                "18": "曲折合符",
                "19": "得失不能疑其志",
                "20": "讒構不能離其交",
                "21": "然後得成功也",
                "22": "其所以得然者",
                "23": "豈徒人事哉",
                "24": "授之者天也",
                "25": "告之者神也",
                "26": "成之者運也"
            }
        },
        "2": {
            "5": {
                "1": "夫黃河清而聖人生",
                "2": "里社鳴而聖人出",
                "3": "羣龍見而聖人用",
                "4": "故伊尹",
                "5": "有莘氏之媵臣也",
                "6": "而阿衡於商",
                "7": "太公",
                "8": "渭濱之賤老也",
                "9": "而尙父於周",
                "10": "百里奚在虞而虞亡",
                "11": "在秦而秦霸",
                "12": "非不才於虞而才於秦也",
                "13": "張良受黃石之符",
                "14": "誦三略之說",
                "15": "以遊於羣雄",
                "16": "其言也",
                "17": "如以水投石",
                "18": "莫之受也",
                "19": "及其遭漢祖",
                "20": "其言也",
                "21": "如以石投水",
                "22": "莫之逆也",
                "23": "非張良之拙說於陳項",
                "24": "而巧言於沛公也",
                "25": "然則張良之言一也",
                "26": "不識其所以合離",
                "27": "合離之由",
                "28": "神明之道也",
                "29": "故彼四賢者",
                "30": "名載於籙圖",
                "31": "事應乎天人",
                "32": "其可格之賢愚哉",
                "33": "孔子曰",
                "34": "清明在躬",
                "35": "氣志如神",
                "36": "嗜慾將至",
                "37": "有開必先",
                "38": "天降時雨",
                "39": "山川出雲",
                "40": "詩云",
                "41": "惟嶽降神",
                "42": "生甫及申",
                "43": "惟申及甫",
                "44": "惟周之翰",
                "45": "運命之謂也",
                "46": "豈惟興主",
                "47": "亂亡者亦如之焉",
                "48": "幽王之惑襃女也",
                "49": "祅始於夏庭",
                "50": "曹伯陽之獲公孫彊也",
                "51": "徵發於社宮",
                "52": "叔孫豹之暱豎牛也",
                "53": "禍成於庚宗",
                "54": "吉凶成敗",
                "55": "各以數至",
                "56": "咸皆不求而自合",
                "57": "不介而自親矣"
            }
        },
        "3": {
            "7": {
                "1": "昔者",
                "2": "聖人受命河洛曰",
                "3": "以文命者",
                "4": "七九而衰",
                "5": "以武興者",
                "6": "六八而謀",
                "7": "及成王定鼎於郟鄏",
                "8": "卜世三十",
                "9": "卜年七百",
                "10": "天所命也",
                "11": "故自幽厲之間",
                "12": "周道大壞",
                "13": "二霸之後",
                "14": "禮樂陵遲",
                "15": "文薄之敝",
                "16": "漸於靈景",
                "17": "辯詐之僞",
                "18": "成於七國",
                "19": "酷烈之極",
                "20": "積於亡秦",
                "21": "文章之貴",
                "22": "棄於漢祖",
                "23": "雖仲尼至聖",
                "24": "顏冉大賢",
                "25": "揖讓於規矩之內",
                "26": "誾誾於洙",
                "27": "泗之上",
                "28": "不能遏其端",
                "29": "孟軻",
                "30": "孫卿體二希聖",
                "31": "從容正道",
                "32": "不能維其末",
                "33": "天下卒至於溺而不可援",
                "34": "夫以仲尼之才也",
                "35": "而器不周於魯衞",
                "36": "以仲尼之辯也",
                "37": "而言不行於定哀",
                "38": "以仲尼之謙也",
                "39": "而見忌於子西",
                "40": "以仲尼之仁也",
                "41": "而取讎於桓魋",
                "42": "以仲尼之智也",
                "43": "而屈厄於陳蔡",
                "44": "以仲尼之行也",
                "45": "而招毀於叔孫",
                "46": "夫道足以濟天下",
                "47": "而不得貴於人",
                "48": "言足以經萬世",
                "49": "而不見信於時",
                "50": "行足以應神明",
                "51": "而不能彌綸於俗",
                "52": "應聘七十國",
                "53": "而不一獲其主",
                "54": "驅驟於蠻夏之域",
                "55": "屈辱於公卿之門",
                "56": "其不遇也如此",
                "57": "及其孫子思",
                "58": "希聖備體",
                "59": "而未之至",
                "60": "封己養高",
                "61": "勢動人主",
                "62": "其所遊歷諸侯",
                "63": "莫不結駟而造門",
                "64": "雖造門猶有不得賓者焉",
                "65": "其徒子夏",
                "66": "升堂而未入於室者也",
                "67": "退老於家",
                "68": "魏文候師之",
                "69": "西河之人肅然歸德",
                "70": "比之於夫子而莫敢間其言",
                "71": "故曰",
                "72": "治亂",
                "73": "運也",
                "74": "窮達",
                "75": "命也",
                "76": "貴賤",
                "77": "時也",
                "78": "而後之君子",
                "79": "區區於一主",
                "80": "歎息於一朝",
                "81": "屈原以之沈湘",
                "82": "賈誼以之發憤",
                "83": "不亦過乎"
            }
        },
        "4": {
            "9": {
                "1": "然則聖人所以爲聖者",
                "2": "蓋在乎樂天知命矣",
                "3": "故遇之而不怨",
                "4": "居之而不疑也",
                "5": "其身可抑",
                "6": "而道不可屈",
                "7": "其位可排",
                "8": "而名不可奪",
                "9": "譬如水也",
                "10": "通之斯爲川焉",
                "11": "塞之斯爲淵焉",
                "12": "升之於雲則雨施",
                "13": "沈之於地則土潤",
                "14": "體清以洗物",
                "15": "不亂於濁",
                "16": "受濁以濟物",
                "17": "不傷於清",
                "18": "是以聖人處窮達如一也",
                "19": "夫忠直之迕於主",
                "20": "獨立之負於俗",
                "21": "理勢然也",
                "22": "故木秀於林",
                "23": "風必摧之",
                "24": "堆出於岸",
                "25": "流必湍之",
                "26": "行高於人",
                "27": "眾必非之",
                "28": "前監不遠",
                "29": "覆車繼軌",
                "30": "然而志士仁人",
                "31": "猶蹈之而弗悔",
                "32": "操之而弗失",
                "33": "何哉",
                "34": "將以遂志而成名也",
                "35": "求遂其志",
                "36": "而冒風波於險塗",
                "37": "求成其名",
                "38": "而歷謗議於當時",
                "39": "彼所以處之",
                "40": "蓋有筭矣",
                "41": "子夏曰",
                "42": "死生有命",
                "43": "富貴在天故道之將行也",
                "44": "命之將貴也",
                "45": "則伊尹呂尙之興於商周",
                "46": "百里子房之用於秦漢",
                "47": "不求而自得",
                "48": "不徼而自遇矣",
                "49": "道之將廢也",
                "50": "命之將賤也",
                "51": "豈獨君子恥之而弗爲乎",
                "52": "蓋亦知爲之而弗得矣",
                "53": "凡希世苟合之士",
                "54": "蘧蒢戚施之人",
                "55": "俛仰尊貴之顏",
                "56": "逶迆勢利之間",
                "57": "杜預左氏傳注曰",
                "58": "俛仰",
                "59": "伏也",
                "60": "鄭玄毛詩箋曰",
                "61": "蘧蒢觀人顏色而爲辭",
                "62": "故不能俯",
                "63": "又曰",
                "64": "戚施下人以色",
                "65": "故不能仰",
                "66": "史記曰蘇秦㛐逶迆而謝曰",
                "67": "見季子位高金多也",
                "68": "意無是非",
                "69": "讚之如流",
                "70": "言無可否",
                "71": "應之如響",
                "72": "以闚看爲精神",
                "73": "以向背爲變通",
                "74": "勢之所集",
                "75": "從之如歸市",
                "76": "勢之所去",
                "77": "棄之如脫遺",
                "78": "其言曰",
                "79": "名與身孰親也",
                "80": "得與失孰賢也",
                "81": "榮與辱孰珍也",
                "82": "故遂絜其衣服",
                "83": "矜其車徒",
                "84": "冒其貨賄",
                "85": "淫其聲色",
                "86": "脈脈然自以爲得矣",
                "87": "蓋見龍逢比干之亡其身",
                "88": "而不惟飛廉惡來之滅其族也",
                "89": "蓋知伍子胥之屬鏤於吳",
                "90": "而不戒費無忌之誅夷於楚也",
                "91": "蓋譏汲黯之白首於主爵",
                "92": "而不懲張湯牛車之禍也",
                "93": "蓋笑蕭望之跋躓於前",
                "94": "而不懼石顯之絞縊於後也"
            }
        },
        "5": {
            "11": {
                "1": "故夫達者之筭也",
                "2": "亦各有盡矣",
                "3": "曰",
                "4": "凡人之所以奔競於富貴",
                "5": "何爲者哉",
                "6": "若夫立德必須貴乎",
                "7": "則幽厲之爲天子",
                "8": "不如仲尼之爲陪臣也",
                "9": "必須勢乎",
                "10": "則王莽董賢之爲三公",
                "11": "不如楊雄仲舒之閴其門也",
                "12": "必須富乎",
                "13": "則齊景之千駟",
                "14": "不如顏回原憲之約其身也",
                "15": "其爲實乎",
                "16": "則執杓而飲河者",
                "17": "不過滿腹",
                "18": "棄室而灑雨者",
                "19": "不過濡身",
                "20": "過此以往",
                "21": "弗能受也",
                "22": "其爲名乎",
                "23": "則善惡書於史冊",
                "24": "毀譽流於千載",
                "25": "賞罰懸於天道",
                "26": "吉凶灼乎鬼神",
                "27": "固可畏也",
                "28": "將以娛耳目",
                "29": "樂心意乎",
                "30": "譬命駕而遊五都之市",
                "31": "則天下之貨畢陳矣",
                "32": "褰裳而涉汶陽之丘",
                "33": "則天下之稼如雲矣",
                "34": "椎紒而守敖庾海陵之倉",
                "35": "則山坻之積在前矣",
                "36": "扱衽而登鍾山藍田之上",
                "37": "則夜光璵璠之珍可觀矣",
                "38": "夫如是也",
                "39": "爲物甚眾",
                "40": "爲己甚寡",
                "41": "不愛其身",
                "42": "而嗇其神",
                "43": "風驚塵起",
                "44": "散而不止",
                "45": "六疾待其前",
                "46": "五刑隨其後",
                "47": "利害生其左",
                "48": "攻奪出其右",
                "49": "而自以爲見身名之親疏",
                "50": "分榮辱之客主哉",
                "51": "天地之大德曰生",
                "52": "聖人之大寶曰位",
                "53": "何以守位曰仁",
                "54": "何以正人曰義",
                "55": "故古之王者",
                "56": "蓋以一人治天下",
                "57": "不以天下奉一人也",
                "58": "古之仕者",
                "59": "蓋以官行其義",
                "60": "不以利冒其官也",
                "61": "古之君子",
                "62": "蓋恥得之而弗能治也",
                "63": "不恥能治而弗得也",
                "64": "原乎天人之性",
                "65": "核乎邪正之分",
                "66": "權乎禍福之門",
                "67": "終乎榮辱之筭",
                "68": "其昭然矣",
                "69": "故君子舍彼取此",
                "70": "若夫出處不違其時",
                "71": "默語不失其人",
                "72": "天動星迴而辰極猶居其所",
                "73": "璣旋輪轉",
                "74": "而衡軸猶執其中",
                "75": "旣明且哲",
                "76": "以保其身",
                "77": "貽厥孫謀",
                "78": "以燕翼子者",
                "79": "昔吾先友",
                "80": "嘗從事於斯矣"
            }
        }
    }
}