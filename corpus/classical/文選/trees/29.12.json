{
    "29.12": {
        "篇名": "傅休奕 雜詩",
        "1": {
            "3": {
                "1": "志士惜日短",
                "2": "愁人知夜長",
                "3": "攝衣步前庭",
                "4": "仰觀南雁翔",
                "5": "玄景隨形運",
                "6": "流響歸空房",
                "7": "清風何飄颻",
                "8": "微月出西方",
                "9": "繁星依青天",
                "10": "列宿自成行",
                "11": "蟬鳴高樹間",
                "12": "野鳥號東箱",
                "13": "纖雲時髣彿",
                "14": "渥露霑我裳",
                "15": "良時無停景",
                "16": "北斗忽低昂",
                "17": "常恐寒節至",
                "18": "凝氣結爲霜",
                "19": "落葉隨風摧",
                "20": "一絕如流光"
            }
        }
    }
