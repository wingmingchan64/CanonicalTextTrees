{
    "04.01": {
        "篇名": "張平子 南都賦",
        "1": {
            "3": {
                "1": "於顯樂都",
                "2": "旣麗且康",
                "3": "陪京之南",
                "4": "居漢之陽",
                "5": "割周楚之豐壤",
                "6": "跨荊豫而爲疆",
                "7": "體爽塏以閑敞",
                "8": "紛郁郁其難詳"
            }
        },
        "2": {
            "5": {
                "1": "爾其地勢",
                "2": "則武闕關其西",
                "3": "桐柏揭其東",
                "4": "流滄浪而爲隍",
                "5": "廓方城而爲墉",
                "6": "湯谷涌其後",
                "7": "淯水盪其胸",
                "8": "推淮引湍",
                "9": "三方是通"
            }
        },
        "3": {
            "7": {
                "1": "其寶利珎怪",
                "2": "則金彩玉璞",
                "3": "隨珠夜光",
                "4": "銅錫鉛鍇",
                "5": "赭堊流黃",
                "6": "綠碧紫英",
                "7": "青雘丹粟",
                "8": "太一餘糧",
                "9": "中黃瑴玉",
                "10": "松子神陂",
                "11": "赤靈解角",
                "12": "耕父揚光於清泠之淵",
                "13": "遊女弄珠於漢皋之曲"
            }
        },
        "4": {
            "9": {
                "1": "其山則崆𡹕嶱嵑",
                "2": "嵣㟐嶚剌",
                "3": "岝㟯㠑嵬",
                "4": "𡼲巇屹𡿖",
                "5": "幽谷嶜岑",
                "6": "夏含霜雪",
                "7": "或㟒嶙而纚連",
                "8": "或豁爾而中絕",
                "9": "鞠巍巍其隱天",
                "10": "俯而觀乎雲霓"
            }
        },
        "5": {
            "11": {
                "1": "若夫天封大狐",
                "2": "列仙之陬",
                "3": "上平衍而曠蕩",
                "4": "下蒙籠而崎嶇",
                "5": "坂坻嶻𡾲而成甗",
                "6": "谿壑錯繆而盤紆",
                "7": "芝房菌蠢生其隈",
                "8": "玉膏滵溢流其隅",
                "9": "崑崙無以奓",
                "10": "閬風不能踰"
            }
        },
        "6": {
            "13": {
                "1": "其木則檉松楔㮨",
                "2": "槾柏杻橿",
                "3": "楓柙櫨櫪",
                "4": "帝女之桑",
                "5": "楈枒栟櫚",
                "6": "柍柘檍檀",
                "7": "結根竦本",
                "8": "垂條蟬媛",
                "9": "布綠葉之萋萋",
                "10": "敷華蕊之蓑蓑",
                "11": "玄雲合而重陰",
                "12": "谷風起而增哀",
                "13": "攢立叢騈",
                "14": "青冥䀒瞑",
                "15": "杳藹蓊鬱於谷底",
                "16": "森䔿䔿而刺天",
                "17": "虎豹黃熊遊其下",
                "18": "豰玃猱㹶戲其巓",
                "19": "鸞鸑鵷雛翔其上",
                "20": "騰猿飛蠝栖其間",
                "21": "其竹則籦籠䈽篾",
                "22": "篠簳箛箠",
                "23": "縁延坻阪",
                "24": "澶漫陸離",
                "25": "阿郍蓊茸",
                "26": "風靡雲披"
            }
        },
        "7": {
            "15": {
                "1": "爾其川瀆",
                "2": "則滍澧𤄶濜",
                "3": "發源巖穴",
                "4": "潛㕎洞出",
                "5": "沒滑瀎潏",
                "6": "布濩漫汗",
                "7": "漭沆洋溢",
                "8": "總括趨欱",
                "9": "箭馳風疾",
                "10": "流湍投濈",
                "11": "砏汃輣軋",
                "12": "長輸遠逝",
                "13": "漻淚淢汩",
                "14": "其水蟲則有蠳龜鳴蛇",
                "15": "潛龍伏螭",
                "16": "鱏鱣鰅鱅",
                "17": "黿鼉鮫𩽌",
                "18": "巨蜯函珠",
                "19": "駮瑕委蛇"
            }
        },
        "8": {
            "17": {
                "1": "於其陂澤",
                "2": "則有鉗盧玉池",
                "3": "赭陽東陂",
                "4": "貯水渟洿",
                "5": "亙望無涯",
                "6": "其草則藨苧薠莞",
                "7": "蔣蒲蒹葭",
                "8": "藻茆菱芡",
                "9": "芙蓉含華",
                "10": "從風發榮",
                "11": "斐披芬葩",
                "12": "其鳥則有鴛鴦鵠鷖",
                "13": "鴻鴇鴐鵝",
                "14": "𪃈鶂鸊鶙",
                "15": "鷫鷞鵾鸕",
                "16": "嚶嚶和鳴",
                "17": "澹淡隨波"
            }
        },
        "9": {
            "19": {
                "1": "其水則開竇灑流",
                "2": "浸彼稻田",
                "3": "溝澮脈連",
                "4": "隄塍相輑",
                "5": "朝雲不興",
                "6": "而潢潦獨臻",
                "7": "決渫則暵",
                "8": "爲漑爲陸",
                "9": "冬稌夏穱",
                "10": "隨時代熟",
                "11": "其原野則有桑漆麻苧",
                "12": "菽麥稷黍",
                "13": "百穀蕃廡",
                "14": "翼翼與與"
            }
        },
        "10": {
            "21": {
                "1": "若其園圃",
                "2": "則有蓼蕺蘘荷",
                "3": "藷蔗薑䪤",
                "4": "菥蓂芋瓜",
                "5": "乃有櫻梅山柿",
                "6": "侯桃梨栗",
                "7": "梬棗若留",
                "8": "穰橙鄧橘",
                "9": "其香草則有薜荔蕙若",
                "10": "薇蕪蓀萇",
                "11": "晻曖蓊蔚",
                "12": "含芬吐芳"
            }
        },
        "11": {
            "23": {
                "1": "若其廚膳",
                "2": "則有華薌重秬",
                "3": "滍皋香秔",
                "4": "歸雁鳴鵽",
                "5": "黃稻鱻魚",
                "6": "以爲芍藥",
                "7": "酸甜滋味",
                "8": "百種千名",
                "9": "春卵夏筍",
                "10": "秋韭冬菁",
                "11": "蘇蔱紫薑",
                "12": "拂徹羶腥",
                "13": "酒則九醞甘醴",
                "14": "十旬兼清",
                "15": "醪敷徑寸",
                "16": "浮蟻若蓱",
                "17": "其甘不爽",
                "18": "醉而不酲"
            }
        },
        "12": {
            "25": {
                "1": "及其糺宗綏族",
                "2": "禴祠蒸嘗",
                "3": "以速遠朋",
                "4": "嘉賓是將",
                "5": "揖讓而升",
                "6": "宴於蘭堂",
                "7": "珍羞琅玕",
                "8": "充溢圓方",
                "9": "琢琱狎獵",
                "10": "金銀琳琅",
                "11": "侍者蠱媚",
                "12": "巾㡚鮮明",
                "13": "被服雜錯",
                "14": "履躡華英",
                "15": "儇才齊敏",
                "16": "受爵傳觴",
                "17": "獻酬旣交",
                "18": "率禮無違",
                "19": "彈琴擫籥",
                "20": "流風徘徊",
                "21": "清角發徵",
                "22": "聽者增哀",
                "23": "客賦醉言歸",
                "24": "主稱露未晞",
                "25": "接歡宴於日夜",
                "26": "終愷樂之令儀"
            }
        },
        "13": {
            "27": {
                "1": "於是暮春之禊",
                "2": "元巳之辰",
                "3": "方軌齊軫",
                "4": "祓於陽瀕",
                "5": "朱帷連網",
                "6": "曜野映雲",
                "7": "男女姣服",
                "8": "駱驛繽紛",
                "9": "致飾程蠱",
                "10": "偠紹便娟",
                "11": "微眺流睇",
                "12": "蛾眉連卷",
                "13": "於是齊僮唱兮列趙女",
                "14": "坐南歌兮起鄭儛",
                "15": "白鶴飛兮繭曳緒",
                "16": "修袖繚繞而滿庭",
                "17": "羅襪躡蹀而容與",
                "18": "翩緜緜其若絕",
                "19": "眩將墜而復舉",
                "20": "翹遙遷延",
                "21": "䠥躠蹁躚",
                "22": "結九秋之增傷",
                "23": "怨西荊之折盤",
                "24": "彈箏吹笙",
                "25": "更爲新聲",
                "26": "寡婦悲吟",
                "27": "鵾雞哀鳴",
                "28": "坐者悽欷",
                "29": "蕩魂傷精"
            }
        },
        "14": {
            "29": {
                "1": "於是羣士放逐",
                "2": "馳乎沙場",
                "3": "騄驥齊鑣",
                "4": "黃間機張",
                "5": "足逸驚飇",
                "6": "鏃析毫芒",
                "7": "俯貫魴鱮",
                "8": "仰落雙鶬",
                "9": "魚不及竄",
                "10": "鳥不暇翔",
                "11": "爾乃撫輕舟兮浮清池",
                "12": "亂北渚兮揭南涯",
                "13": "汰瀺灂兮船容裔",
                "14": "陽侯澆兮掩鳧鷖",
                "15": "追水豹兮鞭蝄蜽",
                "16": "憚夔龍兮怖蛟螭"
            }
        },
        "15": {
            "31": {
                "1": "於是日將逮昏",
                "2": "樂者未荒",
                "3": "收歡命駕",
                "4": "分背迴塘",
                "5": "車雷震而風厲",
                "6": "馬鹿超而龍驤",
                "7": "夕暮言歸",
                "8": "其樂難忘",
                "9": "此乃遊觀之好",
                "10": "耳目之娛",
                "11": "未睹其美者",
                "12": "焉足稱舉"
            }
        },
        "16": {
            "33": {
                "1": "夫南陽者",
                "2": "眞所謂漢之舊都者也",
                "3": "遠世則劉后甘厥龍醢",
                "4": "視魯縣而來遷",
                "5": "奉先帝而追孝",
                "6": "立唐祀乎堯山",
                "7": "固靈根於夏葉",
                "8": "終三代而始蕃",
                "9": "非純德之宏圖",
                "10": "孰能揆而處旃"
            }
        },
        "17": {
            "35": {
                "1": "近則考侯思故",
                "2": "匪居匪寧",
                "3": "穢長沙之無樂",
                "4": "歷江湘而北征",
                "5": "曜朱光於白水",
                "6": "會九世而飛榮",
                "7": "察茲邦之神偉",
                "8": "啟天心而寤靈"
            }
        },
        "18": {
            "37": {
                "1": "於其宮室",
                "2": "則有園廬舊宅",
                "3": "隆崇崔嵬",
                "4": "御房穆以華麗",
                "5": "連閣煥其相徽",
                "6": "聖皇之所逍遙",
                "7": "靈祇之所保綏",
                "8": "章陵鬱以青蔥",
                "9": "清廟肅以微微",
                "10": "皇祖歆而降福",
                "11": "彌萬祀而無衰",
                "12": "帝王臧其擅美",
                "13": "詠南音以顧懷",
                "14": "且其君子",
                "15": "弘懿明叡",
                "16": "允恭溫良",
                "17": "容止可則",
                "18": "出言有章",
                "19": "進退屈伸",
                "20": "與時抑揚"
            }
        },
        "19": {
            "39": {
                "1": "方今天地之睢剌",
                "2": "帝亂其政",
                "3": "豺虎肆虐",
                "4": "眞人革命之秋也",
                "5": "爾其則有謀臣武將",
                "6": "皆能攫戾執猛",
                "7": "破堅摧剛",
                "8": "排揵陷扃",
                "9": "蹵蹈咸陽",
                "10": "高祖階其塗",
                "11": "光武攬其英",
                "12": "是以關門反距",
                "13": "漢德久長",
                "14": "及其去危乘安",
                "15": "視人用遷",
                "16": "周召之儔",
                "17": "據鼎足焉",
                "18": "以庀王職",
                "19": "縉紳之倫",
                "20": "經綸訓典",
                "21": "賦納以言",
                "22": "是以朝無闕政",
                "23": "風烈昭宣也",
                "24": "於是乎鯢齒眉壽",
                "25": "鮐背之叟",
                "26": "皤皤然被黃髮者",
                "27": "喟然相與歌曰",
                "28": "望翠華兮葳蕤",
                "29": "建太常兮裶裶",
                "30": "駟飛龍兮騤騤",
                "31": "振和鸞兮京師",
                "32": "總萬乘兮徘徊",
                "33": "按平路兮來歸",
                "34": "豈不思天子南巡之辭者哉",
                "35": "遂作頌曰"
            }
        },
        "20": {
            "41": {
                "1": "皇祖止焉",
                "2": "光武起焉",
                "3": "據彼河洛",
                "4": "統四海焉",
                "5": "本枝百世",
                "6": "位天子焉",
                "7": "永世克孝",
                "8": "懷桑梓焉",
                "9": "眞人南巡",
                "10": "覩舊里焉"
            }
        }
    }
}