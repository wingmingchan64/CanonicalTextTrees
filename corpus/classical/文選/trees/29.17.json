{
    "29.17": {
        "篇名": "曹顏遠 感舊詩",
        "1": {
            "3": {
                "1": "富貴他人合",
                "2": "貧賤親戚離",
                "3": "廉藺門易軌",
                "4": "田竇相奪移",
                "5": "晨風集茂林",
                "6": "栖鳥去枯枝",
                "7": "今我唯困蒙",
                "8": "郡士所背馳",
                "9": "鄕人敦懿義",
                "10": "濟濟蔭光儀",
                "11": "對賓頌有客",
                "12": "舉觴詠露斯",
                "13": "臨樂何所歎",
                "14": "素絲與路歧"
            }
        }
