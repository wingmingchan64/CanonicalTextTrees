{
    "30.28-06": {
        "篇名": "陸士衡 擬古詩十二首·擬明月何皎皎",
        "1": {
            "3": {
                "1": "安寢北堂上",
                "2": "明月入我牖",
                "3": "照之有餘暉",
                "4": "攬之不盈手",
                "5": "涼風繞曲房",
                "6": "寒蟬鳴高柳",
                "7": "踟躕感節物",
                "8": "我行永已久",
                "9": "遊宦會無成",
                "10": "離思難常守"
            }
        }
    }
}