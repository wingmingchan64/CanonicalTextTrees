{
    "44.03": {
        "篇名": "陳孔璋 檄吳將校部曲文",
        "1": {
            "3": {
                "1": "年月朔日",
                "2": "子尙書令彧",
                "3": "告江東諸將校部曲及孫權宗親中外",
                "4": "蓋聞禍福無門",
                "5": "惟人所召",
                "6": "夫見機而作",
                "7": "不處凶危",
                "8": "上聖之明也",
                "9": "臨事制變",
                "10": "困而能通",
                "11": "智者之慮也",
                "12": "漸漬荒沈",
                "13": "往而不反",
                "14": "下愚之蔽也",
                "15": "是以大雅君子",
                "16": "於安思危",
                "17": "以遠咎悔",
                "18": "小人臨禍懷佚",
                "19": "以待死亡",
                "20": "二者之量",
                "21": "不亦殊乎"
            }
        },
        "2": {
            "5": {
                "1": "孫權小子",
                "2": "未辨菽麥",
                "3": "要領不足以膏齊斧",
                "4": "名字不足以洿簡墨",
                "5": "譬猶鷇卵",
                "6": "始生翰毛",
                "7": "而便陸梁放肆",
                "8": "顧行吠主",
                "9": "謂爲舟楫足以距皇威",
                "10": "江湖可以逃靈誅",
                "11": "不知天網設張",
                "12": "以在綱目",
                "13": "爨鑊之魚",
                "14": "期於消爛也",
                "15": "若使水而可恃",
                "16": "則洞庭無三苗之墟",
                "17": "子陽無荊門之敗",
                "18": "朝鮮之壘不刊",
                "19": "南越之旍不拔",
                "20": "昔夫差承闔閭之遠迹",
                "21": "用申胥之訓兵",
                "22": "栖越會稽",
                "23": "可謂強矣",
                "24": "及其抗衡上國",
                "25": "與晉爭長",
                "26": "都城屠於句踐",
                "27": "武卒散於黃池",
                "28": "終於覆滅",
                "29": "身罄越軍",
                "30": "及吳王濞驕恣屈強",
                "31": "猖猾始亂",
                "32": "自以兵強國富",
                "33": "勢陵京城",
                "34": "太尉帥師",
                "35": "甫下滎陽",
                "36": "則七國之軍",
                "37": "瓦解冰冸",
                "38": "濞之罵言未絕於口",
                "39": "而丹徒之刃以陷其胸",
                "40": "何則",
                "41": "天威不可當",
                "42": "而悖逆之罪重也"
            }
        },
        "3": {
            "7": {
                "1": "且江湖之眾",
                "2": "不足恃也",
                "3": "自董卓作亂",
                "4": "以迄於今",
                "5": "將三十載",
                "6": "其間豪桀縱橫",
                "7": "熊據虎跱",
                "8": "強如二袁",
                "9": "勇如呂布",
                "10": "跨州連郡",
                "11": "有威有名",
                "12": "十有餘輩",
                "13": "其餘鋒捍特起",
                "14": "鸇視狼顧",
                "15": "爭爲梟雄者",
                "16": "不可勝數",
                "17": "然皆伏鈇嬰鉞",
                "18": "首腰分離",
                "19": "雲散原燎",
                "20": "罔有孑遺",
                "21": "近者關中諸將",
                "22": "復相合聚",
                "23": "續爲叛亂",
                "24": "阻二華",
                "25": "據河渭",
                "26": "驅率羌胡",
                "27": "齊鋒東向",
                "28": "氣高志遠",
                "29": "似若無敵",
                "30": "丞相秉鉞鷹揚",
                "31": "順風烈火",
                "32": "元戎啟行",
                "33": "未鼓而破",
                "34": "伏尸千萬",
                "35": "流血漂樐",
                "36": "此皆天下所共知也",
                "37": "是後大軍所以臨江而不濟者",
                "38": "以韓約馬超逋逸逬脫",
                "39": "走還涼州",
                "40": "復欲鳴吠",
                "41": "逆賊宋建",
                "42": "僭號河首",
                "43": "同惡相救",
                "44": "並爲脣齒",
                "45": "又鎭南將軍張魯",
                "46": "負固不恭",
                "47": "皆我王誅所當先加",
                "48": "故且觀兵旋旆",
                "49": "復整六師",
                "50": "長驅西征",
                "51": "致天下誅",
                "52": "偏將涉隴",
                "53": "則建約梟夷",
                "54": "旍首萬里",
                "55": "軍入散關",
                "56": "則羣氐率服",
                "57": "王侯豪帥",
                "58": "奔走前驅",
                "59": "進臨漢中",
                "60": "則陽平不守",
                "61": "十萬之師",
                "62": "土崩魚爛",
                "63": "張魯逋竄",
                "64": "走入巴中",
                "65": "懷恩悔過",
                "66": "委質還降",
                "67": "巴夷王朴胡賨邑侯杜濩",
                "68": "各帥種落",
                "69": "共舉巴郡",
                "70": "以奉王職",
                "71": "鉦鼓一動",
                "72": "二方俱定",
                "73": "利盡西海",
                "74": "兵不鈍鋒",
                "75": "若此之事",
                "76": "皆上天威明",
                "77": "社稷神武",
                "78": "非徒人力所能立也"
            }
        },
        "4": {
            "9": {
                "1": "聖朝寬仁覆載",
                "2": "允信允文",
                "3": "大啟爵命",
                "4": "以示四方",
                "5": "魯及胡濩皆享萬戶之封",
                "6": "魯之五子",
                "7": "各受千室之邑",
                "8": "胡濩子弟部曲將校爲列侯將軍已下千有餘人",
                "9": "百姓安堵",
                "10": "四民反業",
                "11": "而建約之屬",
                "12": "皆爲鯨鯢",
                "13": "超之妻孥",
                "14": "焚首金城",
                "15": "父母嬰孩",
                "16": "覆尸許市",
                "17": "非國家鍾禍於彼",
                "18": "降福於此也",
                "19": "逆順之分",
                "20": "不得不然",
                "21": "夫鷙鳥之擊先高",
                "22": "攫鷙之勢也",
                "23": "牧野之威",
                "24": "孟津之退也",
                "25": "今者枳棘剪扞",
                "26": "戎夏以清",
                "27": "萬里肅齊",
                "28": "六師無事",
                "29": "故大舉天師百萬之眾",
                "30": "與匈奴南單於呼完廚及六郡烏桓丁令屠各",
                "31": "湟中羌僰",
                "32": "霆奮席卷",
                "33": "自壽春而南",
                "34": "又使征西將軍夏侯淵等",
                "35": "率精甲五萬",
                "36": "及武都氐羌",
                "37": "巴漢銳卒",
                "38": "南臨汶江",
                "39": "搤據庸蜀",
                "40": "江夏襄陽諸軍",
                "41": "橫截湘沅",
                "42": "以臨豫章",
                "43": "樓船橫海之師",
                "44": "直指吳會",
                "45": "萬里克期",
                "46": "五道並入",
                "47": "權之期命",
                "48": "於是至矣"
            }
        },
        "5": {
            "11": {
                "1": "丞相銜奉國威",
                "2": "爲民除害",
                "3": "元惡大憝",
                "4": "必當梟夷",
                "5": "至於枝附葉從",
                "6": "皆非詔書所特禽疾",
                "7": "故每破滅強敵",
                "8": "未嘗不務在先降後誅",
                "9": "拔將取才",
                "10": "各盡其用",
                "11": "是以立功之士",
                "12": "莫不翹足引領",
                "13": "望風響應",
                "14": "昔袁術僭逆",
                "15": "王誅將加",
                "16": "則廬江太守劉勳先舉其郡",
                "17": "還歸國家",
                "18": "呂布作亂",
                "19": "師臨下邳",
                "20": "張遼侯成",
                "21": "率眾出降",
                "22": "還討眭固",
                "23": "薛洪樛尙",
                "24": "開城就化",
                "25": "官渡之役",
                "26": "則張郃高奐舉事立功",
                "27": "後討袁尙",
                "28": "則都督將軍馬延",
                "29": "故豫州刺史陰夔",
                "30": "射聲校尉郭昭臨陣來降",
                "31": "圍守鄴城",
                "32": "則將軍蘇遊反爲內應",
                "33": "審配兄子開門入兵",
                "34": "旣誅袁譚",
                "35": "則幽州大將焦觸攻逐袁熙",
                "36": "舉事來服",
                "37": "凡此之輩數百人",
                "38": "皆忠壯果烈",
                "39": "有智有仁",
                "40": "悉與丞相參圖畫策",
                "41": "折衝討難",
                "42": "芟敵搴旗",
                "43": "靜安海內",
                "44": "豈輕舉措也哉",
                "45": "誠乃天啟其心",
                "46": "計深慮遠",
                "47": "審邪正之津",
                "48": "明可否之分",
                "49": "勇不虛死",
                "50": "節不苟立",
                "51": "屈伸變化",
                "52": "唯道所存",
                "53": "故乃建丘山之功",
                "54": "享不訾之祿",
                "55": "朝爲仇虜",
                "56": "夕爲上將",
                "57": "所謂臨難知變",
                "58": "轉禍爲福者也",
                "59": "若夫說誘甘言",
                "60": "懷寶小惠",
                "61": "泥滯苟且",
                "62": "沒而不覺",
                "63": "隨波漂流",
                "64": "與熛俱滅者",
                "65": "亦甚眾多",
                "66": "吉凶得失",
                "67": "豈不哀哉",
                "68": "昔歲軍在漢中",
                "69": "東西懸隔",
                "70": "合肥遺守",
                "71": "不滿五千",
                "72": "權親以數萬之眾",
                "73": "破敗奔走",
                "74": "今乃欲當禦雷霆",
                "75": "難以冀矣"
            }
        },
        "6": {
            "13": {
                "1": "夫天道助順",
                "2": "人道助信",
                "3": "事上之謂義",
                "4": "親親之謂仁",
                "5": "盛孝章",
                "6": "君也",
                "7": "而權誅之",
                "8": "孫輔",
                "9": "兄也",
                "10": "而權殺之",
                "11": "賊義殘仁",
                "12": "莫斯爲甚",
                "13": "乃神靈之逋罪",
                "14": "下民所同讎",
                "15": "辜讎之人",
                "16": "謂之凶賊",
                "17": "是故伊摯去夏",
                "18": "不爲傷德",
                "19": "飛廉死紂",
                "20": "不可謂賢",
                "21": "何者",
                "22": "去就之道",
                "23": "各有宜也",
                "24": "丞相深惟江東舊德名臣",
                "25": "多在載籍",
                "26": "近魏叔英秀出高峙",
                "27": "著名海內",
                "28": "虞文繡砥礪清節",
                "29": "耽學好古",
                "30": "周泰明當世俊彥",
                "31": "德行修明",
                "32": "皆宜膺受多福",
                "33": "保乂子孫",
                "34": "而周盛門戶無辜被戮",
                "35": "遺類流離",
                "36": "湮沒林莽",
                "37": "言之可爲愴然",
                "38": "聞魏周榮虞仲翔各紹堂構",
                "39": "能負析薪",
                "40": "及吳諸顧陸舊族長者",
                "41": "世有高位",
                "42": "當報漢德",
                "43": "顯祖揚名",
                "44": "及諸將校孫權婚親",
                "45": "皆我國家良寶利器",
                "46": "而並見驅迮",
                "47": "雨絕於天",
                "48": "有斧無柯",
                "49": "何以自濟",
                "50": "相隨顚沒",
                "51": "不亦哀乎",
                "52": "蓋鳳鳴高岡以遠罻羅",
                "53": "賢聖之德也",
                "54": "鸋鴃之鳥巢於葦苕",
                "55": "苕折子破",
                "56": "下愚之惑也",
                "57": "韓詩曰",
                "58": "鴟鴞",
                "59": "旣取我子",
                "60": "無毀我室",
                "61": "鴟鴞",
                "62": "鸋鴃",
                "63": "鳥名也",
                "64": "鴟鴞所以愛養其子者",
                "65": "適以病之",
                "66": "愛憐養其子者",
                "67": "謂堅固其窠巢",
                "68": "病之者",
                "69": "謂不知託於大樹茂枝",
                "70": "反敷之葦䓟",
                "71": "風至",
                "72": "䓟折巢覆",
                "73": "有子則死",
                "74": "有卵則破",
                "75": "是其病也",
                "76": "字林曰",
                "77": "鸋鴃",
                "78": "鴞也",
                "79": "上乃丁切",
                "80": "下古穴切",
                "81": "廣雅曰",
                "82": "鸋鴃",
                "83": "工雀也",
                "84": "荀卿子曰",
                "85": "南方鳥名蒙鳩",
                "86": "爲巢",
                "87": "編之以髮",
                "88": "繫之葦苕",
                "89": "苕折卵破",
                "90": "巢非不牢",
                "91": "所繫之弱也",
                "92": "說文曰",
                "93": "葦",
                "94": "大葭也",
                "95": "苕與䓟同",
                "96": "今江東之地",
                "97": "無異葦苕",
                "98": "諸賢處之",
                "99": "信亦危矣",
                "100": "聖朝開弘曠蕩",
                "101": "重惜民命",
                "102": "誅在一人",
                "103": "與眾無忌",
                "104": "故設非常之賞",
                "105": "以待非常之功",
                "106": "乃霸夫烈士奮命之良時也",
                "107": "可不勉乎",
                "108": "若能翻然大舉",
                "109": "建立元勳",
                "110": "以應顯祿",
                "111": "福之上也",
                "112": "如其未能",
                "113": "笇量大小",
                "114": "以存易亡",
                "115": "亦其次也",
                "116": "夫係蹄在足",
                "117": "則猛虎絕其蹯",
                "118": "蝮蛇在手",
                "119": "則壯士斷其節",
                "120": "何則",
                "121": "以其所全者重",
                "122": "以其所棄者輕",
                "123": "若乃樂禍懷寧",
                "124": "迷而忘復",
                "125": "闇大雅之所保",
                "126": "背先賢之去就",
                "127": "忽朝陽之安",
                "128": "甘折苕之末",
                "129": "日忘一日",
                "130": "以至覆沒",
                "131": "大兵一放",
                "132": "玉石俱碎",
                "133": "雖欲救之",
                "134": "亦無及已",
                "135": "故令往購募爵賞科條如左",
                "136": "檄到詳思至言",
                "137": "如詔律令"
            }
        }
    }
}