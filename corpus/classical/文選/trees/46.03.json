{
    "46.03": {
        "篇名": "王元長 三月三日曲水詩序",
        "1": {
            "3": {
                "1": "臣聞出豫爲象",
                "2": "鈞天之樂張焉",
                "3": "時乘旣位",
                "4": "御氣之駕翔焉",
                "5": "是以得一奉宸",
                "6": "逍遙襄城之域",
                "7": "體元則大",
                "8": "悵望姑射之阿",
                "9": "然窅眇寂寥",
                "10": "其獨適者已",
                "11": "至如夏后兩龍",
                "12": "載驅璿臺之上",
                "13": "穆滿八駿",
                "14": "如舞瑤水之陰",
                "15": "亦有饗云",
                "16": "固不與萬民共也"
            }
        },
        "2": {
            "5": {
                "1": "我大齊之握機創歷",
                "2": "誕命建家",
                "3": "接禮貳宮",
                "4": "考庸太室",
                "5": "幽明獻期",
                "6": "雷風通饗",
                "7": "昭華之珍旣徙",
                "8": "延喜之玉攸歸",
                "9": "革宋受天",
                "10": "保生萬國",
                "11": "度邑靜鹿丘之歎",
                "12": "遷鼎息大坰之慚",
                "13": "紹清和於帝猷",
                "14": "聯顯懿於王表",
                "15": "駿發開其遠祥",
                "16": "定爾固其洪業",
                "17": "皇帝體膺上聖",
                "18": "運鍾下武",
                "19": "冠五行之秀氣",
                "20": "邁三代之英風",
                "21": "昭章雲漢",
                "22": "暉麗日月",
                "23": "牢籠天地",
                "24": "彈壓山川",
                "25": "設神理以景俗",
                "26": "敷文化以柔遠",
                "27": "澤普汜而無私",
                "28": "法含弘而不殺",
                "29": "猶且具明廢寢",
                "30": "昃晷忘餐",
                "31": "念負重於春冰",
                "32": "懷御奔於秋駕",
                "33": "可謂巍巍弗與",
                "34": "蕩蕩誰名",
                "35": "秉靈圖而非泰",
                "36": "涉孟門其何嶮",
                "37": "儲后睿哲在躬",
                "38": "妙善居質",
                "39": "內積和順",
                "40": "外發英華",
                "41": "斧藻至德",
                "42": "琢磨令範",
                "43": "言炳丹青",
                "44": "道潤金璧",
                "45": "出龍樓而問豎",
                "46": "入虎闈而齒胄",
                "47": "愛敬盡於一人",
                "48": "光耀究於四海",
                "49": "若夫族茂麟趾",
                "50": "宗固盤石",
                "51": "跨掩昌姬",
                "52": "韜軼炎漢",
                "53": "元宰比肩於尙父",
                "54": "中鉉繼踵乎周南",
                "55": "分陝流勿剪之歡",
                "56": "來仕允克施之譽",
                "57": "莫不如珪如璋",
                "58": "令聞令望",
                "59": "朱茀斯皇",
                "60": "室家君王者也"
            }
        },
        "3": {
            "7": {
                "1": "本枝之盛如此",
                "2": "稽古之政如彼",
                "3": "用能免羣生於湯火",
                "4": "納百姓於休和",
                "5": "草萊樂業",
                "6": "守屛稱事",
                "7": "引鏡皆明目",
                "8": "臨池無洗耳",
                "9": "沈冥之怨旣缺",
                "10": "薖軸之疾已消",
                "11": "興廉舉孝",
                "12": "歲時於外府",
                "13": "署行議年",
                "14": "日夕於中甸",
                "15": "協律摠章之司",
                "16": "厚倫正俗",
                "17": "崇文成均之職",
                "18": "導德齊禮",
                "19": "挈壺宣夜",
                "20": "辯氣朔於靈臺",
                "21": "書笏珥彤",
                "22": "紀言事於仙室",
                "23": "褰帷斷裳",
                "24": "危冠空履之吏",
                "25": "彯搖武猛",
                "26": "扛鼎揭旗之士",
                "27": "勤卹民隱",
                "28": "糾逖王慝",
                "29": "射集隼於高墉",
                "30": "繳大風於長隧",
                "31": "不仁者遠",
                "32": "惟道斯行",
                "33": "讒莠蔑聞",
                "34": "攘爭掩息",
                "35": "稀鳴桴於砥路",
                "36": "鞠茂草於圓扉",
                "37": "耆年闕市井之遊",
                "38": "稚齒豐車馬之好",
                "39": "宮鄰昭泰",
                "40": "荒憬清夷",
                "41": "侮食來王",
                "42": "左言入侍",
                "43": "離身反踵之君",
                "44": "髽首貫胸之長",
                "45": "屈膝厥角",
                "46": "請受纓縻"
            }
        },
        "4": {
            "9": {
                "1": "文鉞碧砮之琛",
                "2": "奇幹善芳之賦",
                "3": "紈牛露犬之玩",
                "4": "乘黃茲白之駟",
                "5": "盈衍儲邸",
                "6": "充仞郊虞",
                "7": "匭牘相尋",
                "8": "鞮譯無曠",
                "9": "一尉候於西東",
                "10": "合車書於南北",
                "11": "暢轂埋轔轔之轍",
                "12": "綏旍卷悠悠之旆",
                "13": "四方無拂",
                "14": "五戎不距",
                "15": "偃革辭軒",
                "16": "銷金罷刃",
                "17": "天瑞降",
                "18": "地符升",
                "19": "澤馬來",
                "20": "器車出",
                "21": "紫脫華",
                "22": "朱英秀",
                "23": "佞枝植",
                "24": "歷草孳",
                "25": "雲潤星暉",
                "26": "風揚月至",
                "27": "江海呈象",
                "28": "龜龍載文",
                "29": "方握河沈璧",
                "30": "封山紀石",
                "31": "邁三五而不追",
                "32": "踐八九之遙迹",
                "33": "功旣成矣",
                "34": "世旣貞矣",
                "35": "信可以優遊暇豫",
                "36": "作樂崇德者歟﹖"
            }
        },
        "5": {
            "11": {
                "1": "於時青鳥司開",
                "2": "條風發歲",
                "3": "粵上斯巳",
                "4": "惟暮之春",
                "5": "同律克和",
                "6": "樹草自樂",
                "7": "禊飲之日在茲",
                "8": "風舞之情咸蕩",
                "9": "去肅表乎時訓",
                "10": "行慶動於天矚",
                "11": "載懷平圃",
                "12": "乃睠芳林",
                "13": "芳林園者",
                "14": "福地奧區之湊",
                "15": "丹陵若水之舊",
                "16": "殷殷均乎姚澤",
                "17": "膴膴尙於周原",
                "18": "狹豐邑之未宏",
                "19": "陋譙居之猶褊",
                "20": "山海經曰",
                "21": "槐江之山",
                "22": "實惟帝之平圃",
                "23": "南望崑崙",
                "24": "十洲記曰",
                "25": "芳林園在青溪菰首橋東",
                "26": "齊高帝舊宅",
                "27": "齊有天子",
                "28": "爲舊宮",
                "29": "宮東築山鑿池",
                "30": "號曰芳林園",
                "31": "遁甲開山圖曰",
                "32": "驪山之西原有阜",
                "33": "名曰風涼",
                "34": "雍州之福地",
                "35": "西京賦曰",
                "36": "寔惟地之奧區神皋",
                "37": "帝王世紀曰",
                "38": "堯生於丹陵",
                "39": "呂氏春秋曰",
                "40": "顓頊生於若水",
                "41": "乃登爲帝",
                "42": "又曰",
                "43": "舜陶於河濱",
                "44": "釣於雷澤",
                "45": "登爲天子",
                "46": "賢士歸之",
                "47": "萬人譽之",
                "48": "陳陳殷殷",
                "49": "無不戴悅",
                "50": "高誘曰",
                "51": "殷",
                "52": "盛也",
                "53": "呂氏春秋曰",
                "54": "舜爲天子",
                "55": "輒輒��",
                "56": "莫不戴悅",
                "57": "高誘曰��",
                "58": "動而喜貌也",
                "59": "殷殷",
                "60": "或爲��",
                "61": "故兩引之",
                "62": "輒",
                "63": "知葉切",
                "64": "�",
                "65": "仕勤切",
                "66": "帝王世紀曰",
                "67": "瞽叟之妻曰握登",
                "68": "生舜於姚墟",
                "69": "故姓姚氏",
                "70": "堯求賢而四嶽薦舜",
                "71": "堯乃命於順澤之陽",
                "72": "毛詩曰",
                "73": "周原膴膴",
                "74": "堇荼如飴",
                "75": "漢高祖",
                "76": "豐人",
                "77": "魏太祖",
                "78": "譙人",
                "79": "求中和而經處",
                "80": "揆景緯以裁基",
                "81": "飛觀神行",
                "82": "虛檐雲構",
                "83": "離房乍設",
                "84": "層樓間起",
                "85": "負朝陽而抗殿",
                "86": "跨靈沼而浮榮",
                "87": "鏡文虹於綺疏",
                "88": "浸蘭泉於玉砌",
                "89": "幽幽叢薄",
                "90": "秩秩斯干",
                "91": "曲拂邅迴",
                "92": "潺湲徑復",
                "93": "新蓱泛沚",
                "94": "華桐發岫",
                "95": "雜夭采於柔荑",
                "96": "亂嚶聲於綿羽",
                "97": "禁軒承幸",
                "98": "清宮俟宴",
                "99": "緹帷宿置",
                "100": "帟幕宵懸",
                "101": "旣而滅宿澄霞",
                "102": "登光辨色",
                "103": "式道執殳",
                "104": "展軨效駕",
                "105": "徐鑾警節",
                "106": "明鍾暢音",
                "107": "七萃連鑣",
                "108": "九斿齊軌",
                "109": "建旗拂霓",
                "110": "揚葭振木",
                "111": "魚甲煙聚",
                "112": "貝胄星羅",
                "113": "重英曲瑵之飾",
                "114": "絕景遺風之騎",
                "115": "昭灼甄部",
                "116": "駔駿函列",
                "117": "虎視龍超",
                "118": "雷駭電逝",
                "119": "轟轟隱隱",
                "120": "紛紛軫軫",
                "121": "羌難得而稱計"
            }
        },
        "6": {
            "13": {
                "1": "爾乃迴輿駐罕",
                "2": "嶽鎭淵渟",
                "3": "睟容有穆",
                "4": "賓儀式序",
                "5": "授几肆筵",
                "6": "因流波而成次",
                "7": "蕙肴芳醴",
                "8": "任激水而推移",
                "9": "葆佾陳階",
                "10": "金瓟在席",
                "11": "戚奏翹舞",
                "12": "籥動邠詩",
                "13": "召鳴鳥於弇州",
                "14": "追伶倫於嶰谷",
                "15": "發參差於王子",
                "16": "傳妙靡於帝江",
                "17": "正歌有闋",
                "18": "羽觴無筭",
                "19": "上陳景福之賜",
                "20": "下獻南山之壽",
                "21": "信凱讌之在藻",
                "22": "知和樂於食苹",
                "23": "桑楡之陰不居",
                "24": "草露之滋方渥",
                "25": "有詔曰",
                "26": "今日嘉會",
                "27": "咸可賦詩",
                "28": "凡四十有五人",
                "29": "其辭云爾"
            }
        }
    }
