{
    "17.02": {
        "篇名": "王子淵 洞簫賦",
        "1": {
            "3": {
                "1": "原夫簫幹之所生兮",
                "2": "於江南之丘墟",
                "3": "洞條暢而罕節兮",
                "4": "標敷紛以扶疏",
                "5": "徒觀其旁山側兮",
                "6": "則嶇嶔巋崎",
                "7": "倚巇迆㠧",
                "8": "誠可悲乎其不安也",
                "9": "彌望儻莽",
                "10": "聯延曠盪",
                "11": "又足樂乎其敞閑也",
                "12": "託身軀於后土兮",
                "13": "經萬載而不遷",
                "14": "吸至精之滋熙兮",
                "15": "稟蒼色之潤堅",
                "16": "感陰陽之變化兮",
                "17": "附性命乎皇天",
                "18": "翔風蕭蕭而徑其末兮",
                "19": "迴江流川而漑其山",
                "20": "揚素波而揮連珠兮",
                "21": "聲磕磕而澍淵",
                "22": "朝露清泠而隕其側兮",
                "23": "玉液浸潤而承其根",
                "24": "孤雌寡鶴",
                "25": "娛優乎其下兮",
                "26": "春禽羣嬉",
                "27": "翱翔乎其顚",
                "28": "秋蜩不食",
                "29": "抱樸而長吟兮",
                "30": "玄猿悲嘯",
                "31": "搜索乎其間",
                "32": "處幽隱而奧庰兮",
                "33": "密漠泊以𤡻猭",
                "34": "惟詳察其素體兮",
                "35": "宜清靜而弗諠",
                "36": "幸得謚爲洞簫兮",
                "37": "蒙聖主之渥恩",
                "38": "可謂惠而不費兮",
                "39": "因天性之自然"
            }
        },
        "2": {
            "5": {
                "1": "於是般匠施巧",
                "2": "夔妃准法",
                "3": "帶以象牙",
                "4": "掍其會合",
                "5": "鎪鏤離灑",
                "6": "絳脣錯雜",
                "7": "鄰菌繚糾",
                "8": "羅鱗捷獵",
                "9": "膠緻理比",
                "10": "挹抐㩎㩶",
                "11": "於是乃使夫性昧之宕冥",
                "12": "生不睹天地之體勢",
                "13": "闇於白黑之貌形",
                "14": "憤伊鬱而酷𦓖",
                "15": "愍眸子之喪精",
                "16": "寡所舒其思慮兮",
                "17": "專發憤乎音聲",
                "18": "故吻吮値夫宮商兮",
                "19": "龢紛離其匹溢",
                "20": "形旖旎以順吹兮",
                "21": "瞋㖤㗅以紆鬱",
                "22": "氣旁迕以飛射兮",
                "23": "馳散渙以輟律",
                "24": "趣從容其勿述兮",
                "25": "騖合遝以詭譎",
                "26": "或渾沌而潺湲兮",
                "27": "獵若枚折",
                "28": "或漫衍而駱驛兮",
                "29": "沛焉競溢",
                "30": "惏慄密率",
                "31": "掩以絕滅",
                "32": "㘊霵曄踕",
                "33": "跳然復出"
            }
        },
        "3": {
            "7": {
                "1": "若乃徐聽其曲度兮",
                "2": "廉察其賦歌",
                "3": "啾咇㘉而將吟兮",
                "4": "行鍖銋以龢囉",
                "5": "風鴻洞而不絕兮",
                "6": "優嬈嬈以婆娑",
                "7": "翩綿連以牢落兮",
                "8": "漂乍棄而爲他",
                "9": "要復遮其蹊徑兮",
                "10": "與謳謠乎相龢",
                "11": "故聽其巨音",
                "12": "則周流汜濫",
                "13": "幷包吐含",
                "14": "若慈父之畜子也",
                "15": "其妙聲",
                "16": "則清靜厭㥷",
                "17": "順敍卑迖",
                "18": "若孝子之事父也",
                "19": "科條譬類",
                "20": "誠應義理",
                "21": "澎濞慷慨",
                "22": "一何壯士",
                "23": "優柔溫潤",
                "24": "又似君子",
                "25": "故其武聲",
                "26": "則若雷霆輘輷",
                "27": "佚豫以沸㥜",
                "28": "其仁聲",
                "29": "則若颽風紛披",
                "30": "容與而施惠",
                "31": "或雜遝以聚斂兮",
                "32": "或拔摋以奮棄",
                "33": "悲愴怳以惻惐兮",
                "34": "時恬淡以綏肆",
                "35": "被淋灑其靡靡兮",
                "36": "時橫潰以陽遂",
                "37": "哀悁悁之可懷兮",
                "38": "良醰醰而有味"
            }
        },
        "4": {
            "9": {
                "1": "故貪饕者聽之而廉隅兮",
                "2": "狼戾者聞之而不懟",
                "3": "剛毅彊𧇭反仁恩兮",
                "4": "嘽唌逸豫戒其失",
                "5": "鍾期牙曠悵然而愕兮",
                "6": "杞梁之妻不能爲其氣",
                "7": "師襄嚴春不敢竄其巧兮",
                "8": "浸淫叔子遠其類",
                "9": "嚚頑朱均惕復惠兮",
                "10": "桀跖鬻博儡以頓顇",
                "11": "吹參差而入道德兮",
                "12": "故永御而可貴"
            }
        },
        "5": {
            "11": {
                "1": "時奏狡弄",
                "2": "則彷徨翱翔",
                "3": "或留而不行",
                "4": "或行而不留",
                "5": "愺恅瀾漫",
                "6": "亡耦失疇",
                "7": "薄索合沓",
                "8": "罔象相求",
                "9": "故知音者樂而悲之",
                "10": "不知音者怪而偉之",
                "11": "故聞其悲聲",
                "12": "則莫不愴然累欷",
                "13": "撆涕抆淚",
                "14": "其奏歡娛",
                "15": "則莫不憚漫衍凱",
                "16": "阿那腲腇者已",
                "17": "是以蟋蟀蚸蠖",
                "18": "蚑行喘息",
                "19": "螻蟻蝘蜒",
                "20": "蠅蠅翊翊",
                "21": "遷延徙迆",
                "22": "魚瞰雞睨",
                "23": "垂喙䖤轉",
                "24": "瞪瞢忘食",
                "25": "況感陰陽之龢",
                "26": "而化風俗之倫哉"
            }
        },
        "6": {
            "13": {
                "1": "亂曰",
                "2": "狀若捷武",
                "3": "超騰踰曳",
                "4": "迅漂巧兮",
                "5": "又似流波",
                "6": "泡溲泛𣶏",
                "7": "趨巇道兮",
                "8": "哮呷呟喚",
                "9": "躋躓連絕",
                "10": "淈殄沌兮",
                "11": "攪搜㶅捎",
                "12": "逍遙踊躍",
                "13": "若壞頹兮",
                "14": "優遊流離",
                "15": "躊躇稽詣",
                "16": "亦足耽兮",
                "17": "頹唐遂往",
                "18": "長辭遠逝",
                "19": "漂不還兮",
                "20": "賴蒙聖化",
                "21": "從容中道",
                "22": "樂不淫兮",
                "23": "條暢洞達",
                "24": "中節操兮",
                "25": "終詩卒曲",
                "26": "尙餘音兮",
                "27": "吟氣遺響",
                "28": "聯綿漂撇",
                "29": "生微風兮",
                "30": "連延駱驛",
                "31": "變無窮兮"
            }
        }
    }
}