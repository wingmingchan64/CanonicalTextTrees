{
    "26.11": {
        "篇名": "范彥龍 贈張徐州稷",
        "1": {
            "3": {
                "1": "田家樵采去",
                "2": "薄暮方來歸",
                "3": "還聞稚子說",
                "4": "有客款柴扉",
                "5": "儐從皆珠玳",
                "6": "裘馬悉輕肥",
                "7": "軒蓋照墟落",
                "8": "傳瑞生光輝",
                "9": "疑是徐方牧",
                "10": "旣是復疑非",
                "11": "思舊昔言有",
                "12": "此道今已微",
                "13": "物情棄疵賤",
                "14": "何獨顧衡闈",
                "15": "恨不具雞黍",
                "16": "得與故人揮",
                "17": "懷情徒草草",
                "18": "淚下空霏霏",
                "19": "寄書雲間雁",
                "20": "爲我西北飛"
            }
        }
    }
