{
    "31.01": {
        "篇名": "袁陽源 效曹子建樂府白馬篇",
        "1": {
            "3": {
                "1": "劍騎何翩翩",
                "2": "長安五陵間",
                "3": "秦地天下樞",
                "4": "八方湊才賢",
                "5": "荊魏多壯士",
                "6": "宛洛富少年",
                "7": "意氣深自負",
                "8": "肯事郡邑權",
                "9": "籍籍關外來",
                "10": "車徒傾國鄽",
                "11": "五侯競書幣",
                "12": "羣公亟爲言",
                "13": "義分明於霜",
                "14": "信行直如弦",
                "15": "交歡池陽下",
                "16": "留宴汾陰西",
                "17": "一朝許人諾",
                "18": "何能坐相捐",
                "19": "彯節去函谷",
                "20": "投珮出甘泉",
                "21": "嗟此務遠圖",
                "22": "心爲四海懸",
                "23": "但營身意遂",
                "24": "豈校耳目前",
