{
    "42.10": {
        "篇名": "應休璉 與廣川長岑文瑜書",
        "1": {
            "3": {
                "1": "璩白",
                "2": "頃者炎旱",
                "3": "日更增甚",
                "4": "沙礫銷鑠",
                "5": "草木焦卷",
                "6": "處涼臺而有鬱蒸之煩",
                "7": "浴寒水而有灼爛之慘",
                "8": "宇宙雖廣",
                "9": "無陰以憩",
                "10": "雲漢之詩",
                "11": "何以過此",
                "12": "土龍矯首於玄寺",
                "13": "泥人鶴立於闕里",
                "14": "修之歷旬",
                "15": "靜無徵效",
                "16": "明勸教之術",
                "17": "非致雨之備也"
            }
        },
        "2": {
            "5": {
                "1": "知卹下人",
                "2": "躬自暴露",
                "3": "拜起靈壇",
                "4": "勤亦至矣",
                "5": "昔夏禹之解陽旴",
                "6": "殷湯之禱桑林",
                "7": "言未發而水旋流",
                "8": "辭未卒而澤滂沛",
                "9": "今者雲重積而復散",
                "10": "雨垂落而復收",
                "11": "得無賢聖殊品",
                "12": "優劣異姿",
                "13": "割髮宜及膚",
                "14": "剪爪宜侵肌乎",
                "15": "周征殷而年豐",
                "16": "衞伐郉而致雨",
                "17": "善否之應",
                "18": "甚於影響",
                "19": "未可以爲不然也",
                "20": "想雅思所未及",
                "21": "謹書起予",
                "22": "應璩白"
            }
        }
    }
}