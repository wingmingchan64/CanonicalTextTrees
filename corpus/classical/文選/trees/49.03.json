{
    "49.03": {
        "篇名": "干令升 晉紀·總論",
        "1": {
            "3": {
                "1": "史臣曰",
                "2": "昔高祖宣皇帝以雄才碩量",
                "3": "應運而仕",
                "4": "値魏太祖創基之初",
                "5": "籌畫軍國",
                "6": "嘉謀屢中",
                "7": "遂服輿軫",
                "8": "驅馳三世",
                "9": "性深阻有如城府",
                "10": "而能寬綽以容納",
                "11": "行任數以御物",
                "12": "而知人善采拔",
                "13": "故賢愚咸懷",
                "14": "小大畢力",
                "15": "爾乃取鄧艾於農隙",
                "16": "引州泰於行役",
                "17": "委以文武",
                "18": "各善其事",
                "19": "故能西禽孟達",
                "20": "東舉公孫淵",
                "21": "內夷曹爽",
                "22": "外襲王陵",
                "23": "神略獨斷",
                "24": "征伐四克",
                "25": "維御羣后",
                "26": "大權在己",
                "27": "屢拒諸葛亮節制之兵",
                "28": "而東支吳人輔車之勢",
                "29": "世宗承基",
                "30": "太祖繼業",
                "31": "軍旅屢動",
                "32": "邊鄙無虧",
                "33": "於是百姓與能",
                "34": "大象始構矣",
                "35": "玄豐亂內",
                "36": "欽誕寇外",
                "37": "潛謀雖密",
                "38": "而在幾必兆",
                "39": "淮浦再擾",
                "40": "而許洛不震",
                "41": "咸黜異圖",
                "42": "用融前烈",
                "43": "然後推轂鍾鄧",
                "44": "長驅庸蜀",
                "45": "三關電掃",
                "46": "劉禪入臣",
                "47": "天符人事",
                "48": "於是信矣",
                "49": "始當非常之禮",
                "50": "終受備物之錫",
                "51": "名器崇於周公",
                "52": "權制嚴於伊尹",
                "53": "至於世祖",
                "54": "遂享皇極",
                "55": "正位居體",
                "56": "重言愼法",
                "57": "仁以厚下",
                "58": "儉以足用",
                "59": "和而不弛",
                "60": "寬而能斷",
                "61": "故民詠惟新",
                "62": "四海悅勸矣",
                "63": "聿修祖宗之志",
                "64": "思輯戰國之苦",
                "65": "腹心不同",
                "66": "公卿異議",
                "67": "而獨納羊祜之策",
                "68": "以從善爲眾",
                "69": "故至於咸寧之末",
                "70": "遂排羣議而杖王杜之決",
                "71": "泛舟三峽",
                "72": "介馬桂陽",
                "73": "役不二時",
                "74": "江湘來同",
                "75": "夷吳蜀之壘垣",
                "76": "通二方之險塞",
                "77": "掩唐虞之舊域",
                "78": "班正朔於八荒",
                "79": "太康之中",
                "80": "天下書同文",
                "81": "車同軌",
                "82": "牛馬被野",
                "83": "餘糧栖畝",
                "84": "行旅草舍",
                "85": "外閭不閉",
                "86": "民相遇者如親",
                "87": "其匱乏者",
                "88": "取資於道路",
                "89": "故於時有天下無窮人之諺",
                "90": "雖太平未洽",
                "91": "亦足以明吏奉其法",
                "92": "民樂其生",
                "93": "百代之一時矣"
            }
        },
        "2": {
            "5": {
                "1": "武皇旣崩",
                "2": "山陵未乾",
                "3": "楊駿被誅",
                "4": "母后廢黜",
                "5": "朝士舊臣",
                "6": "夷滅者數十族",
                "7": "尋以二公楚王之變",
                "8": "宗子無維城之助",
                "9": "而閼伯實沈之郤歲構",
                "10": "師尹無具瞻之貴",
                "11": "而顚墜戮辱之禍日有",
                "12": "至乃易天子以太上之號",
                "13": "而有免官之謠",
                "14": "民不見德",
                "15": "唯亂是聞",
                "16": "朝爲伊周",
                "17": "夕爲桀跖",
                "18": "善惡陷於成敗",
                "19": "毀譽脅於勢利",
                "20": "於是輕薄干紀之士",
                "21": "役姦智以投之",
                "22": "如夜蟲之赴火",
                "23": "內外混淆",
                "24": "庶官失才",
                "25": "名實反錯",
                "26": "天網解紐",
                "27": "國政迭移於亂人",
                "28": "禁兵外散於四方",
                "29": "方岳無鈞石之鎭",
                "30": "關門無結草之固",
                "31": "李辰石冰",
                "32": "傾之於荊揚",
                "33": "劉淵王彌",
                "34": "撓之於青冀",
                "35": "二十餘年而河洛爲墟",
                "36": "戎羯稱制",
                "37": "二帝失尊",
                "38": "山陵無所",
                "39": "何哉",
                "40": "樹立失權",
                "41": "託付非才",
                "42": "四維不張",
                "43": "而苟且之政多也",
                "44": "夫作法於治",
                "45": "其敝猶亂",
                "46": "作法於亂",
                "47": "誰能救之",
                "48": "故於時天下非暫弱也",
                "49": "軍旅非無素也",
                "50": "彼劉淵者",
                "51": "離石之將兵都尉",
                "52": "王彌者",
                "53": "青州之散吏也",
                "54": "蓋皆弓馬之士",
                "55": "驅走之人",
                "56": "凡庸之才",
                "57": "非有吳先主諸葛孔明之能也",
                "58": "新起之寇",
                "59": "烏合之眾",
                "60": "非吳蜀之敵也",
                "61": "脫耒爲兵",
                "62": "裂裳爲旗",
                "63": "非戰國之器也",
                "64": "自下逆上",
                "65": "非鄰國之勢也",
                "66": "然而成敗異效",
                "67": "擾天下如驅羣羊",
                "68": "舉二都如拾遺",
                "69": "將相侯王",
                "70": "連頭受戮",
                "71": "乞爲奴僕而猶不獲",
                "72": "后嬪妃主",
                "73": "虜辱於戎卒",
                "74": "豈不哀哉",
                "75": "夫天下",
                "76": "大器也",
                "77": "羣生",
                "78": "重畜也",
                "79": "愛惡相攻",
                "80": "利害相奪",
                "81": "其勢常也",
                "82": "若積水於防",
                "83": "燎火於原",
                "84": "未嘗暫靜也",
                "85": "器大者不可以小道治",
                "86": "勢動者不可以爭競擾",
                "87": "古先哲王",
                "88": "知其然也",
                "89": "是以扞其大患而不有其功",
                "90": "禦其大災而不尸其利",
                "91": "百姓皆知上德之生己",
                "92": "而不謂浚己以生也",
                "93": "是以感而應之",
                "94": "悅而歸之",
                "95": "如晨風之鬱北林",
                "96": "龍魚之趣淵澤也",
                "97": "順乎天而享其運",
                "98": "應乎人而和其義",
                "99": "然後設禮文以治之",
                "100": "斷刑罰以威之",
                "101": "謹好惡以示之",
                "102": "審禍福以喩之",
                "103": "求明察以官之",
                "104": "篤慈愛以固之",
                "105": "故眾知向方",
                "106": "皆樂其生而哀其死",
                "107": "悅其教而安其俗",
                "108": "君子勤禮",
                "109": "小人盡力",
                "110": "廉恥篤於家閭",
                "111": "邪僻銷於胸懷",
                "112": "故其民有見危以授命",
                "113": "而不求生以害義",
                "114": "又況可奮臂大呼",
                "115": "聚之以干紀作亂之事乎",
                "116": "基廣則難傾",
                "117": "根深則難拔",
                "118": "理節則不亂",
                "119": "膠結則不遷",
                "120": "是以昔之有天下者",
                "121": "所以長久也",
                "122": "夫豈無僻主",
                "123": "賴道德典刑以維持之也",
                "124": "故延陵季子聽樂以知諸侯存亡之數",
                "125": "短長之期者",
                "126": "蓋民情風教",
                "127": "國家安危之本也"
            }
        },
        "3": {
            "7": {
                "1": "昔周之興也",
                "2": "后稷生於姜嫄",
                "3": "而天命昭顯",
                "4": "文武之功",
                "5": "起於后稷",
                "6": "故其詩曰",
                "7": "思文后稷",
                "8": "克配彼天",
                "9": "又曰",
                "10": "立我蒸民",
                "11": "莫匪爾極",
                "12": "又曰",
                "13": "實穎實栗",
                "14": "卽有邰家室",
                "15": "至於公劉遭狄人之亂",
                "16": "去邰之豳",
                "17": "身服厥勞",
                "18": "故其詩曰",
                "19": "乃裹餱糧",
                "20": "於橐於囊",
                "21": "陟則在巘",
                "22": "復降在原",
                "23": "以處其民",
                "24": "以至於太王爲戎翟所逼",
                "25": "而不忍百姓之命",
                "26": "杖策而去之",
                "27": "故其詩曰",
                "28": "來朝走馬",
                "29": "帥西水滸",
                "30": "至於岐下",
                "31": "周民從而思之",
                "32": "曰",
                "33": "仁人不可失也",
                "34": "故從之如歸市",
                "35": "居之一年成邑",
                "36": "二年成都",
                "37": "三年五倍其初",
                "38": "每勞來而安集之",
                "39": "故其詩曰",
                "40": "乃慰乃止",
                "41": "乃左乃右",
                "42": "乃疆乃理",
                "43": "乃宣乃畝",
                "44": "以至於王季",
                "45": "能貊其德音",
                "46": "故其詩曰",
                "47": "克明克類",
                "48": "克長克君",
                "49": "載錫之光",
                "50": "至於文王",
                "51": "備修舊德",
                "52": "而惟新其命",
                "53": "故其詩曰",
                "54": "惟此文王",
                "55": "小心翼翼",
                "56": "昭事上帝",
                "57": "聿懷多福",
                "58": "由此觀之",
                "59": "周家世積忠厚",
                "60": "仁及草木",
                "61": "內睦九族",
                "62": "外尊事黃耇",
                "63": "養老乞言",
                "64": "以成其福祿者也",
                "65": "而其妃后躬行四教",
                "66": "尊敬師傅",
                "67": "服澣濯之衣",
                "68": "修煩辱之事",
                "69": "化天下以婦道",
                "70": "毛詩葛覃序也",
                "71": "詩曰",
                "72": "葛之覃兮",
                "73": "毛萇曰",
                "74": "葛所以爲絺𥿭",
                "75": "女功之事煩辱者也",
                "76": "故其詩曰",
                "77": "刑於寡妻",
                "78": "至於兄弟",
                "79": "以御於家邦",
                "80": "是以漢濱之女",
                "81": "守絜白之志",
                "82": "中林之士",
                "83": "有純一之德",
                "84": "故曰",
                "85": "文武自天保以上治內",
                "86": "采薇以下治外",
                "87": "始於憂勤",
                "88": "終於逸樂",
                "89": "於是天下三分有二",
                "90": "猶以服事殷",
                "91": "諸侯不期而會者八百",
                "92": "猶曰天命未至",
                "93": "以三聖之智",
                "94": "伐獨夫之紂",
                "95": "猶正其名教曰逆取順守",
                "96": "保大定功",
                "97": "安民和眾",
                "98": "猶著大武之容曰未盡善也",
                "99": "及周公遭變",
                "100": "陳后稷先公風化之所由",
                "101": "致王業之艱難者",
                "102": "則皆農夫女工衣食之事也",
                "103": "故自后稷之始基靜民",
                "104": "十五王而文始平之",
                "105": "十六王而武始居之",
                "106": "十八王而康克安之",
                "107": "故其積基樹木",
                "108": "經緯禮俗",
                "109": "節理人情",
                "110": "卹隱民事",
                "111": "如此之纏綿也",
                "112": "爰及上代",
                "113": "雖文質異時",
                "114": "功業不同",
                "115": "及其安民立政者",
                "116": "其揆一也"
            }
        },
        "4": {
            "9": {
                "1": "今晉之興也",
                "2": "功烈於百王",
                "3": "事捷於三代",
                "4": "蓋有爲以爲之矣",
                "5": "宣景遭多難之時",
                "6": "務伐英雄",
                "7": "誅庶桀以便事",
                "8": "不及修公劉太王之仁也",
                "9": "受遺輔政",
                "10": "屢遇廢置",
                "11": "故齊王不明",
                "12": "不獲思庸於亳",
                "13": "高貴沖人",
                "14": "不得復子明辟",
                "15": "二祖逼禪代之期",
                "16": "不暇待參分八百之會也",
                "17": "是其創基立本",
                "18": "異於先代者也",
                "19": "又加之以朝寡純德之士",
                "20": "鄕乏不二之老",
                "21": "風俗淫僻",
                "22": "恥尙失所",
                "23": "學者以莊老爲宗",
                "24": "而黜六經",
                "25": "談者以虛薄爲辯",
                "26": "而賤名儉",
                "27": "行身者以放濁爲通",
                "28": "而狹節信",
                "29": "進仕者以苟得爲貴",
                "30": "而鄙居正",
                "31": "當官者以望空爲高",
                "32": "而笑勤恪",
                "33": "是以目三公以蕭杌之稱",
                "34": "標上議以虛談之名",
                "35": "劉頌屢言治道",
                "36": "傅咸每糾邪正",
                "37": "皆謂之俗吏",
                "38": "其倚杖虛曠",
                "39": "依阿無心者",
                "40": "皆名重海內",
                "41": "若夫文王日昃不暇食",
                "42": "仲山甫夙夜匪懈者",
                "43": "蓋共嗤點以爲灰塵",
                "44": "而相詬病矣",
                "45": "由是毀譽亂於善惡之實",
                "46": "情慝奔於貨慾之塗",
                "47": "選者爲人擇官",
                "48": "官者爲身擇利",
                "49": "而秉鈞當軸之士",
                "50": "身兼官以十數",
                "51": "大極其尊",
                "52": "小錄其要",
                "53": "機事之失",
                "54": "十恆八九",
                "55": "而世族貴戚之子弟",
                "56": "陵邁超越",
                "57": "不拘資次",
                "58": "悠悠風塵",
                "59": "皆奔競之士",
                "60": "列官千百",
                "61": "無讓賢之舉",
                "62": "子眞著崇讓而莫之省",
                "63": "子雅制九班而不得用",
                "64": "長虞數直筆而不能糾",
                "65": "其婦女莊櫛織紝",
                "66": "皆取成於婢僕",
                "67": "未嘗知女工絲枲之業",
                "68": "中饋酒食之事也",
                "69": "先時而婚",
                "70": "任情而動",
                "71": "故皆不恥淫逸之過",
                "72": "不拘妬忌之惡",
                "73": "有逆於舅姑",
                "74": "有反易剛柔",
                "75": "有殺戮妾媵",
                "76": "有黷亂上下",
                "77": "父兄弗之罪也",
                "78": "天下莫之非也",
                "79": "又況責之聞四教於古",
                "80": "修貞順於今",
                "81": "以輔佐君子者哉",
                "82": "禮法刑政",
                "83": "於此大壞",
                "84": "如室斯構而去其鑿契",
                "85": "如水斯積而決其隄防",
                "86": "如火斯畜而離其薪燎也",
                "87": "國之將亡",
                "88": "本必先顚",
                "89": "其此之謂乎"
            }
        },
        "5": {
            "11": {
                "1": "故觀阮籍之行",
                "2": "而覺禮教崩弛之所由",
                "3": "察庾純賈充之事",
                "4": "而見師尹之多僻",
                "5": "考平吳之功",
                "6": "知將帥之不讓",
                "7": "思郭欽之謀",
                "8": "而悟戎狄之有釁",
                "9": "覽傅玄劉毅之言",
                "10": "而得百官之邪",
                "11": "核傅咸之奏",
                "12": "錢神之論",
                "13": "而睹寵賂之彰",
                "14": "民風國勢如此",
                "15": "雖以中庸之才",
                "16": "守文之主治之",
                "17": "辛有必見之於祭祀",
                "18": "季札必得之於聲樂",
                "19": "范燮必爲之請死",
                "20": "賈誼必爲之痛哭",
                "21": "又況我惠帝以蕩蕩之德臨之哉",
                "22": "故賈后肆虐於六宮",
                "23": "韓午助亂於外內",
                "24": "其所由來者漸矣",
                "25": "豈特繫一婦人之惡乎",
                "26": "懷帝承亂之後得位",
                "27": "羈於彊臣",
                "28": "愍帝奔播之後",
                "29": "徒廁其虛名",
                "30": "天下之政",
                "31": "旣已去矣",
                "32": "非命世之雄",
                "33": "不能取之矣",
                "34": "然懷帝初載",
                "35": "嘉禾生於南昌",
                "36": "望氣者又云豫章有天子氣",
                "37": "及國家多難",
                "38": "宗室迭興",
                "39": "以愍懷之正",
                "40": "淮南之壯",
                "41": "成都之功",
                "42": "長沙之權",
                "43": "皆卒於傾覆",
                "44": "而懷帝以豫章王登天位",
                "45": "劉向之讖云",
                "46": "滅亡之後",
                "47": "有少如水名者得之",
                "48": "起事者據秦川",
                "49": "西南乃得其朋",
                "50": "案愍帝",
                "51": "蓋秦王之子也",
                "52": "得位於長安",
                "53": "長安",
                "54": "固秦地也",
                "55": "而西以南陽王爲右丞相",
                "56": "東以琅邪王爲左丞相",
                "57": "上諱業",
                "58": "故改鄴爲臨漳",
                "59": "漳",
                "60": "水名也",
                "61": "由此推之",
                "62": "亦有徵祥",
                "63": "而皇極不建",
                "64": "禍辱及身",
                "65": "豈上帝臨我而貳其心",
                "66": "將由人能弘道",
                "67": "非道弘人者乎",
                "68": "淳耀之烈未渝",
                "69": "故大命重集於中宗元皇帝"
            }
        }
    }
}