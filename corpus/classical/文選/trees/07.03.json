{
    "07.03": {
        "篇名": "司馬長卿 子虛賦",
        "1": {
            "3": {
                "1": "楚使子虛使於齊",
                "2": "齊王悉發境內之士",
                "3": "備車騎之眾",
                "4": "與使者出畋",
                "5": "畋罷",
                "6": "子虛過詫烏有先生",
                "7": "而亡是公存焉",
                "8": "坐定",
                "9": "烏有先生問曰",
                "10": "今日畋樂乎",
                "11": "子虛曰",
                "12": "樂",
                "13": "獲多乎",
                "14": "曰",
                "15": "少",
                "16": "然則何樂",
                "17": "對曰",
                "18": "僕樂齊王之欲夸僕以車騎之眾",
                "19": "而僕對以雲夢之事也",
                "20": "曰",
                "21": "可得聞乎"
            }
        },
        "2": {
            "5": {
                "1": "子虛曰",
                "2": "可",
                "3": "王車駕千乘",
                "4": "選徒萬騎",
                "5": "畋於海濱",
                "6": "列卒滿澤",
                "7": "罘網彌山",
                "8": "掩兔轔鹿",
                "9": "射麋腳麟",
                "10": "騖於鹽浦",
                "11": "割鮮染輪",
                "12": "射中獲多",
                "13": "矜而自功",
                "14": "顧謂僕曰",
                "15": "楚亦有平原廣澤遊獵之地饒樂若此者乎",
                "16": "楚王之獵孰與寡人乎",
                "17": "僕下車對曰",
                "18": "臣",
                "19": "楚國之鄙人也",
                "20": "幸得宿衞十有餘年",
                "21": "時從出遊",
                "22": "遊於後園",
                "23": "覽於有無",
                "24": "然猶未能徧覩也",
                "25": "又焉足以言其外澤者乎",
                "26": "齊王曰",
                "27": "雖然",
                "28": "略以子之所聞見而言之"
            }
        },
        "3": {
            "7": {
                "1": "僕對曰",
                "2": "唯唯",
                "3": "臣聞楚有七澤",
                "4": "嘗見",
                "5": "未覩其餘也",
                "6": "臣之所見",
                "7": "蓋特其小小者耳",
                "8": "名曰雲夢",
                "9": "雲夢者",
                "10": "方九百里",
                "11": "其中有山焉",
                "12": "其山則盤紆岪鬱",
                "13": "隆崇嵂崒",
                "14": "岑崟參差",
                "15": "日月蔽虧",
                "16": "交錯糾紛",
                "17": "上干青雲",
                "18": "罷池陂陀",
                "19": "下屬江河",
                "20": "其土則丹青赭堊",
                "21": "雌黃白坿",
                "22": "錫碧金銀",
                "23": "眾色炫耀",
                "24": "照爛龍鱗",
                "25": "其石則赤玉玫瑰",
                "26": "琳瑉昆吾",
                "27": "瑊玏玄厲",
                "28": "碝石碔砆",
                "29": "其東則有蕙圃蘅蘭",
                "30": "茝若射干",
                "31": "芎藭菖蒲",
                "32": "江離蘪蕪",
                "33": "諸柘巴且",
                "34": "其南則有平原廣澤",
                "35": "登降阤靡",
                "36": "案衍壇曼",
                "37": "緣以大江",
                "38": "限以巫山",
                "39": "其高燥則生葴菥苞荔",
                "40": "薜莎青薠",
                "41": "其埤濕則生藏莨蒹葭",
                "42": "東蘠彫胡",
                "43": "蓮藕觚蘆",
                "44": "菴䕡軒芋",
                "45": "眾物居之",
                "46": "不可勝圖",
                "47": "其西則有湧泉清池",
                "48": "激水推移",
                "49": "外發芙蓉蔆華",
                "50": "內隱鉅石白沙",
                "51": "其中則有神龜蛟鼉",
                "52": "瑇瑁鱉黿",
                "53": "其北則有陰林巨樹",
                "54": "楩柟豫樟",
                "55": "桂椒木蘭",
                "56": "蘗離朱楊",
                "57": "樝棃梬栗",
                "58": "橘柚芬芳",
                "59": "其上則有赤猿玃猱",
                "60": "鵷雛孔鸞",
                "61": "騰遠射干",
                "62": "其下則有白虎玄豹",
                "63": "蟃蜒貙犴",
                "64": "兕象野犀",
                "65": "窮奇獌狿"
            }
        },
        "4": {
            "9": {
                "1": "於是乎乃使專諸之倫",
                "2": "手格此獸",
                "3": "楚王乃駕馴駮之駟",
                "4": "乘彫玉之輿",
                "5": "靡魚須之橈旃",
                "6": "曳明月之珠旗",
                "7": "建干將之雄戟",
                "8": "左烏號之彫弓",
                "9": "右夏服之勁箭",
                "10": "陽子驂乘",
                "11": "孅阿爲御",
                "12": "案節未舒",
                "13": "卽陵狡獸",
                "14": "蹴蛩蛩",
                "15": "轔距虛",
                "16": "軼野馬",
                "17": "轊騊駼",
                "18": "乘遺風",
                "19": "射遊騏",
                "20": "鯈眒倩浰",
                "21": "雷動猋至",
                "22": "星流霆擊",
                "23": "弓不虛發",
                "24": "中必決眥",
                "25": "洞胸達掖",
                "26": "絕乎心繫",
                "27": "獲若雨獸",
                "28": "揜草蔽地",
                "29": "於是楚王乃弭節徘徊",
                "30": "翱翔容與",
                "31": "覽乎陰林",
                "32": "觀壯士之暴怒",
                "33": "與猛獸之恐懼",
                "34": "徼𠫷受詘",
                "35": "殫覩眾物之變態"
            }
        },
        "5": {
            "11": {
                "1": "於是鄭女曼姬",
                "2": "被阿緆",
                "3": "揄紵縞",
                "4": "雜纖羅",
                "5": "垂霧縠",
                "6": "襞積褰縐",
                "7": "紆徐委曲",
                "8": "鬱橈谿谷",
                "9": "衯衯裶裶",
                "10": "揚袘戌削",
                "11": "蜚襳垂髾",
                "12": "扶輿猗靡",
                "13": "翕呷萃蔡",
                "14": "下靡蘭蕙",
                "15": "上拂羽蓋",
                "16": "錯翡翠之威蕤",
                "17": "繆繞玉綏",
                "18": "眇眇忽忽",
                "19": "若神仙之髣髴"
            }
        },
        "6": {
            "13": {
                "1": "於是乃相與獠於蕙圃",
                "2": "媻姍勃窣",
                "3": "上乎金隄",
                "4": "揜翡翠",
                "5": "射鵔鸃",
                "6": "微矰出",
                "7": "孅繳施",
                "8": "弋白鵠",
                "9": "連鴐鵞",
                "10": "雙鶬下",
                "11": "玄鶴加",
                "12": "怠而後發",
                "13": "遊於清池",
                "14": "浮文鷁",
                "15": "揚旌枻",
                "16": "張翠帷",
                "17": "建羽蓋",
                "18": "罔瑇瑁",
                "19": "鉤紫貝",
                "20": "摐金鼓",
                "21": "吹鳴籟",
                "22": "榜人歌",
                "23": "聲流喝",
                "24": "水蟲駭",
                "25": "波鴻沸",
                "26": "涌泉起",
                "27": "奔揚會",
                "28": "磊石相擊",
                "29": "硠硠礚礚",
                "30": "若雷霆之聲",
                "31": "聞乎數百里之外"
            }
        },
        "7": {
            "15": {
                "1": "將息獠者",
                "2": "擊靈鼓",
                "3": "起烽燧",
                "4": "車案行",
                "5": "騎就隊",
                "6": "纚乎淫淫",
                "7": "般乎裔裔",
                "8": "於是楚王乃登雲陽之臺",
                "9": "泊乎無爲",
                "10": "憺乎自持",
                "11": "勺藥之和具而後御之",
                "12": "不若大王終日馳騁",
                "13": "曾不下輿",
                "14": "脟割輪焠",
                "15": "自以爲娛",
                "16": "臣竊觀之",
                "17": "齊殆不如",
                "18": "於是齊王無以應僕也"
            }
        },
        "8": {
            "17": {
                "1": "烏有先生曰",
                "2": "是何言之過也",
                "3": "足下不遠千里",
                "4": "來貺齊國",
                "5": "王悉發境內之士",
                "6": "備車騎之眾與使者出畋",
                "7": "乃欲戮力致獲以娛左右",
                "8": "何名爲夸哉",
                "9": "問楚地之有無者",
                "10": "願聞大國之風烈",
                "11": "先生之餘論",
                "12": "今足下不稱楚王之德厚",
                "13": "而盛推雲夢以爲驕",
                "14": "奢言淫樂而顯侈靡",
                "15": "竊爲足下不取也",
                "16": "必若所言",
                "17": "固非楚國之美也",
                "18": "有而言之",
                "19": "是彰君惡",
                "20": "無而言之",
                "21": "是害足下之信",
                "22": "彰君之惡而傷私義",
                "23": "二者無一可",
                "24": "而先生行之",
                "25": "必且輕於齊而累於楚矣",
                "26": "且齊東渚鉅海",
                "27": "南有琅邪",
                "28": "觀乎成山",
                "29": "射乎之罘",
                "30": "浮渤澥",
                "31": "遊孟諸",
                "32": "邪與肅愼爲鄰",
                "33": "右以湯谷爲界",
                "34": "秋田乎青丘",
                "35": "仿偟乎海外",
                "36": "吞若雲夢者八九",
                "37": "於其胸中曾不蔕芥",
                "38": "若乃俶儻瑰瑋",
                "39": "異方殊類",
                "40": "珍怪鳥獸",
                "41": "萬端鱗崒",
                "42": "充牣其中者",
                "43": "不可勝記",
                "44": "禹不能名",
                "45": "卨不能計",
                "46": "然在諸侯之位",
                "47": "不敢言遊戲之樂",
                "48": "苑囿之大",
                "49": "先生又見客",
                "50": "是以王辭而不復",
                "51": "何爲無以應哉"
            }
        }
    }
}