{
    "46.02": {
        "篇名": "顏延年 三月三日曲水詩序",
        "1": {
            "3": {
                "1": "夫方策旣載",
                "2": "皇王之迹已殊",
                "3": "鐘石畢陳",
                "4": "舞詠之情不一",
                "5": "雖淵流遂往",
                "6": "詳略異聞",
                "7": "然其宅天衷",
                "8": "立民極",
                "9": "莫不崇尙其道",
                "10": "神明其位",
                "11": "拓世貽統",
                "12": "固萬葉而爲量者也"
            }
        },
        "2": {
            "5": {
                "1": "有宋函夏",
                "2": "帝圖弘遠",
                "3": "高祖以聖武定鼎",
                "4": "規同造物",
                "5": "皇上以叡文承歷",
                "6": "景屬宸居",
                "7": "隆周之卜旣永",
                "8": "宗漢之兆在焉",
                "9": "正體毓德於少陽",
                "10": "王宰宣哲於元輔",
                "11": "晷緯昭應",
                "12": "山瀆效靈",
                "13": "五方雜遝",
                "14": "四隩來曁",
                "15": "選賢建戚",
                "16": "則宅之於茂典",
                "17": "施命發號",
                "18": "必酌之於故實",
                "19": "大予協樂",
                "20": "上庠肆教",
                "21": "章程明密",
                "22": "品式周備",
                "23": "國容視令而動",
                "24": "軍政象物而具",
                "25": "箴闕記言",
                "26": "校文講藝之官",
                "27": "采遺於內",
                "28": "輶車朱軒",
                "29": "懷荒振遠之使",
                "30": "論德於外",
                "31": "赬莖素毳",
                "32": "幷柯共穗之瑞",
                "33": "史不絕書",
                "34": "棧山航海",
                "35": "踰沙軼漠之貢",
                "36": "府無虛月",
                "37": "烈燧千城",
                "38": "通驛萬里",
                "39": "穹居之君",
                "40": "內首稟朔",
                "41": "卉服之酋",
                "42": "回面受吏",
                "43": "是以異人慕響",
                "44": "俊民間出",
                "45": "警蹕清夷",
                "46": "表裏悅穆",
                "47": "將徙縣中宇",
                "48": "張樂岱郊",
                "49": "增類帝之宮",
                "50": "飭禮神之館",
                "51": "塗歌邑誦",
                "52": "以望屬車之塵者久矣"
            }
        },
        "3": {
            "7": {
                "1": "日躔胃維",
                "2": "月軌青陸",
                "3": "皇祇發生之始",
                "4": "后王布和之辰",
                "5": "思對上靈之心",
                "6": "以惠庶萌之願",
                "7": "加以二王於邁",
                "8": "出餞戒告",
                "9": "有詔掌故",
                "10": "爰命司歷",
                "11": "獻洛飲之禮",
                "12": "具上巳之儀",
                "13": "南除輦道",
                "14": "北清禁林",
                "15": "左關巖隥",
                "16": "右梁潮源",
                "17": "略亭皋",
                "18": "跨芝廛",
                "19": "苑太液",
                "20": "懷曾山",
                "21": "松石峻垝",
                "22": "蔥翠陰煙",
                "23": "遊泳之所攢萃",
                "24": "翔驟之所往還",
                "25": "於是離宮設衞",
                "26": "別殿周徼旌門洞立",
                "27": "延帷接枑",
                "28": "閱水環階",
                "29": "引池分席",
                "30": "春官聯事",
                "31": "蒼靈奉塗",
                "32": "然後升祕駕",
                "33": "胤緹騎",
                "34": "搖玉鸞",
                "35": "發流吹",
                "36": "天動神移",
                "37": "淵旋雲被",
                "38": "以降於行所",
                "39": "禮也"
            }
        },
        "4": {
            "9": {
                "1": "旣而帝暉臨幄",
                "2": "百司定列",
                "3": "鳳蓋俄軫",
                "4": "虹旗委旆",
                "5": "肴蔌芬藉",
                "6": "觴醳泛浮",
                "7": "姸歌妙舞之容",
                "8": "銜組樹羽之器",
                "9": "三奏四上之調",
                "10": "六莖九成之曲",
                "11": "競氣繁聲",
                "12": "合變爭節",
                "13": "龍文飾轡",
                "14": "青翰侍御",
                "15": "華裔殷至",
                "16": "觀聽騖集",
                "17": "揚袂風山",
                "18": "舉袖陰澤",
                "19": "靚莊藻野",
                "20": "袨服縟川",
                "21": "故以殷賑外區",
                "22": "煥衍都內者矣",
                "23": "上膺萬壽",
                "24": "下禔百福帀筵稟和",
                "25": "闔堂依德",
                "26": "情盤景遽",
                "27": "歡洽日斜",
                "28": "金駕總駟",
                "29": "聖儀載佇",
                "30": "悵鈞臺之未臨",
                "31": "慨酆宮之不縣",
                "32": "方且排鳳闕以高遊",
                "33": "開爵園而廣宴",
                "34": "並命在位",
                "35": "展詩發志",
                "36": "則夫誦美有章",
                "37": "陳信無愧者歟"
            }
        }
    }
}