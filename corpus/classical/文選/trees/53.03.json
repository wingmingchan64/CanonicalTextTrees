{
    "53.03": {
        "篇名": "陸士衡 辯亡論上下二首",
        "1": {
            "3": {
                "1": "昔漢氏失御",
                "2": "姦臣竊命",
                "3": "禍基京畿",
                "4": "毒遍宇內",
                "5": "皇綱弛紊",
                "6": "王室遂卑",
                "7": "於是羣雄蜂駭",
                "8": "義兵四合",
                "9": "吳武烈皇帝慷慨下國",
                "10": "電發荊南",
                "11": "權略紛紜",
                "12": "忠勇伯世",
                "13": "威稜則夷羿震盪",
                "14": "兵交則醜虜授馘",
                "15": "遂掃清宗祊",
                "16": "蒸禋皇祖",
                "17": "於時雲興之將帶州",
                "18": "飆起之師跨邑",
                "19": "哮闞之羣風驅",
                "20": "熊羆之眾霧集",
                "21": "雖兵以義合",
                "22": "同盟戮力",
                "23": "然皆苞藏禍心",
                "24": "阻兵怙亂",
                "25": "或師無謀律",
                "26": "喪威稔寇",
                "27": "忠規武節",
                "28": "未有如此其著者也"
            }
        },
        "2": {
            "5": {
                "1": "武烈旣沒",
                "2": "長沙桓王逸才命世",
                "3": "弱冠秀發",
                "4": "招攬遺老",
                "5": "與之述業",
                "6": "神兵東驅",
                "7": "奮寡犯眾",
                "8": "攻無堅城之將",
                "9": "戰無交鋒之虜",
                "10": "誅叛柔服",
                "11": "而江外底定",
                "12": "飾法修師",
                "13": "則威德翕赫",
                "14": "賓禮名賢",
                "15": "而張昭爲之雄",
                "16": "交御豪俊",
                "17": "而周瑜爲之傑",
                "18": "彼二君子",
                "19": "皆弘敏而多奇",
                "20": "雅達而聰哲",
                "21": "故同方者以類附",
                "22": "等契者以氣集",
                "23": "而江東蓋多士矣",
                "24": "將北伐諸華",
                "25": "誅鉏干紀",
                "26": "旋皇輿於夷庚",
                "27": "反帝座乎紫闥",
                "28": "挾天子以令諸侯",
                "29": "清天步而歸舊物",
                "30": "戎車旣次",
                "31": "羣凶側目",
                "32": "大業未就",
                "33": "中世而殞",
                "34": "用集我大皇帝以奇蹤襲於逸軌",
                "35": "叡心因於令圖",
                "36": "從政咨於故實",
                "37": "播憲稽乎遺風",
                "38": "而加之以篤固",
                "39": "申之以節儉",
                "40": "疇咨俊茂",
                "41": "好謀善斷",
                "42": "束帛旅於丘園",
                "43": "旌命交於塗巷",
                "44": "故豪彥尋聲而響臻",
                "45": "志士希光而景騖",
                "46": "異人輻湊",
                "47": "猛士如林",
                "48": "於是張昭爲師傅",
                "49": "周瑜陸公魯肅呂蒙之儔",
                "50": "入爲腹心",
                "51": "出作股肱",
                "52": "甘寧凌統程普賀齊朱桓朱然之徒",
                "53": "奮其威",
                "54": "韓當潘璋黃蓋蔣欽周泰之屬宣其力",
                "55": "風雅則諸葛瑾張承步騭",
                "56": "以名聲光國",
                "57": "政事則顧雍潘濬呂範呂岱",
                "58": "以器任幹職",
                "59": "奇偉則虞翻陸績張溫張惇",
                "60": "以諷議舉正",
                "61": "奉使則趙咨沈珩以敏達延譽",
                "62": "術數則吳範趙達",
                "63": "以禨祥協德",
                "64": "董襲陳武",
                "65": "殺身以衞主",
                "66": "駱統劉基",
                "67": "彊諫以補過",
                "68": "謀無遺諝",
                "69": "舉不失策",
                "70": "故遂割據山川",
                "71": "跨制荊吳",
                "72": "而與天下爭衡矣"
            }
        },
        "3": {
            "7": {
                "1": "魏氏嘗藉戰勝之威",
                "2": "率百萬之師",
                "3": "浮鄧塞之舟",
                "4": "下漢陰之眾",
                "5": "羽楫萬計",
                "6": "龍躍順流",
                "7": "銳騎千旅",
                "8": "虎步原隰",
                "9": "喟然有吞江滸之志",
                "10": "一宇宙之氣",
                "11": "而周瑜驅我偏師",
                "12": "黜之赤壁",
                "13": "喪旗亂轍",
                "14": "僅而獲免",
                "15": "收迹遠遁",
                "16": "漢王亦憑帝王之號",
                "17": "帥巴漢之民",
                "18": "乘危騁變",
                "19": "結壘千里",
                "20": "志報關羽之敗",
                "21": "圖收湘西之地",
                "22": "而陸公亦挫之西陵",
                "23": "覆師敗績",
                "24": "困而後濟",
                "25": "絕命永安",
                "26": "續以濡須之寇",
                "27": "臨川摧銳",
                "28": "蓬籠之戰",
                "29": "孑輪不反",
                "30": "由是二邦之將",
                "31": "喪氣挫鋒",
                "32": "勢衄財匱",
                "33": "而吳莞然坐乘其敝",
                "34": "故魏人請好",
                "35": "漢氏乞盟",
                "36": "遂躋天號",
                "37": "鼎跱而立",
                "38": "西屠庸益之郊",
                "39": "北裂淮漢之涘",
                "40": "東包百越之地",
                "41": "南括羣蠻之表",
                "42": "於是講八代之禮",
                "43": "蒐三王之樂",
                "44": "告類上帝",
                "45": "拱揖羣后",
                "46": "虎臣毅卒",
                "47": "循江而守",
                "48": "長棘勁鎩",
                "49": "望飆而奮",
                "50": "庶尹盡規於上",
                "51": "四民展業於下",
                "52": "化協殊裔",
                "53": "風衍遐圻",
                "54": "乃俾一介行人",
                "55": "撫巡外域",
                "56": "巨象逸駿",
                "57": "擾於外閑",
                "58": "明珠瑋寶",
                "59": "耀於內府",
                "60": "珍瑰重迹而至",
                "61": "奇玩應響而赴",
                "62": "輶軒騁於南荒",
                "63": "衝輣息於朔野",
                "64": "楊雄答劉歆書曰",
                "65": "嘗聞先代輶軒之使",
                "66": "班固漢書述曰",
                "67": "戎車七征",
                "68": "衝輣閑閑",
                "69": "字略作䡴樓也",
                "70": "音義曰",
                "71": "輣",
                "72": "兵車名也",
                "73": "薄萌切",
                "74": "齊民免干戈之患",
                "75": "戎馬無晨服之虞",
                "76": "而帝業固矣"
            }
        },
        "4": {
            "9": {
                "1": "大皇旣歿",
                "2": "幼主蒞朝",
                "3": "姦回肆虐",
                "4": "景皇聿興",
                "5": "虔修遺憲",
                "6": "政無大闕",
                "7": "守文之良主也",
                "8": "降及歸命之初",
                "9": "典刑未滅",
                "10": "故老猶存",
                "11": "大司馬陸公以文武熙朝",
                "12": "左丞相陸凱以謇諤盡規",
                "13": "而施績范愼以威重顯",
                "14": "丁奉離斐以武毅稱",
                "15": "孟宗丁固之徒爲公卿",
                "16": "樓玄賀劭之屬掌機事",
                "17": "元首雖病",
                "18": "股肱猶存",
                "19": "爰及末葉",
                "20": "羣公旣喪",
                "21": "然後黔首有瓦解之志",
                "22": "皇家有土崩之釁",
                "23": "歷命應化而微",
                "24": "王師躡運而發",
                "25": "卒散於陣",
                "26": "民奔於邑",
                "27": "城池無藩籬之固",
                "28": "山川無溝阜之勢",
                "29": "非有工輸雲梯之械",
                "30": "智伯灌激之害",
                "31": "楚子築室之圍",
                "32": "燕人濟西之隊",
                "33": "軍未浹辰",
                "34": "而社稷夷矣",
                "35": "雖忠臣孤憤",
                "36": "烈士死節",
                "37": "將奚救哉"
            }
        },
        "5": {
            "11": {
                "1": "夫曹劉之將",
                "2": "非一世所選",
                "3": "向時之師",
                "4": "無曩日之眾",
                "5": "戰守之道",
                "6": "抑有前符",
                "7": "險阻之利",
                "8": "俄然未改",
                "9": "而成敗貿理",
                "10": "古今詭趣",
                "11": "何哉",
                "12": "彼此之化殊",
                "13": "授任之才異也"
            }
        }
    }
}