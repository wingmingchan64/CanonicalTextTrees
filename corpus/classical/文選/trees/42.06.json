{
    "42.06": {
        "篇名": "曹子建 與吳季重書",
        "1": {
            "3": {
                "1": "植白",
                "2": "季重足下",
                "3": "前日雖因常調",
                "4": "得爲密坐",
                "5": "雖燕飲彌日",
                "6": "其於別遠會稀",
                "7": "猶不盡其勞積也",
                "8": "若夫觴酌凌波於前",
                "9": "簫笳發音於後",
                "10": "足下鷹揚其體",
                "11": "鳳歎虎視",
                "12": "謂蕭曹不足儔",
                "13": "衞霍不足侔也",
                "14": "左顧右眄",
                "15": "謂若無人",
                "16": "豈非君子壯志哉",
                "17": "過屠門而大嚼雖不得肉",
                "18": "貴且快意",
                "19": "當斯之時",
                "20": "願舉太山以爲肉",
                "21": "傾東海以爲酒",
                "22": "伐雲夢之竹以爲笛",
                "23": "斬泗濱之梓以爲箏",
                "24": "食若塡巨壑",
                "25": "飲若灌漏卮",
                "26": "其樂固難量",
                "27": "豈非大丈夫之樂哉",
                "28": "然日不我與",
                "29": "曜靈急節",
                "30": "面有逸量之速",
                "31": "別有參商之闊",
                "32": "思欲抑六龍之首",
                "33": "頓羲和之轡",
                "34": "折若木之華",
                "35": "閉濛汜之谷",
                "36": "天路高邈",
                "37": "良久無緣",
                "38": "懷戀反側",
                "39": "如何如何"
            }
        },
        "2": {
            "5": {
                "1": "得所來訊",
                "2": "文采委曲",
                "3": "曄若春榮",
                "4": "瀏若清風",
                "5": "申詠反覆",
                "6": "曠若復面",
                "7": "其諸賢所著文章",
                "8": "想還所治",
                "9": "復申詠之也",
                "10": "可令埙事小吏諷而誦之",
                "11": "夫文章之難",
                "12": "非獨今也",
                "13": "古之君子",
                "14": "猶亦病諸",
                "15": "家有千里",
                "16": "驥而不珍焉",
                "17": "人懷盈尺",
                "18": "和氏無貴矣",
                "19": "夫君子而知音樂",
                "20": "古之達論",
                "21": "謂之通而蔽",
                "22": "墨翟不好伎",
                "23": "何爲過朝歌而迴車乎",
                "24": "足下好伎",
                "25": "値墨翟迴車之縣",
                "26": "想足下助我張目也"
            }
        },
        "3": {
            "7": {
                "1": "又聞足下在彼",
                "2": "自有佳政",
                "3": "夫求而不得者有之矣",
                "4": "未有不求而得者也",
                "5": "且改轍易行",
                "6": "非良樂之御",
                "7": "易民而治",
                "8": "非楚鄭之政",
                "9": "願足下勉之而已矣",
                "10": "適對嘉賓",
                "11": "口授不悉",
                "12": "往來數相聞",
                "13": "曹植白"
            }
        }
    }
}