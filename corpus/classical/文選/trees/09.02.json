{
    "09.02": {
        "篇名": "潘安仁 射雉賦",
        "1": {
            "3": {
                "1": "涉青林以遊覽兮",
                "2": "樂羽族之羣飛",
                "3": "聿采毛之英麗兮",
                "4": "有五色之名翬",
                "5": "厲耿介之專心兮",
                "6": "奓雄豔之姱姿",
                "7": "巡丘陵以經略兮",
                "8": "畫墳衍而分畿"
            }
        },
        "2": {
            "5": {
                "1": "於時青陽告謝",
                "2": "朱明肇授",
                "3": "靡木不滋",
                "4": "無草不茂",
                "5": "初莖蔚其曜新",
                "6": "陳柯槭以改舊",
                "7": "天泱泱以垂雲",
                "8": "泉涓涓而吐溜",
                "9": "麥漸漸以擢芒",
                "10": "雉鷕鷕而朝鴝",
                "11": "眄箱籠以揭驕",
                "12": "睨驍媒之變態",
                "13": "奮勁骹以角槎",
                "14": "瞵悍目以旁睞",
                "15": "鶯綺翼而䞓撾",
                "16": "灼繡頸而衮背",
                "17": "鬱軒翥以餘怒",
                "18": "思長鳴以效能"
            }
        },
        "3": {
            "7": {
                "1": "爾乃搫場拄翳",
                "2": "停僮蔥翠",
                "3": "綠柏參差",
                "4": "文翮鱗次",
                "5": "蕭森繁茂",
                "6": "婉轉輕利",
                "7": "衷料戾以徹鑒",
                "8": "表厭躡以密緻",
                "9": "恐吾遊之晏起",
                "10": "慮原禽之罕至",
                "11": "甘疲心於企想",
                "12": "分倦目以寓視",
                "13": "何調翰之喬桀",
                "14": "邈疇類而殊才",
                "15": "候扇舉而清叫",
                "16": "野聞聲而應媒",
                "17": "褰微罟以長眺",
                "18": "已踉蹡而徐來",
                "19": "摛朱冠之赩赫",
                "20": "敷藻翰之陪鰓",
                "21": "首葯綠素",
                "22": "身拕黼繪",
                "23": "青鞦莎靡",
                "24": "丹臆蘭綷",
                "25": "或蹶或啄",
                "26": "時行時止",
                "27": "班尾揚翹",
                "28": "雙角特起"
            }
        },
        "4": {
            "9": {
                "1": "良遊呃喔",
                "2": "引之規裏",
                "3": "應叱愕立",
                "4": "擢身竦峙",
                "5": "捧黃間以密彀",
                "6": "屬剛罫以潛擬",
                "7": "倒禽紛以逬落",
                "8": "機聲振而未已",
                "9": "山鷩悍害",
                "10": "猋迅已甚",
                "11": "越壑凌岑",
                "12": "飛鳴薄廩",
                "13": "鯨牙低鏃",
                "14": "心平望審",
                "15": "毛體摧落",
                "16": "霍若碎錦",
                "17": "逸羣之儁",
                "18": "擅場挾兩",
                "19": "櫟雌妬異",
                "20": "倏來忽往",
                "21": "忌上風之餮切",
                "22": "畏映日之儻朗",
                "23": "屛發布而累息",
                "24": "徒心煩而技懩",
                "25": "伊義鳥之應敵",
                "26": "啾擭地以厲響",
                "27": "彼聆音而徑進",
                "28": "忽交距以接壤",
                "29": "彤盈窗以美發",
                "30": "紛首頹而臆仰"
            }
        },
        "5": {
            "11": {
                "1": "或乃崇墳夷靡",
                "2": "農不易壟",
                "3": "稊菽藂糅",
                "4": "蘙薈菶茸",
                "5": "鳴雄振羽",
                "6": "依於其冢",
                "7": "㨛降丘以馳敵",
                "8": "雖形隱而草動",
                "9": "瞻挺穟之傾掉",
                "10": "意淰躍以振踊",
                "11": "暾出苗以入場",
                "12": "愈情駭而神悚",
                "13": "望黶合而翳皛",
                "14": "雉脥肩而旋踵",
                "15": "俽余志之精銳",
                "16": "擬青顱而點項",
                "17": "亦有目不步體",
                "18": "邪眺旁剔",
                "19": "靡聞而驚",
                "20": "無見自䳮",
                "21": "周環回復",
                "22": "繚繞磐辟",
                "23": "戾翳旋把",
                "24": "縈隨所歷",
                "25": "彳亍中輟",
                "26": "馥焉中鏑",
                "27": "前𠜺重膺",
                "28": "傍截疊翮"
            }
        },
        "6": {
            "13": {
                "1": "若夫多疑少決",
                "2": "膽劣心狷",
                "3": "內無固守",
                "4": "出不交戰",
                "5": "來若處子",
                "6": "去如激電",
                "7": "闚䦓𧆇葉",
                "8": "幎歷乍見",
                "9": "於是筭分銖",
                "10": "商遠邇",
                "11": "揆懸刀",
                "12": "騁絕技",
                "13": "如䡹如軒",
                "14": "不高不埤",
                "15": "當咮値胸",
                "16": "裂膆破觜",
                "17": "夷險殊地",
                "18": "馴粗異變",
                "19": "𣅳不暇食",
                "20": "夕不告勌",
                "21": "昔賈氏之如皋",
                "22": "始解顏於一箭",
                "23": "醜夫爲之改貌",
                "24": "憾妻爲之釋怨",
                "25": "彼遊田之致獲",
                "26": "咸乘危以馳騖",
                "27": "何斯藝之安逸",
                "28": "羌禽從其己豫",
                "29": "清道而行",
                "30": "擇地而住",
                "31": "尾飾鑣而在服",
                "32": "肉登俎而永御",
                "33": "豈唯皁隸",
                "34": "此焉君舉"
            }
        },
        "7": {
            "15": {
                "1": "若乃耽槃流遁",
                "2": "放心不移",
                "3": "忘其身卹",
                "4": "司其雄雌",
                "5": "樂而無節",
                "6": "端操或虧",
                "7": "此則老氏所誡",
                "8": "君子不爲"
            }
        }
    }
}