{
    "23.08-02": {
        "篇名": "潘安仁 悼亡詩三首·其二",
        "1": {
            "3": {
                "1": "皎皎窗中月",
                "2": "照我室南端",
                "3": "清商應秋至",
                "4": "溽暑隨節闌",
                "5": "凜凜涼風升",
                "6": "始覺夏衾單",
                "7": "豈曰無重纊",
                "8": "誰與同歲寒",
                "9": "歲寒無與同",
                "10": "朗月何朧朧",
                "11": "展轉眄枕席",
                "12": "長簟竟牀空",
                "13": "牀空委清塵",
                "14": "室虛來悲風",
                "15": "獨無李氏靈",
                "16": "髣髴覩爾容",
                "17": "撫衿長歎息",
                "18": "不覺涕霑胸",
                "19": "霑胸安能已",
                "20": "悲懷從中起",
                "21": "寢興目存形",
                "22": "遺音猶在耳",
                "23": "上慚東門吳",
                "24": "下愧蒙莊子",
                "25": "賦詩欲言志",
                "26": "此志難具紀",
                "27": "命也可柰何",
                "28": "長戚自令鄙"
            }
        }
    }
}