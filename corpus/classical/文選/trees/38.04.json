{
    "38.04": {
        "篇名": "殷仲文 解尙書表",
        "1": {
            "3": {
                "1": "臣聞洪波振壑",
                "2": "川無恬鱗",
                "3": "驚飆拂野",
                "4": "林無靜柯",
                "5": "何者",
                "6": "勢弱則受制於巨力",
                "7": "質微則莫以自保",
                "8": "於理雖可得而言",
                "9": "於臣寔所敢喩",
                "10": "昔桓玄之世",
                "11": "誠復驅迫者眾",
                "12": "至於愚臣",
                "13": "罪實深矣",
                "14": "進不能見危授命",
                "15": "忘身殉國",
                "16": "退不能辭粟首陽",
                "17": "拂衣高謝",
                "18": "遂乃宴安昏寵",
                "19": "叨昧僞封",
                "20": "錫文篡事",
                "21": "曾無獨固",
                "22": "名義以之俱淪",
                "23": "情節自茲兼撓",
                "24": "宜其極法",
                "25": "以判忠邪",
                "26": "鎭軍臣裕",
                "27": "匡復社稷",
                "28": "大弘善貸",
                "29": "佇一戮於微命",
                "30": "申三驅於大信",
                "31": "旣惠之以首領",
                "32": "復引之以縶維",
                "33": "於時皇輿否隔",
                "34": "天人未泰",
                "35": "用忘進退",
                "36": "惟力是視",
                "37": "是以僶俛從事",
                "38": "自同全人",
                "39": "今宸極反正",
                "40": "惟新告始",
                "41": "憲章旣明",
                "42": "品物思舊",
                "43": "臣亦胡顏之厚",
                "44": "可以顯居榮次",
                "45": "乞解所職",
                "46": "待罪私門",
                "47": "違謝闕庭",
                "48": "乃心愧戀",
                "49": "謹拜表以聞",
                "50": "臣某云云"
            }
        }
    }
}