{
    "19.05-03": {
        "篇名": "束廣微 補亡詩六首華黍。時和歲豐。宜黍稷也。",
        "1": {
            "3": {
                "1": "黮黮重雲",
                "2": "輯輯和風",
                "3": "黍華陵巓 ",
                "4": "麥秀丘中",
                "5": "靡田不播",
                "6": "九穀斯豐",
                "7": "奕奕玄霄",
                "8": "濛濛甘霤",
                "9": "黍發稠華",
                "10": "亦挺其秀",
                "11": "靡田不殖",
                "12": "九穀斯茂",
                "13": "無高不播",
                "14": "無下不殖",
                "15": "芒芒其稼",
                "16": "參參其穡",
                "17": "稸我王委",
                "18": "充我民食",
                "19": "玉燭陽明",
                "20": "顯猷翼翼"
            }
        }
    }
}