{
    "33.05-05": {
        "篇名": "宋玉 九辯五首·其五",
        "1": {
            "3": {
                "1": "何時俗之工巧兮",
                "2": "背繩墨而改錯",
                "3": "卻騏驥而不乘兮",
                "4": "策駑駘而取路",
                "5": "當世豈無騏驥兮",
                "6": "誠莫之能善御",
                "7": "見執轡者非其人兮",
                "8": "故駒跳而遠去",
                "9": "鳧雁皆唼夫梁藻兮",
                "10": "鳳愈飄翔而高舉",
                "11": "圜鑿而方枘兮",
                "12": "吾固知其鉏鋙而難入",
                "13": "眾鳥皆有所登栖兮",
                "14": "鳳獨遑遑而無所集",
                "15": "願銜枚而無言兮",
                "16": "常被君之渥洽",
                "17": "太公九十乃顯榮兮",
                "18": "誠未遇其匹合",
                "19": "謂騏驥兮安歸",
                "20": "謂鳳皇兮安栖",
                "21": "變古易俗兮世衰",
                "22": "今之相者兮舉肥",
                "23": "騏驥伏匿而不見兮",
                "24": "鳳皇高飛而不下",
                "25": "鳥獸猶知懷德兮",
                "26": "何云賢士之不處",
                "27": "驥不驟進而求服兮",
                "28": "鳳亦不貪餧而妄食",
                "29": "君棄遠而不察兮",
                "30": "雖願忠其焉得",
                "31": "欲寂寞而絕端兮",
                "32": "竊不敢忘初之厚德",
                "33": "獨悲愁其傷人兮",
                "34": "馮鬱鬱其何極"
            }
        }
    }
}