{
    "24.05-04": {
        "篇名": "曹子建 贈白馬王彪·其四",
        "1": {
            "3": {
                "1": "踟躕亦何留",
                "2": "相思無終極",
                "3": "秋風發微涼",
                "4": "寒蟬鳴我側",
                "5": "原野何蕭條",
                "6": "白日忽西匿",
                "7": "歸鳥赴喬林",
                "8": "翩翩厲羽翼",
                "9": "孤獸走索羣",
                "10": "銜草不遑食",
                "11": "感物傷我懷",
                "12": "撫心長太息"
            }
        }
    }
}