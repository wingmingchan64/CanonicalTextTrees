{
    "11.05": {
        "篇名": "何平叔 景福殿賦",
        "1": {
            "3": {
                "1": "大哉惟魏",
                "2": "世有哲聖",
                "3": "武創元基",
                "4": "文集大命",
                "5": "皆體天作制",
                "6": "順時立政",
                "7": "至於帝皇",
                "8": "遂重熙而累盛",
                "9": "遠則襲陰陽之自然",
                "10": "近則本人物之至情",
                "11": "上則崇稽古之弘道",
                "12": "下則闡長世之善經",
                "13": "庶事旣康",
                "14": "天秩孔明",
                "15": "故載祀二三",
                "16": "而國富刑清",
                "17": "歲三月",
                "18": "東巡狩",
                "19": "至於許昌",
                "20": "望祠山川",
                "21": "考時度方",
                "22": "存問高年",
                "23": "率民耕桑",
                "24": "越六月旣望",
                "25": "林鍾紀律",
                "26": "大火昏正",
                "27": "桑梓繁廡",
                "28": "大雨時行",
                "29": "三事九司",
                "30": "宏儒碩生",
                "31": "感乎溽暑之伊鬱",
                "32": "而慮性命之所平",
                "33": "惟岷越之不靜",
                "34": "寤征行之未寧"
            }
        },
        "2": {
            "5": {
                "1": "乃昌言曰",
                "2": "昔在蕭公",
                "3": "曁於孫卿",
                "4": "皆先識博覽",
                "5": "明允篤誠",
                "6": "莫不以爲不壯不麗",
                "7": "不足以一民而重威靈",
                "8": "不飭不美",
                "9": "不足以訓後而永厥成",
                "10": "故當時享其功利",
                "11": "後世賴其英聲",
                "12": "且許昌者",
                "13": "乃大運之攸戾",
                "14": "圖讖之所旌",
                "15": "苟德義其如斯",
                "16": "夫何宮室之勿營",
                "17": "帝曰",
                "18": "兪哉",
                "19": "玄輅旣駕",
                "20": "輕裘斯御",
                "21": "乃命有司",
                "22": "禮儀是具",
                "23": "審量日力",
                "24": "詳度費務",
                "25": "鳩經始之黎民",
                "26": "輯農功之暇豫",
                "27": "因東師之獻捷",
                "28": "就海孼之賄賂",
                "29": "立景福之祕殿",
                "30": "備皇居之制度"
            }
        },
        "3": {
            "7": {
                "1": "爾乃豐層覆之耽耽",
                "2": "建高基之堂堂",
                "3": "羅疏柱之汩越",
                "4": "肅坻鄂之鏘鏘",
                "5": "飛櫩翼以軒翥",
                "6": "反宇䡾以高驤",
                "7": "流羽毛之威蕤",
                "8": "垂環玭之琳琅",
                "9": "參旗九旒",
                "10": "從風飄揚",
                "11": "皓皓旰旰",
                "12": "丹彩煌煌",
                "13": "故其華表",
                "14": "則鎬鎬鑠鑠",
                "15": "赫奕章灼",
                "16": "若日月之麗天也",
                "17": "其奧祕則蘙蔽曖昧",
                "18": "髣彿退槪",
                "19": "若幽星之纚連也",
                "20": "旣櫛比而攢集",
                "21": "又宏璉以豐敞",
                "22": "兼苞博落",
                "23": "不常一象",
                "24": "遠而望之",
                "25": "若摛朱霞而耀天文",
                "26": "迫而察之",
                "27": "若仰崇山而戴垂雲",
                "28": "羌瑰瑋以壯麗",
                "29": "紛彧彧其難分",
                "30": "此其大較也",
                "31": "若乃高甍崔嵬",
                "32": "飛宇承霓",
                "33": "綿蠻黮䨴",
                "34": "隨雲融泄",
                "35": "鳥企山峙",
                "36": "若翔若滯",
                "37": "峨峨嶪嶪",
                "38": "罔識所屆",
                "39": "雖離朱之至精",
                "40": "猶眩曜而不能昭晰也"
            }
        },
        "4": {
            "9": {
                "1": "爾乃開南端之豁達",
                "2": "張筍虡之輪豳",
                "3": "華鍾杌其高懸",
                "4": "悍獸仡以儷陳",
                "5": "體洪剛之猛毅",
                "6": "聲訇𥉻其若震爰有遐狄",
                "7": "鐐質輪菌",
                "8": "坐高門之側堂",
                "9": "彰聖主之威神",
                "10": "芸若充庭",
                "11": "槐楓被宸",
                "12": "綴以萬年",
                "13": "綷以紫榛",
                "14": "或以嘉名取寵",
                "15": "或以美材見珍",
                "16": "結實商秋",
                "17": "敷華青春",
                "18": "藹藹萋萋",
                "19": "馥馥芬芬",
                "20": "爾其結構",
                "21": "則修梁彩制",
                "22": "下褰上奇",
                "23": "桁梧複疊",
                "24": "勢合形離",
                "25": "赩如宛虹",
                "26": "赫如奔螭",
                "27": "南距陽榮",
                "28": "北極幽崖",
                "29": "任重道遠",
                "30": "厥庸孔多"
            }
        },
        "5": {
            "11": {
                "1": "於是列髹彤之繡桷",
                "2": "垂琬琰之文璫",
                "3": "蝹若神龍之登降",
                "4": "灼若明月之流光",
                "5": "爰有禁楄",
                "6": "勒分翼張",
                "7": "承以陽馬",
                "8": "接以員方",
                "9": "斑間賦白",
                "10": "疏密有章",
                "11": "飛枊鳥踊",
                "12": "雙轅是荷",
                "13": "赴險凌虛",
                "14": "獵捷相加",
                "15": "皎皎白間",
                "16": "離離列錢",
                "17": "晨光內照",
                "18": "流景外烻",
                "19": "烈若鉤星在漢",
                "20": "煥若雲梁承天",
                "21": "騧徙增錯",
                "22": "轉縣成郛",
                "23": "茄蔤倒植",
                "24": "吐被芙蕖",
                "25": "繚以藻井",
                "26": "編以綷疏",
                "27": "紅葩𦾏𦁛",
                "28": "丹綺離婁菡萏赩翕",
                "29": "纖縟紛敷",
                "30": "繁飾累巧",
                "31": "不可勝書"
            }
        },
        "6": {
            "13": {
                "1": "於是蘭栭積重",
                "2": "寠數矩設",
                "3": "櫼櫨各落以相承",
                "4": "欒栱夭蟜而交結",
                "5": "金楹齊列",
                "6": "玉舄承跋",
                "7": "青瑣銀鋪",
                "8": "是爲閨闥",
                "9": "雙枚旣修",
                "10": "重桴乃飾",
                "11": "㮰梠緣邊",
                "12": "周流四極",
                "13": "侯衞之班",
                "14": "藩服之職",
                "15": "溫房承其東序",
                "16": "涼室處其西偏",
                "17": "開建陽則朱炎豔",
                "18": "啟金光則清風臻",
                "19": "故冬不淒寒",
                "20": "夏無炎燀",
                "21": "鈞調中適",
                "22": "可以永年",
                "23": "墉垣碭基",
                "24": "其光昭昭",
                "25": "周制白盛",
                "26": "今也惟縹",
                "27": "落帶金釭",
                "28": "此焉二等",
                "29": "明珠翠羽",
                "30": "往往而在",
                "31": "欽先王之允塞",
                "32": "悅重華之無爲",
                "33": "命共工使作繢",
                "34": "明五采之彰施",
                "35": "圖象古昔",
                "36": "以當箴規",
                "37": "椒房之列",
                "38": "是準是儀",
                "39": "觀虞姬之容止",
                "40": "知治國之佞臣",
                "41": "見姜后之解珮",
                "42": "寤前世之所遵",
                "43": "賢鍾離之讜言",
                "44": "懿楚樊之退身",
                "45": "嘉班妾之辭輦",
                "46": "偉孟母之擇鄰",
                "47": "故將廣智",
                "48": "必先多聞",
                "49": "多聞多雜",
                "50": "多雜眩眞",
                "51": "不眩焉在",
                "52": "在乎擇人",
                "53": "故將立德",
                "54": "必先近仁",
                "55": "欲此禮之不諐",
                "56": "是以盡乎行道之先民",
                "57": "朝觀夕覽",
                "58": "何與書紳"
            }
        },
        "7": {
            "15": {
                "1": "若乃階除連延",
                "2": "蕭曼雲征",
                "3": "櫺檻邳張",
                "4": "鉤錯矩成",
                "5": "楯類騰蛇",
                "6": "槢似瓊英",
                "7": "如螭之蟠",
                "8": "如虯之停",
                "9": "玄軒交登",
                "10": "光藻昭明",
                "11": "騶虞承獻",
                "12": "素質仁形",
                "13": "彰天瑞之休顯",
                "14": "照遠戎之來庭",
                "15": "陰堂承北",
                "16": "方軒九戶",
                "17": "右个清宴",
                "18": "西東其宇",
                "19": "連以永寧",
                "20": "安昌臨圃",
                "21": "遂及百子",
                "22": "後宮攸處",
                "23": "處之斯何",
                "24": "窈窕淑女",
                "25": "思齊徽音",
                "26": "聿求多祜",
                "27": "其祜伊何",
                "28": "宜爾子孫",
                "29": "克明克哲",
                "30": "克聰克敏",
                "31": "永錫難老",
                "32": "兆民賴止",
                "33": "於南則有承光前殿",
                "34": "賦政之宮",
                "35": "納賢用能",
                "36": "詢道求中",
                "37": "疆理宇宙",
                "38": "甄陶國風",
                "39": "雲行雨施",
                "40": "品物咸融",
                "41": "其西則有左墄右平",
                "42": "講肄之場",
                "43": "二六對陳",
                "44": "殿翼相當",
                "45": "僻脫承便",
                "46": "蓋象戎兵",
                "47": "察解言歸",
                "48": "譬諸政刑",
                "49": "將以行令",
                "50": "豈唯娛情",
                "51": "鎭以崇臺",
                "52": "寔曰永始",
                "53": "複閣重闈",
                "54": "猖狂是俟",
                "55": "京庾之儲",
                "56": "無物不有",
                "57": "不虞之戒",
                "58": "於是焉取"
            }
        },
        "8": {
            "17": {
                "1": "爾乃建凌雲之層盤",
                "2": "浚虞淵之靈沼",
                "3": "清露瀼瀼",
                "4": "淥水浩浩",
                "5": "樹以嘉木",
                "6": "植以芳草",
                "7": "悠悠玄魚",
                "8": "曤曤白鳥",
                "9": "沈浮翱翔",
                "10": "樂我皇道",
                "11": "若乃虯龍灌注",
                "12": "溝洫交流",
                "13": "陸設殿館",
                "14": "水方輕舟",
                "15": "篁栖鵾鷺",
                "16": "瀨戲鰋鮋豐侔淮海",
                "17": "富賑山丘",
                "18": "叢集委積",
                "19": "焉可殫籌",
                "20": "雖咸池之壯觀",
                "21": "夫何足以比讎"
            }
        },
        "9": {
            "19": {
                "1": "於是碣以高昌崇觀",
                "2": "表以建城峻廬",
                "3": "岧嶢岑立",
                "4": "崔嵬巒居",
                "5": "飛閣干雲",
                "6": "浮階乘虛",
                "7": "遙目九野",
                "8": "遠覽長圖",
                "9": "頫眺三市",
                "10": "孰有誰無",
                "11": "睹農人之耘耔",
                "12": "亮稼穡之艱難",
                "13": "惟饗年之豐寡",
                "14": "思無逸之所歎",
                "15": "感物眾而思深",
                "16": "因居高而慮危",
                "17": "惟天德之不易",
                "18": "懼世俗之難知",
                "19": "觀器械之良窳",
                "20": "察俗化之誠僞",
                "21": "瞻貴賤之所在",
                "22": "悟政刑之夷陂",
                "23": "亦所以省風助教",
                "24": "豈惟盤樂而崇侈靡",
                "25": "屯坊列署",
                "26": "三十有二",
                "27": "星居宿陳",
                "28": "綺錯鱗比",
                "29": "辛壬癸甲",
                "30": "爲之名秩",
                "31": "房室齊均",
                "32": "堂庭如一",
                "33": "出此入彼",
                "34": "欲反忘術",
                "35": "惟工匠之多端",
                "36": "固萬變之不窮",
                "37": "物無難而不知",
                "38": "乃與造化乎比隆",
                "39": "讎天地以開基",
                "40": "並列宿而作制",
                "41": "制無細而不協於規景",
                "42": "作無微而不違於水臬故其增構如積",
                "43": "植木如林",
                "44": "區連域絕",
                "45": "葉比枝分",
                "46": "離背別趣",
                "47": "騈田胥附",
                "48": "縱橫踰延",
                "49": "各有攸注",
                "50": "公輸荒其規矩",
                "51": "匠石不知其所斲",
                "52": "旣窮巧於規摹",
                "53": "何彩章之未殫",
                "54": "爾乃文以朱綠",
                "55": "飾以碧丹",
                "56": "點以銀黃",
                "57": "爍以琅玕",
                "58": "光明熠爚",
                "59": "文彩璘班",
                "60": "清風萃而成響",
                "61": "朝日曜而增鮮",
                "62": "雖崑崙之靈宮",
                "63": "將何以乎侈旃",
                "64": "規矩旣應乎天地",
                "65": "舉措又順乎四時",
                "66": "是以六合元亨",
                "67": "九有雍熙",
                "68": "家懷克讓之風",
                "69": "人詠康哉之詩",
                "70": "莫不優遊以自得",
                "71": "故淡泊而無所思",
                "72": "歷列辟而論功",
                "73": "無今日之至治彼吳蜀之湮滅",
                "74": "固可翹足而待之"
            }
        },
        "10": {
            "21": {
                "1": "然而聖上猶孜孜靡忒",
                "2": "求天下之所以自悟",
                "3": "招忠正之士",
                "4": "開公直之路",
                "5": "想周公之昔戒",
                "6": "慕咎繇之典謨",
                "7": "除無用之官",
                "8": "省生事之故",
                "9": "絕流遁之繁禮",
                "10": "反民情於太素",
                "11": "故能翔岐陽之鳴鳳",
                "12": "納虞氏之白環",
                "13": "蒼龍覿於陂塘",
                "14": "龜書出於河源",
                "15": "醴泉涌於池圃",
                "16": "靈芝生於丘園",
                "17": "總神靈之貺祐",
                "18": "集華夏之至歡",
                "19": "方四三皇而六五帝",
                "20": "曾何周夏之足言"
            }
        }
    }
}