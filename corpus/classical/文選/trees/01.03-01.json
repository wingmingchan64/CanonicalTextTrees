{
    "01.03-01": {
        "篇名": "班孟堅 東都賦*",
        "1": {
            "3": {
                "1": "東都主人喟然而歎曰",
                "2": "痛乎風俗之移人也",
                "3": "子實秦人",
                "4": "矜夸館室",
                "5": "保界河山",
                "6": "信識昭襄而知始皇矣",
                "7": "烏睹大漢之云爲乎",
                "8": "夫大漢之開元也",
                "9": "奮布衣以登皇位",
                "10": "由數朞而創萬代",
                "11": "蓋六籍所不能談",
                "12": "前聖靡得言焉",
                "13": "當此之時",
                "14": "功有橫而當天",
                "15": "討有逆而順民",
                "16": "故婁敬度勢而獻其說",
                "17": "蕭公權宜而拓其制",
                "18": "時豈泰而安之哉",
                "19": "計不得以已也",
                "20": "吾子曾不是睹",
                "21": "顧曜後嗣之末造",
                "22": "不亦暗乎",
                "23": "今將語子以建武之治",
                "24": "永平之事",
                "25": "監於太清",
                "26": "以變子之惑志"
            }
        },
        "2": {
            "5": {
                "1": "往者王莽作逆",
                "2": "漢祚中缺",
                "3": "天人致誅",
                "4": "六合相滅",
                "5": "於時之亂",
                "6": "生人幾亡",
                "7": "鬼神泯絕",
                "8": "壑無完柩",
                "9": "郛罔遺室",
                "10": "原野厭人之肉",
                "11": "川谷流人之血",
                "12": "秦項之災猶不克半",
                "13": "書契以來未之或紀",
                "14": "故下人號而上訴",
                "15": "上帝懷而降監",
                "16": "乃致命乎聖皇",
                "17": "於是聖皇乃握乾符",
                "18": "闡坤珍",
                "19": "披皇圖",
                "20": "稽帝文",
                "21": "赫然發憤",
                "22": "應若興雲",
                "23": "霆擊昆陽",
                "24": "憑怒雷震",
                "25": "遂超大河",
                "26": "跨北嶽",
                "27": "立號高邑",
                "28": "建都河洛",
                "29": "紹百王之荒屯",
                "30": "因造化之盪滌",
                "31": "體元立制",
                "32": "繼天而作",
                "33": "系唐統",
                "34": "接漢緒",
                "35": "茂育羣生",
                "36": "恢復疆宇",
                "37": "勳兼乎在昔",
                "38": "事勤乎三五",
                "39": "豈特方軌並迹",
                "40": "紛綸后辟",
                "41": "治近古之所務",
                "42": "蹈一聖之險易云爾哉",
                "43": "且夫建武之元",
                "44": "天地革命",
                "45": "四海之內",
                "46": "更造夫婦",
                "47": "肇有父子",
                "48": "君臣初建",
                "49": "人倫寔始",
                "50": "斯乃伏犧氏之所以基皇德也",
                "51": "分州土",
                "52": "立市朝",
                "53": "作舟輿",
                "54": "造器械",
                "55": "斯乃軒轅氏之所以開帝功也",
                "56": "龔行天罰",
                "57": "應天順人",
                "58": "斯乃湯武之所以昭王業也",
                "59": "遷都改邑",
                "60": "有殷宗中興之則焉",
                "61": "卽土之中",
                "62": "有周成隆平之制焉",
                "63": "不階尺土一人之柄",
                "64": "同符乎高祖",
                "65": "克己復禮",
                "66": "以奉終始",
                "67": "允恭乎孝文",
                "68": "憲章稽古",
                "69": "封岱勒成",
                "70": "儀炳乎世宗",
                "71": "案六經而校德",
                "72": "眇古昔而論功",
                "73": "仁聖之事旣該",
                "74": "而帝王之道備矣"
            }
        },
        "3": {
            "7": {
                "1": "至乎永平之際",
                "2": "重熙而累洽",
                "3": "盛三雍之上儀",
                "4": "修衮龍之法服",
                "5": "鋪鴻藻",
                "6": "信景鑠",
                "7": "揚世廟",
                "8": "正雅樂",
                "9": "人神之和允洽",
                "10": "羣臣之序旣肅",
                "11": "乃動大輅",
                "12": "遵皇衢",
                "13": "省方巡狩",
                "14": "躬覽萬國之有無",
                "15": "考聲教之所被",
                "16": "散皇明以爥幽",
                "17": "然後增周舊",
                "18": "修洛邑",
                "19": "扇巍巍",
                "20": "顯翼翼",
                "21": "光漢京於諸夏",
                "22": "總八方而爲之極",
                "23": "於是皇城之內",
                "24": "宮室光明",
                "25": "闕庭神麗",
                "26": "奢不可踰",
                "27": "儉不能侈",
                "28": "外則因原野以作苑",
                "29": "塡流泉而爲沼",
                "30": "發蘋藻以潛魚",
                "31": "豐圃草以毓獸",
                "32": "制同乎梁鄒",
                "33": "誼合乎靈囿",
                "34": "若乃順時節而蒐狩",
                "35": "簡車徒以講武",
                "36": "則必臨之以王制",
                "37": "考之以風雅",
                "38": "歷騶虞",
                "39": "覽駟鐵",
                "40": "嘉車攻",
                "41": "采吉日",
                "42": "禮官整儀",
                "43": "乘輿乃出",
                "44": "於是發鯨魚",
                "45": "鏗華鐘",
                "46": "登玉輅",
                "47": "乘時龍",
                "48": "鳳蓋棽麗",
                "49": "龢鑾玲瓏",
                "50": "天官景從",
                "51": "寢威盛容",
                "52": "山靈護野",
                "53": "屬御方神",
                "54": "雨師泛灑",
                "55": "風伯清塵",
                "56": "千乘雷起",
                "57": "萬騎紛紜",
                "58": "元戎竟野",
                "59": "戈鋋彗雲",
                "60": "羽旄掃霓",
                "61": "旌旗拂天",
                "62": "焱焱炎炎",
                "63": "揚光飛文",
                "64": "吐爓生風",
                "65": "欱野歕山",
                "66": "日月爲之奪明",
                "67": "丘陵爲之搖震",
                "68": "遂集乎中囿",
                "69": "陳師按屯",
                "70": "騈部曲",
                "71": "列校隊",
                "72": "勒三軍",
                "73": "誓將帥",
                "74": "然後舉烽伐鼓",
                "75": "申令三驅",
                "76": "輶車霆激",
                "77": "驍騎電騖",
                "78": "由基發射",
                "79": "范氏施御",
                "80": "弦不睼禽",
                "81": "轡不詭遇",
                "82": "飛者未及翔",
                "83": "走者未及去",
                "84": "指顧倏忽",
                "85": "獲車已實",
                "86": "樂不極盤",
                "87": "殺不盡物",
                "88": "馬踠餘足",
                "89": "士怒未㳿",
                "90": "先驅復路",
                "91": "屬車案節",
                "92": "於是薦三犧",
                "93": "效五牲",
                "94": "禮神祇",
                "95": "懷百靈",
                "96": "覲明堂",
                "97": "臨辟雍",
                "98": "揚緝熙",
                "99": "宣皇風",
                "100": "登靈臺",
                "101": "考休徵",
                "102": "俯仰乎乾坤",
                "103": "參象乎聖躬",
                "104": "目中夏而布德",
                "105": "瞰四裔而抗稜",
                "106": "西盪河源",
                "107": "東澹海漘",
                "108": "北動幽崖",
                "109": "南燿朱垠",
                "110": "殊方別區",
                "111": "界絕而不鄰",
                "112": "自孝武之所不征",
                "113": "孝宣之所未臣",
                "114": "莫不陸讋水慄",
                "115": "奔走而來賓",
                "116": "遂綏哀牢",
                "117": "開永昌",
                "118": "春王三朝",
                "119": "會同漢京",
                "120": "是日也",
                "121": "天子受四海之圖籍",
                "122": "膺萬國之貢珍",
                "123": "內撫諸夏",
                "124": "外綏百蠻",
                "125": "爾乃盛禮興樂",
                "126": "供帳置乎雲龍之庭",
                "127": "陳百僚而贊羣后",
                "128": "究皇儀而展帝容",
                "129": "於是庭實千品",
                "130": "旨酒萬鍾",
                "131": "列金罍",
                "132": "班玉觴",
                "133": "嘉珍御",
                "134": "太牢饗",
                "135": "爾乃食舉雍徹",
                "136": "太師奏樂",
                "137": "陳金石",
                "138": "布絲竹",
                "139": "鐘鼓鏗鍧",
                "140": "管絃燁煜",
                "141": "抗五聲",
                "142": "極六律",
                "143": "歌九功",
                "144": "舞八佾",
                "145": "韶武備",
                "146": "泰古畢",
                "147": "四夷間奏",
                "148": "德廣所及",
                "149": "僸佅兜離",
                "150": "罔不具集",
                "151": "萬樂備",
                "152": "百禮曁",
                "153": "皇歡浹",
                "154": "羣臣醉",
                "155": "降煙熅",
                "156": "調元氣",
                "157": "然後撞鐘告罷",
                "158": "百僚遂退"
            }
        },
        "4": {
            "9": {
                "1": "於是聖上覩萬方之歡娛",
                "2": "又沐浴於膏澤",
                "3": "懼其侈心之將萌",
                "4": "而怠於東作也",
                "5": "乃申舊章",
                "6": "下明詔",
                "7": "命有司",
                "8": "班憲度",
                "9": "昭節儉",
                "10": "示太素",
                "11": "去後宮之麗飾",
                "12": "損乘輿之服御",
                "13": "抑工商之淫業",
                "14": "興農桑之盛務",
                "15": "遂令海內棄末而反本",
                "16": "背僞而歸眞",
                "17": "女修織絍",
                "18": "男務耕耘",
                "19": "器用陶匏",
                "20": "服尙素玄",
                "21": "恥纖靡而不服",
                "22": "賤奇麗而弗珍",
                "23": "捐金於山",
                "24": "沈珠於淵",
                "25": "於是百姓滌瑕盪穢",
                "26": "而鏡至清",
                "27": "形神寂漠",
                "28": "耳目弗營",
                "29": "嗜欲之源滅",
                "30": "廉恥之心生",
                "31": "莫不優遊而自得",
                "32": "玉潤而金聲",
                "33": "是以四海以內",
                "34": "學校如林",
                "35": "庠序盈門",
                "36": "獻酬交錯",
                "37": "俎豆莘莘",
                "38": "下舞上歌",
                "39": "蹈德詠仁",
                "40": "登降飫宴之禮旣畢",
                "41": "因相與嗟歎玄德",
                "42": "讜言弘說",
                "43": "咸含和而吐氣",
                "44": "頌曰",
                "45": "盛哉乎斯世"
            }
        },
        "5": {
            "11": {
                "1": "今論者但知誦虞夏之書",
                "2": "詠殷周之詩",
                "3": "講羲文之易",
                "4": "論孔氏之春秋",
                "5": "罕能精古今之清濁",
                "6": "究漢德之所由",
                "7": "唯子頗識舊典",
                "8": "又徒馳騁乎末流",
                "9": "溫故知新已難",
                "10": "而知德者鮮矣",
                "11": "且夫僻界西戎",
                "12": "險阻四塞",
                "13": "修其防禦",
                "14": "孰與處乎土中",
                "15": "平夷洞達",
                "16": "萬方輻湊",
                "17": "秦嶺九嵕",
                "18": "涇渭之川",
                "19": "曷若四瀆五嶽",
                "20": "帶河泝洛",
                "21": "圖書之淵",
                "22": "建章甘泉",
                "23": "館御列仙",
                "24": "孰與靈臺明堂",
                "25": "統和天人",
                "26": "太液昆明",
                "27": "鳥獸之囿",
                "28": "曷若辟雍海流",
                "29": "道德之富",
                "30": "遊俠踰侈",
                "31": "犯義侵禮",
                "32": "孰與同履法度",
                "33": "翼翼濟濟也",
                "34": "子徒習秦阿房之造天",
                "35": "而不知京洛之有制也",
                "36": "識函谷之可關",
                "37": "而不知王者之無外也"
            }
        },
        "6": {
            "13": {
                "1": "主人之辭未終",
                "2": "西都賓矍然失容",
                "3": "逡巡降階",
                "4": "𢛐然意下",
                "5": "捧手欲辭",
                "6": "主人曰",
                "7": "復位",
                "8": "今將授子以五篇之詩",
                "9": "賓旣卒業",
                "10": "乃稱曰",
                "11": "美哉乎斯詩",
                "12": "義正乎楊雄",
                "13": "事實乎相如",
                "14": "匪唯主人之好學",
                "15": "蓋乃遭遇乎斯時也",
                "16": "小子狂簡",
                "17": "不知所裁",
                "18": "旣聞正道",
                "19": "請終身而誦之",
                "20": "其詩曰"
            }
        }
    }
}