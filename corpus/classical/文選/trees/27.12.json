{
    "27.12": {
        "篇名": "沈休文 早發定山",
        "1": {
            "3": {
                "1": "夙齡愛遠壑",
                "2": "晚蒞見奇山",
                "3": "標峯綵虹外",
                "4": "置嶺白雲間",
                "5": "傾壁忽斜豎",
                "6": "絕頂復孤員",
                "7": "歸海流漫漫",
                "8": "出浦水淺淺",
                "9": "野棠開未落",
                "10": "山櫻發欲然",
                "11": "忘歸屬蘭杜",
                "12": "懷祿寄芳荃",
                "13": "眷言采三秀",
                "14": "徘徊望九仙"
            }
        }
    }
}