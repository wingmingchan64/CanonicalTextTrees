{
    "19.02": {
        "篇名": "宋玉 神女賦[幷序]",
        "1": {
            "3": {
                "1": "楚襄王與宋玉遊於雲夢之浦",
                "2": "使玉賦高唐之事",
                "3": "其夜玉寢",
                "4": "果夢與神女遇",
                "5": "其狀甚麗",
                "6": "玉異之",
                "7": "明日以白王",
                "8": "王曰",
                "9": "其夢若何",
                "10": "玉對曰",
                "11": "晡夕之後",
                "12": "精神怳忽",
                "13": "若有所喜",
                "14": "紛紛擾擾",
                "15": "未知何意",
                "16": "目色髣髴",
                "17": "乍若有記",
                "18": "見一婦人",
                "19": "狀甚奇異",
                "20": "寐而夢之",
                "21": "寤不自識",
                "22": "罔兮不樂",
                "23": "悵然失志",
                "24": "於是撫心定氣",
                "25": "復見所夢",
                "26": "王曰",
                "27": "狀何如也",
                "28": "玉曰",
                "29": "茂矣美矣",
                "30": "諸好備矣",
                "31": "盛矣麗矣",
                "32": "難測究矣",
                "33": "上古旣無",
                "34": "世所未見",
                "35": "瑰姿瑋態",
                "36": "不可勝贊",
                "37": "其始來也",
                "38": "耀乎若白日初出照屋梁",
                "39": "其少進也",
                "40": "皎若明月舒其光",
                "41": "須臾之間",
                "42": "美貌橫生",
                "43": "曄兮如華",
                "44": "溫乎如瑩",
                "45": "五色並馳",
                "46": "不可殫形",
                "47": "詳而視之",
                "48": "奪人目精",
                "49": "其盛飾也",
                "50": "則羅紈綺繢盛文章",
                "51": "極服妙采照萬方",
                "52": "振繡衣",
                "53": "被褂裳",
                "54": "穠不短",
                "55": "纖不長",
                "56": "步裔裔兮曜殿堂",
                "57": "忽兮改容",
                "58": "婉若遊龍乘雲翔",
                "59": "嫷被服",
                "60": "侻薄裝",
                "61": "沐蘭澤",
                "62": "含若芳",
                "63": "性和適",
                "64": "宜侍旁",
                "65": "順序卑",
                "66": "調心腸",
                "67": "王曰",
                "68": "若此盛矣",
                "69": "試爲寡人賦之",
                "70": "玉曰",
                "71": "唯唯"
            }
        },
        "2": {
            "5": {
                "1": "夫何神女之姣麗兮",
                "2": "含陰陽之渥飾",
                "3": "被華藻之可好兮",
                "4": "若翡翠之奮翼",
                "5": "其象無雙",
                "6": "其美無極",
                "7": "毛嬙鄣袂",
                "8": "不足程式",
                "9": "西施掩面",
                "10": "比之無色",
                "11": "近之旣妖",
                "12": "遠之有望",
                "13": "骨法多奇",
                "14": "應君之相",
                "15": "視之盈目",
                "16": "孰者克尙",
                "17": "私心獨悅",
                "18": "樂之無量",
                "19": "交希恩疏",
                "20": "不可盡暢",
                "21": "他人莫睹",
                "22": "王覽其狀",
                "23": "其狀峨峨",
                "24": "何可極言",
                "25": "貌豐盈以莊姝兮",
                "26": "苞溫潤之玉顏",
                "27": "眸子炯其精朗兮",
                "28": "瞭多美而可觀",
                "29": "眉聯娟以蛾揚兮",
                "30": "朱脣的其若丹",
                "31": "素質幹之醲實兮",
                "32": "志解泰而體閑",
                "33": "旣姽嫿於幽靜兮",
                "34": "又婆娑乎人間",
                "35": "宜高殿以廣意兮",
                "36": "翼放縱而綽寬",
                "37": "動霧縠以徐步兮",
                "38": "拂墀聲之珊珊"
            }
        },
        "3": {
            "7": {
                "1": "望余帷而延視兮",
                "2": "若流波之將瀾",
                "3": "奮長袖以正衽兮",
                "4": "立躑躅而不安",
                "5": "澹清靜其愔嫕兮",
                "6": "性沈詳而不煩",
                "7": "時容與以微動兮",
                "8": "志未可乎得原",
                "9": "意似近而旣遠兮",
                "10": "若將來而復旋",
                "11": "褰余幬而請御兮",
                "12": "願盡心之惓惓",
                "13": "懷貞亮之絜清兮",
                "14": "卒與我兮相難",
                "15": "陳嘉辭而云對兮",
                "16": "吐芬芳其若蘭",
                "17": "精交接以來往兮",
                "18": "心凱康以樂歡",
                "19": "神獨亨而未結兮",
                "20": "魂煢煢以無端",
                "21": "含然諾其不分兮",
                "22": "喟揚音而哀歎",
                "23": "頩薄怒以自持兮",
                "24": "曾不可乎犯干"
            }
        },
        "4": {
            "9": {
                "1": "於是搖珮飾",
                "2": "鳴玉鸞",
                "3": "整衣服",
                "4": "斂容顏",
                "5": "顧女師",
                "6": "命太傅",
                "7": "歡情未接",
                "8": "將辭而去",
                "9": "遷延引身",
                "10": "不可親附",
                "11": "似逝未行",
                "12": "中若相首",
                "13": "目略微眄",
                "14": "精彩相授",
                "15": "志態橫出",
                "16": "不可勝記",
                "17": "意離未絕",
                "18": "神心怖覆",
                "19": "禮不遑訖",
                "20": "辭不及究",
                "21": "願假須臾",
                "22": "神女稱遽",
                "23": "徊腸傷氣",
                "24": "顚倒失據",
                "25": "闇然而暝",
                "26": "忽不知處",
                "27": "情獨私懷",
                "28": "誰者可語",
                "29": "惆悵垂涕",
                "30": "求之至曙"
            }
        }
    }
}