{
    "19.05-04": {
        "篇名": "束廣微 補亡詩六首由庚。萬物得由其道也。",
        "1": {
            "3": {
                "1": "蕩蕩夷庚",
                "2": "物則由之",
                "3": "蠢蠢庶類",
                "4": "王亦柔之",
                "5": "道之旣由",
                "6": "化之旣柔",
                "7": "木以秋零",
                "8": "草以春抽",
                "9": "獸在於草",
                "10": "魚躍順流",
                "11": "四時遞謝",
                "12": "八風代扇",
                "13": "纖阿案晷",
                "14": "星變其躔",
                "15": "五是不逆",
                "16": "六氣無易",
                "17": "愔愔我王",
                "18": "紹文之迹"
            }
        }
    }
}