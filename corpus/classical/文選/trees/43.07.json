{
    "43.07": {
        "篇名": "孔德璋 北山移文",
        "1": {
            "3": {
                "1": "鍾山之英",
                "2": "草堂之靈",
                "3": "馳煙驛路",
                "4": "勒移山庭",
                "5": "夫以耿介拔俗之標",
                "6": "蕭灑出塵之想",
                "7": "度白雪以方絜",
                "8": "干青雲而直上",
                "9": "吾方知之矣",
                "10": "若其亭亭物表",
                "11": "皎皎霞外",
                "12": "芥千金而不眄",
                "13": "屣萬乘其如脫",
                "14": "聞鳳吹於洛浦",
                "15": "値薪歌於延瀨",
                "16": "固亦有焉",
                "17": "豈期終始參差",
                "18": "蒼黃翻覆",
                "19": "淚翟子之悲",
                "20": "慟朱公之哭",
                "21": "乍迴迹以心染",
                "22": "或先貞而後黷",
                "23": "何其謬哉",
                "24": "嗚呼",
                "25": "尙生不存",
                "26": "仲氏旣往",
                "27": "山阿寂寥",
                "28": "千載誰賞"
            }
        },
        "2": {
            "5": {
                "1": "世有周子",
                "2": "雋俗之士",
                "3": "旣文旣博",
                "4": "亦玄亦史",
                "5": "然而學遁東魯",
                "6": "習隱南郭",
                "7": "偶吹草堂",
                "8": "濫巾北岳",
                "9": "誘我松桂",
                "10": "欺我雲壑",
                "11": "雖假容於江皋",
                "12": "乃纓情於好爵",
                "13": "其始至也",
                "14": "將欲排巢父",
                "15": "拉許由",
                "16": "傲百氏",
                "17": "薎王侯",
                "18": "風情張日",
                "19": "霜氣橫秋",
                "20": "或歎幽人長往",
                "21": "或怨王孫不遊",
                "22": "談空空於釋部",
                "23": "覈玄玄於道流",
                "24": "務光何足比",
                "25": "涓子不能儔"
            }
        },
        "3": {
            "7": {
                "1": "及其鳴騶入谷",
                "2": "鶴書赴隴",
                "3": "形馳魄散",
                "4": "志變神動",
                "5": "爾乃眉軒席次",
                "6": "袂聳筵上",
                "7": "焚芰製而裂荷衣",
                "8": "抗塵容而走俗狀",
                "9": "風雲悽其帶憤",
                "10": "石泉咽而下愴",
                "11": "望林巒而有失",
                "12": "顧草木而如喪",
                "13": "至其紐金章",
                "14": "綰墨綬",
                "15": "跨屬城之雄",
                "16": "冠百里之首",
                "17": "張英風於海甸",
                "18": "馳妙譽於浙右",
                "19": "道帙長殯",
                "20": "法筵久埋",
                "21": "敲扑諠囂犯其慮",
                "22": "牒訴倥乔裝其懷",
                "23": "琴歌旣斷",
                "24": "酒賦無續",
                "25": "常綢繆於結課",
                "26": "每紛綸於折獄",
                "27": "籠張趙於往圖",
                "28": "架卓魯於前籙",
                "29": "希蹤三輔豪",
                "30": "馳聲九州牧",
                "31": "使我高霞孤映",
                "32": "明月獨舉",
                "33": "青松落陰",
                "34": "白雲誰侶",
                "35": "磵石摧絕無與歸",
                "36": "石徑荒涼徒延佇",
                "37": "至於還飈入幕",
                "38": "寫霧出楹",
                "39": "蕙帳空兮夜鵠怨",
                "40": "山人去兮曉猿驚",
                "41": "昔聞投簪逸海岸",
                "42": "今見解蘭縛塵纓"
            }
        },
        "4": {
            "9": {
                "1": "於是南岳獻嘲",
                "2": "北壟騰笑",
                "3": "列壑爭譏",
                "4": "攢峯竦誚",
                "5": "慨遊子之我欺",
                "6": "悲無人以赴弔",
                "7": "故其林慚無盡",
                "8": "诙愧不歇",
                "9": "秋桂遺風",
                "10": "春蘿罷月",
                "11": "騁西山之逸議",
                "12": "馳東皋之素謁",
                "13": "今又促裝下邑",
                "14": "浪拽上京",
                "15": "雖情投於魏闕",
                "16": "或假步於山扃",
                "17": "豈可使芳杜厚顏",
                "18": "薜荔無恥",
                "19": "碧嶺再辱",
                "20": "丹崖重滓",
                "21": "塵遊躅於蕙路",
                "22": "汙淥池以洗耳",
                "23": "宜扃岫幌",
                "24": "掩雲關",
                "25": "斂輕霧",
                "26": "藏鳴湍",
                "27": "截來轅於谷口",
                "28": "杜妄轡於郊端",
                "29": "於是叢條瞋膽",
                "30": "疊穎怒魄",
                "31": "或飛柯以折輪",
                "32": "乍低枝而掃迹",
                "33": "請迴俗士駕",
                "34": "爲君謝逋客"
            }
        }
    }
}