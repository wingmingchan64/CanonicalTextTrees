{
    "47.04": {
        "篇名": "劉伯倫 酒德頌",
        "1": {
            "3": {
                "1": "有大人先生",
                "2": "以天地爲一朝",
                "3": "萬期爲須臾",
                "4": "日月爲扃牖",
                "5": "八荒爲庭衢",
                "6": "行無轍迹",
                "7": "居無室廬",
                "8": "幕天席地",
                "9": "縱意所如",
                "10": "止則操卮執觚",
                "11": "動則挈榼提壺",
                "12": "唯酒是務",
                "13": "焉知其餘",
                "14": "有貴介公子",
                "15": "搢紳處士",
                "16": "聞吾風聲",
                "17": "議其所以",
                "18": "乃奮袂攘襟",
                "19": "怒目切齒",
                "20": "陳說禮法",
                "21": "是非鋒起",
                "22": "先生於是方捧甖承槽",
                "23": "銜杯漱醪",
                "24": "奮髯踑踞",
                "25": "枕麴藉糟",
                "26": "無思無慮",
                "27": "其樂陶陶",
                "28": "兀然而醉",
                "29": "豁爾而醒",
                "30": "靜聽不聞雷霆之聲",
                "31": "熟視不睹泰山之形",
                "32": "不覺寒暑之切肌",
                "33": "利欲之感情",
                "34": "俯觀萬物",
                "35": "擾擾焉如江漢之載浮萍",
                "36": "二豪侍側",
                "37": "焉如蜾蠃之與螟蛉"
            }
        }
    }
}