{
    "29.04-04": {
        "篇名": "張平子 四愁詩四首[幷序]",
        "1": {
            "3": {
                "1": "四思曰",
                "2": "我所思兮在雁門",
                "3": "欲往從之雪紛紛",
                "4": "側身北望涕霑巾",
                "5": "美人贈我錦繡段",
                "6": "何以報之青玉案",
                "7": "路遠莫致倚增歎",
                "8": "何爲懷憂心煩惋"
            }
        }
    }
}