{
    "26.27": {
        "篇名": "謝靈運 初去郡",
        "1": {
            "3": {
                "1": "彭薛裁知恥",
                "2": "貢公未遺榮",
                "3": "或可優貪競",
                "4": "豈足稱達生",
                "5": "伊余秉微尙",
                "6": "拙訥謝浮名",
                "7": "廬園當栖巖",
                "8": "卑位代躬耕",
                "9": "顧己雖自許",
                "10": "心迹猶未幷",
                "11": "無庸妨周任",
                "12": "有疾像長卿",
                "13": "畢娶類尙子",
                "14": "薄遊似邴生",
                "15": "恭承古人意",
                "16": "促裝反柴荊",
                "17": "牽絲及元興",
                "18": "解龜在景平",
                "19": "負心二十載",
                "20": "於今廢將迎",
                "21": "理棹遄還期",
                "22": "遵渚騖修坰",
                "23": "溯溪終水涉",
                "24": "登嶺始山行",
                "25": "野曠沙岸淨",
                "26": "天高秋月明",
                "27": "憩石挹飛泉",
                "28": "攀林搴落英",
                "29": "戰勝臞者肥",
                "30": "止監流歸停",
                "31": "卽是羲唐化",
                "32": "獲我擊壤聲"
            }
        }
    }
}