{
    "48.01": {
        "篇名": "司馬長卿 封禪文",
        "1": {
            "3": {
                "1": "伊上古之初肇",
                "2": "自昊穹兮生民",
                "3": "歷選列辟",
                "4": "以迄於秦",
                "5": "率邇者踵武",
                "6": "逖聽者風聲",
                "7": "紛綸威蕤",
                "8": "湮滅而不稱者",
                "9": "不可勝數",
                "10": "繼韶夏",
                "11": "崇號謚",
                "12": "略可道者七十有二君",
                "13": "罔若淑而不昌",
                "14": "疇逆失而能存"
            }
        },
        "2": {
            "5": {
                "1": "軒轅之前",
                "2": "遐哉邈乎",
                "3": "其詳不可得聞已",
                "4": "五三六經載籍之傳",
                "5": "維風可觀也",
                "6": "書曰",
                "7": "元首明哉",
                "8": "股肱良哉",
                "9": "因斯以談",
                "10": "君莫盛於唐堯",
                "11": "臣莫賢於后稷",
                "12": "后稷創業於唐堯",
                "13": "公劉發迹於西戎",
                "14": "文王改制",
                "15": "爰周郅隆",
                "16": "大行越成",
                "17": "而後陵遲衰微",
                "18": "千載亡聲",
                "19": "豈不善始善終哉",
                "20": "然無異端",
                "21": "愼所由於前",
                "22": "謹遺教於後耳",
                "23": "故軌迹夷易",
                "24": "易遵也",
                "25": "湛恩厖鴻",
                "26": "易豐也",
                "27": "憲度著明",
                "28": "易則也",
                "29": "垂統理順",
                "30": "易繼也",
                "31": "是以業隆於繈褓而崇冠於二后",
                "32": "揆厥所元",
                "33": "終都攸卒",
                "34": "未有殊尤絕迹可考於今者也",
                "35": "然猶躡梁父",
                "36": "登泰山",
                "37": "建顯號",
                "38": "施尊名",
                "39": "大漢之德",
                "40": "逢涌原泉",
                "41": "沕潏曼羨",
                "42": "旁魄四塞",
                "43": "雲布霧散",
                "44": "上暢九垓",
                "45": "下泝八埏",
                "46": "懷生之類",
                "47": "霑濡浸潤",
                "48": "協氣橫流",
                "49": "武節猋逝",
                "50": "邇陿遊原",
                "51": "遐闊泳末",
                "52": "首惡鬱沒",
                "53": "晻昧昭晰",
                "54": "昆蟲闓澤",
                "55": "迴首面內",
                "56": "然後囿騶虞之珍羣",
                "57": "徼麋鹿之怪獸",
                "58": "導一莖六穗於庖",
                "59": "犧雙觡共柢之獸",
                "60": "獲周餘珍放龜於岐",
                "61": "招翠黃乘龍於沼",
                "62": "鬼神接靈圉",
                "63": "賓於間館",
                "64": "奇物譎詭",
                "65": "俶儻窮變",
                "66": "欽哉",
                "67": "符瑞臻茲",
                "68": "猶以爲德薄",
                "69": "不敢道封禪",
                "70": "蓋周躍魚隕航",
                "71": "休之以燎",
                "72": "微夫此之爲符也",
                "73": "以登介丘",
                "74": "不亦恧乎",
                "75": "進讓之道",
                "76": "何其爽歟﹖"
            }
        },
        "3": {
            "7": {
                "1": "於是大司馬進曰",
                "2": "陛下仁育羣生",
                "3": "義征不譓諸夏樂貢",
                "4": "百蠻執贄",
                "5": "德侔往初",
                "6": "功無與二",
                "7": "休烈浹洽",
                "8": "符瑞眾變",
                "9": "期應紹至",
                "10": "不特創見",
                "11": "意泰山梁甫設壇場望幸",
                "12": "蓋號以況榮",
                "13": "陛下謙讓而弗發",
                "14": "挈三神之歡",
                "15": "缺王道之儀",
                "16": "羣臣恧焉",
                "17": "或曰且天爲質闇",
                "18": "示珍符固不可辭",
                "19": "若然辭之",
                "20": "是泰山靡記而梁甫罔幾也",
                "21": "亦各並時而榮",
                "22": "咸濟厥世而屈",
                "23": "說者尙何稱於後",
                "24": "而云七十二君哉﹖夫修德以錫符",
                "25": "奉命以行事",
                "26": "不爲進越也",
                "27": "故聖王不替",
                "28": "而修禮地祇",
                "29": "謁款天神",
                "30": "勒功中嶽",
                "31": "以章至尊",
                "32": "舒盛德",
                "33": "發號榮",
                "34": "受厚福",
                "35": "以浸黎元",
                "36": "皇皇哉此天下之壯觀",
                "37": "王者之卒業",
                "38": "不可貶也",
                "39": "願陛下全之",
                "40": "而後因雜搢紳先生之略術",
                "41": "使獲燿日月之末光絕炎",
                "42": "以展寀錯事",
                "43": "猶兼正列其義",
                "44": "祓飾厥文",
                "45": "作春秋一藝",
                "46": "將襲舊六爲七",
                "47": "攄之亡窮",
                "48": "俾萬世得激清流",
                "49": "揚微波",
                "50": "蜚英聲",
                "51": "騰茂實",
                "52": "前聖所以永保鴻名而常爲稱首者用此",
                "53": "宜命掌故悉奏其儀而覽焉"
            }
        },
        "4": {
            "9": {
                "1": "於是天子俙然改容",
                "2": "曰",
                "3": "兪乎",
                "4": "朕其試哉",
                "5": "乃遷思迴慮",
                "6": "總公卿之議",
                "7": "詢封禪之事",
                "8": "詩大澤之博",
                "9": "廣符瑞之富",
                "10": "遂作頌曰"
            }
        },
        "5": {
            "11": {
                "1": "自我天覆",
                "2": "雲之油油",
                "3": "甘露時雨",
                "4": "厥壤可遊",
                "5": "滋液滲漉何生不育",
                "6": "嘉穀六穗",
                "7": "我穡曷蓄﹖"
            }
        },
        "6": {
            "13": {
                "1": "非惟雨之",
                "2": "又潤澤之",
                "3": "非惟遍之我",
                "4": "汜布護之",
                "5": "萬物熙熙",
                "6": "懷而慕思",
                "7": "名山顯位",
                "8": "望君之來",
                "9": "君乎君乎",
                "10": "侯不邁哉"
            }
        },
        "7": {
            "15": {
                "1": "𣪂𣪂之獸",
                "2": "樂我君圃",
                "3": "白質黑章",
                "4": "其儀可嘉",
                "5": "旼旼穆穆",
                "6": "君子之態",
                "7": "蓋聞其聲",
                "8": "今親其來",
                "9": "厥塗靡從",
                "10": "天瑞之徵",
                "11": "茲亦於舜",
                "12": "虞氏以興"
            }
        },
        "8": {
            "17": {
                "1": "濯濯之麟",
                "2": "遊彼靈畤",
                "3": "孟冬十月",
                "4": "君徂郊祀",
                "5": "馳我君輿",
                "6": "帝用享祉",
                "7": "三代之前",
                "8": "蓋未嘗有"
            }
        },
        "9": {
            "19": {
                "1": "宛宛黃龍",
                "2": "興德而升",
                "3": "采色炫燿",
                "4": "煥炳煇煌",
                "5": "正陽顯見",
                "6": "覺悟黎蒸",
                "7": "於傳載之",
                "8": "云受命所乘"
            }
        },
        "10": {
            "21": {
                "1": "厥之有章",
                "2": "不必諄諄",
                "3": "依類託寓",
                "4": "喩以封巒"
            }
        },
        "11": {
            "23": {
                "1": "披藝觀之",
                "2": "天人之際已交",
                "3": "上下相發允答",
                "4": "聖王之德",
                "5": "兢兢翼翼",
                "6": "故曰於興必慮衰",
                "7": "安必思危",
                "8": "是以湯武至尊嚴",
                "9": "不失肅祇",
                "10": "舜在假典",
                "11": "顧省闕遺",
                "12": "此之謂也"
            }
        }
    }
}