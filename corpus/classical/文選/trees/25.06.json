{
    "25.06": {
        "篇名": "劉越石 答盧諶詩[幷書]",
        "1": {
            "3": {
                "1": "琨頓首",
                "2": "損書及詩",
                "3": "備辛酸之苦言",
                "4": "暢經通之遠旨",
                "5": "執玩反覆",
                "6": "不能釋手",
                "7": "慨然以悲",
                "8": "歡然以喜",
                "9": "昔在少壯",
                "10": "未嘗檢括",
                "11": "遠慕老莊之齊物",
                "12": "近嘉阮生之放曠",
                "13": "怪厚薄何從而生",
                "14": "哀樂何由而至",
                "15": "自頃輈張",
                "16": "困於逆亂",
                "17": "國破家亡",
                "18": "親友凋殘",
                "19": "塊然獨坐",
                "20": "則哀憤兩集",
                "21": "負杖行吟",
                "22": "則百憂俱至",
                "23": "時復相與舉觴對膝",
                "24": "破涕爲笑",
                "25": "排終身之積慘",
                "26": "求數刻之暫歡",
                "27": "譬由疾疢彌年",
                "28": "而欲一丸銷之",
                "29": "其可得乎",
                "30": "夫才生於世",
                "31": "世實須才",
                "32": "和氏之璧",
                "33": "焉得獨曜於郢握",
                "34": "夜光之珠",
                "35": "何得專玩於隨掌",
                "36": "天下之寶",
                "37": "固當與天下共之",
                "38": "但分析之日",
                "39": "不能不悵恨爾",
                "40": "然後知聃周之爲虛誕",
                "41": "嗣宗之爲妄作也",
                "42": "昔騄驥倚輈於吳坂",
                "43": "長鳴於良樂",
                "44": "知與不知也",
                "45": "百里奚愚於虞而智於秦",
                "46": "遇與不遇也",
                "47": "今君遇之矣",
                "48": "勖之而已",
                "49": "不復屬意於文",
                "50": "二十餘年矣",
                "51": "久廢則無次",
                "52": "想必欲反",
                "53": "故稱指送一篇",
                "54": "適足以彰來詩之益美耳",
                "55": "琨頓首頓首"
            }
        },
        "2": {
            "5": {
                "1": "厄運初遘",
                "2": "陽爻在六",
                "3": "乾象棟傾",
                "4": "坤儀舟覆",
                "5": "橫厲糾紛",
                "6": "羣妖競逐",
                "7": "火燎神州",
                "8": "洪流華域",
                "9": "彼黍離離",
                "10": "彼稷育育",
                "11": "哀我皇晉",
                "12": "痛心在目"
            }
        },
        "3": {
            "7": {
                "1": "天地無心",
                "2": "萬物同塗",
                "3": "禍淫莫驗",
                "4": "福善則虛",
                "5": "逆有全邑",
                "6": "義無完都",
                "7": "英蕊夏落",
                "8": "毒卉冬敷",
                "9": "如彼龜玉",
                "10": "韞櫝毀諸",
                "11": "芻狗之談",
                "12": "其最得乎"
            }
        },
        "4": {
            "9": {
                "1": "咨余軟弱",
                "2": "弗克負荷",
                "3": "愆釁仍彰",
                "4": "榮寵屢加",
                "5": "威之不建",
                "6": "禍延凶播",
                "7": "忠損於國",
                "8": "孝愆於家",
                "9": "斯罪之積",
                "10": "如彼山河",
                "11": "斯釁之深",
                "12": "終莫能磨"
            }
        },
        "5": {
            "11": {
                "1": "郁穆舊姻",
                "2": "嬿婉新婚",
                "3": "不慮其敗",
                "4": "唯義是敦",
                "5": "裹糧攜弱",
                "6": "匍匐星奔"
            }
        },
        "6": {
            "13": {
                "1": "未輟爾駕",
                "2": "已隳我門",
                "3": "二族偕覆",
                "4": "三孼並根",
                "5": "長慚舊孤",
                "6": "永負冤魂"
            }
        },
        "7": {
            "15": {
                "1": "亭亭孤干",
                "2": "獨生無伴",
                "3": "綠頁繁縟",
                "4": "柔條修罕",
                "5": "朝采爾實",
                "6": "夕捋爾竿",
                "7": "竿翠豐尋",
                "8": "逸珠盈碗",
                "9": "實消我憂",
                "10": "憂急用緩",
                "11": "逝將去矣",
                "12": "庭虛情滿"
            }
        },
        "8": {
            "17": {
                "1": "虛滿伊何",
                "2": "蘭桂移植",
                "3": "茂彼春林",
                "4": "瘁此秋棘",
                "5": "有鳥翻飛",
                "6": "不遑休息",
                "7": "匪桐不栖",
                "8": "匪竹不食",
                "9": "永戢東羽",
                "10": "翰撫西翼",
                "11": "我之敬之",
                "12": "廢歡輟職"
            }
        },
        "9": {
            "19": {
                "1": "音以賞奏",
                "2": "味以殊珍",
                "3": "文以明言",
                "4": "言以暢神",
                "5": "之子之往",
                "6": "四美不臻",
                "7": "澄醪覆觴",
                "8": "絲竹生塵",
                "9": "素卷莫啟",
                "10": "幄無談賓",
                "11": "旣孤我德",
                "12": "又闕我鄰"
            }
        },
        "10": {
            "21": {
                "1": "光光段生",
                "2": "出幽遷喬",
                "3": "資忠履信",
                "4": "武烈文昭",
                "5": "旌弓騂騂",
                "6": "輿馬翹翹",
                "7": "乃奮長縻",
                "8": "是轡是鑣",
                "9": "何以贈子",
                "10": "竭心公朝",
                "11": "何以敍懷",
                "12": "引領長謠"
            }
        }
    }
}