{
    "23.16-03": {
        "篇名": "劉公幹 贈五官中郎將四首·其三",
        "1": {
            "3": {
                "1": "秋日多悲懷",
                "2": "感慨以長歎",
                "3": "終夜不遑寐",
                "4": "敍意於濡翰",
                "5": "明鐙曜閨中",
                "6": "清風淒已寒",
                "7": "白露塗前庭",
                "8": "應門重其關",
                "9": "四節相推斥",
                "10": "歲月忽欲殫",
                "11": "壯士遠出征",
                "12": "戎事將獨難",
                "13": "涕泣灑衣裳",
                "14": "能不懷所歡"
            }
        }
