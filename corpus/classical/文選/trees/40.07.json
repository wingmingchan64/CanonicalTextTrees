{
    "40.07": {
        "篇名": "吳季重 答魏太子牋",
        "1": {
            "3": {
                "1": "二月八日庚寅",
                "2": "臣質言",
                "3": "奉讀手命",
                "4": "追亡慮存",
                "5": "恩哀之隆",
                "6": "形於文墨",
                "7": "日月冉冉",
                "8": "歲不我與",
                "9": "昔侍左右",
                "10": "廁坐眾賢",
                "11": "出有微行之遊",
                "12": "入有管絃之歡",
                "13": "置酒樂飲",
                "14": "賦詩稱壽",
                "15": "自謂可終始相保",
                "16": "並騁材力",
                "17": "效節明主",
                "18": "何意數年之間",
                "19": "死喪略盡",
                "20": "臣獨何德",
                "21": "以堪久長"
            }
        },
        "2": {
            "5": {
                "1": "陳徐劉應",
                "2": "才學所著",
                "3": "誠如來命",
                "4": "惜其不遂",
                "5": "可爲痛切",
                "6": "凡此數字",
                "7": "於雍容侍從",
                "8": "實其人也",
                "9": "若乃邊境有虞",
                "10": "羣下鼎沸",
                "11": "軍書輻至",
                "12": "羽檄交馳",
                "13": "於彼諸賢",
                "14": "非其任也",
                "15": "往者孝武之世",
                "16": "文章爲盛",
                "17": "若東方朔枚皋之徒",
                "18": "不能持論",
                "19": "卽阮陳之儔也",
                "20": "其唯嚴助壽王",
                "21": "與聞政事",
                "22": "然皆不愼其身",
                "23": "善謀於國",
                "24": "卒以敗亡",
                "25": "臣竊恥之",
                "26": "至於司馬長卿稱疾避事",
                "27": "以著書爲務",
                "28": "則徐生庶幾焉",
                "29": "而今各逝",
                "30": "已爲異物矣",
                "31": "後來君子",
                "32": "實可畏也"
            }
        },
        "3": {
            "7": {
                "1": "伏惟所天",
                "2": "優遊典籍之場",
                "3": "休息篇章之囿",
                "4": "發言抗論",
                "5": "窮理盡微",
                "6": "摛藻下筆",
                "7": "鸞龍之文奮矣",
                "8": "雖年齊蕭王",
                "9": "才實百之",
                "10": "此眾議所以歸高",
                "11": "遠近所以同聲",
                "12": "然年歲若墜",
                "13": "今質已四十二矣",
                "14": "白髮生鬢",
                "15": "所慮日深",
                "16": "實不復若平日之時也",
                "17": "但欲保身敕行",
                "18": "不蹈有過之地",
                "19": "以爲知己之累耳",
                "20": "遊宴之歡",
                "21": "難可再遇",
                "22": "盛年一過",
                "23": "實不可追",
                "24": "臣幸得下愚之才",
                "25": "値風雲之會",
                "26": "時邁齒臷猶欲觸匈奮首",
                "27": "展其割裂之用也",
                "28": "不勝慺慺",
                "29": "以來命備悉",
                "30": "故略陳至情",
                "31": "質死罪死罪"
            }
        }
    }
}