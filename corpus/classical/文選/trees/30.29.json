{
    "30.29": {
        "篇名": "張孟陽 擬四愁詩",
        "1": {
            "3": {
                "1": "我所思兮在營州",
                "2": "欲往從之路阻修",
                "3": "登崖遠望涕泗流",
                "4": "我之懷矣心傷憂",
                "5": "佳人遺我綠綺琴",
                "6": "何以贈之雙南金",
                "7": "願因流波超重深",
                "8": "終然莫致增永吟"
            }
        }
    }
}