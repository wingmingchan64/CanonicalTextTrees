{
    "30.03": {
        "篇名": "陶淵明 詠貧士詩",
        "1": {
            "3": {
                "1": "萬族各有託",
                "2": "孤雲獨無依",
                "3": "曖曖虛中滅",
                "4": "何時見餘輝",
                "5": "朝霞開宿霧",
                "6": "眾鳥相與飛",
                "7": "遲遲出林翮",
                "8": "未夕復來歸",
                "9": "量力守故轍",
                "10": "豈不寒與飢",
                "11": "知音苟不存",
                "12": "已矣何所悲"
            }
        }
    }
}