{
    "23.13": {
        "篇名": "王仲宣 贈蔡子篤詩",
        "1": {
            "3": {
                "1": "翼翼飛鸞",
                "2": "載飛載東",
                "3": "我友云徂",
                "4": "言戾舊邦",
                "5": "舫舟翩翩",
                "6": "以泝大江",
                "7": "蔚矣荒塗",
                "8": "時行靡通",
                "9": "慨我懷慕",
                "10": "君子所同",
                "11": "悠悠世路",
                "12": "亂離多阻",
                "13": "濟岱江行",
                "14": "邈焉異處",
                "15": "風流雲散",
                "16": "一別如雨",
                "17": "人生實難",
                "18": "願其弗與",
                "19": "瞻望遐路",
                "20": "允企伊佇",
                "21": "烈烈冬日",
                "22": "肅肅淒風",
                "23": "潛鱗在淵",
                "24": "歸雁載軒",
                "25": "苟非鴻雕",
                "26": "孰能飛翻",
                "27": "雖則追慕",
                "28": "予思罔宣",
                "29": "瞻望東路",
                "30": "慘愴增歎",
                "31": "率彼江流",
                "32": "爰逝靡期",
                "33": "君子信誓",
                "34": "不遷於時",
                "35": "及子同僚",
                "36": "生死固之",
                "37": "何以贈行",
                "38": "言授斯詩",
                "39": "中心孔悼",
                "40": "涕淚漣洏",
                "41": "嗟爾君子",
                "42": "如何勿思"
            }
        }
    }
}