{
    "45.03": {
        "篇名": "楊子雲 解嘲[幷序]",
        "1": {
            "3": {
                "1": "哀帝時",
                "2": "丁傅董賢用事",
                "3": "諸附離之者",
                "4": "起家至二千石",
                "5": "時雄方草創太玄",
                "6": "有以自守",
                "7": "泊如也",
                "8": "人有嘲雄以玄之尙白",
                "9": "雄解之",
                "10": "號曰解嘲",
                "11": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "客嘲楊子曰",
                "2": "吾聞上世之士",
                "3": "人綱人紀",
                "4": "不生則已",
                "5": "生必上尊人君",
                "6": "下榮父母",
                "7": "析人之珪",
                "8": "儋人之爵",
                "9": "懷人之符",
                "10": "分人之祿",
                "11": "紆青拖紫",
                "12": "朱丹其轂",
                "13": "今吾子幸得遭明盛之世",
                "14": "處不諱之朝",
                "15": "與羣賢同行",
                "16": "歷金門",
                "17": "上玉堂有日矣",
                "18": "曾不能畫一奇",
                "19": "出一策",
                "20": "上說人主",
                "21": "下談公卿",
                "22": "目如耀星",
                "23": "舌如電光",
                "24": "一從一橫",
                "25": "論者莫當",
                "26": "顧默而作太玄五千文",
                "27": "枝葉扶疏",
                "28": "獨說數十餘萬言",
                "29": "深者入黃泉",
                "30": "高者出蒼天",
                "31": "大者含元氣",
                "32": "細者入無間",
                "33": "然而位不過侍郎",
                "34": "擢纔給事黃門",
                "35": "意者玄得無尙白乎",
                "36": "何爲官之拓落也"
            }
        },
        "3": {
            "7": {
                "1": "楊子笑而應之曰",
                "2": "客徒朱丹吾轂",
                "3": "不知一跌將赤吾之族也",
                "4": "往昔周網解結",
                "5": "羣鹿爭逸",
                "6": "離爲十二",
                "7": "合爲六七",
                "8": "四分五剖",
                "9": "並爲戰國",
                "10": "士無常君",
                "11": "國無定臣",
                "12": "得士者富",
                "13": "失士者貧",
                "14": "矯翼厲翮",
                "15": "恣意所存",
                "16": "故士或自盛以橐",
                "17": "或鑿坏以遁",
                "18": "是故鄒衍以頡頏而取世資",
                "19": "孟軻雖連蹇",
                "20": "猶爲萬乘師"
            }
        },
        "4": {
            "9": {
                "1": "今大漢左東海",
                "2": "右渠搜",
                "3": "前番禺",
                "4": "後椒塗",
                "5": "東南一尉",
                "6": "西北一候",
                "7": "徽以糾墨",
                "8": "制以鑽鈇",
                "9": "散以禮樂",
                "10": "風以詩書",
                "11": "曠以歲月",
                "12": "結以倚廬",
                "13": "天下之士",
                "14": "雷動雲合",
                "15": "魚鱗雜襲",
                "16": "咸營於八區",
                "17": "家家自以爲稷契",
                "18": "人人自以爲皋陶",
                "19": "戴縰垂纓",
                "20": "而談者皆擬於阿衡",
                "21": "五尺童子",
                "22": "羞比晏嬰與夷吾",
                "23": "當塗者升青雲",
                "24": "失路者委溝渠",
                "25": "旦握權則爲卿相",
                "26": "夕失勢則爲匹夫",
                "27": "譬若江湖之崖",
                "28": "渤澥之島",
                "29": "乘雁集不爲之多",
                "30": "雙鳧飛不爲之少",
                "31": "昔三仁去而殷墟",
                "32": "二老歸而周熾",
                "33": "子胥死而吳亡",
                "34": "種蠡存而越霸",
                "35": "五羖入而秦喜",
                "36": "樂毅出而燕懼",
                "37": "范雎以折摺而危穰侯",
                "38": "蔡澤以噤吟而笑唐舉",
                "39": "故當其有事也",
                "40": "非蕭曹子房平勃樊霍則不能安",
                "41": "當其無事也",
                "42": "章句之徒相與坐而守之",
                "43": "亦無所患",
                "44": "故世亂則聖哲馳騖而不足",
                "45": "世治則庸夫高枕而有餘"
            }
        },
        "5": {
            "11": {
                "1": "夫上世之士",
                "2": "或解縛而相",
                "3": "或釋褐而傅",
                "4": "或倚夷門而笑",
                "5": "或橫江潭而漁",
                "6": "或七十說而不遇",
                "7": "或立談而封侯",
                "8": "或枉千乘於陋巷",
                "9": "或擁篲而先驅",
                "10": "是以士頗得信其舌而奮其筆",
                "11": "窒隙蹈瑕而無所詘也",
                "12": "當今縣令不請士",
                "13": "郡守不迎師",
                "14": "羣卿不揖客",
                "15": "將相不俛眉",
                "16": "言奇者見疑",
                "17": "行殊者得辟",
                "18": "是以欲談者卷舌而同聲",
                "19": "欲步者擬足而投迹",
                "20": "嚮使上世之士",
                "21": "處乎今世",
                "22": "策非甲科",
                "23": "行非孝廉",
                "24": "舉非方正",
                "25": "獨可抗疏",
                "26": "時道是非",
                "27": "高得待詔",
                "28": "下觸聞罷",
                "29": "又安得青紫"
            }
        },
        "6": {
            "13": {
                "1": "且吾聞之",
                "2": "炎炎者滅",
                "3": "隆隆者絕",
                "4": "觀雷觀火",
                "5": "爲盈爲實",
                "6": "天收其聲",
                "7": "地藏其熱",
                "8": "高明之家",
                "9": "鬼瞰其室",
                "10": "攫拏者亡",
                "11": "默默者存",
                "12": "位極者高危",
                "13": "自守者身全",
                "14": "是故知玄知默",
                "15": "守道之極",
                "16": "爰清爰靜",
                "17": "遊神之庭",
                "18": "惟寂惟漠",
                "19": "守德之宅",
                "20": "世異事變",
                "21": "人道不殊",
                "22": "彼我易時",
                "23": "未知何如",
                "24": "今子乃以鴟梟而笑鳳皇",
                "25": "執蝘蜓而嘲龜龍",
                "26": "不亦病乎",
                "27": "子之笑我玄之尙白",
                "28": "吾亦笑子病甚不遇兪跗與扁鵲也",
                "29": "悲夫"
            }
        },
        "7": {
            "15": {
                "1": "客曰",
                "2": "然則靡玄無所成名乎",
                "3": "范蔡以下",
                "4": "何必玄哉"
            }
        },
        "8": {
            "17": {
                "1": "楊子曰",
                "2": "范雎",
                "3": "魏之亡命也",
                "4": "折脅摺髂",
                "5": "免於徽索",
                "6": "翕肩蹈背",
                "7": "扶服入橐",
                "8": "激卬萬乘之主",
                "9": "介涇陽",
                "10": "抵穰侯而代之",
                "11": "當也",
                "12": "蔡澤",
                "13": "山東之匹夫也",
                "14": "顩頤折頞",
                "15": "涕唾流沫",
                "16": "西揖強秦之相",
                "17": "搤其咽而亢其氣",
                "18": "捬其背而奪其位",
                "19": "時也",
                "20": "天下已定",
                "21": "金革已平",
                "22": "都於洛陽",
                "23": "婁敬委輅脫輓",
                "24": "掉三寸之舌",
                "25": "建不拔之策",
                "26": "舉中國徙之長安",
                "27": "適也",
                "28": "五帝垂典",
                "29": "三王傳禮",
                "30": "百世不易",
                "31": "叔孫通起於枹鼓之間",
                "32": "解甲投戈",
                "33": "遂作君臣之儀",
                "34": "得也",
                "35": "呂刑靡敝",
                "36": "秦法酷烈",
                "37": "聖漢權制",
                "38": "而蕭何造律",
                "39": "宜也",
                "40": "故有造蕭何之律於唐虞之世",
                "41": "則悂矣",
                "42": "有作叔孫通儀於夏殷之時",
                "43": "則惑矣",
                "44": "有建婁敬之策於成周之世",
                "45": "則乖矣",
                "46": "有談范蔡之說於金張許史之間",
                "47": "則狂矣",
                "48": "夫蕭規曹隨",
                "49": "留侯畫策",
                "50": "陳平出奇",
                "51": "功若泰山",
                "52": "響若坻隤",
                "53": "雖其人之膽智哉",
                "54": "亦會其時之可爲也",
                "55": "故爲可爲於可爲之時",
                "56": "則從",
                "57": "爲不可爲於不可爲之時",
                "58": "則凶",
                "59": "若夫藺生收功於章臺",
                "60": "四皓采榮於南山",
                "61": "公孫創業於金馬",
                "62": "驃騎發迹於祁連",
                "63": "司馬長卿竊貲於卓氏",
                "64": "東方朔割炙於細君",
                "65": "僕誠不能與此數子並",
                "66": "故默然獨守吾太玄"
            }
        }
    }
}