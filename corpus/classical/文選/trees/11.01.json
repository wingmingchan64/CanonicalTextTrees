{
    "11.01": {
        "篇名": "王仲宣 登樓賦",
        "1": {
            "3": {
                "1": "登茲樓以四望兮",
                "2": "聊暇日以銷憂",
                "3": "覽斯宇之所處兮",
                "4": "實顯敞而寡仇",
                "5": "挾清漳之通浦兮",
                "6": "倚曲沮之長洲",
                "7": "背墳衍之廣陸兮",
                "8": "臨皋隰之沃流",
                "9": "北彌陶牧",
                "10": "西接昭丘",
                "11": "華實蔽野",
                "12": "黍稷盈疇",
                "13": "雖信美而非吾土兮",
                "14": "曾何足以少留"
            }
        },
        "2": {
            "5": {
                "1": "遭紛濁而遷逝兮",
                "2": "漫踰紀以迄今",
                "3": "情眷眷而懷歸兮",
                "4": "孰憂思之可任",
                "5": "憑軒檻以遙望兮",
                "6": "向北風而開襟",
                "7": "平原遠而極目兮",
                "8": "蔽荊山之高岑",
                "9": "路逶迆而修迥兮",
                "10": "川旣漾而濟深",
                "11": "悲舊鄕之壅隔兮",
                "12": "涕橫墜而弗禁",
                "13": "昔尼父之在陳兮",
                "14": "有歸歟之歎音",
                "15": "鍾儀幽而楚奏兮",
                "16": "莊舄顯而越吟",
                "17": "人情同於懷土兮",
                "18": "豈窮達而異心"
            }
        },
        "3": {
            "7": {
                "1": "惟日月之逾邁兮",
                "2": "俟河清其未極",
                "3": "冀王道之一平兮",
                "4": "假高衢而騁力",
                "5": "懼匏瓜之徒懸兮",
                "6": "畏井渫之莫食",
                "7": "步栖遲以徙倚兮",
                "8": "白日忽其將匿",
                "9": "風蕭瑟而並興兮",
                "10": "天慘慘而無色",
                "11": "獸狂顧以求羣兮",
                "12": "鳥相鳴而舉翼",
                "13": "原野闃其無人兮",
                "14": "征夫行而未息",
                "15": "心悽愴以感發兮",
                "16": "意忉怛而憯惻",
                "17": "循階除而下降兮",
                "18": "氣交憤於胸臆",
                "19": "夜參半而不寐兮",
                "20": "悵盤桓以反側"
            }
        }
    }
}