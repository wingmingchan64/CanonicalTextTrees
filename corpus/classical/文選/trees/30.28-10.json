{
    "30.28-10": {
        "篇名": "陸士衡 擬古詩十二首·擬西北有高樓",
        "1": {
            "3": {
                "1": "高樓一何峻",
                "2": "苕苕峻而安",
                "3": "綺窗出塵冥",
                "4": "飛陛躡雲端",
                "5": "佳人撫琴瑟",
                "6": "纖手清且閑",
                "7": "芳氣隨風結",
                "8": "哀響馥若蘭",
                "9": "玉容誰得顧",
                "10": "傾城在一彈",
                "11": "佇立望日昃",
                "12": "躑躅再三歎",
                "13": "不怨佇立久",
                "14": "但願歌者歡",
                "15": "思駕歸鴻羽",
                "16": "比翼雙飛翰"
            }
        }
    }
}