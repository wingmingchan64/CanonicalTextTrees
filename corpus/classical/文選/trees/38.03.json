{
    "38.03": {
        "篇名": "桓元子 薦譙元彥表",
        "1": {
            "3": {
                "1": "臣聞太朴旣虧",
                "2": "則高尙之標顯",
                "3": "道喪時昏",
                "4": "則忠貞之義彰",
                "5": "故有洗耳投淵",
                "6": "以振玄邈之風",
                "7": "亦有秉心矯迹",
                "8": "以敦在三之節",
                "9": "是故上代之君",
                "10": "莫不崇重斯軌",
                "11": "所以篤俗訓民",
                "12": "靜一流競",
                "13": "伏惟大晉",
                "14": "應符御世",
                "15": "運無常通",
                "16": "時有屯蹇",
                "17": "神州丘墟",
                "18": "三方圯裂",
                "19": "兔罝絕響於中林",
                "20": "白駒無聞於空谷",
                "21": "斯有識之所悼心",
                "22": "大雅之所歎息者也"
            }
        },
        "2": {
            "5": {
                "1": "陛下聖德嗣興",
                "2": "方恢天緒",
                "3": "臣昔奉役",
                "4": "有事西土",
                "5": "鯨鯢旣懸",
                "6": "思宣大化",
                "7": "訪諸故老",
                "8": "搜揚潛逸",
                "9": "庶武羅於羿浞之墟",
                "10": "想王蠋於亡齊之境",
                "11": "竊聞巴西譙秀",
                "12": "植操貞固",
                "13": "抱德肥遯",
                "14": "揚清渭波",
                "15": "於時皇極遘道消之會",
                "16": "羣黎蹈顚沛之艱",
                "17": "中華有顧瞻之哀",
                "18": "幽谷無遷喬之望",
                "19": "凶命屢招",
                "20": "姦威仍逼",
                "21": "身寄虎吻",
                "22": "危同朝露",
                "23": "而能抗節玉立",
                "24": "誓不降辱",
                "25": "杜門絕迹",
                "26": "不面僞庭",
                "27": "進免龔勝亡身之禍",
                "28": "退無薛方詭對之譏",
                "29": "雖園綺之栖商洛",
                "30": "管寧之默遼海",
                "31": "方之於秀",
                "32": "殆無以過",
                "33": "於今西土",
                "34": "以爲美談"
            }
        },
        "3": {
            "7": {
                "1": "夫旌德禮賢",
                "2": "化道之所先",
                "3": "崇表殊節",
                "4": "聖喆之上務",
                "5": "方今六合未康",
                "6": "豺豕當路",
                "7": "遺黎偸薄",
                "8": "義聲弗聞",
                "9": "益宜振起道義之徒",
                "10": "以敦流遯之敝",
                "11": "若秀蒙蒲帛之徵",
                "12": "足以鎭靜頹風",
                "13": "軌訓囂俗",
                "14": "幽遐仰流",
                "15": "九服知化矣"
            }
        }
    }
}