{
    "27.14-01": {
        "篇名": "王仲宣 從軍詩五首·其一",
        "1": {
            "3": {
                "1": "從軍有苦樂",
                "2": "但聞所從誰",
                "3": "所從神且武",
                "4": "焉得久勞師",
                "5": "相公征關右",
                "6": "赫怒震天威",
                "7": "一舉滅獯虜",
                "8": "再舉服羌夷",
                "9": "西收邊地賊",
                "10": "忽若俯拾遺",
                "11": "陳賞越丘山",
                "12": "酒肉踰川坻",
                "13": "軍人多飫饒",
                "14": "人馬皆溢肥",
                "15": "徒行兼乘還",
                "16": "空出有餘資",
                "17": "拓地三千里",
                "18": "往返速若飛",
                "19": "歌舞入鄴城",
                "20": "所願獲無違",
                "21": "盡日處大朝",
                "22": "日暮薄言歸",
                "23": "外參時明政",
                "24": "內不廢家私",
                "25": "禽獸憚爲犧",
                "26": "良苗實已揮",
                "27": "不能效沮溺",
                "28": "相隨把鋤犁",
                "29": "孰覽夫子詩",
                "30": "信知所言非"
            }
        }
    }
}