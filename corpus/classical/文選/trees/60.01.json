                "30": "良家入徙",
                "31": "戚里內屬",
                "32": "政非一軌",
                "33": "俗備五方",
                "34": "公內樹寬明",
                "35": "外施簡惠",
                "36": "神皋載穆",
                "37": "轂下以清"
            }
        },
        "4": {
            "9": {
                "1": "武皇帝嗣位",
