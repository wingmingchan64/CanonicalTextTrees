                "59": "聲化之有倫",
                "60": "繄公是賴",
                "61": "庠序肇興",
                "62": "儀形國胄",
                "63": "師氏之選",
                "64": "允師人範",
                "65": "以本官領國子祭酒",
                "66": "固辭不拜",
                "67": "八座初啟",
                "68": "以公補尙書令",
                "69": "式是敷奏",
                "70": "百揆時序",
                "71": "夫國家之道",
                "72": "互爲公私",
                "73": "君親之義",
                "74": "遞爲隱犯",
                "75": "公二極一致",
                "76": "愛敬同歸",
                "77": "亮誠盡規",
                "78": "謀猷弘遠矣",
                "79": "又授使持節",
                "80": "都督楊州諸軍事",
                "81": "楊州刺史",
                "82": "本官悉如故",
                "83": "舊惟淮海",
                "84": "今則神牧",
                "85": "編戶殷阜",
                "86": "萌俗繁滋",
                "87": "不言之化",
                "88": "若門到戶說矣",
                "89": "頃之",
                "90": "解尙書令",
                "91": "改授中書監",
                "92": "餘悉如故",
                "93": "獻納樞機",
                "94": "絲綸允緝",
