{
    "60.01": {
        "篇名": "任彥升 齊竟陵文宣王行狀",
        "1": {
            "3": {
                "1": "公道亞生知",
                "2": "照鄰幾庶",
                "3": "孝始人倫",
                "4": "忠爲令德",
                "5": "公實體之",
                "6": "非毀譽所至",
                "7": "天才博贍",
                "8": "學綜該明",
                "9": "至若曲臺之禮",
                "10": "九師之易",
                "11": "樂分龍趙",
                "12": "詩析齊韓",
                "13": "陳農所未究",
                "14": "河間所未輯",
                "15": "有一於此",
                "16": "罔不兼綜者與",
                "17": "昔沛獻訪對於雲臺",
                "18": "東平齊聲於楊史",
