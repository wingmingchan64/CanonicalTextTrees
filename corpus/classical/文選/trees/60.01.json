                "38": "敷興邦教",
                "39": "方任雖重",
                "40": "比此爲輕",
                "41": "徵護軍將軍",
                "42": "兼司徒",
                "43": "侍中如故",
                "44": "又授車騎將軍",
                "45": "兼司徒",
                "46": "侍中如故",
                "47": "卽授司徒",
                "48": "侍中又如故",
                "49": "上穆三能",
                "50": "下敷五典",
                "51": "闢玄闈以闡化",
                "52": "寢鳴鍾以體國",
                "53": "翼亮孝治",
                "54": "緝熙中教",
                "55": "奪金恥訟",
                "56": "蹊田自嘿",
