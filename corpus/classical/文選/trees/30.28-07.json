    "30.28-07": {
        "篇名": "陸士衡 擬古詩十二首·擬蘭若生朝陽",
        "1": {
            "3": {
                "1": "嘉樹生朝陽",
                "2": "凝霜封其條",
                "3": "執心守時信",
                "4": "歲寒終不彫",
                "5": "美人何其曠",
                "6": "灼灼在雲霄",
                "7": "隆想彌年月",
                "8": "長嘯入飛飆",
                "9": "引領望天末",
                "10": "譬彼向陽翹"
            }
        }
    }
