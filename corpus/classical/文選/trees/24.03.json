{
    "24.03": {
        "篇名": "曹子建 贈王粲",
        "1": {
            "3": {
                "1": "端坐苦愁思",
                "2": "攬衣起西遊",
                "3": "樹木發春華",
                "4": "清池激長流",
                "5": "中有孤鴛鴦",
                "6": "哀鳴求匹儔",
                "7": "我願執此鳥",
                "8": "惜哉無輕舟",
                "9": "欲歸忘故道",
                "10": "顧望但懷愁",
                "11": "悲風鳴我側",
                "12": "羲和逝不留",
                "13": "重陰潤萬物",
                "14": "何懼澤不周",
                "15": "誰令君多念",
                "16": "自使懷百憂"
            }
        }
    }
}