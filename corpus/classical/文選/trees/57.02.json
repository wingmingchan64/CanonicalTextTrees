{
    "57.02": {
        "篇名": "潘安仁 馬汧督誄[幷序]",
        "1": {
            "3": {
                "1": "惟元康七年秋九月十五日",
                "2": "晉故督守關中侯扶風馬君卒",
                "3": "嗚呼哀哉",
                "4": "初",
                "5": "雍部之內屬",
                "6": "羌反未弭",
                "7": "而編戶之氐又肆逆焉",
                "8": "雖王旅致討",
                "9": "終於殄滅",
                "10": "而蜂蠆有毒",
                "11": "驟失小利",
                "12": "俾百姓流亡",
                "13": "頻於塗炭",
                "14": "建威喪元於好畤",
                "15": "州伯宵遁乎大谿",
                "16": "若夫偏師裨將之殞首覆軍者",
                "17": "蓋以十數",
                "18": "剖符專城",
                "19": "紆青拖墨之司",
                "20": "奔走失其守者",
                "21": "相望於境",
                "22": "秦隴之僭",
                "23": "鞏更爲魁",
                "24": "旣已襲汧而館其縣",
                "25": "子以眇爾之身",
                "26": "介乎重圍之裏",
                "27": "率寡弱之眾",
                "28": "據十雉之城",
                "29": "羣氐如蝟毛而起",
                "30": "四面雨射城中",
                "31": "城中鑿穴而處",
                "32": "負戶而汲",
                "33": "木石將盡",
                "34": "樵蘇乏竭",
                "35": "芻蕘罄絕",
                "36": "於是乎發梁棟而用之",
                "37": "𦉹以鐵鎖機關",
                "38": "旣縱礧而又升焉",
                "39": "爨陳焦之麥",
                "40": "柿梠桷之松",
                "41": "用能薪芻不匱",
                "42": "人畜取給",
                "43": "青煙傍起",
                "44": "歷馬長鳴",
                "45": "凶醜駭而疑懼",
                "46": "乃闕地而攻",
                "47": "子命穴浚塹",
                "48": "寘壺鐳甁甒以偵之",
                "49": "將穿",
                "50": "響作",
                "51": "內焚穬火薰之",
                "52": "潛氐殲焉",
                "53": "久之",
                "54": "安西之救至",
                "55": "竟免虎口之厄",
                "56": "全數百萬石之積",
                "57": "文契書於幕府"
            }
        },
        "2": {
            "5": {
                "1": "聖朝疇咨",
                "2": "進以顯秩",
                "3": "殊以幢蓋之制",
                "4": "而州之有司",
                "5": "乃以私隸數口",
                "6": "穀十斛",
                "7": "考訊吏兵",
                "8": "以檟楚之辭連之",
                "9": "大將軍屢抗其疏",
                "10": "曰",
                "11": "敦固守孤城",
                "12": "獨當羣寇",
                "13": "以少禦眾",
                "14": "載離寒暑",
                "15": "臨危奮節",
                "16": "保穀全城",
                "17": "而雍州從事",
                "18": "忌敦勳效",
                "19": "極推小疵",
                "20": "非所以襃獎元功",
                "21": "宜解敦禁劾假授",
                "22": "詔書遽許",
                "23": "而子固已下獄發憤而卒也",
                "24": "朝廷聞而傷之",
                "25": "策書曰",
                "26": "皇帝咨故督守關中侯馬敦",
                "27": "忠勇果毅",
                "28": "率厲有力",
                "29": "固守孤城",
                "30": "危逼獲濟",
                "31": "寵秩未加",
                "32": "不幸喪亡",
                "33": "朕用悼焉",
                "34": "今追贈牙門將軍印綬",
                "35": "祠以少牢",
                "36": "魂而有靈",
                "37": "嘉茲寵榮",
                "38": "然絜士之聞穢",
                "39": "其庸致思乎",
                "40": "若乃下吏之肆其噤害",
                "41": "則皆妬之徒也",
                "42": "嗟乎",
                "43": "妬之欺善",
                "44": "抑亦貿首之讎也",
                "45": "語曰",
                "46": "或戒其子",
                "47": "愼無爲善",
                "48": "言固可以若是",
                "49": "悲夫"
            }
        },
        "3": {
            "7": {
                "1": "昔乘丘之戰",
                "2": "縣賁父御魯莊公",
                "3": "馬驚敗績",
                "4": "賁父曰",
                "5": "他日未嘗敗績",
                "6": "而今敗績",
                "7": "是無勇也",
                "8": "遂死之",
                "9": "圉人浴馬",
                "10": "有流矢在白肉",
                "11": "公曰",
                "12": "非其罪也",
                "13": "乃誄之",
                "14": "漢明帝時",
                "15": "有司馬叔持者",
                "16": "白日於都市手劍父讎",
                "17": "視死如歸",
                "18": "亦命史臣班固而爲之誄",
                "19": "然則忠孝義烈之流",
                "20": "慷慨非命而死者",
                "21": "綴辭之士",
                "22": "未之或遺也",
                "23": "天子旣已策而贈之",
                "24": "微臣託乎舊史之末",
                "25": "敢闕其文哉",
                "26": "乃作誄曰"
            }
        },
        "4": {
            "9": {
                "1": "知人未易",
                "2": "人未易知",
                "3": "嗟茲馬生",
                "4": "位末名卑",
                "5": "西戎猾夏",
                "6": "乃奮其奇",
                "7": "保此汧城",
                "8": "救我邊危",
                "9": "彼邊奚危",
                "10": "城小粟富",
                "11": "子以眇身",
                "12": "而裁其守",
                "13": "兵無加衞",
                "14": "墉不增築",
                "15": "婪婪羣狄",
                "16": "豺虎競逐",
                "17": "鞏更恣睢",
                "18": "潛跱官寺",
                "19": "齊萬虓闞",
                "20": "震驚台司",
                "21": "聲勢沸騰",
                "22": "種落煽熾",
                "23": "旌旗電舒",
                "24": "戈矛林植",
                "25": "彤珠星流",
                "26": "飛矢雨集",
                "27": "惴惴士女",
                "28": "號天以泣",
                "29": "爨麥而炊",
                "30": "負戶以汲",
                "31": "累卵之危",
                "32": "倒懸之急"
            }
        },
        "5": {
            "11": {
                "1": "馬生爰發",
                "2": "在險彌亮",
                "3": "精冠白日",
                "4": "猛烈秋霜",
                "5": "稜威可厲",
                "6": "懦夫克壯",
                "7": "霑恩撫循",
                "8": "寒士挾纊",
                "9": "蠢蠢犬羊",
                "10": "阻眾陵寡",
                "11": "潛隧密攻",
                "12": "九地之下",
                "13": "愜愜窮城",
                "14": "氣若無假",
                "15": "昔命懸天",
                "16": "今也惟馬",
                "17": "惟此馬生",
                "18": "才博智贍",
                "19": "偵以甁壺",
                "20": "𠜺以長塹",
                "21": "徐爰射雉賦注曰",
                "22": "𠜺",
                "23": "割也",
                "24": "說文曰",
                "25": "塹",
                "26": "坑也",
                "27": "七豔切",
                "28": "鍤未見鋒",
                "29": "火以起焰",
                "30": "薰尸滿窟",
                "31": "棓穴以斂",
                "32": "木石匱竭",
                "33": "萁稈空虛",
                "34": "瞷然馬生",
                "35": "傲若有餘",
                "36": "𦉹梁爲礧",
                "37": "柿松爲芻",
                "38": "守不乏械",
                "39": "歷有鳴駒",
                "40": "哀哀建威",
                "41": "身伏斧質",
                "42": "悠悠烈將",
                "43": "覆軍喪器",
                "44": "戎釋我徒",
                "45": "顯誅我帥",
                "46": "以生易死",
                "47": "疇克不二",
                "48": "聖朝西顧",
                "49": "關右震惶",
                "50": "分我汧庾",
                "51": "化爲寇糧",
                "52": "實賴夫子",
                "53": "思謩彌長",
                "54": "咸使有勇",
                "55": "致命知方"
            }
        },
        "6": {
            "13": {
                "1": "我雖末學",
                "2": "聞之前典",
                "3": "十世宥能",
                "4": "表墓旌善",
                "5": "思人愛樹",
                "6": "甘棠不剪",
                "7": "矧乃吾子",
                "8": "功深疑淺",
                "9": "兩造未具",
                "10": "儲隸蓋鮮",
                "11": "孰是勳庸",
                "12": "而不獲免",
                "13": "猾哉部司",
                "14": "其心反側",
                "15": "斲善害能",
                "16": "醜正惡直",
                "17": "牧人逶迆",
                "18": "自公退食",
                "19": "聞穢鷹揚",
                "20": "曾不戢翼",
                "21": "忘爾大勞",
                "22": "猜爾小利",
                "23": "苟莫開懷",
                "24": "於何不至",
                "25": "慨慨馬生",
                "26": "琅琅高致",
                "27": "發憤囹圄",
                "28": "沒而猶視",
                "29": "嗚呼哀哉"
            }
        },
        "7": {
            "15": {
                "1": "安平出奇",
                "2": "破齊克完",
                "3": "張孟運籌",
                "4": "危趙獲安",
                "5": "汧人賴子",
                "6": "猶彼談單",
                "7": "如何吝嫉",
                "8": "搖之筆端",
                "9": "傾倉可賞",
                "10": "矧云私粟",
                "11": "狄隸可頒",
                "12": "況曰家僕",
                "13": "剔子雙龜",
                "14": "貫以三木",
                "15": "功存汧城",
                "16": "身死汧獄",
                "17": "凡爾同圍",
                "18": "心焉摧剝",
                "19": "扶老攜幼",
                "20": "街號巷哭",
                "21": "嗚呼哀哉"
            }
        },
        "8": {
            "17": {
                "1": "明明天子",
                "2": "旌以殊恩",
                "3": "光光寵贈",
                "4": "乃牙其門",
                "5": "司勳頒爵",
                "6": "亦兆後昆",
                "7": "死而有靈",
                "8": "庶慰冤魂",
                "9": "嗚呼哀哉"
            }
        }
    }
}