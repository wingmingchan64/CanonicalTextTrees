{
    "59.02": {
        "篇名": "沈休文 齊故安陸昭王碑文",
        "1": {
            "3": {
                "1": "公諱緬",
                "2": "字景業",
                "3": "南蘭陵人也",
                "4": "稷契身佐唐虞",
                "5": "有大功於天地",
                "6": "商武姬文",
                "7": "所以膺圖受籙",
                "8": "蕭曹扶翼漢祖",
                "9": "滅秦項以寧亂",
                "10": "魏氏乘時於前",
                "11": "皇齊握符於後",
                "12": "靈源與積石爭流",
                "13": "神基與極天比峻",
                "14": "祖宣皇帝",
                "15": "雄才盛烈",
                "16": "名蓋當時",
                "17": "考景皇帝",
                "18": "含道居貞",
                "19": "卷懷前代",
                "20": "公含辰象之秀德",
                "21": "體河岳之上靈",
                "22": "氣蘊風雲",
                "23": "身負日月",
                "24": "立行可模",
                "25": "置言成範",
                "26": "英華外發",
                "27": "清明內昭",
                "28": "天經地義之德",
                "29": "因心必盡",
                "30": "簡久遠大之方",
                "31": "率由斯至",
                "32": "挹其源者遊泳而莫測",
                "33": "懷其道者日用而不知",
                "34": "昭昭若三辰之麗於天",
                "35": "滔滔猶四瀆之紀於地",
                "36": "六幽允洽",
                "37": "一德無爽",
                "38": "萬物仰之而彌高",
                "39": "千里不言而斯應",
                "40": "若夫彈冠出仕之日",
                "41": "登庸蒞事之年",
                "42": "軍麾命服之序",
                "43": "監督方部之數",
                "44": "斯固國史之所詳",
                "45": "今可得略也"
            }
        },
        "2": {
            "5": {
                "1": "水德方衰",
                "2": "天命未改",
                "3": "太祖龍躍俟時",
                "4": "作鎭淮泗",
                "5": "如仁夕惕之志",
                "6": "中夜九迴",
                "7": "龕世拯亂之情",
                "8": "獨用懷抱",
                "9": "深圖密慮",
                "10": "眾莫能窺",
                "11": "公陪奉朝夕",
                "12": "從容左右",
                "13": "蓋同王子洛濱之歲",
                "14": "實惟辟彊內侍之年",
                "15": "起予聖懷",
                "16": "發言中旨",
                "17": "始以文學遊梁",
                "18": "俄而入掌綸誥",
                "19": "蘭桂有芬",
                "20": "清暉自遠",
                "21": "帝出於震",
                "22": "日衣青光",
                "23": "方軌茅社",
                "24": "俾侯安陸",
                "25": "受瑞析珪",
                "26": "遂荒雲野",
                "27": "式掌儲命",
                "28": "帝難其人",
                "29": "公以宗室羽儀",
                "30": "允膺嘉選",
                "31": "協隆三善",
                "32": "仰敷四德",
                "33": "博望之苑載暉",
                "34": "龍樓之門以峻",
                "35": "獻替帷扆",
                "36": "實掌喉脣",
                "37": "奉待漏之書",
                "38": "銜如絲之旨",
                "39": "前暉後光",
                "40": "非止恆受",
                "41": "公以密戚上賢",
                "42": "俄而奉職",
                "43": "出納惟允",
                "44": "劍璽增華",
                "45": "伊昔帝唐",
                "46": "九官咸事",
                "47": "熊豹臨戭",
                "48": "納言是司",
                "49": "自此迄今",
                "50": "其任無爽",
                "51": "爰自近侍",
                "52": "式贊權衡",
                "53": "而皇情眷眷",
                "54": "慮深求瘼"
            }
        },
        "3": {
            "7": {
                "1": "姑蘇奧壤",
                "2": "任切關河",
                "3": "都會殷負",
                "4": "提封百萬",
                "5": "全趙之袨服叢臺",
                "6": "方此爲劣",
                "7": "臨淄之揮汗成雨",
                "8": "曾何足稱",
                "9": "乃鴻騫舊吳",
                "10": "作守東楚",
                "11": "弘義讓以勖君子",
                "12": "振平惠以字小人",
                "13": "撫同上德",
                "14": "綏用中典",
                "15": "疑獄得情而弗喜",
                "16": "宿訟兩讓而同歸",
                "17": "雖春申之大啟封疆",
                "18": "鄧攸之緝熙萌庶",
                "19": "不能尙也",
                "20": "夏首藩要",
                "21": "任重推轂",
                "22": "衿帶中流",
                "23": "地殷江漢",
                "24": "南接衡巫",
                "25": "風雲之路千里",
                "26": "西通鄾鄧",
                "27": "水陸之塗三七",
                "28": "是惟形勝",
                "29": "閫外莫先",
                "30": "建麾作牧",
                "31": "明德攸在",
                "32": "乃暴以秋陽",
                "33": "威以夏日",
                "34": "澤無不漸",
                "35": "螻蟻之穴靡遺",
                "36": "明無不察",
                "37": "容光之微必照",
                "38": "由近而被遠",
                "39": "自己而及物",
                "40": "惠與八風俱翔",
                "41": "德與五才並運",
                "42": "遠無不懷",
                "43": "邇無不肅",
                "44": "邑居不聞夜吠之犬",
                "45": "牧人不睹晨飲之羊",
                "46": "譽表六條",
                "47": "功最萬里",
                "48": "還居近侍",
                "49": "兼浜戎秩",
                "50": "候府寄隆",
                "51": "儲端任顯",
                "52": "東西兩晉",
                "53": "茲選特難",
                "54": "羊琇願言而匪獲",
                "55": "謝琰功高而後至",
                "56": "升降二宮",
                "57": "令績斯俟",
                "58": "禁旅尊嚴",
                "59": "主器彌固"
            }
        },
        "4": {
            "9": {
                "1": "禹穴神皋",
                "2": "地埒分陝",
                "3": "江左已來",
                "4": "常遞斯任",
                "5": "東渚鉅海",
                "6": "南望秦稽",
                "7": "淵藪胥萃",
                "8": "雚蒲攸在",
                "9": "貨殖之民",
                "10": "千金比屋",
                "11": "郛鄽之內",
                "12": "雲屋萬家",
                "13": "刑政繁舛",
                "14": "舊難詳一",
                "15": "南山羣盜",
                "16": "未足云多",
                "17": "渤海亂繩",
                "18": "方斯易理",
                "19": "公下車敷化",
                "20": "風動神行",
                "21": "誠恕旣孚",
                "22": "鉤距靡用",
                "23": "不待赭汙之權",
                "24": "而姦渠必剪",
                "25": "無假里端之籍",
                "26": "而惡子咸誅",
                "27": "被以哀矜",
                "28": "孚以信順",
                "29": "南陽葦杖",
                "30": "未足比其仁",
                "31": "潁川時雨",
                "32": "無以豐其澤",
                "33": "公攬轡升車",
                "34": "牧州典郡",
                "35": "感達民祇",
                "36": "非待期月",
                "37": "老安少懷",
                "38": "塗歌里詠",
                "39": "莫不歡若親戚",
                "40": "芬若椒蘭",
                "41": "麾旆每反",
                "42": "行悲道泣",
                "43": "攀車臥轍之戀",
                "44": "爭塗忘遠",
                "45": "去思一借之情",
                "46": "愈久彌結"
            }
        },
        "5": {
            "11": {
                "1": "方城漢池",
                "2": "南顧莫重",
                "3": "北指崤潼",
                "4": "平塗不過七百",
                "5": "西接嶢武",
                "6": "關路曾不盈千",
                "7": "蠻陬夷徼",
                "8": "重山萬里",
                "9": "小則俘民略畜",
                "10": "大則攻城剽邑",
                "11": "晉宋迄今",
                "12": "有切民患",
                "13": "烽鼓相望",
                "14": "歲時不息",
                "15": "椎埋穿掘之黨",
                "16": "阡陌成羣",
                "17": "傲法侮吏之人",
                "18": "曾莫禁禦",
                "19": "累藩咸受其敝",
                "20": "歷政所不能裁",
                "21": "加以戎羯窺窬",
                "22": "伺我邊隙",
                "23": "北風未起",
                "24": "馬首便以南向",
                "25": "塞草未衰",
                "26": "嚴城於焉早閉",
                "27": "永明八載",
                "28": "疆埸大駭",
                "29": "天子乃心北眷",
                "30": "聽朝不怡",
                "31": "揚旆漢南",
                "32": "非公莫可",
                "33": "於是驅馬原隰",
                "34": "卷甲遄征",
                "35": "威令首塗",
                "36": "仁風載路",
                "37": "軌躅清晏",
                "38": "車徒不擾",
                "39": "牛酒日至",
                "40": "壺漿塞陌",
                "41": "失義犬羊",
                "42": "其來久矣",
                "43": "徵賦嚴切",
                "44": "唯利是求",
                "45": "首鼠疆界",
                "46": "災蠹彌廣",
                "47": "公扇以廉風",
                "48": "孚以誠德",
                "49": "盡任棠置水之情",
                "50": "弘郭伋待期之信",
                "51": "東觀漢記曰",
                "52": "龐參",
                "53": "字仲達",
                "54": "拜漢陽太守",
                "55": "郡民任棠者",
                "56": "有奇節",
                "57": "參到先候之",
                "58": "棠不與言",
                "59": "但以䪥一本",
                "60": "水一杯",
                "61": "置戶屛前",
                "62": "自抱孫兒伏於戶下",
                "63": "參思其微意",
                "64": "良久曰",
                "65": "棠是欲曉太守也",
                "66": "水者",
                "67": "欲吾清也",
                "68": "拔大本䪥",
                "69": "欲吾擊強宗也",
                "70": "抱兒當戶",
                "71": "欲吾開門卹孤也",
                "72": "於是歎息而還",
                "73": "參在職",
                "74": "果能抑豪助弱",
                "75": "以惠政得民",
                "76": "司馬彪續漢書曰",
                "77": "郭伋拜幷州牧",
                "78": "行部西河",
                "79": "到美稷",
                "80": "數百小兒各騎竹馬逢迎",
                "81": "伋問曰",
                "82": "兒曹何自遠來",
                "83": "對曰",
                "84": "聞使君到",
                "85": "喜",
                "86": "故來迎",
                "87": "伋謝曰",
                "88": "辛苦諸童",
                "89": "小兒復送至郭門外",
                "90": "問使君何日當還",
                "91": "伋謂別駕計日告之",
                "92": "行部還入美稷",
                "93": "先期一日",
                "94": "伋念負諸兒",
                "95": "卽止野亭",
                "96": "須期乃往",
                "97": "伋重信得人心",
                "98": "皆此類也",
                "99": "金如粟而弗睹",
                "100": "馬如羊而靡入",
                "101": "雛雉必懷",
                "102": "豚魚不爽",
                "103": "由是傾巢舉落",
                "104": "望德如歸",
                "105": "椎髻髽首",
                "106": "日拜門闕",
                "107": "卉服滿塗",
                "108": "夷歌成韻",
                "109": "禮義旣敷",
                "110": "威刑具舉",
                "111": "強民獷俗",
                "112": "反志遷情",
                "113": "風塵不起",
                "114": "囹圄寂寞",
                "115": "富商野次",
                "116": "宿秉停菑",
                "117": "蝝蝗弗起",
                "118": "豺虎遠迹",
                "119": "北狄懼威",
                "120": "關塞謐靜",
                "121": "偵諜不敢東窺",
                "122": "駝馬不敢南牧",
                "123": "方欲振策燕趙",
                "124": "席卷秦代",
                "125": "陪龍駕於伊洛",
                "126": "侍紫蓋於咸陽",
                "127": "而遘疾彌留",
                "128": "欻焉大漸",
                "129": "耕夫釋耒",
                "130": "桑婦下機",
                "131": "參請門衢",
                "132": "並走羣望",
                "133": "維永明九年夏五月三十日辛酉薨",
                "134": "春秋三十有七",
                "135": "城府䬃然",
                "136": "庶僚如霣",
                "137": "男女老幼",
                "138": "大臨街衢",
                "139": "接響傳聲",
                "140": "不踰時而達於四境",
                "141": "夷羣戎落",
                "142": "幽遠必至",
                "143": "望城拊膺",
                "144": "震動郛邑",
                "145": "並求入奉靈櫬",
                "146": "藩司抑而不許",
                "147": "雖鄧訓致劈面之哀",
                "148": "羊公深罷市之慕",
                "149": "對而爲言",
                "150": "遠有慚德",
                "151": "神駕東還",
                "152": "號送踰境",
                "153": "奉觴奠以望靈",
                "154": "仰蒼天而自訴",
                "155": "震響成雷",
                "156": "盈塗咽水"
            }
        },
        "6": {
            "13": {
                "1": "公臨危審正",
                "2": "載惟話言",
                "3": "楚囊之情",
                "4": "惟幾而彌固",
                "5": "衞魚之心",
                "6": "身亡而意結",
                "7": "二宮軫慟",
                "8": "遐邇同哀",
                "9": "追贈侍中領衞將軍",
                "10": "給鼓吹一部",
                "11": "謚曰昭侯",
                "12": "時皇上納麓在辰",
                "13": "登庸伊始",
                "14": "允副朝端",
                "15": "兼掌屯衞",
                "16": "聞凶哀震",
                "17": "感絕移時",
                "18": "因遘沈痾",
                "19": "綿留氣序",
                "20": "世祖日夜憂懷",
                "21": "備盡寬譬",
                "22": "勉膳禁哭",
                "23": "中使相望",
                "24": "上雖外順皇旨",
                "25": "內殷私痛",
                "26": "獨居不御酒肉",
                "27": "坐臥泣涕霑衣",
                "28": "若此移年",
                "29": "虞瘠改貌",
                "30": "天倫之愛",
                "31": "振古莫儔",
                "32": "及俯膺天眷",
                "33": "入纂絕業",
                "34": "分命懿親",
                "35": "台牧並建",
                "36": "對繁弱以流涕",
                "37": "望曲阜而含悲",
                "38": "改贈司徒",
                "39": "因謚爲郡王",
                "40": "禮也"
            }
        },
        "7": {
            "15": {
                "1": "惟公少而英明",
                "2": "長而弘潤",
                "3": "風標秀舉",
                "4": "清暉映世",
                "5": "學遍書部",
                "6": "特善玄言",
                "7": "鞶帨之麗",
                "8": "篆籀之則",
                "9": "窮六義於懷抱",
                "10": "究八體於毫端",
                "11": "弈思之微",
                "12": "秋儲無以競巧",
                "13": "取睽之妙",
                "14": "流睇未足稱奇",
                "15": "至公以奉上",
                "16": "鳴謙以接下",
                "17": "撫僚庶盡盛德之容",
                "18": "交士林忘公侯之貴",
                "19": "虛懷博約",
                "20": "幽關洞開",
                "21": "宴語談笑",
                "22": "情瀾不竭",
                "23": "譽滿天下",
                "24": "德冠生民",
                "25": "蓋百代之儀表",
                "26": "千年之領袖",
                "27": "曾不憖留",
                "28": "梁摧奄及",
                "29": "豈唯僑終蹇謝",
                "30": "興謠輟相而已哉",
                "31": "凡我僚舊",
                "32": "均哀共戚",
                "33": "怨天德之無厚",
                "34": "痛棠陰之不留",
                "35": "思所以克播遺塵",
                "36": "敝之穹壤",
                "37": "乃刊石圖徽",
                "38": "寄情銘頌",
                "39": "其辭曰"
            }
        },
        "8": {
            "17": {
                "1": "天命玄鳥",
                "2": "降而生商",
                "3": "是開金運",
                "4": "祚始玉筐",
                "5": "三仁去國",
                "6": "五曜入房",
                "7": "亦白其馬",
                "8": "侯服周王"
            }
        },
        "9": {
            "19": {
                "1": "本枝派別",
                "2": "因菜命氏",
                "3": "涉徐而東",
                "4": "義均梁徙",
                "5": "自茲以降",
                "6": "懷青拕紫",
                "7": "崇基巖巖",
                "8": "長瀾濔濔"
            }
        },
        "10": {
            "21": {
                "1": "惟聖造物",
                "2": "龍飛天步",
                "3": "載鼎載革",
                "4": "有除有布",
                "5": "高皇赫矣",
                "6": "仰膺乾顧",
                "7": "景皇蒸哉",
                "8": "實啟洪祚"
            }
        },
        "11": {
            "23": {
                "1": "喬嶽峻峙",
                "2": "命世興賢",
                "3": "膺期誕德",
                "4": "絕後光前",
                "5": "幾以成務",
                "6": "覺在民先",
                "7": "位非大寶",
                "8": "爵乃上天"
            }
        },
        "12": {
            "25": {
                "1": "爰始濯纓",
                "2": "清猷浚發",
                "3": "升降文陛",
                "4": "逶迆魏闕",
                "5": "惠露霑吳",
                "6": "仁風扇越",
                "7": "涉夏踰漢",
                "8": "政成期月"
