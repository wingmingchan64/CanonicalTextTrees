{
    "16.03": {
        "篇名": "向子期 思舊賦[幷序]",
        "1": {
            "3": {
                "1": "余與嵇康呂安居止接近",
                "2": "其人並有不羈之才",
                "3": "然嵇志遠而疏",
                "4": "呂心曠而放",
                "5": "其後各以事見法",
                "6": "嵇博綜技藝",
                "7": "於絲竹特妙",
                "8": "臨當就命",
                "9": "顧視日影",
                "10": "索琴而彈之",
                "11": "余逝將西邁",
                "12": "經其舊廬",
                "13": "於時日薄虞淵",
                "14": "寒冰淒然",
                "15": "鄰人有吹笛者",
                "16": "發聲寥亮",
                "17": "追思曩昔遊宴之好",
                "18": "感音而歎",
                "19": "故作賦云"
            }
        },
        "2": {
            "5": {
                "1": "將命適於遠京兮",
                "2": "遂旋反而北徂",
                "3": "濟黃河以泛舟兮",
                "4": "經山陽之舊居",
                "5": "瞻曠野之蕭條兮",
                "6": "息余駕乎城隅",
                "7": "踐二子之遺迹兮",
                "8": "歷窮巷之空廬",
                "9": "歎黍離之愍周兮",
                "10": "悲麥秀於殷墟",
                "11": "惟古昔以懷今兮",
                "12": "心徘徊以躊躇",
                "13": "棟宇存而弗毀兮",
                "14": "形神逝其焉如",
                "15": "昔李斯之受罪兮",
                "16": "歎黃犬而長吟",
                "17": "悼嵇生之永辭兮",
                "18": "顧日影而彈琴",
                "19": "託運遇於領會兮",
                "20": "寄餘命於寸陰",
                "21": "聽鳴笛之慷慨兮",
                "22": "妙聲絕而復尋",
                "23": "停駕言其將邁兮",
                "24": "遂援翰而寫心"
            }
        }
    }
}