{
    "23.18-01": {
        "篇名": "劉公幹 贈從弟三首·其一",
        "1": {
            "3": {
                "1": "泛泛東流水",
                "2": "磷磷水中石",
                "3": "蘋藻生其涯",
                "4": "華紛何擾弱",
                "5": "采之薦宗廟",
                "6": "可以羞嘉客",
                "7": "豈無園中葵",
                "8": "懿此出深澤"
            }
        }
    }
