{
    "55.02": {
        "篇名": "陸士衡 演連珠五十首",
        "1": {
            "3": {
                "1": "臣聞日薄星迴",
                "2": "穹天所以紀物",
                "3": "山盈川沖",
                "4": "后土所以播氣",
                "5": "五行錯而致用",
                "6": "四時違而成歲",
                "7": "是以百官恪居",
                "8": "以赴八音之離",
                "9": "明君執契",
                "10": "以要克諧之會"
            }
        },
        "2": {
            "5": {
                "1": "臣聞任重於力",
                "2": "才盡則困",
                "3": "用廣其器",
                "4": "應博則凶",
                "5": "是以物勝權而衡殆",
                "6": "形過鏡則照窮",
                "7": "故明主程才以效業",
                "8": "貞臣底力而辭豐"
            }
        },
        "3": {
            "7": {
                "1": "臣聞髦俊之才",
                "2": "世所希乏",
                "3": "丘園之秀",
                "4": "因時則揚",
                "5": "是以大人基命",
                "6": "不擢才於后土",
                "7": "明主聿興",
                "8": "不降佐於昊蒼"
            }
        },
        "4": {
            "9": {
                "1": "臣聞世之所遺",
                "2": "未爲非寶",
                "3": "主之所珍",
                "4": "不必適治",
                "5": "是以俊乂之藪",
                "6": "希蒙翹車之招",
                "7": "金碧之巖",
                "8": "必辱鳳舉之使"
            }
        },
        "5": {
            "11": {
                "1": "臣聞祿放於寵",
                "2": "非隆家之舉",
                "3": "官私於親",
                "4": "非興邦之選",
                "5": "是以三卿世及",
                "6": "東國多衰敝之政",
                "7": "五侯並軌",
                "8": "西京有陵夷之運"
            }
        },
        "6": {
            "13": {
                "1": "臣聞靈輝朝覯",
                "2": "稱物納照",
                "3": "時風夕灑",
                "4": "程形賦音",
                "5": "是以至道之行",
                "6": "萬類取足於世",
                "7": "大化旣洽",
                "8": "百姓無匱於心"
            }
        },
        "7": {
            "15": {
                "1": "臣聞頓網探淵",
                "2": "不能招龍",
                "3": "振綱羅雲",
                "4": "不必招鳳",
                "5": "是以巢箕之叟",
                "6": "不眄丘園之幣",
                "7": "洗渭之民",
                "8": "不發傅巖之夢"
            }
        },
        "8": {
            "17": {
                "1": "臣聞鑑之積也無厚",
                "2": "而照有重淵之深",
                "3": "目之察也有畔",
                "4": "而視周天壤之際",
                "5": "何則",
                "6": "應事以精不以形",
                "7": "造物以神不以器",
                "8": "是以萬邦凱樂",
                "9": "非悅鍾鼓之娛",
                "10": "天下歸仁",
                "11": "非感玉帛之惠"
            }
        },
        "9": {
            "19": {
                "1": "臣聞積實雖微",
                "2": "必動於物",
                "3": "崇虛雖廣",
                "4": "不能移心",
                "5": "是以都人冶容",
                "6": "不悅西施之影",
                "7": "乘馬班如",
                "8": "不輟太山之陰"
            }
        },
        "10": {
            "21": {
                "1": "臣聞應物有方",
                "2": "居難則易",
                "3": "藏器在身",
                "4": "所乏者時",
                "5": "是以充堂之芳",
                "6": "非幽蘭所難",
                "7": "繞梁之音",
                "8": "實縈絃所思"
            }
        },
        "11": {
            "23": {
                "1": "臣聞智周通塞",
                "2": "不爲時窮",
                "3": "才經夷險",
                "4": "不爲世屈",
                "5": "是以凌飆之羽",
                "6": "不求反風",
                "7": "耀夜之目",
                "8": "不思倒日"
            }
        },
        "12": {
            "25": {
                "1": "臣聞忠臣率志",
                "2": "不謀其報",
                "3": "貞士發憤",
                "4": "期在明賢",
                "5": "是以柳莊黜殯",
                "6": "非貪瓜衍之賞",
                "7": "禽息碎首",
                "8": "豈要先茅之田"
            }
        },
        "13": {
            "27": {
                "1": "臣聞利眼臨雲",
                "2": "不能垂照",
                "3": "朗璞蒙垢",
                "4": "不能吐輝",
                "5": "是以明哲之君",
                "6": "時有蔽壅之累",
                "7": "俊乂之臣",
                "8": "屢抱後時之悲"
            }
        },
        "14": {
            "29": {
                "1": "臣聞郁烈之芳",
                "2": "出於委灰",
                "3": "繁會之音",
                "4": "生於絕絃",
                "5": "是以貞女要名於沒世",
                "6": "烈士赴節於當年"
            }
        },
        "15": {
            "31": {
                "1": "臣聞良宰謀朝",
                "2": "不必借威",
                "3": "貞臣衞主",
                "4": "修身則足",
                "5": "是以三晉之強",
                "6": "屈於齊堂之俎",
                "7": "千乘之勢",
                "8": "弱於陽門之哭"
            }
        },
        "16": {
            "33": {
                "1": "臣聞赴曲之音",
                "2": "洪細入韻",
                "3": "蹈節之容",
                "4": "俯仰依詠",
                "5": "是以言苟適事",
                "6": "精粗可施",
                "7": "士苟適道",
                "8": "修短可命"
            }
        },
        "17": {
            "35": {
                "1": "臣聞因雲灑潤",
                "2": "則芬澤易流",
                "3": "乘風載響",
                "4": "則音徽自遠",
                "5": "是以德教俟物而濟",
                "6": "榮名緣時而顯"
            }
        },
        "18": {
            "37": {
                "1": "臣聞覽影偶質",
                "2": "不能解獨",
                "3": "指迹慕遠",
                "4": "無救於遲",
                "5": "是以循虛器者",
                "6": "非應物之具",
                "7": "翫空言者",
                "8": "非致治之機"
            }
        },
        "19": {
            "39": {
                "1": "臣聞鑽燧吐火",
                "2": "以續湯谷之晷",
                "3": "揮翮生風",
                "4": "而繼飛廉之功",
                "5": "是以物有微而毗著",
                "6": "事有瑣而助洪"
            }
        },
        "20": {
            "41": {
                "1": "臣聞春風朝煦",
                "2": "蕭艾蒙其溫",
                "3": "秋霜宵墜",
                "4": "芝蕙被其涼",
                "5": "是故威以齊物爲肅",
                "6": "德以普濟爲弘"
            }
        },
        "21": {
            "43": {
                "1": "臣聞巧盡於器",
                "2": "習數則貫",
                "3": "道繫於神",
                "4": "人亡則滅",
                "5": "是以輪匠肆目",
                "6": "不乏奚仲之妙",
                "7": "瞽叟清耳",
                "8": "而無伶倫之察"
            }
        },
        "22": {
            "45": {
                "1": "臣聞性之所期",
                "2": "貴賤同量",
                "3": "理之所極",
                "4": "卑高一歸",
                "5": "是以准月稟水",
                "6": "不能加涼",
                "7": "晞日引火",
                "8": "不必增輝"
            }
        },
        "23": {
            "47": {
                "1": "臣聞絕節高唱",
                "2": "非凡耳所悲",
                "3": "肆義芳訊",
                "4": "非庸聽所善",
                "5": "是以南荊有寡和之歌",
                "6": "東野有不釋之辯"
            }
        },
        "24": {
            "49": {
                "1": "臣聞尋煙染芬",
                "2": "薰息猶芳",
                "3": "徵音錄響",
                "4": "操終則絕",
                "5": "何則",
                "6": "垂於世者可繼",
                "7": "止乎身者難結",
                "8": "是以玄晏之風恆存",
                "9": "動神之化已滅"
            }
        },
        "25": {
            "51": {
                "1": "臣聞託闇藏形",
                "2": "不爲巧密",
                "3": "倚智隱情",
                "4": "不足自匿",
                "5": "是以重光發藻",
                "6": "尋虛捕景",
                "7": "大人貞觀",
                "8": "探心昭忒"
            }
        },
        "26": {
            "53": {
                "1": "臣聞披雲看霄",
                "2": "則天文清",
                "3": "澄風觀水",
                "4": "則川流平",
                "5": "是以四族放而唐劭",
                "6": "二臣誅而楚寧"
            }
        },
        "27": {
            "55": {
                "1": "臣聞音以比耳爲美",
                "2": "色以悅目爲歡",
                "3": "是以眾聽所傾",
                "4": "非假百里之操",
                "5": "萬夫婉孌",
                "6": "非俟西子之顏",
                "7": "故聖人隨世以擢佐",
                "8": "明主因時而命官"
            }
        },
        "28": {
            "57": {
                "1": "臣聞出乎身者",
                "2": "非假物所隆",
                "3": "牽乎時者",
                "4": "非克己所勖",
                "5": "是以利盡萬物",
                "6": "不能叡童昏之心",
                "7": "德表生民",
                "8": "不能救栖遑之辱"
            }
        },
        "29": {
            "59": {
                "1": "臣聞動循定檢",
                "2": "天有可察",
                "3": "應無常節",
                "4": "身或難照",
                "5": "是以望景揆日",
                "6": "盈數可期",
                "7": "撫臆論心",
                "8": "有時而謬"
            }
        },
        "30": {
            "61": {
                "1": "臣聞傾耳求音",
                "2": "視優聽苦",
                "3": "澄心徇物",
                "4": "形逸神勞",
                "5": "是以天殊其數",
                "6": "雖同方不能分其慼",
                "7": "理塞其通",
                "8": "則並質不能共其休"
            }
        },
        "31": {
            "63": {
                "1": "臣聞遯世之士",
                "2": "非受匏瓜之性",
                "3": "幽居之女",
                "4": "非無懷春之情",
                "5": "是以名勝欲",
                "6": "故偶影之操矜",
                "7": "窮愈達",
                "8": "故凌霄之節厲"
            }
        },
        "32": {
            "65": {
                "1": "臣聞聽極於音",
                "2": "不慕鈞天之樂",
                "3": "身足於蔭",
                "4": "無假垂天之雲",
                "5": "是以蒲密之黎",
                "6": "遺時雍之世",
                "7": "豐沛之士",
                "8": "忘桓撥之君"
            }
        },
        "33": {
            "67": {
                "1": "臣聞飛轡西頓",
                "2": "則離朱與矇瞍收察",
                "3": "懸景東秀",
                "4": "則夜光與武夫匿耀",
                "5": "是以才換世則俱困",
                "6": "功偶時而並劭"
            }
        },
        "34": {
            "69": {
                "1": "臣聞示應於近",
                "2": "遠有可察",
                "3": "託驗於顯",
                "4": "微或可包",
                "5": "是以寸管下傃",
                "6": "天地不能以氣欺",
                "7": "尺表逆立",
                "8": "日月不能以形逃"
            }
        },
        "35": {
            "71": {
                "1": "臣聞絃有常音",
                "2": "故曲終則改",
                "3": "鏡無畜影",
                "4": "故觸形則照",
                "5": "是以虛己應物",
                "6": "必究千變之容",
                "7": "挾情適事",
                "8": "不觀萬殊之妙"
            }
        },
        "36": {
            "73": {
                "1": "臣聞柷敔希聲",
                "2": "以諧金石之和",
                "3": "鼙鼓疏擊",
                "4": "以節繁絃之契",
                "5": "是以經治必宣其通",
                "6": "圖物恆審其會"
            }
        },
        "37": {
            "75": {
                "1": "臣聞目無嘗音之察",
                "2": "耳無照景之神",
                "3": "故在乎我者",
                "4": "不誅之於己",
                "5": "存乎物者",
                "6": "不求備於人"
            }
        },
        "38": {
            "77": {
                "1": "臣聞放身而居",
                "2": "體逸則安",
                "3": "肆口而食",
                "4": "屬厭則充",
                "5": "是以王鮪登俎",
                "6": "不假吞波之魚",
                "7": "蘭膏停室",
                "8": "不思銜燭之龍"
            }
        },
        "39": {
            "79": {
                "1": "臣聞衝波安流",
                "2": "則龍舟不能以漂",
                "3": "震風洞發",
                "4": "則夏屋有時而傾",
                "5": "何則﹖牽乎動則靜凝",
                "6": "係乎靜則動貞",
                "7": "是以淫風大行",
                "8": "貞女蒙冶容之悔",
                "9": "淳化殷流",
                "10": "盜跖挾曾史之情"
            }
        },
        "40": {
            "81": {
                "1": "臣聞達之所服",
                "2": "貴有或遺",
                "3": "窮之所接",
                "4": "賤而必尋",
                "5": "是以江漢之君",
                "6": "悲其墜屨",
                "7": "少原之婦",
                "8": "哭其亡簪"
            }
        },
        "41": {
            "83": {
                "1": "臣聞觸非其類",
                "2": "雖疾弗應",
                "3": "感以其方",
                "4": "雖微則順",
                "5": "是以商飆漂山",
                "6": "不興盈尺之雲",
                "7": "谷風乘條",
                "8": "必降彌天之潤",
                "9": "故暗於治者",
                "10": "唱繁而和寡",
                "11": "審乎物者",
                "12": "力約而功峻"
            }
        },
        "42": {
            "85": {
                "1": "臣聞煙出於火",
                "2": "非火之和",
                "3": "情生於性",
                "4": "非性之適",
                "5": "故火壯則煙微",
                "6": "性充則情約",
                "7": "是以殷墟有感物之悲",
                "8": "周京無佇立之迹"
            }
        },
        "43": {
            "87": {
                "1": "臣聞適物之技",
                "2": "俯仰異用",
                "3": "應事之器",
                "4": "通塞異任",
                "5": "是以鳥栖雲而繳飛",
                "6": "魚藏淵而網沈",
                "7": "賁鼓密而含響",
                "8": "朗笛疏而吐音"
            }
        },
        "44": {
            "89": {
                "1": "臣聞理之所守",
                "2": "勢所常奪",
                "3": "道之所閉",
                "4": "權所必開",
                "5": "是以生重於利",
                "6": "故據圖無揮劍之痛",
                "7": "義貴於身",
                "8": "故臨川有投迹之哀"
            }
        },
        "45": {
            "91": {
                "1": "臣聞通於變者",
                "2": "用約而利博",
                "3": "明其要者",
                "4": "器淺而應玄",
                "5": "是以天地之賾",
                "6": "該於六位",
                "7": "萬殊之曲",
                "8": "窮於五絃"
            }
        },
        "46": {
            "93": {
                "1": "臣聞圖形於影",
                "2": "未盡纖麗之容",
                "3": "察火於灰",
                "4": "不睹洪赫之烈",
                "5": "是以問道存乎其人",
                "6": "觀物必造其質"
            }
        },
        "47": {
            "95": {
                "1": "臣聞情見於物",
                "2": "雖遠猶疏",
                "3": "神藏於形",
                "4": "雖近則密",
                "5": "是以儀天步晷",
                "6": "而修短可量",
                "7": "臨淵揆水",
                "8": "而淺深難察"
            }
        },
        "48": {
            "97": {
                "1": "臣聞虐暑熏天",
                "2": "不減堅冰之寒",
                "3": "涸陰凝地",
                "4": "無累陵火之熱",
                "5": "是以吞縱之強",
                "6": "不能反蹈海之志",
                "7": "漂鹵之威",
                "8": "不能降西山之節"
            }
        },
        "49": {
            "99": {
                "1": "臣聞理之所開",
                "2": "力所常達",
                "3": "數之所塞",
                "4": "威有必窮",
                "5": "是以烈火流金",
                "6": "不能焚景",
                "7": "沈寒凝海",
                "8": "不能結風"
            }
        },
        "50": {
            "101": {
                "1": "臣聞足於性者",
                "2": "天損不能入",
                "3": "貞於期者",
                "4": "時累不能淫",
                "5": "是以迅風陵雨",
                "6": "不謬晨禽之察",
                "7": "勁陰殺節",
                "8": "不凋寒木之心"
            }
        }
    }
}