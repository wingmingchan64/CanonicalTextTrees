{
    "50.01": {
        "篇名": "范蔚宗 後漢書二十八將傳論",
        "1": {
            "3": {
                "1": "論曰",
                "2": "中興二十八將",
                "3": "前世以爲上應二十八宿",
                "4": "未之詳也",
                "5": "然咸能感會風雲",
                "6": "奮其智勇",
                "7": "稱爲佐命",
                "8": "亦各志能之士也"
            }
        },
        "2": {
            "5": {
                "1": "議者多非光武不以功臣任職",
                "2": "至使英姿茂績",
                "3": "委而勿用",
                "4": "然原夫深圖遠筭",
                "5": "固將有以爲爾",
                "6": "若乃王道旣衰",
                "7": "降及霸德",
                "8": "猶能授受惟庸",
                "9": "勳賢兼序",
                "10": "如管隰之迭升桓世",
                "11": "先趙之同列文朝",
                "12": "可謂兼通矣",
                "13": "降自秦漢",
                "14": "世資戰力",
                "15": "至於翼扶王室",
                "16": "皆武人屈起",
                "17": "亦有鬻繒盜狗輕猾之徒",
                "18": "或崇以連城之賞",
                "19": "或任以阿衡之地",
                "20": "故勢疑則隙生",
                "21": "力侔則亂起",
                "22": "蕭樊且猶縲紲",
                "23": "信越終見葅戮",
                "24": "不其然乎",
                "25": "自茲以降",
                "26": "訖於孝武",
                "27": "宰輔五世",
                "28": "莫非公侯",
                "29": "遂使縉紳道塞",
                "30": "賢能蔽壅",
                "31": "朝有世及之私",
                "32": "下多抱關之怨",
                "33": "其懷道無聞",
                "34": "委身草莽者",
                "35": "亦何可勝言",
                "36": "故光武鑒前事之違",
                "37": "存矯枉之志",
                "38": "雖寇鄧之高勳",
                "39": "耿賈之鴻烈",
                "40": "分土不過大縣數四",
                "41": "所加特進朝請而已",
                "42": "觀其治平臨政",
                "43": "課職責咎",
                "44": "將所謂導之以法",
                "45": "齊之以刑者乎"
            }
        },
        "3": {
            "7": {
                "1": "若格之功臣",
                "2": "其傷已甚",
                "3": "何者",
                "4": "直繩則虧喪恩舊",
                "5": "撓情則違廢禁典",
                "6": "選德則功不必厚",
                "7": "舉勞則人或未賢",
                "8": "參任則羣心難塞",
                "9": "並列則其敝未遠",
                "10": "不得不校其勝否",
                "11": "卽事相權",
                "12": "故高秩厚禮",
                "13": "允答元功",
                "14": "峻文深憲",
                "15": "責成吏職",
                "16": "漢書曰",
                "17": "翟方進爲相",
                "18": "峻文深𧥮",
                "19": "中傷者尤多",
                "20": "建武之世",
                "21": "侯者百數",
                "22": "若夫數公者",
                "23": "則與參國議",
                "24": "分均休咎",
                "25": "其餘並優以寬科",
                "26": "完其封祿",
                "27": "莫不終以功名",
                "28": "延慶於後",
                "29": "昔留侯以爲高祖悉用蕭曹故人",
                "30": "郭伋亦議南陽多顯",
                "31": "鄭興又戒功臣專任",
                "32": "夫崇恩偏授",
                "33": "易啟私溺之失",
                "34": "至公均被",
                "35": "必廣招賢之路",
                "36": "意者不其然乎"
            }
        },
        "4": {
            "9": {
                "1": "永平中",
                "2": "顯宗追感前世功臣",
                "3": "乃圖畫二十八將於南宮雲臺",
                "4": "其外又有王常李通竇融卓茂",
                "5": "合三十二人",
                "6": "故依本第",
                "7": "係之篇末",
                "8": "以志功次云爾"
            }
        }
    }
}