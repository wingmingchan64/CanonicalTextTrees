{
    "25.12-02": {
        "篇名": "謝宣遠 於安城答靈運·其二",
        "1": {
            "3": {
                "1": "華萼相光飾",
                "2": "嚶嚶悅同響",
                "3": "毛詩曰",
                "4": "棠棣之華",
                "5": "萼不𩋾𩋾",
                "6": "鄭玄曰",
                "7": "興者",
                "8": "諭弟以敬事兄",
                "9": "兄以榮覆弟也",
                "10": "親親子敦予",
                "11": "賢賢吾爾賞",
                "12": "比景後鮮輝",
                "13": "方年一日長",
                "14": "萎葉愛榮條",
                "15": "涸流好河廣"
            }
        }
    }
}