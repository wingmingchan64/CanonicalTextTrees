{
    "07.01": {
        "篇名": "楊子雲 甘泉賦[幷序]",
        "1": {
            "3": {
                "1": "孝成帝時",
                "2": "客有薦雄文似相如者",
                "3": "上方郊祀甘泉泰畤",
                "4": "汾陰后土",
                "5": "以求繼嗣",
                "6": "召雄待詔承明之庭",
                "7": "正月",
                "8": "從上甘泉還",
                "9": "奏甘泉賦以風",
                "10": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "惟漢十世",
                "2": "將郊上玄",
                "3": "定泰畤",
                "4": "雍神休",
                "5": "尊明號",
                "6": "同符三皇",
                "7": "錄功五帝",
                "8": "卹胤錫羨",
                "9": "拓迹開統",
                "10": "於是迺命羣僚",
                "11": "歷吉日",
                "12": "協靈辰",
                "13": "星陳而天行"
            }
        },
        "3": {
            "7": {
                "1": "詔招搖與泰陰兮",
                "2": "伏鉤陳使當兵",
                "3": "屬堪輿以壁壘兮",
                "4": "梢夔魖而抶獝狂",
                "5": "八神奔而警蹕兮",
                "6": "振殷轔而軍裝",
                "7": "蚩尤之倫",
                "8": "帶干將而秉玉戚兮",
                "9": "飛蒙茸而走陸梁",
                "10": "齊總總以撙撙其相膠轕兮",
                "11": "猋駭雲迅奮以方攘",
                "12": "騈羅列布",
                "13": "鱗以雜沓兮",
                "14": "柴虒參差",
                "15": "魚頡而鳥䀪",
                "16": "翕赫曶霍",
                "17": "霧集而蒙合兮",
                "18": "半散昭爛",
                "19": "粲以成章"
            }
        },
        "4": {
            "9": {
                "1": "於是乘輿迺登夫鳳皇兮而翳華芝",
                "2": "駟蒼螭兮六素虯",
                "3": "蠖略蕤綏",
                "4": "灕虖幓纚",
                "5": "帥爾陰閉",
                "6": "霅然陽開",
                "7": "騰清霄而軼浮景兮",
                "8": "夫何旟旐郅偈之旖柅也",
                "9": "流星旄以電燭兮",
                "10": "咸翠蓋而鸞旗",
                "11": "敦萬騎於中營兮",
                "12": "方玉車之千乘",
                "13": "聲駍隱以陸離兮",
                "14": "輕先疾雷而馺遺風",
                "15": "陵高衍之嵱嵷兮",
                "16": "超紆譎之清澄",
                "17": "登椽欒而羾天門兮",
                "18": "馳閶闔而入凌兢"
            }
        },
        "5": {
            "11": {
                "1": "是時未轃夫甘泉也",
                "2": "迺望通天之繹繹",
                "3": "下陰潛以慘廩兮",
                "4": "上洪紛而相錯",
                "5": "直嶢嶢以造天兮",
                "6": "厥高慶而不可虖疆度",
                "7": "平原唐其壇曼兮",
                "8": "列新雉於林薄",
                "9": "攢幷閭與茇葀兮",
                "10": "紛被麗其亡鄂",
                "11": "崇丘陵之駊騀兮",
                "12": "深溝嶔巖而爲谷",
                "13": "𨓹𨓹離宮般以相燭兮",
                "14": "封巒石關施靡乎延屬"
            }
        },
        "6": {
            "13": {
                "1": "於是大廈雲譎波詭",
                "2": "嶊嶉而成觀",
                "3": "仰撟首以高視兮",
                "4": "目冥眴而亡見",
                "5": "正瀏濫以弘惝兮",
                "6": "指東西之漫漫",
                "7": "徒徊徊以徨徨兮",
                "8": "魂眇眇而昏亂",
                "9": "據軨軒而周流兮",
                "10": "忽軮圠而亡垠",
                "11": "翠玉樹之青蔥兮",
                "12": "璧馬犀之瞵㻞",
                "13": "金人仡仡其承鍾虡兮",
                "14": "嵌巖巖其龍鱗",
                "15": "揚光曜之燎燭兮",
                "16": "垂景炎之炘炘",
                "17": "配帝居之縣圃兮",
                "18": "象泰壹之威神",
                "19": "洪臺崛其獨出兮",
                "20": "㨖北極之嶟嶟",
                "21": "列宿迺施於上榮兮",
                "22": "日月纔經於柍桭",
                "23": "雷鬱律於巖突兮",
                "24": "電倏忽於牆藩",
                "25": "鬼魅不能自逮兮",
                "26": "半長途而下顚"
            }
        },
        "7": {
            "15": {
                "1": "歷倒景而絕飛梁兮",
                "2": "浮蔑蠓而撇天",
                "3": "左欃槍而右玄冥兮",
                "4": "前熛闕後應門",
                "5": "陰西海與幽都兮",
                "6": "涌醴汩以生川",
                "7": "蛟龍連蜷於東厓兮",
                "8": "白虎敦圉虖昆侖",
                "9": "覽樛流於高光兮",
                "10": "溶方皇於西清",
                "11": "前殿崔巍兮和氏玲瓏",
                "12": "炕浮柱之飛榱兮",
                "13": "神莫莫而扶傾",
                "14": "閌閬閬其寥廓兮",
                "15": "似紫宮之崢嶸",
                "16": "騈交錯而曼衍兮",
                "17": "㟎𡽁隗虖其相嬰",
                "18": "乘雲閣而上下兮",
                "19": "紛蒙籠以掍成",
                "20": "曳紅采之流離兮",
                "21": "颺翠氣之冤延",
                "22": "襲琁室與傾宮兮",
                "23": "若登高妙遠",
                "24": "肅乎臨淵"
            }
        },
        "8": {
            "17": {
                "1": "回猋肆其碭駭兮",
                "2": "翍桂椒而鬱杼楊",
                "3": "香芬茀以窮隆兮",
                "4": "擊薄櫨而將榮",
                "5": "薌呹肸以掍根兮",
                "6": "聲駍隱而歷鍾",
                "7": "排玉戶而颺金鋪兮",
                "8": "發蘭惠與𦲄藭",
                "9": "帷弸彋其拂汨兮",
                "10": "稍暗暗而靚深",
                "11": "陰陽清濁穆羽相和兮",
                "12": "若夔牙之調琴",
                "13": "般倕棄其剞劂兮",
                "14": "王爾投其鉤繩",
                "15": "雖方征僑與偓佺兮",
                "16": "猶彷彿其若夢",
                "17": "於是事變物化",
                "18": "目駭耳回",
                "19": "蓋天子穆然",
                "20": "珍臺間館",
                "21": "琁題玉英",
                "22": "蜵蜎蠖濩之中",
                "23": "惟夫所以澄心清魂",
                "24": "儲精垂思",
                "25": "感動天地",
                "26": "逆釐三神者"
            }
        },
        "9": {
            "19": {
                "1": "迺搜逑索偶",
                "2": "皋伊之徒冠倫魁能",
                "3": "函甘棠之惠",
                "4": "挾東征之意",
                "5": "相與齊乎陽靈之宮",
                "6": "靡薜荔而爲席兮",
                "7": "折瓊枝以爲芳",
                "8": "噏清雲之流瑕兮",
                "9": "飲若木之露英",
                "10": "集虖禮神之囿",
                "11": "登虖頌祇之堂",
                "12": "建光燿之長旓兮",
                "13": "昭華覆之威威",
                "14": "攀琁璣而下視兮",
                "15": "行遊目虖三危",
                "16": "陳眾車於東阬兮",
                "17": "肆玉釱而下馳",
                "18": "漂龍淵而還九垠兮",
                "19": "窺地底而上回",
                "20": "風傱傱而扶轄兮",
                "21": "鸞鳳紛其御蕤",
                "22": "梁弱水之濎濙兮",
                "23": "躡不周之逶蛇",
                "24": "想西王母欣然而上壽兮",
                "25": "屛玉女而卻虙妃",
                "26": "玉女亡所眺其清矑兮",
                "27": "虙妃曾不得施其蛾眉",
                "28": "方擥道德之精剛兮",
                "29": "眸神明與之爲資"
            }
        },
        "10": {
            "21": {
                "1": "於是欽柴宗祈",
                "2": "燎熏皇天",
                "3": "招繇泰壹",
                "4": "舉洪頤",
                "5": "樹靈旗",
                "6": "樵蒸焜上",
                "7": "配藜四施",
                "8": "東燭滄海",
                "9": "西燿流沙",
                "10": "北爌幽都",
                "11": "南煬丹厓",
                "12": "玄瓚觩䚧",
                "13": "秬鬯泔淡",
                "14": "肸嚮豐融",
                "15": "懿懿芬芬",
                "16": "炎感黃龍兮",
                "17": "熛訛碩麟",
                "18": "選巫咸兮叫帝閽",
                "19": "開天庭兮延羣神",
                "20": "儐暗藹兮降清壇",
                "21": "瑞穰穰兮委如山"
            }
        },
        "11": {
            "23": {
                "1": "於是事畢功弘",
                "2": "回車而歸",
                "3": "度三巒兮偈棠黎",
                "4": "天閫決兮地垠開",
                "5": "八荒協兮萬國諧",
                "6": "登長平兮雷鼓磕",
                "7": "天聲起兮勇士厲",
                "8": "雲飛揚兮雨滂沛",
                "9": "於胥德兮麗萬世"
            }
        },
        "12": {
            "25": {
                "1": "亂曰",
                "2": "崇崇圜丘",
                "3": "隆隱天兮",
                "4": "登降峛崺",
                "5": "單埢垣兮",
                "6": "增宮㠁差",
                "7": "騈嵯峨兮",
                "8": "岭巆嶙峋",
                "9": "洞無厓兮",
                "10": "上天之縡",
                "11": "杳旭卉兮",
                "12": "聖皇穆穆",
                "13": "信厥對兮",
                "14": "徠祇郊禋",
                "15": "神所依兮",
                "16": "俳佪招搖",
                "17": "靈遟𨒈兮",
                "18": "煇光眩燿",
                "19": "隆厥福兮",
                "20": "子子孫孫",
                "21": "長亡極兮"
            }
        }
    }
}