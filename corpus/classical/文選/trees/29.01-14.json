{
    "29.01-14": {
        "篇名": "古詩一十九首·去者日以疏",
        "1": {
            "3": {
                "1": "去者日以疏",
                "2": "生者日以親",
                "3": "出郭門直視",
                "4": "但見丘與墳",
                "5": "古墓犁爲田",
                "6": "松柏摧爲薪",
                "7": "白楊多悲風",
                "8": "蕭蕭愁殺人",
                "9": "思還故里閭",
                "10": "欲歸道無因"
            }
        }
    }
}