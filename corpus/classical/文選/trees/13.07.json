{
    "13.07": {
        "篇名": "張茂先 鷦鷯賦[幷序]",
        "1": {
            "3": {
                "1": "鷦鷯",
                "2": "小鳥也",
                "3": "生於蒿萊之間",
                "4": "長於藩籬之下",
                "5": "翔集尋常之內",
                "6": "而生生之理足矣",
                "7": "色淺體陋",
                "8": "不爲人用",
                "9": "形微處卑",
                "10": "物莫之害",
                "11": "繁滋族類",
                "12": "乘居匹遊",
                "13": "翩翩然有以自樂也",
                "14": "彼鷲鶚鵾鴻",
                "15": "孔雀翡翠",
                "16": "或淩赤霄之際",
                "17": "或託絕垠之外",
                "18": "翰舉足以沖天",
                "19": "觜距足以自衞",
                "20": "然皆負矰嬰繳",
                "21": "羽毛入貢",
                "22": "何者",
                "23": "有用於人也",
                "24": "夫言有淺而可以託深",
                "25": "類有微而可以喩大",
                "26": "故賦之云爾"
            }
        },
        "2": {
            "5": {
                "1": "何造化之多端兮",
                "2": "播羣形於萬類",
                "3": "惟鷦鷯之微禽兮",
                "4": "亦攝生而受氣",
                "5": "育翩翾之陋體",
                "6": "無玄黃以自貴",
                "7": "毛弗施於器用",
                "8": "肉弗登於俎味",
                "9": "鷹鸇過猶俄翼",
                "10": "尙何懼於罿罻翳薈蒙籠",
                "11": "是焉遊集",
                "12": "飛不飄颺",
                "13": "翔不翕習",
                "14": "其居易容",
                "15": "其求易給",
                "16": "巢林不過一枝",
                "17": "每食不過數粒",
                "18": "栖無所滯",
                "19": "遊無所盤",
                "20": "匪陋荊棘",
                "21": "匪榮茞蘭",
                "22": "動翼而逸",
                "23": "投足而安",
                "24": "委命順理",
                "25": "與物無患"
            }
        },
        "3": {
            "7": {
                "1": "伊茲禽之無知",
                "2": "何處身之似智",
                "3": "不懷寶以賈害",
                "4": "不飾表以招累",
                "5": "靜守約而不矜",
                "6": "動因循以簡易",
                "7": "任自然以爲資",
                "8": "無誘慕於世僞",
                "9": "雕鶡介其觜距",
                "10": "鵠鷺軼於雲際",
                "11": "鵾雞竄於幽險",
                "12": "孔翠生乎遐裔",
                "13": "彼晨鳧與歸雁",
                "14": "又矯翼而增逝",
                "15": "咸美羽而豐肌",
                "16": "故無罪而皆斃",
                "17": "徒銜蘆以避繳",
                "18": "終爲戮於此世",
                "19": "蒼鷹鷙而受緤",
                "20": "鸚鵡惠而入籠",
                "21": "屈猛志以服養",
                "22": "塊幽縶於九重",
                "23": "變音聲以順旨",
                "24": "思摧翮而爲庸",
                "25": "戀鍾岱之林野",
                "26": "慕隴坻之高松",
                "27": "雖蒙幸於今日",
                "28": "未若疇昔之從容"
            }
        },
        "4": {
            "9": {
                "1": "海鳥鶢鶋",
                "2": "避風而至",
                "3": "條枝巨雀",
                "4": "踰嶺自致",
                "5": "提挈萬里",
                "6": "飄颻逼畏",
                "7": "夫唯體大妨物",
                "8": "而形瑰足瑋也",
                "9": "陰陽陶蒸",
                "10": "萬品一區",
                "11": "巨細舛錯",
                "12": "種繁類殊",
                "13": "鷦螟巢於蚊睫",
                "14": "大鵬彌乎天隅",
                "15": "將以上方不足",
                "16": "而下比有餘",
                "17": "普天壤以遐觀",
                "18": "吾又安知大小之所如"
            }
        }
    }
}