{
    "30.30": {
        "篇名": "陶淵明 擬古詩",
        "1": {
            "3": {
                "1": "日暮天無雲",
                "2": "春風扇微和",
                "3": "佳人美清夜",
                "4": "達曙酣且歌",
                "5": "歌竟長歎息",
                "6": "持此感人多",
                "7": "明明雲間月",
                "8": "灼灼葉中花",
                "9": "豈無一時好",
                "10": "不久當如何"
            }
        }
    }
}