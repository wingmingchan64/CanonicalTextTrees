{
    "60.04": {
        "篇名": "謝惠連 祭古冢文[幷序]",
        "1": {
            "3": {
                "1": "東府掘城北塹",
                "2": "入丈餘",
                "3": "得古冢",
                "4": "上無封域",
                "5": "不用塼甓",
                "6": "以木爲槨",
                "7": "中有二棺",
                "8": "正方",
                "9": "兩頭無和",
                "10": "明器之屬",
                "11": "材瓦銅漆",
                "12": "有數十種",
                "13": "多異形",
                "14": "不可盡識",
                "15": "刻木爲人",
                "16": "長三尺",
                "17": "可有二十餘頭",
                "18": "初開見",
                "19": "悉是人形",
                "20": "以物棖撥之",
                "21": "應手灰滅",
                "22": "棺上有五銖錢百餘枚",
                "23": "水中有甘蔗節及梅李核瓜瓣",
                "24": "皆浮出不甚爛壞",
                "25": "銘誌不存",
                "26": "世代不可得而知也",
                "27": "公命城者改埋於東岡",
                "28": "祭之以豚酒",
                "29": "旣不知其名字遠近",
                "30": "故假爲之號曰冥漠君云爾"
            }
        },
        "2": {
            "5": {
                "1": "元嘉七年九月十四日",
                "2": "司徒御屬領直兵令史",
                "3": "統作城錄事",
                "4": "臨漳令亭侯朱林",
                "5": "具豚醪之祭",
                "6": "敬薦冥漠君之靈"
            }
        },
        "3": {
            "7": {
                "1": "忝摠徒旅",
                "2": "板築是司",
                "3": "窮泉爲塹",
                "4": "聚壤成基",
                "5": "一槨旣啟",
                "6": "雙棺在茲",
                "7": "捨畚悽愴",
                "8": "縱鍤漣而",
                "9": "芻靈已毀",
                "10": "塗車旣摧",
                "11": "几筵糜腐",
                "12": "俎豆傾低",
                "13": "盤或梅李",
                "14": "盎或醢醯",
                "15": "蔗傳餘節",
                "16": "瓜表遺犀",
                "17": "追惟夫子",
                "18": "生自何代",
                "19": "曜質幾年",
                "20": "潛靈幾載",
                "21": "爲壽爲夭",
                "22": "寧顯寧晦",
                "23": "銘誌湮滅",
                "24": "姓字不傳",
                "25": "今誰子後",
                "26": "曩誰子先",
                "27": "功名美惡",
                "28": "如何蔑然"
            }
        },
        "4": {
            "9": {
                "1": "百堵皆作",
                "2": "十仞斯齊",
                "3": "墉不可轉",
                "4": "塹不可迴",
                "5": "黃腸旣毀",
                "6": "便房已頹",
                "7": "循題興念",
                "8": "撫俑增哀",
                "9": "射聲垂仁",
                "10": "廣漢流渥",
                "11": "祠骸府阿",
                "12": "掩骼城曲",
                "13": "仰羨古風",
                "14": "爲君改卜",
                "15": "輪移北隍",
                "16": "窀穸東麓",
                "17": "壙卽新營",
                "18": "棺仍舊木",
                "19": "鄭玄周禮注曰",
                "20": "壙",
                "21": "謂冢中也",
                "22": "棺或爲𡑞",
                "23": "非也",
                "24": "合葬非古",
                "25": "周公所存",
                "26": "敬遵昔義",
                "27": "還祔雙魂",
                "28": "酒以兩壺",
                "29": "牲以特豚",
                "30": "幽靈髣彿",
                "31": "歆我犧尊",
                "32": "嗚呼哀哉"
