{
    "24.08": {
        "篇名": "司馬紹統 贈山濤",
        "1": {
            "3": {
                "1": "苕苕椅桐樹",
                "2": "寄生於南岳",
                "3": "上凌青雲霓",
                "4": "下臨千仞谷",
                "5": "處身孤且危",
                "6": "於何託余足",
                "7": "昔也植朝陽",
                "8": "傾枝俟鸞鷟",
                "9": "今者絕世用",
                "10": "倥偬見迫束",
                "11": "班匠不我顧",
                "12": "牙曠不我錄",
                "13": "焉得成琴瑟",
                "14": "何由揚妙曲",
                "15": "冉冉三光馳",
                "16": "逝者一何速",
                "17": "中夜不能寐",
                "18": "撫劍起躑䠱",
                "19": "感彼孔聖歎",
                "20": "哀此年命促",
                "21": "卞和潛幽冥",
                "22": "誰能證奇璞",
                "23": "冀願神龍來",
                "24": "揚光以見燭"
            }
        }
    }
}