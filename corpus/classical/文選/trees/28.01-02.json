{
    "28.01-02": {
        "篇名": "陸士衡 樂府十七首君子行·其二",
        "1": {
            "3": {
                "1": "天道夷且簡",
                "2": "人道嶮而難",
                "3": "休咎相乘躡",
                "4": "翻覆若波瀾",
                "5": "去疾苦不遠",
                "6": "疑似實生患",
                "7": "近火固宜熱",
                "8": "履冰豈惡寒",
                "9": "掇蜂滅天道",
                "10": "拾塵惑孔顏",
                "11": "逐臣尙何有",
                "12": "棄友焉足歎",
                "13": "福鍾恆有兆",
                "14": "禍集非無端",
                "15": "天損未易辭",
                "16": "人益猶可歡",
                "17": "朗鑒豈遠假",
                "18": "取之在傾冠",
                "19": "近情苦自信",
                "20": "君子防未然"
            }
        }
    }
}