{
    "20.01-01": {
        "篇名": "曹子建 上責躬應詔詩表",
        "1": {
            "3": {
                "1": "臣植言",
                "2": "臣自抱舋歸藩",
                "3": "刻肌刻骨",
                "4": "追思罪戾",
                "5": "晝分而食",
                "6": "夜分而寢",
                "7": "誠以天網不可重罹",
                "8": "聖恩難可再恃",
                "9": "竊感相鼠之篇",
                "10": "無禮遄死之義",
                "11": "形影相弔",
                "12": "五情愧赧以罪棄生",
                "13": "則違古賢夕改之勸",
                "14": "忍垢苟全",
                "15": "則犯詩人胡顏之譏",
                "16": "伏惟陛下",
                "17": "德象天地",
                "18": "恩隆父母",
                "19": "施暢春風",
                "20": "澤如時雨",
                "21": "是以不別荊棘者",
                "22": "慶雲之惠也",
                "23": "七子均養者",
                "24": "鳲鳩之仁也",
                "25": "舍罪責功者",
                "26": "明君之舉也",
                "27": "矜愚愛能者",
                "28": "慈父之恩也",
                "29": "是以愚臣徘徊於恩澤",
                "30": "而不敢自棄者也",
                "31": "前奉詔書",
                "32": "臣等絕朝",
                "33": "心離志絕",
                "34": "自分黃耇",
                "35": "永無執珪之望",
                "36": "不圖聖詔",
                "37": "猥垂齒召",
                "38": "至止之日",
                "39": "馳心輦轂",
                "40": "僻處西館",
                "41": "未奉闕庭",
                "42": "踴躍之懷",
                "43": "瞻望反側",
                "44": "不勝犬馬戀主之情",
                "45": "謹拜表並獻詩二篇",
                "46": "詞旨淺末",
                "47": "不足采覽",
                "48": "貴露下情",
                "49": "冒顏以聞",
                "50": "臣植誠惶誠恐",
                "51": "頓首頓首",
                "52": "死罪死罪"
            }
        }
    }
}