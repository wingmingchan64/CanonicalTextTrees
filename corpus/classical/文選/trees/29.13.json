{
    "29.13": {
        "篇名": "張茂先 雜詩",
        "1": {
            "3": {
                "1": "晷度隨天運",
                "2": "四時互相承",
                "3": "東壁正昏中",
                "4": "固陰寒節升",
                "5": "繁霜降當夕",
                "6": "悲風中夜興",
                "7": "朱火青無光",
                "8": "蘭膏坐自凝",
                "9": "重衾無暖氣",
                "10": "挾纊如懷冰",
                "11": "伏枕終遙昔",
                "12": "寤言莫予應",
                "13": "永思慮崇替",
                "14": "慨然獨撫膺"
            }
        }
    }
}