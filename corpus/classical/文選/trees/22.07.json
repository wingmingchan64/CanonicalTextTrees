{
    "22.07": {
        "篇名": "謝惠連 泛湖歸出樓中翫月",
        "1": {
            "3": {
                "1": "日落泛澄瀛",
                "2": "星羅遊輕橈",
                "3": "憩榭面曲汜",
                "4": "臨流對迴潮",
                "5": "輟策共騈筵",
                "6": "並坐相招要",
                "7": "哀鴻鳴沙渚",
                "8": "悲猿響山椒",
                "9": "亭亭映江月",
                "10": "瀏瀏出谷飆",
                "11": "斐斐氣幕岫",
                "12": "泫泫露盈條",
                "13": "近矚袪幽蘊",
                "14": "遠視盪諠囂",
                "15": "悟言不知罷",
                "16": "從夕至清朝"
            }
        }
    }
}