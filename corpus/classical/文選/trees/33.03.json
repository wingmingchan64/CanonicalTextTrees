{
    "33.03": {
        "篇名": "屈平 卜居",
        "1": {
            "3": {
                "1": "屈原旣放三年",
                "2": "不得復見",
                "3": "竭智盡忠",
                "4": "蔽鄣於讒",
                "5": "心煩意亂",
                "6": "不知所從",
                "7": "乃往見太卜鄭詹尹",
                "8": "曰",
                "9": "余有所疑",
                "10": "願因先生決之",
                "11": "詹尹乃端策拂龜",
                "12": "曰",
                "13": "君將何以教之",
                "14": "屈原曰",
                "15": "吾寧悃悃款款",
                "16": "朴以忠乎",
                "17": "將送往勞來",
                "18": "斯無窮乎",
                "19": "寧誅鋤草茅",
                "20": "以力耕乎",
                "21": "將遊大人",
                "22": "以成名乎",
                "23": "寧正言不諱",
                "24": "以危身乎",
                "25": "將從俗富貴",
                "26": "以媮生乎",
                "27": "寧超然高舉",
                "28": "以保眞乎",
                "29": "將哫訾慄斯",
                "30": "喔咿嚅唲",
                "31": "以事婦人乎",
                "32": "寧廉絜正直",
                "33": "以自清乎",
                "34": "將突梯滑稽",
                "35": "如脂如韋",
                "36": "以潔楹乎",
                "37": "寧昂昂若千里之駒乎",
                "38": "將汜汜若水中之鳧乎",
                "39": "與波上下",
                "40": "偸以全吾軀乎",
                "41": "寧與騏驥抗軛乎",
                "42": "將隨駑馬之迹乎",
                "43": "寧與黃鵠比翼乎",
                "44": "將與雞鶩爭食乎",
                "45": "此孰吉孰凶",
                "46": "何去何從",
                "47": "世溷濁而不清",
                "48": "蟬翼爲重",
                "49": "千鈞爲輕",
                "50": "黃鍾毀棄",
                "51": "瓦釜雷鳴",
                "52": "讒人高張",
                "53": "賢士無名",
                "54": "吁嗟嘿嘿兮",
                "55": "誰知吾之廉貞",
                "56": "詹尹乃釋策而謝",
                "57": "曰",
                "58": "夫尺有所短",
                "59": "寸有所長",
                "60": "物有所不足",
                "61": "智有所不明",
                "62": "數有所不逮",
                "63": "神有所不通",
                "64": "用君之心",
                "65": "行君之意",
                "66": "龜策誠不能知此事"
            }
        }
    }
}