{
    "31.09-08": {
        "篇名": "江文通 雜體詩三十首·嵇中散[言志]康",
        "1": {
            "3": {
                "1": "曰余不師訓",
                "2": "潛志去世塵",
                "3": "遠想出宏域",
                "4": "高步超常倫",
                "5": "靈鳳振羽儀",
                "6": "戢景西海濱",
                "7": "朝食琅玕實",
                "8": "夕飲玉池津",
                "9": "處順故無累",
                "10": "養德乃入神",
                "11": "曠哉宇宙惠",
                "12": "雲羅更四陳",
                "13": "哲人貴識義",
                "14": "大雅明庇身",
                "15": "莊生悟無爲",
                "16": "老氏守其眞",
                "17": "天下皆得一",
                "18": "名實久相賓",
                "19": "咸池饗爰居",
                "20": "鍾鼓或愁辛",
                "21": "柳惠善直道",
                "22": "孫登庶知人",
                "23": "寫懷良未遠",
                "24": "感贈以書紳"
            }
        }
    }
}