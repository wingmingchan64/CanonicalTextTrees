{
    "29.04-02": {
        "篇名": "張平子 四愁詩四首[幷序]",
        "1": {
            "3": {
                "1": "二思曰",
                "2": "我所思兮在桂林",
                "3": "欲往從之湘水深",
                "4": "側身南望涕霑襟",
                "5": "美人贈我金琅玕",
                "6": "何以報之雙玉盤",
                "7": "路遠莫致倚惆悵",
                "8": "何爲懷憂心煩傷"
            }
        }
    }
}