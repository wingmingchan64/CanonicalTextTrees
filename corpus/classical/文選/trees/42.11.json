{
    "42.11": {
        "篇名": "應休璉 與從弟君苗君冑書",
        "1": {
            "3": {
                "1": "璩報",
                "2": "間者北遊",
                "3": "喜歡無量",
                "4": "登芒濟河",
                "5": "曠若發矇",
                "6": "風伯掃途",
                "7": "雨師灑道",
                "8": "按轡清路",
                "9": "周望山野",
                "10": "亦旣至止",
                "11": "酌彼春酒",
                "12": "接武茅茨",
                "13": "涼過大夏",
                "14": "扶寸肴修",
                "15": "味踰方丈",
                "16": "逍遙陂塘之上",
                "17": "吟詠菀柳之下",
                "18": "結春芳以崇佩",
                "19": "折若華以翳日",
                "20": "弋下高雲之鳥",
                "21": "餌出深淵之魚",
                "22": "蒲且讚善",
                "23": "便嬛稱妙",
                "24": "何其樂哉",
                "25": "雖仲尼忘味於虞韶",
                "26": "楚人流遯於京臺",
                "27": "無以過也",
                "28": "班嗣之書",
                "29": "信不虛矣"
            }
        },
        "2": {
            "5": {
                "1": "來還京都",
                "2": "塊然獨處",
                "3": "營宅濱洛",
                "4": "困於囂塵",
                "5": "思樂汶上",
                "6": "發於寤寐",
                "7": "昔伊尹輟耕",
                "8": "郅惲投竿",
                "9": "思致君於有虞",
                "10": "濟蒸人於塗炭",
                "11": "而吾方欲秉耒耜於山陽",
                "12": "沈鉤緡於丹水",
                "13": "知其不如古人遠矣",
                "14": "然山父不貪天地之樂",
                "15": "曾參不慕晉楚之富",
                "16": "亦其志也"
            }
        },
        "3": {
            "7": {
                "1": "前者邑人念弟無已",
                "2": "欲州郡崇禮",
                "3": "官師授邑",
                "4": "誠美意也",
                "5": "歷觀前後",
                "6": "來入軍府",
                "7": "至有皓首",
                "8": "猶未遇也",
                "9": "徒有飢寒駿奔之勞",
                "10": "俟河之清",
                "11": "人壽幾何",
                "12": "且宦無金張之援",
                "13": "遊無子孟之資",
                "14": "而圖富貴之榮",
                "15": "望殊異之寵",
                "16": "是隴西之遊",
                "17": "越人之射耳",
                "18": "幸賴先君之靈",
                "19": "免負擔之勤",
                "20": "追蹤丈人",
                "21": "畜雞種黍",
                "22": "潛精墳籍",
                "23": "立身揚名",
                "24": "斯爲可矣",
                "25": "無或遊言",
                "26": "以增邑邑",
                "27": "郊牧之田",
                "28": "宜以爲意",
                "29": "廣開土宇",
                "30": "吾將老焉",
                "31": "劉杜二生",
                "32": "想數往來",
                "33": "朱明之期",
                "34": "已復至矣",
                "35": "相見在近",
                "36": "故不復爲書",
                "37": "愼夏自愛",
                "38": "璩白"
            }
        }
    }
}