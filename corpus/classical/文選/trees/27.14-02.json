{
    "27.14-02": {
        "篇名": "王仲宣 從軍詩五首·其二",
        "1": {
            "3": {
                "1": "涼風厲秋節",
                "2": "司典告詳刑",
                "3": "我君順時發",
                "4": "桓桓東南征",
                "5": "泛舟蓋長川",
                "6": "陳卒被隰坰",
                "7": "征夫懷親戚",
                "8": "誰能無戀情",
                "9": "拊襟倚舟檣",
                "10": "眷眷思鄴城",
                "11": "哀彼東山人",
                "12": "喟然感鸛鳴",
                "13": "日月不安處",
                "14": "人誰獲常寧",
                "15": "昔人從公旦",
                "16": "一徂輒三齡",
                "17": "今我神武師",
                "18": "暫往必速平",
                "19": "棄余親睦恩",
                "20": "輸力竭忠貞",
                "21": "懼無一夫用",
                "22": "報我素餐誠",
                "23": "夙夜自恲性",
                "24": "思逝若抽縈",
                "25": "將秉先登羽",
                "26": "豈敢聽金聲"
            }
        }
    }
