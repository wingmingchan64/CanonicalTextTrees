{
    "22.12": {
        "篇名": "謝靈運 遊赤石進帆海",
        "1": {
            "3": {
                "1": "首夏猶清和",
                "2": "芳草亦未歇",
                "3": "水宿淹晨暮",
                "4": "陰霞屢興沒",
                "5": "周覽倦瀛壖",
                "6": "況乃陵窮髮",
                "7": "川后時安流",
                "8": "天吳靜不發",
                "9": "揚帆采石華",
                "10": "挂席拾海月",
                "11": "溟漲無端倪",
                "12": "虛舟有超越",
                "13": "仲連輕齊組",
                "14": "子牟眷魏闕",
                "15": "矜名道不足",
                "16": "適己物可忽",
                "17": "請附任公言",
                "18": "終然謝天伐"
            }
        }
    }
}