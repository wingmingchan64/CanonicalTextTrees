{
    "55.01": {
        "篇名": "劉孝標 廣絕交論",
        "1": {
            "3": {
                "1": "客問主人曰",
                "2": "朱公叔絕交論",
                "3": "爲是乎",
                "4": "爲非乎",
                "5": "主人曰",
                "6": "客奚此之問",
                "7": "客曰",
                "8": "夫草蟲鳴則阜螽躍",
                "9": "雕虎嘯而清風起",
                "10": "故絪縕相感",
                "11": "霧涌雲蒸",
                "12": "嚶鳴相召",
                "13": "星流電激",
                "14": "是以王陽登則貢公喜",
                "15": "罕生逝而國子悲",
                "16": "且心同琴瑟",
                "17": "言鬱郁於蘭茞",
                "18": "道協膠漆",
                "19": "志婉孌於塤篪",
                "20": "聖賢以此鏤金版而鐫盤盂",
                "21": "書玉牒而刻鍾鼎",
                "22": "若乃匠人輟成風之妙巧",
                "23": "伯子息流波之雅引",
                "24": "范張款款於下泉",
                "25": "尹班陶陶於永夕",
                "26": "駱驛縱橫",
                "27": "煙霏雨散",
                "28": "巧歷所不知",
                "29": "心計莫能測",
                "30": "而朱益州汩彝敍",
                "31": "粵謨訓",
                "32": "捶直切",
                "33": "絕交遊",
                "34": "比黔首以鷹鸇",
                "35": "媲人靈於豺虎",
                "36": "蒙有猜焉",
                "37": "請辨其惑"
            }
        },
        "2": {
            "5": {
                "1": "主人听然而笑曰",
                "2": "客所謂撫絃徽音",
                "3": "未達燥濕變響",
                "4": "張羅沮澤",
                "5": "不睹鴻雁雲飛",
                "6": "蓋聖人握金鏡",
                "7": "闡風烈",
                "8": "龍歡蠖屈",
                "9": "從道汙隆",
                "10": "日月聯璧",
                "11": "贊亹亹之弘致",
                "12": "雲飛電薄",
                "13": "顯棣華之微旨",
                "14": "若五音之變化",
                "15": "濟九成之妙曲",
                "16": "此朱生得玄珠於赤水",
                "17": "謨神睿而爲言",
                "18": "至夫組織仁義",
                "19": "琢磨道德",
                "20": "歡其愉樂",
                "21": "卹其陵夷",
                "22": "寄通靈臺之下",
                "23": "遺迹江湖之上",
                "24": "風雨急而不輟其音",
                "25": "霜雪零而不渝其色",
                "26": "斯賢達之素交",
                "27": "歷萬古而一遇",
                "28": "逮叔世民訛",
                "29": "狙詐飆起",
                "30": "谿谷不能踰其險",
                "31": "鬼神無以究其變",
                "32": "競毛羽之輕",
                "33": "趨錐刀之末",
                "34": "於是素交盡",
                "35": "利交興",
                "36": "天下蚩蚩",
                "37": "鳥驚雷駭",
                "38": "然則利交同源",
                "39": "派流則異",
                "40": "較言其略",
                "41": "有五術焉"
            }
        },
        "3": {
            "7": {
                "1": "若其寵鈞董石",
                "2": "權壓梁竇",
                "3": "雕刻百工",
                "4": "爐捶萬物",
                "5": "吐漱興雲雨",
                "6": "呼噏下霜露",
                "7": "九域聳其風塵",
                "8": "四海疊其燻灼",
                "9": "靡不望影星奔",
                "10": "藉響川騖",
                "11": "雞人始唱",
                "12": "鶴蓋成陰",
                "13": "高門旦開",
                "14": "流水接軫",
                "15": "皆願摩頂至踵",
                "16": "隳膽抽腸",
                "17": "約同要離焚妻子",
                "18": "誓殉荊卿湛七族",
                "19": "是日勢交",
                "20": "其流一也"
            }
        },
        "4": {
            "9": {
                "1": "富埒陶白",
                "2": "貲巨程羅",
                "3": "山擅銅陵",
                "4": "家藏金穴",
                "5": "出平原而聯騎",
                "6": "居里閈而鳴鍾",
                "7": "則有窮巷之賓",
                "8": "繩樞之士",
                "9": "冀宵燭之末光",
                "10": "邀潤屋之微澤",
                "11": "魚貫鳧躍",
                "12": "䬃沓鱗萃",
                "13": "分雁鶩之稻粱",
                "14": "霑玉斝之餘瀝",
                "15": "漢書曰",
                "16": "陳平家貧",
                "17": "負郭窮巷",
                "18": "以席爲門",
                "19": "過秦論曰",
                "20": "陳涉甕牖繩樞之子",
                "21": "戰國策曰",
                "22": "甘茂去秦",
                "23": "且之齊",
                "24": "出關",
                "25": "遇蘇子",
                "26": "曰",
                "27": "君聞夫江上之處女乎",
                "28": "夫江上之處女",
                "29": "有家貧而無燭者",
                "30": "處女相與語",
                "31": "欲去之",
                "32": "家貧無燭者將去矣",
                "33": "謂處女曰",
                "34": "妾以無燭之故",
                "35": "常先掃室布席",
                "36": "何愛餘明之照四壁者",
                "37": "處女以爲然",
                "38": "留之",
                "39": "今臣棄逐於秦",
                "40": "出關",
                "41": "願爲足下掃室布席",
                "42": "幸無我逐也",
                "43": "賈逵國語注曰",
                "44": "邀",
                "45": "求也",
                "46": "禮記曰",
                "47": "富潤屋",
                "48": "德潤身",
                "49": "貫魚",
                "50": "已見鮑昭出自薊北門行",
                "51": "潘岳哀辭曰",
                "52": "望歸瞥見",
                "53": "鳧藻踴躍",
                "54": "張衡羽獵賦曰",
                "55": "輕車䬃沓",
                "56": "西京賦曰",
                "57": "鳥集鱗萃",
                "58": "魯連子曰",
                "59": "君雁鶩有餘粟",
                "60": "韓詩外傳",
                "61": "田饒謂魯哀公曰",
                "62": "黃鵠止君園池",
                "63": "啄君稻粱",
                "64": "說文曰",
                "65": "斝",
                "66": "玉爵也",
                "67": "史記",
                "68": "淳於髡曰",
                "69": "親有嚴客",
                "70": "持酒於前",
                "71": "時賜餘瀝",
                "72": "銜恩遇",
                "73": "進款誠",
                "74": "援青松以示心",
                "75": "指白水而旌信",
                "76": "是曰賄交",
                "77": "其流二也"
            }
        },
        "5": {
            "11": {
                "1": "陸大夫宴喜西都",
                "2": "郭有道人倫東國",
                "3": "公卿貴其籍甚",
                "4": "搢紳羨其登仙",
                "5": "加以顩頤蹙頞",
                "6": "涕唾流沫",
                "7": "騁黃馬之劇談",
                "8": "縱碧雞之雄辯",
                "9": "敍溫郁則寒谷成暄",
                "10": "論嚴苦則春叢零葉",
                "11": "飛沈出其顧指",
                "12": "榮辱定其一言",
                "13": "於是有弱冠王孫",
                "14": "綺紈公子",
                "15": "道不挂於通人",
                "16": "聲未遒於雲閣",
                "17": "攀其鱗翼",
                "18": "丐其餘論",
                "19": "附駔驥之旄端",
                "20": "軼歸鴻於碣石",
                "21": "是曰談交",
                "22": "其流三也"
            }
        },
        "6": {
            "13": {
                "1": "陽舒陰慘",
                "2": "生民大情",
                "3": "憂合歡離",
                "4": "品物恆性",
                "5": "故魚以泉涸而呴沫",
                "6": "鳥因將死而鳴哀",
                "7": "同病相憐",
                "8": "綴河上之悲曲",
                "9": "恐懼置懷",
                "10": "昭谷風之盛典",
                "11": "斯則斷金由於湫隘",
                "12": "刎頸起於苫蓋",
                "13": "是以伍員濯漑於宰嚭",
                "14": "張王撫翼於陳相",
                "15": "是曰窮交",
                "16": "其流四也"
            }
        },
        "7": {
            "15": {
                "1": "馳騖之俗",
                "2": "澆薄之倫",
                "3": "無不操權衡",
                "4": "秉纖纊",
                "5": "衡所以揣其輕重",
                "6": "纊所以屬其鼻息",
                "7": "若衡不能舉",
                "8": "纊不能飛",
                "9": "雖顏冉龍翰鳳雛",
                "10": "曾史蘭薰雪白",
                "11": "舒向金玉淵海",
                "12": "卿雲黼黻河漢",
                "13": "視若遊塵",
                "14": "遇同土梗",
                "15": "莫肯費其半菽",
                "16": "罕有落其一毛",
                "17": "若衡重錙銖",
                "18": "纊微彯撇雖共工之蒐慝",
                "19": "歡兠之掩義",
                "20": "南荊之跋扈",
                "21": "東陵之巨猾",
                "22": "皆爲匍匐逶迆",
                "23": "折枝䑛痔",
                "24": "金膏翠羽將其意",
                "25": "脂韋便辟導其誠",
                "26": "故輪蓋所遊",
                "27": "必非夷惠之室",
                "28": "苞苴所入",
                "29": "實行張霍之家",
                "30": "謀而後動",
                "31": "毫芒寡忒",
                "32": "是曰量交",
                "33": "其流五也"
            }
        },
        "8": {
            "17": {
                "1": "凡斯五交",
                "2": "義同賈鬻",
                "3": "故桓譚譬之於闤闠",
                "4": "林回喩之於甘醴",
                "5": "夫寒暑遞進",
                "6": "盛衰相襲",
                "7": "或前榮而後悴",
                "8": "或始富而終貧",
                "9": "或初存而末亡",
                "10": "或古約而今泰",
                "11": "循環翻覆",
                "12": "迅若波瀾",
                "13": "此則殉利之情未嘗異",
                "14": "變化之道不得一",
                "15": "由是觀之",
                "16": "張陳所以凶終",
                "17": "蕭朱所以隙末",
                "18": "斷焉可知矣",
                "19": "而翟公方規規然勒門以箴客",
                "20": "何所見之晚乎"
            }
        },
        "9": {
            "19": {
                "1": "因此五交",
                "2": "是生三釁",
                "3": "敗德殄義",
                "4": "禽獸相若",
                "5": "一釁也",
                "6": "難固易攜",
                "7": "讎訟所聚",
                "8": "二釁也",
                "9": "名陷饕餮",
                "10": "貞介所羞",
                "11": "三釁也",
                "12": "古人知三釁之爲梗",
                "13": "懼五交之速尤",
                "14": "故王丹威子以檟楚",
                "15": "朱穆昌言而示絕",
                "16": "有旨哉",
                "17": "有旨哉"
            }
        },
        "10": {
            "21": {
                "1": "近世有樂安任昉",
                "2": "海內髦傑",
                "3": "早綰銀黃",
                "4": "夙昭民譽",
                "5": "遒文麗藻",
                "6": "方駕曹王",
                "7": "英跱俊邁",
                "8": "聯橫許郭",
                "9": "類田文之愛客",
                "10": "同鄭莊之好賢",
                "11": "見一善則盱衡扼腕",
                "12": "遇一才則揚眉抵掌",
                "13": "雌黃出其脣吻",
                "14": "朱紫由其月旦",
                "15": "於是冠蓋輻湊",
                "16": "衣裳雲合",
                "17": "輜軿擊轊",
                "18": "坐客恆滿",
                "19": "蹈其閫閾",
                "20": "若升闕里之堂",
                "21": "入其隩隅",
                "22": "謂登龍門之阪",
                "23": "至於顧眄增其倍價",
                "24": "剪拂使其長鳴",
                "25": "彯組雲臺者摩肩",
                "26": "趍走丹墀者疊迹",
                "27": "莫不締恩狎",
                "28": "結綢繆",
                "29": "想惠莊之清塵",
                "30": "庶羊左之徽烈",
                "31": "及瞑目東粵",
                "32": "歸骸洛浦",
                "33": "繐帳猶懸",
                "34": "門罕漬酒之彥",
                "35": "墳未宿草",
                "36": "野絕動輪之賓",
                "37": "藐爾諸孤",
                "38": "朝不謀夕",
                "39": "流離大海之南",
                "40": "寄命嶂癘之地",
                "41": "自昔把臂之英",
                "42": "金蘭之友",
                "43": "曾無羊舌下泣之仁",
                "44": "寧慕郈成分宅之德"
            }
        },
        "11": {
            "23": {
                "1": "嗚呼",
                "2": "世路險巇",
                "3": "一至於此",
                "4": "太行孟門",
                "5": "豈云嶃絕",
                "6": "是以耿介之士",
                "7": "疾其若斯",
                "8": "裂裳裹足",
                "9": "棄之長騖",
                "10": "獨立高山之頂",
                "11": "歡與麋鹿同羣",
                "12": "皦皦然絕其雰濁",
                "13": "誠恥之也",
                "14": "誠畏之也"
            }
        }
    }
}