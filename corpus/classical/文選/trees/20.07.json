{
    "20.07": {
        "篇名": "應德璉 侍五官中郎將建章臺集詩",
        "1": {
            "3": {
                "1": "朝雁鳴雲中",
                "2": "音響一何哀",
                "3": "問子遊何鄕",
                "4": "戢翼正徘徊",
                "5": "言我寒門來",
                "6": "將就衡陽栖",
                "7": "往春翔北土",
                "8": "今冬客南淮",
                "9": "遠行蒙霜雪",
                "10": "毛羽日摧頹",
                "11": "常恐傷肌骨",
                "12": "身隕沈黃泥",
                "13": "簡珠墯沙石",
                "14": "何能中自諧",
                "15": "欲因雲雨會",
                "16": "濯翼陵高梯",
                "17": "良遇不可値",
                "18": "伸眉路何階",
                "19": "公子敬愛客",
                "20": "樂飲不知疲",
                "21": "和顏旣以暢",
                "22": "乃肯顧細微",
                "23": "贈詩見存慰",
                "24": "小子非所宜",
                "25": "爲且極歡情",
                "26": "不醉其無歸",
