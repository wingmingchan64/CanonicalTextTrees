{
    "13.04": {
        "篇名": "謝希逸 月賦",
        "1": {
            "3": {
                "1": "陳王初喪應劉",
                "2": "端憂多暇",
                "3": "綠苔生閣",
                "4": "芳塵凝榭",
                "5": "悄焉疚懷",
                "6": "不怡中夜",
                "7": "迺清蘭路",
                "8": "肅桂苑",
                "9": "騰吹寒山",
                "10": "弭蓋秋阪",
                "11": "臨濬壑而怨遙",
                "12": "登崇岫而傷遠",
                "13": "於時斜漢左界",
                "14": "北陸南躔",
                "15": "白露曖空",
                "16": "素月流天",
                "17": "沈吟齊章",
                "18": "殷勤陳篇",
                "19": "抽毫進牘",
                "20": "以命仲宣"
            }
        },
        "2": {
            "5": {
                "1": "仲宣跪而稱曰",
                "2": "臣東鄙幽介",
                "3": "長自丘樊",
                "4": "昧道懵學",
                "5": "孤奉明恩",
                "6": "臣聞沈潛旣義",
                "7": "高明旣經",
                "8": "日以陽德",
                "9": "月以陰靈",
                "10": "擅扶光於東沼",
                "11": "嗣若英於西冥",
                "12": "引玄兔於帝臺",
                "13": "集素娥於后庭",
                "14": "朒朓警闕",
                "15": "朏魄示沖",
                "16": "順辰通燭",
                "17": "從星澤風",
                "18": "增華台室",
                "19": "揚采軒宮",
                "20": "委照而吳業昌",
                "21": "淪精而漢道融"
            }
        },
        "3": {
            "7": {
                "1": "若夫氣霽地表",
                "2": "雲斂天末",
                "3": "洞庭始波",
                "4": "木葉微脫",
                "5": "菊散芳於山椒",
                "6": "雁流哀於江瀨",
                "7": "升清質之悠悠",
                "8": "降澄輝之藹藹",
                "9": "列宿掩縟",
                "10": "長河韜映",
                "11": "柔祇雪凝",
                "12": "圓靈水鏡",
                "13": "連觀霜縞",
                "14": "周除冰淨",
                "15": "君王迺厭晨歡",
                "16": "樂宵宴",
                "17": "收妙舞",
                "18": "弛清縣",
                "19": "去燭房",
                "20": "卽月殿",
                "21": "芳酒登",
                "22": "鳴琴薦"
            }
        },
        "4": {
            "9": {
                "1": "若迺涼夜自淒",
                "2": "風篁成韻",
                "3": "親懿莫從",
                "4": "羈孤遞進",
                "5": "聆皋禽之夕聞",
                "6": "聽朔管之秋引",
                "7": "於是絃桐練響",
                "8": "音容選和",
                "9": "徘徊房露",
                "10": "惆悵陽阿",
                "11": "聲林虛籟",
                "12": "淪池滅波",
                "13": "情紆軫其何託",
                "14": "愬皓月而長歌"
            }
        },
        "5": {
            "11": {
                "1": "歌曰",
                "2": "美人邁兮音塵闕",
                "3": "隔千里兮共明月",
                "4": "臨風歎兮將焉歇",
                "5": "川路長兮不可越",
                "6": "歌響未終",
                "7": "餘景就畢",
                "8": "滿堂變容",
                "9": "迴遑如失",
                "10": "又稱歌曰",
                "11": "月旣沒兮露欲晞",
                "12": "歲方晏兮無與歸",
                "13": "佳期可以還",
                "14": "微霜霑人衣"
            }
        },
        "6": {
            "13": {
                "1": "陳王曰",
                "2": "善",
                "3": "迺命執事",
                "4": "獻壽羞璧",
                "5": "敬佩玉音",
                "6": "復之無斁"
            }
        }
    }
}