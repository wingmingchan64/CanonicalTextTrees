{
    "36.01": {
        "篇名": "任彥升 宣德皇后令",
        "1": {
            "3": {
                "1": "宣德皇后敬問具位",
                "2": "夫功在不賞",
                "3": "故庸勳之典蓋闕",
                "4": "施侔造物",
                "5": "則謝德之途已寡也",
                "6": "要不得不彊爲之名",
                "7": "使荃宰有寄",
                "8": "公實天生德",
                "9": "齊聖廣淵",
                "10": "不改參辰而九星仰止",
                "11": "不易日月而二儀貞觀",
                "12": "在昔晦明",
                "13": "隱鱗戢翼",
                "14": "博通羣籍",
                "15": "而讓齒乎一卷之師",
                "16": "劍氣凌雲",
                "17": "而屈迹於萬夫之下",
                "18": "辯析天口",
                "19": "而似不能言",
                "20": "文擅彫龍",
                "21": "而成輒削藁"
            }
        },
        "2": {
            "5": {
                "1": "爰在弱冠",
                "2": "首應弓旌",
                "3": "客遊梁朝",
                "4": "則聲華籍甚",
                "5": "薦名宰府",
                "6": "則延譽自高",
                "7": "何之元梁典曰",
                "8": "高祖遷儀同王儉東閤祭酒",
                "9": "王隱晉書曰",
                "10": "周玘累薦名宰府",
                "11": "國語曰",
                "12": "使張老延君譽於四方",
                "13": "隆昌季年",
                "14": "勤王始著",
                "15": "建武惟新",
                "16": "締構斯在",
                "17": "功隆賞薄",
                "18": "嘉庸莫疇",
                "19": "一馬之田",
                "20": "介山之志愈厲",
                "21": "六百之秩",
                "22": "大樹之號斯存",
                "23": "及擁旄司部",
                "24": "代馬不敢南牧",
                "25": "推轂樊鄧",
                "26": "胡塵罕嘗夕起",
                "27": "惟彼狡僮",
                "28": "窮凶極虐",
                "29": "衣冠泯絕",
                "30": "禮樂崩喪"
            }
        },
        "3": {
            "7": {
                "1": "旣而鞠旅誓眾",
                "2": "言謀王室",
                "3": "白羽一麾",
                "4": "黃鳥底定",
                "5": "甲旣鱗下",
                "6": "車亦瓦裂",
                "7": "致天之屆",
                "8": "拱揖羣后",
                "9": "豐功厚利",
                "10": "無德而稱",
                "11": "是以祥光摠至",
                "12": "休氣四塞",
                "13": "五老遊河",
                "14": "飛星入昴",
                "15": "元功茂勳",
                "16": "若斯之盛",
                "17": "而地狹乎四履",
                "18": "勢卑乎九伯",
                "19": "帝有恧焉",
                "20": "輶軒萃止",
                "21": "今遣某位某甲等",
                "22": "率茲百辟",
                "23": "人致其誠",
                "24": "庶匪席之旨",
                "25": "不遠而復"
            }
        }
    }
}