{
    "59.01": {
        "篇名": "王簡栖 頭陀寺碑文",
        "1": {
            "3": {
                "1": "蓋聞挹朝夕之池者",
                "2": "無以測其淺深",
                "3": "家語曰",
                "4": "孔子觀於魯桓公之廟",
                "5": "有攲器焉",
                "6": "使弟子挹之水",
                "7": "毛萇詩傳曰",
                "8": "挹",
                "9": "𣂏也",
                "10": "漢書",
                "11": "枚乘上書吳王曰",
                "12": "遊曲臺",
                "13": "臨上路",
                "14": "不如挹朝夕之池",
                "15": "桓子新論",
                "16": "子貢謂齊景公曰",
                "17": "臣之事仲尼",
                "18": "譬如渴而操杯就江海飲",
                "19": "飲滿而去",
                "20": "又焉知江海之深乎",
                "21": "挹",
                "22": "於入切",
                "23": "𣂏",
                "24": "句愚切",
                "25": "仰蒼蒼之色者",
                "26": "不足知其遠近",
                "27": "況視聽之外",
                "28": "若存若亡",
                "29": "心行之表",
                "30": "不生不滅者哉",
                "31": "是以掩室摩竭",
                "32": "用啟息言之津",
                "33": "杜口毗邪",
                "34": "以通得意之路",
                "35": "然語彝倫者",
                "36": "必求宗於九疇",
                "37": "談陰陽者",
                "38": "亦硏幾於六位",
                "39": "是故三才旣辨",
                "40": "識妙物之功",
                "41": "萬象已陳",
                "42": "悟太極之致",
                "43": "言之不可以已",
                "44": "其在茲乎",
                "45": "然爻繫所筌",
                "46": "窮於此域",
                "47": "則稱謂所絕",
                "48": "形乎彼岸矣",
                "49": "彼岸者引之於有",
                "50": "則高謝四流﹔推之於無",
                "51": "則俯弘六度",
                "52": "名言不得其性相",
                "53": "隨迎不見其終始",
                "54": "不可以學地知",
                "55": "不可以意生及",
                "56": "其涅盤之蘊也"
            }
        },
        "2": {
            "5": {
                "1": "夫幽谷無私",
                "2": "有至斯響",
                "3": "洪鍾虛受",
                "4": "無來不應",
                "5": "況法身圓對",
                "6": "規矩冥立",
                "7": "一音稱物",
                "8": "宮商潛運",
                "9": "是以如來利見迦維",
                "10": "託生王室",
                "11": "憑五衍之軾",
                "12": "拯溺逝川",
                "13": "開八正之門",
                "14": "大庇交喪",
                "15": "於是玄關幽揵",
                "16": "感而遂通",
                "17": "遙源濬波",
                "18": "酌而不竭",
                "19": "行不捨之檀",
                "20": "而施洽羣有",
                "21": "唱無緣之慈",
                "22": "而澤周萬物",
                "23": "演勿照之明",
                "24": "而鑒窮沙界",
                "25": "導亡機之權",
                "26": "而功濟塵劫",
                "27": "時義遠矣",
                "28": "能事畢矣",
                "29": "然後拂衣雙樹",
                "30": "脫屣金沙",
                "31": "惟怳惟惚",
                "32": "不皦不昧",
                "33": "莫繫於去來",
                "34": "復歸於無物",
                "35": "因斯而談",
                "36": "則栖遑大千",
                "37": "無爲之寂不撓",
                "38": "焚燎堅林",
                "39": "不盡之靈無歇",
                "40": "大矣哉"
            }
        },
        "3": {
            "7": {
                "1": "正法旣沒",
                "2": "象教陵夷",
                "3": "穿鑿異端者",
                "4": "以違方爲得一",
                "5": "順非辯僞者",
                "6": "比微言於目論",
                "7": "於是馬鳴幽讚",
                "8": "龍樹虛求",
                "9": "並振頹綱",
                "10": "俱維絕紐",
                "11": "蔭法雲於眞際",
                "12": "則火宅晨涼",
                "13": "曜慧日於康衢",
                "14": "則重昏夜曉",
                "15": "故能使三十七品有尊俎之師",
                "16": "九十六種無藩籬之固",
                "17": "旣而方廣東被",
                "18": "教肄南移",
                "19": "周魯二莊",
                "20": "親昭夜景之鑒",
                "21": "漢晉兩明",
                "22": "並勒丹青之飾",
                "23": "然後遺文間出",
                "24": "列剎相望",
                "25": "澄什結轍於山西",
                "26": "林遠肩隨乎江左矣"
            }
        },
        "4": {
            "9": {
                "1": "頭陀寺者",
                "2": "沙門釋慧宗之所立也",
                "3": "南則大川浩汗",
                "4": "雲霞之所沃蕩",
                "5": "周易曰",
                "6": "利涉大川",
                "7": "海賦曰",
                "8": "膠㵧浩汗",
                "9": "又曰",
                "10": "瀖泋濩渭",
                "11": "蕩雲沃日",
                "12": "北則層峯削成",
                "13": "日月之所迴薄",
                "14": "西眺城邑",
                "15": "百雉紆餘",
                "16": "東望平皋",
                "17": "千里超忽",
                "18": "信楚都之勝地也",
                "19": "宗法師行絜珪璧",
                "20": "擁錫來遊",
                "21": "以爲宅生者緣",
                "22": "業空則緣廢",
                "23": "存軀者惑",
                "24": "理勝則惑亡",
                "25": "遂欲捨百齡於中身",
                "26": "殉肌膚於猛鷙",
                "27": "班荊蔭松者久之",
                "28": "宋大明五年",
                "29": "始立方丈茅茨",
                "30": "以庇經像",
                "31": "後軍長史江夏內史會稽孔府君諱覬",
                "32": "爲之薙草開林",
                "33": "置經行之室",
                "34": "安西將軍郢州刺史江安伯濟陽蔡使君諱興宗",
                "35": "復爲崇基表剎",
                "36": "立禪誦之堂焉",
                "37": "以法師景行大迦葉",
                "38": "故以頭陀爲稱首",
                "39": "後有僧勤法師",
                "40": "貞節苦心",
                "41": "求仁養志",
                "42": "纂修堂宇",
                "43": "未就而沒",
                "44": "高軌難追",
                "45": "藏舟易遠",
                "46": "僧徒閴其無人",
                "47": "榱椽毀而莫構",
                "48": "可爲長太息矣"
            }
        },
        "5": {
            "11": {
                "1": "惟齊繼五帝洪名",
                "2": "紐三王絕業",
                "3": "祖武宗文之德",
                "4": "昭升嚴配",
                "5": "格天光表之功",
                "6": "弘啟興服",
                "7": "是以惟新舊物",
                "8": "康濟多難",
                "9": "步中雅頌",
                "10": "驟合韶護",
                "11": "炎區九譯",
                "12": "沙場一候",
                "13": "粵在於建武焉",
                "14": "乃詔西中郎將郢州刺史江夏王觀政藩維",
                "15": "樹風江漢",
                "16": "擇方城之令典",
                "17": "酌龜蒙之故實",
                "18": "政肅刑清",
                "19": "於是乎在",
                "20": "寧遠將軍長史江夏內史行事彭城劉府君諱諠",
                "21": "智刃所遊",
                "22": "日新月故",
                "23": "道勝之韻",
                "24": "虛往實歸",
                "25": "以此寺業廢於已安",
                "26": "功墜於幾立",
                "27": "慨深覆簣",
                "28": "悲同棄井",
                "29": "因百姓之有餘",
                "30": "間天下之無事",
                "31": "庀徒揆日",
                "32": "各有司存"
            }
        },
        "6": {
            "13": {
                "1": "於是民以悅來",
                "2": "工以心競",
                "3": "亙丘被陵",
                "4": "因高就遠",
                "5": "層軒延袤",
                "6": "上出雲霓",
                "7": "飛閣逶迆",
                "8": "下臨無地",
                "9": "夕露爲珠網",
                "10": "朝霞爲丹雘",
                "11": "九衢之草千計",
                "12": "四照之花萬品",
                "13": "崖谷共清",
                "14": "風泉相渙",
                "15": "金資寶相",
                "16": "永藉閑安",
                "17": "息心了義",
                "18": "終焉遊集",
                "19": "法師釋曇珍業行淳修",
                "20": "理懷淵遠",
                "21": "今屈知寺任",
                "22": "永奉神居",
                "23": "夫民勞事功",
                "24": "旣鏤文於鍾鼎",
                "25": "言時稱伐",
                "26": "亦樹碑於宗廟",
                "27": "世彌積而功宣",
                "28": "身逾遠而名劭",
                "29": "敢寓言於彫篆",
                "30": "庶髣彿於眾妙",
                "31": "其辭曰"
            }
        },
        "7": {
            "15": {
                "1": "質判玄黃",
                "2": "氣分清濁",
                "3": "涉器千名",
                "4": "含靈萬族",
                "5": "淳源上派",
                "6": "澆風下黷",
                "7": "莊子曰",
                "8": "德又下衰",
                "9": "及唐",
                "10": "虞",
                "11": "𣻏淳散朴",
                "12": "淮南子以𣻏爲澆",
                "13": "音義同",
                "14": "說文曰",
                "15": "派",
                "16": "水別流也",
                "17": "字林曰",
                "18": "黷",
                "19": "垢也",
                "20": "杜木切",
                "21": "愛流成海",
                "22": "情塵爲岳",
                "23": "皇矣能仁",
                "24": "撫期命世",
                "25": "乃睠中土",
                "26": "聿來迦衞",
                "27": "奄有大千",
                "28": "遂荒三界",
                "29": "殷鑒四門",
                "30": "幽求六歲",
                "31": "亦旣成德",
                "32": "妙盡無爲",
                "33": "帝獻方石",
                "34": "天開淥池",
                "35": "祥河輟水",
                "36": "寶樹低枝",
                "37": "通莊九折",
                "38": "安步三危",
                "39": "川靜波澄",
                "40": "龍翔雲起",
                "41": "耆山廣運",
                "42": "給園多士",
                "43": "金粟來儀",
                "44": "文殊戾止",
                "45": "應乾動寂",
                "46": "順民終始",
                "47": "法本不然",
                "48": "今則無滅",
                "49": "象正雖闌",
                "50": "希夷未缺",
                "51": "於昭有齊",
                "52": "式揚洪烈",
                "53": "釋網更維",
                "54": "玄津重枻",
                "55": "惟此名區",
                "56": "禪慧攸託",
                "57": "倚據崇巖",
                "58": "臨睨通壑",
                "59": "溝池湘漢",
                "60": "堆阜衡霍",
                "61": "膴膴亭皋",
                "62": "幽幽林薄"
            }
        },
        "8": {
            "17": {
                "1": "媚茲邦后",
                "2": "法流是挹",
                "3": "氣茂三明",
                "4": "情超六入",
                "5": "眷言靈宇",
                "6": "載懷興葺",
                "7": "丹刻翬飛",
                "8": "輪奐離立",
                "9": "象設旣闢",
                "10": "睟容已安",
                "11": "桂深冬燠",
                "12": "松疏夏寒",
                "13": "神足遊息",
                "14": "靈心往還",
                "15": "勝幡西振",
                "16": "貞石南刊"
            }
        }
    }
}