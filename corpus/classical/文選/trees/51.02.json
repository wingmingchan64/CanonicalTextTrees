{
    "51.02": {
        "篇名": "東方曼倩 非有先生論",
        "1": {
            "3": {
                "1": "非有先生仕於吳",
                "2": "進不能稱往古以廣主意",
                "3": "退不能揚君美以顯其功",
                "4": "默然無言者三年矣",
                "5": "吳王怪而問之",
                "6": "曰",
                "7": "寡人獲先人之功",
                "8": "寄於眾賢之上",
                "9": "夙興夜寐",
                "10": "未嘗敢怠也",
                "11": "今先生率然高舉",
                "12": "遠集吳地",
                "13": "將以輔治寡人",
                "14": "誠竊嘉之",
                "15": "體不安席",
                "16": "食不甘味",
                "17": "目不視靡曼之色",
                "18": "耳不聽鐘鼓之音",
                "19": "虛心定志",
                "20": "欲聞流議者三年於茲矣",
                "21": "今先生進無以輔治",
                "22": "退不揚主譽",
                "23": "竊爲先生不取也",
                "24": "蓋懷能而不見",
                "25": "是不忠也",
                "26": "見而不行",
                "27": "主不明也",
                "28": "意者寡人殆不明乎",
                "29": "非有先生伏而唯唯",
                "30": "吳王曰",
                "31": "可以談矣",
                "32": "寡人將竦意而聽焉",
                "33": "先生曰",
                "34": "於戲",
                "35": "可乎哉",
                "36": "可乎哉",
                "37": "談何容易",
                "38": "夫談者有悖於目而佛於耳",
                "39": "謬於心而便於身者",
                "40": "或有說於目",
                "41": "順於耳",
                "42": "快於心而毀於行者",
                "43": "非有明王聖主",
                "44": "孰能聽之矣",
                "45": "吳王曰",
                "46": "何爲其然也",
                "47": "中人以上可以語上也",
                "48": "先生試言",
                "49": "寡人將覽焉"
            }
        },
        "2": {
            "5": {
                "1": "先生對曰",
                "2": "昔關龍逢深諫於桀",
                "3": "而王子比干直言於紂",
                "4": "此二臣者",
                "5": "皆極慮盡忠",
                "6": "閔主澤不下流",
                "7": "而萬民騷動",
                "8": "故直言其失",
                "9": "切諫其邪者",
                "10": "將以爲君之榮",
                "11": "除主之禍也",
                "12": "今則不然",
                "13": "反以爲誹謗君之行",
                "14": "無人臣之禮",
                "15": "果紛然傷於身",
                "16": "蒙不辜之名",
                "17": "戮及先人",
                "18": "爲天下笑",
                "19": "故曰談何容易",
                "20": "是以輔弼之臣瓦解",
                "21": "而邪諂之人並進",
                "22": "遂及飛廉",
                "23": "惡來革等",
                "24": "三人皆詐僞",
                "25": "巧言利口",
                "26": "以進其身",
                "27": "陰奉彫琢刻鏤之好",
                "28": "以納其心",
                "29": "務快耳目之欲",
                "30": "以苟容爲度",
                "31": "遂往不戒",
                "32": "身沒被戮",
                "33": "宗廟崩弛",
                "34": "國家爲墟",
                "35": "殺戮賢臣",
                "36": "親近讒夫",
                "37": "詩不云乎",
                "38": "讒人罔極",
                "39": "交亂四國",
                "40": "此之謂也",
                "41": "故卑身賤體",
                "42": "說色微辭",
                "43": "愉愉喣喣終無益於主上之治",
                "44": "卽志士仁人不忍爲也",
                "45": "將儼然作矜莊之色",
                "46": "深言直諫",
                "47": "上以拂人主之邪",
                "48": "下以損百姓之害",
                "49": "則忤於邪主之心",
                "50": "歷於衰世之法",
                "51": "故養壽命之士莫肯進也",
                "52": "遂居深山之間",
                "53": "積土爲室",
                "54": "編蓬爲戶",
                "55": "彈琴其中",
                "56": "以詠先王之風",
                "57": "亦可以樂而忘死矣",
                "58": "是以伯夷叔齊避周",
                "59": "餓於首陽之下",
                "60": "後世稱其仁",
                "61": "如是",
                "62": "邪主之行固足畏也",
                "63": "故曰談何容易"
            }
        },
        "3": {
            "7": {
                "1": "於是吳王戄然易容",
                "2": "捐薦去几",
                "3": "危坐而聽",
                "4": "先生曰",
                "5": "接輿避世",
                "6": "箕子被髮佯狂",
                "7": "此二子者",
                "8": "皆避濁世以全其身者也",
                "9": "使遇明王聖主",
                "10": "得賜清讌之閑",
                "11": "寬和之色",
                "12": "發憤畢誠",
                "13": "圖畫安危",
                "14": "揆度得失",
                "15": "上以安主體",
                "16": "下以便萬民",
                "17": "則五帝三王之道可幾而見也",
                "18": "故伊尹蒙恥辱",
                "19": "負鼎俎",
                "20": "和五味以干湯",
                "21": "太公釣於渭之陽以見文王",
                "22": "心合意同",
                "23": "謀無不成",
                "24": "計無不從",
                "25": "誠得其君也",
                "26": "深念遠慮",
                "27": "引義以正其身",
                "28": "推恩以廣其下",
                "29": "本仁祖誼",
                "30": "襃有德",
                "31": "祿賢能",
                "32": "誅惡亂",
                "33": "摠遠方",
                "34": "壹統類",
                "35": "美風俗",
                "36": "此帝王所由昌也",
                "37": "上不變天性",
                "38": "下不奪人倫",
                "39": "則天地和洽",
                "40": "遠方懷之",
                "41": "故號聖王",
                "42": "臣子之職旣加矣",
                "43": "於是裂地定封",
                "44": "爵爲公侯",
                "45": "傳國子孫",
                "46": "名顯後世",
                "47": "民到於今稱之",
                "48": "以遇湯與文王也",
                "49": "太公伊尹以如此",
                "50": "龍逢比干獨如彼",
                "51": "豈不哀哉",
                "52": "故曰談何容易"
            }
        },
        "4": {
            "9": {
                "1": "於是吳王穆然",
                "2": "俛而深惟",
                "3": "仰而泣下交頤",
                "4": "曰",
                "5": "嗟乎",
                "6": "余國之不亡也",
                "7": "綿綿連連",
                "8": "殆哉",
                "9": "世之不絕也",
                "10": "於是正明堂之朝",
                "11": "齊君臣之位",
                "12": "舉賢才",
                "13": "布德惠",
                "14": "施仁義",
                "15": "賞有功",
                "16": "躬親節儉",
                "17": "減後宮之費",
                "18": "損車馬之用",
                "19": "放鄭聲",
                "20": "遠佞人",
                "21": "省庖廚",
                "22": "去侈靡",
                "23": "卑宮館",
                "24": "壞苑囿",
                "25": "塡池塹",
                "26": "以與貧民無產業者",
                "27": "開內藏",
                "28": "振貧窮",
                "29": "存耆老",
                "30": "卹孤獨",
                "31": "薄賦斂",
                "32": "省刑罰",
                "33": "行此三年",
                "34": "海內晏然",
                "35": "天下大洽",
                "36": "陰陽和調",
                "37": "萬物咸得其宜",
                "38": "國無災害之變",
                "39": "民無飢寒之色",
                "40": "家給人足",
                "41": "畜積有餘",
                "42": "囹圄空虛",
                "43": "鳳皇來集",
                "44": "麒麟在郊",
                "45": "甘露旣降",
                "46": "朱草萌芽",
                "47": "遠方異俗之人",
                "48": "嚮風慕義",
                "49": "各奉其職而來朝賀",
                "50": "故治亂之道",
                "51": "存亡之端",
                "52": "若此易見",
                "53": "而君人者莫肯爲也",
                "54": "臣愚竊以爲過",
                "55": "故詩曰王國克生",
                "56": "惟周之貞",
                "57": "濟濟多士",
                "58": "文王以寧",
                "59": "此之謂也"
            }
        }
    }
}