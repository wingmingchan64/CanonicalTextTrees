{
    "21.02": {
        "篇名": "曹子建 三良詩",
        "1": {
            "3": {
                "1": "功名不可爲",
                "2": "忠義我所安"
            },
            "4": {
                "1": "秦穆先下世",
                "2": "三臣皆自殘"
            },
            "5": {
                "1": "生時等榮樂",
                "2": "旣沒同憂患"
            },
            "6": {
                "1": "誰言捐軀易",
                "2": "殺身誠獨難"
            },
            "7": {
                "1": "攬涕登君墓",
                "2": "臨穴仰天歎"
            },
            "8": {
                "1": "長夜何冥冥",
                "2": "一往不復還"
            },
            "9": {
                "1": "黃鳥爲悲鳴",
                "2": "哀哉傷肺肝"
            }
        }
    }
