{
    "43.01": {
        "篇名": "嵇叔夜 與山巨源絕交書",
        "1": {
            "3": {
                "1": "康白",
                "2": "足下昔稱吾於潁川",
                "3": "吾常謂之知言",
                "4": "然經怪此意",
                "5": "尙未熟悉於足下",
                "6": "何從便得之也",
                "7": "前年從河東還",
                "8": "顯宗阿都說足下議以吾自代",
                "9": "事雖不行",
                "10": "知足下故不知之",
                "11": "足下傍通",
                "12": "多可而少怪",
                "13": "吾直性狹中",
                "14": "多所不堪",
                "15": "偶與足下相知耳",
                "16": "間聞足下遷",
                "17": "惕然不喜",
                "18": "恐足下羞庖人之獨割",
                "19": "引尸祝以自助",
                "20": "手薦鸞刀",
                "21": "漫之羶腥",
                "22": "故具爲足下陳其可否"
            }
        },
        "2": {
            "5": {
                "1": "吾昔讀書",
                "2": "得幷介之人",
                "3": "或謂無之",
                "4": "今乃信其眞有耳",
                "5": "性有所不堪",
                "6": "眞不可強",
                "7": "今空語同知有達人",
                "8": "無所不堪",
                "9": "外不殊俗",
                "10": "而內不失正",
                "11": "與一世同其波流",
                "12": "而悔吝不生耳",
                "13": "老子莊周",
                "14": "吾之師也",
                "15": "親居賤職",
                "16": "柳下惠東方朔",
                "17": "達人也",
                "18": "安乎卑位",
                "19": "吾豈敢短之哉",
                "20": "又仲尼兼愛",
                "21": "不羞執鞭",
                "22": "子文無欲卿相",
                "23": "而三登令尹",
                "24": "是乃君子思濟物之意也",
                "25": "所謂達能兼善而不渝",
                "26": "窮則自得而無悶",
                "27": "以此觀之",
                "28": "故堯舜之君世",
                "29": "許由之巖栖",
                "30": "子房之佐漢",
                "31": "接輿之行歌",
                "32": "其揆一也",
                "33": "仰瞻數君",
                "34": "可謂能遂其志者也",
                "35": "故君子百行",
                "36": "殊塗而同致",
                "37": "循性而動",
                "38": "各附所安",
                "39": "故有處朝廷而不出",
                "40": "入山林而不反之論",
                "41": "且延陵高子臧之風",
                "42": "長卿慕相如之節",
                "43": "志氣所託",
                "44": "不可奪也"
            }
        },
        "3": {
            "7": {
                "1": "吾每讀尙子平臺孝威傳",
                "2": "慨然慕之",
                "3": "想其爲人",
                "4": "少加孤露",
                "5": "母兄見驕",
                "6": "不涉經學",
                "7": "性復疏懶",
                "8": "筋駑肉緩",
                "9": "頭面常一月十五日不洗",
                "10": "不大悶癢",
                "11": "不能沐也",
                "12": "每常小便",
                "13": "而忍不起",
                "14": "令胞中略轉乃起耳",
                "15": "又縱逸來久",
                "16": "情意傲散",
                "17": "簡與禮相背",
                "18": "懶與慢相成",
                "19": "而爲儕類見寬",
                "20": "不攻其過",
                "21": "又讀莊老",
                "22": "重增其放",
                "23": "故使榮進之心日穨",
                "24": "任實之情轉篤",
                "25": "此由禽鹿少見馴育",
                "26": "則服從教制",
                "27": "長而見羈",
                "28": "則狂顧頓纓",
                "29": "赴蹈湯火",
                "30": "雖飾以金鑣",
                "31": "饗以嘉肴",
                "32": "逾思長林",
                "33": "而志在豐草也"
            }
        },
        "4": {
            "9": {
                "1": "阮嗣宗口不論人過",
                "2": "吾每師之",
                "3": "而未能及",
                "4": "至性過人",
                "5": "與物無傷",
                "6": "唯飲酒過差耳",
                "7": "至爲禮法之士所繩",
                "8": "疾之如讎",
                "9": "幸賴大將軍保持之耳",
                "10": "吾不如嗣宗之賢",
                "11": "而有慢弛之闕",
                "12": "又不識人情",
                "13": "闇於機宜",
                "14": "無萬石之愼",
                "15": "而有好盡之累",
                "16": "久與事接",
                "17": "疵釁日興",
                "18": "雖欲無患",
                "19": "其可得乎"
            }
        },
        "5": {
            "11": {
                "1": "又人倫有禮",
                "2": "朝廷有法",
                "3": "自惟至熟",
                "4": "有必不堪者七",
                "5": "甚不可者二",
                "6": "臥喜晚起",
                "7": "而當關呼之不置",
                "8": "一不堪也",
                "9": "抱琴行吟",
                "10": "弋釣草野",
                "11": "而吏卒守之",
                "12": "不得妄動",
                "13": "二不堪也",
                "14": "危坐一時",
                "15": "痺不得搖",
                "16": "性復多蝨把搔無已",
                "17": "而當裹以章服",
                "18": "揖拜上官",
                "19": "三不堪也",
                "20": "素不便書",
                "21": "又不喜作書",
                "22": "而人間多事",
                "23": "堆案盈机",
                "24": "不相酬答",
                "25": "則犯教傷義",
                "26": "欲自勉強",
                "27": "則不能久",
                "28": "四不堪也",
                "29": "不喜弔喪",
                "30": "而人道以此爲重",
                "31": "己爲未見恕者所怨",
                "32": "至欲見中傷者",
                "33": "雖瞿然自責",
                "34": "然性不可化",
                "35": "欲降心順俗",
                "36": "則詭故不情",
                "37": "亦終不能獲無咎無譽如此",
                "38": "五不堪也",
                "39": "不喜俗人",
                "40": "而當與之共事",
                "41": "或賓客盈坐",
                "42": "鳴聲聒耳",
                "43": "囂塵臭處",
                "44": "千變百伎",
                "45": "在人目前",
                "46": "六不堪也",
                "47": "心不耐煩",
                "48": "而官事鞅掌",
                "49": "機務纏其心",
                "50": "世故繁其慮",
                "51": "七不堪也",
                "52": "又每非湯武而薄周孔",
                "53": "在人間不止",
                "54": "此事會顯世教所不容",
                "55": "此甚不可一也",
                "56": "剛腸疾惡",
                "57": "輕肆直言",
                "58": "遇事便發",
                "59": "此甚不可二也",
                "60": "以促中小心之性",
                "61": "統此九患",
                "62": "不有外難",
                "63": "當有內病",
                "64": "寧可久處人間邪",
                "65": "又聞道士遺言",
                "66": "餌朮黃精",
                "67": "令人久壽",
                "68": "意甚信之",
                "69": "遊山澤",
                "70": "觀鳥魚",
                "71": "心甚樂之",
                "72": "一行作吏",
                "73": "此事便廢",
                "74": "安能舍其所樂",
                "75": "而從其所懼哉"
            }
        },
        "6": {
            "13": {
                "1": "夫人之相知",
                "2": "貴識其天性",
                "3": "因而濟之",
                "4": "禹不偪伯成子高",
                "5": "全其節也",
                "6": "仲尼不假蓋於子夏",
                "7": "護其短也",
                "8": "近諸葛孔明不偪元直以入蜀",
                "9": "華子魚不強幼安以卿相",
                "10": "此可謂能相終始",
                "11": "眞相知者也",
                "12": "足下見直木必不可以爲輪",
                "13": "曲者不可以爲桷",
                "14": "蓋不欲以枉其天才",
                "15": "令得其所也",
                "16": "故四民有業",
                "17": "各以得志爲樂",
                "18": "唯達者爲能通之",
                "19": "此足下度內耳",
                "20": "不可自見好章甫",
                "21": "強越人以文冕也",
                "22": "己嗜臭腐",
                "23": "養鴛雛以死鼠也",
                "24": "吾頃學養生之術",
                "25": "方外榮華",
                "26": "去滋味",
                "27": "遊心於寂寞",
                "28": "以無爲爲貴",
                "29": "縱無九患",
                "30": "尙不顧足下所好者",
                "31": "又有心悶疾",
                "32": "頃轉增篤",
                "33": "私意自試",
                "34": "不能堪其所不樂",
                "35": "自卜已審",
                "36": "若道盡塗窮則已耳",
                "37": "足下無事冤之",
                "38": "令轉於溝壑也"
            }
        },
        "7": {
            "15": {
                "1": "吾新失母兄之歡",
                "2": "意常悽切",
                "3": "女年十三",
                "4": "男年八歲",
                "5": "未及成人",
                "6": "況復多病",
                "7": "顧此悢悢",
                "8": "如何可言",
                "9": "今但願守陋巷",
                "10": "教養子孫",
                "11": "時與親舊敍闊",
                "12": "陳說平生",
                "13": "濁酒一杯",
                "14": "彈琴一曲",
                "15": "志願畢矣",
                "16": "足下若嬲之不置",
                "17": "不過欲爲官得人",
                "18": "以益時用耳",
                "19": "足下舊知吾潦倒粗疏",
                "20": "不切事情",
                "21": "自惟亦皆不如今日之賢能也",
                "22": "若以俗人皆喜榮華",
                "23": "獨能離之",
                "24": "以此爲快",
                "25": "此最近之",
                "26": "可得言耳",
                "27": "然使長才廣度",
                "28": "無所不淹",
                "29": "而能不營",
                "30": "乃可貴耳",
                "31": "若吾多病困",
                "32": "欲離事自全",
                "33": "以保餘年",
                "34": "此眞所乏耳",
                "35": "豈可見黃門而稱貞哉",
                "36": "若趣欲共登王塗",
                "37": "期於相致",
                "38": "時爲歡益",
                "39": "一旦迫之",
                "40": "必發其狂疾",
                "41": "自非重怨",
                "42": "不至於此也"
            }
        },
        "8": {
            "17": {
                "1": "野人有快炙背而美芹子者",
                "2": "欲獻之至尊",
                "3": "雖有區區之意",
                "4": "亦已疏矣",
                "5": "願足下勿似之",
                "6": "其意如此",
                "7": "旣以解足下",
                "8": "幷以爲別",
                "9": "嵇康白"
            }
        }
    }
}