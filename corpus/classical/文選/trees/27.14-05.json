{
    "27.14-05": {
        "篇名": "王仲宣 從軍詩五首·其五",
        "1": {
            "3": {
                "1": "悠悠涉荒路",
                "2": "靡靡我心愁",
                "3": "四望無煙火",
                "4": "但見林與丘",
                "5": "城郭生榛棘",
                "6": "蹊徑無所由",
                "7": "雚蒲竟廣澤",
                "8": "葭葦夾長流",
                "9": "日夕涼風發",
                "10": "翩翩漂吾舟",
                "11": "寒蟬在樹鳴",
                "12": "鸛鵠摩天遊",
                "13": "客子多悲傷",
                "14": "淚下不可收",
                "15": "朝入譙郡界",
                "16": "曠然消人憂",
                "17": "雞鳴達四境",
                "18": "黍稷盈原疇",
                "19": "館宅充廛里",
                "20": "女士滿莊馗",
                "21": "自非聖賢國",
                "22": "誰能享斯休",
                "23": "詩人美樂土",
                "24": "雖客猶願留"
