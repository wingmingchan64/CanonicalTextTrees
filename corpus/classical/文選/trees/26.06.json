{
    "26.06": {
        "篇名": "謝玄暉 郡內高齋閑坐答呂法曹",
        "1": {
            "3": {
                "1": "結構何迢遰",
                "2": "曠望極高深",
                "3": "牕中列遠岫",
                "4": "庭際俯喬林",
                "5": "日出眾鳥散",
                "6": "山暝孤猿吟",
                "7": "已有池上酌",
                "8": "復此風中琴",
                "9": "非君美無度",
                "10": "孰爲勞寸心",
                "11": "惠而能好我",
                "12": "問以瑤華音",
                "13": "若遺金門步",
                "14": "見就玉山岑"
            }
        }
    }
}