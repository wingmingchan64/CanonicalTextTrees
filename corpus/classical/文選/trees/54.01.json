{
    "54.01": {
        "篇名": "陸士衡 五等論",
        "1": {
            "3": {
                "1": "夫體國經野",
                "2": "先王所愼",
                "3": "創制垂基",
                "4": "思隆後葉",
                "5": "然而經略不同",
                "6": "長世異術",
                "7": "五等之制",
                "8": "始於黃唐",
                "9": "郡縣之治",
                "10": "創自秦漢",
                "11": "得失成敗",
                "12": "備在典謨",
                "13": "是以其詳",
                "14": "可得而言"
            }
        },
        "2": {
            "5": {
                "1": "夫先王知帝業至重",
                "2": "天下至曠",
                "3": "曠不可以偏制",
                "4": "重不可以獨任",
                "5": "任重必於借力",
                "6": "制曠終乎因人",
                "7": "故設官分職",
                "8": "所以輕其任也",
                "9": "並建五長",
                "10": "所以弘其制也",
                "11": "於是乎立其封疆之典",
                "12": "財其親疏之宜",
                "13": "使萬國相維",
                "14": "以成盤石之固",
                "15": "宗庶雜居",
                "16": "而定維城之業",
                "17": "又有以見綏世之長御",
                "18": "識人情之大方",
                "19": "知其爲人不如厚己",
                "20": "利物不如圖身",
                "21": "安上在於悅下",
                "22": "爲己在乎利人",
                "23": "故易曰",
                "24": "說以使民",
                "25": "民忘其勞",
                "26": "孫卿曰",
                "27": "不利而利之",
                "28": "不如利而後利之之利也",
                "29": "是以分天下以厚樂",
                "30": "而己得與之同憂",
                "31": "饗天下以豐利",
                "32": "而我得與之共害",
                "33": "利博則恩篤",
                "34": "樂遠則憂深",
                "35": "故諸侯享食土之實",
                "36": "萬國受世及之祚矣",
                "37": "夫然",
                "38": "則南面之君",
                "39": "各務其治",
                "40": "九服之民",
                "41": "知有定主",
                "42": "上之子愛於是乎生",
                "43": "下之體信於是乎結",
                "44": "世治足以敦風",
                "45": "道衰足以御暴",
                "46": "故強毅之國",
                "47": "不能擅一時之勢",
                "48": "雄俊之士",
                "49": "無所寄霸王之志",
                "50": "然後國安由萬邦之思治",
                "51": "主尊賴羣后之圖身",
                "52": "譬猶眾目營方",
                "53": "則天網自昶",
                "54": "四體辭難",
                "55": "而心膂獲乂",
                "56": "三代所以直道",
                "57": "四王所以垂業也"
            }
        },
        "3": {
            "7": {
                "1": "夫盛衰隆敝",
                "2": "理所固有",
                "3": "教之廢興",
                "4": "繫乎其人",
                "5": "愿法期於必涼",
                "6": "明道有時而闇",
                "7": "故世及之制",
                "8": "敝於彊禦",
                "9": "厚下之典",
                "10": "漏於末折",
                "11": "侵弱之舋",
                "12": "遘自三季",
                "13": "陵夷之禍",
                "14": "終於七雄",
                "15": "昔者成湯親照夏后之鑒",
                "16": "公旦目涉商人之戒",
                "17": "文質相濟",
                "18": "損益有物",
                "19": "故五等之禮",
                "20": "不革於時",
                "21": "封畛之制",
                "22": "有隆焉爾時",
                "23": "豈玩二王之禍",
                "24": "而闇經世之筭乎",
                "25": "固知百世非可懸御",
                "26": "善制不能無敝",
                "27": "而侵弱之辱",
                "28": "愈於殄祀",
                "29": "土崩之困",
                "30": "痛於陵夷也",
                "31": "是以經始權其多福",
                "32": "慮終取其少禍",
                "33": "非謂侯伯無可亂之符",
                "34": "郡縣非致治之具也",
                "35": "故國憂賴其釋位",
                "36": "主弱憑其翼戴",
                "37": "及承微積敝",
                "38": "王室遂卑",
                "39": "猶保名位",
                "40": "祚垂後嗣",
                "41": "皇統幽而不輟",
                "42": "神器否而必存者",
                "43": "豈非置勢使之然與"
            }
        },
        "4": {
            "9": {
                "1": "降及亡秦",
                "2": "棄道任術",
                "3": "懲周之失",
                "4": "自矜其得",
                "5": "尋斧始於所庇",
                "6": "制國昧於弱下",
                "7": "國慶獨饗其利",
                "8": "主憂莫與共害",
                "9": "雖速亡趨亂",
                "10": "不必一道",
                "11": "顚沛之釁",
                "12": "實由孤立",
                "13": "是蓋思五等之小怨",
                "14": "忘萬國之大德",
                "15": "知陵夷之可患",
                "16": "闇土崩之爲痛也",
                "17": "周之不競",
                "18": "有自來矣",
                "19": "左氏傳",
                "20": "鄭石㚟謂子囊曰",
                "21": "今楚實不競",
                "22": "行人何罪",
                "23": "又",
                "24": "叔孫曰",
                "25": "叔出季處",
                "26": "有自來矣",
                "27": "國乏令主",
                "28": "十有餘世",
                "29": "然片言勤王",
                "30": "諸侯必應",
                "31": "一朝振矜",
                "32": "遠國先叛",
                "33": "故彊晉收其請隧之圖",
                "34": "暴楚頓其觀鼎之志",
                "35": "豈劉項之能闚關",
                "36": "勝廣之敢號澤哉",
                "37": "借使秦人因循周制",
                "38": "雖則無道",
                "39": "有與共敝",
                "40": "覆滅之禍",
                "41": "豈在曩日"
            }
        },
        "5": {
            "11": {
                "1": "漢矯秦枉",
                "2": "大啟侯王",
                "3": "境土踰溢",
                "4": "不遵舊典",
                "5": "故賈生憂其危",
                "6": "朝錯痛其亂",
                "7": "是以諸侯阻其國家之富",
                "8": "憑其士民之力",
                "9": "勢足者反疾",
                "10": "土狹者逆遲",
                "11": "六臣犯其弱綱",
                "12": "七子衢其漏網",
                "13": "皇祖夷於黥徒",
                "14": "西京病於東帝",
                "15": "是蓋過正之災",
                "16": "而非建侯之累也",
                "17": "然呂氏之難",
                "18": "朝士外顧",
                "19": "宋昌策漢",
                "20": "必稱諸侯",
                "21": "逮至中葉",
                "22": "忌其失節",
                "23": "割削宗子",
                "24": "有名無實",
                "25": "天下曠然",
                "26": "復襲亡秦之軌矣",
                "27": "是以五侯作威",
                "28": "不忌萬邦",
                "29": "新都襲漢",
                "30": "易於拾遺也",
                "31": "光武中興",
                "32": "纂隆皇統",
                "33": "而猶遵覆車之遺轍",
                "34": "養喪家之宿疾",
                "35": "僅及數世",
                "36": "姦軌充斥",
                "37": "卒有彊臣專朝",
                "38": "則天下風靡",
                "39": "一夫縱衡",
                "40": "則城池自夷",
                "41": "豈不危哉"
            }
        },
        "6": {
            "13": {
                "1": "在周之衰",
                "2": "難興王室",
                "3": "放命者七臣",
                "4": "干位者三子",
                "5": "嗣王委其九鼎",
                "6": "凶族據其天邑",
                "7": "鉦鼙震於閫宇",
                "8": "鋒鏑流乎絳闕",
                "9": "然禍止畿甸",
                "10": "害不覃及",
                "11": "天下晏然",
                "12": "以治待亂",
                "13": "是以宣王興於共和",
                "14": "襄惠振於晉鄭",
                "15": "豈若二漢",
                "16": "階闥暫擾",
                "17": "而四海已沸",
                "18": "孼臣朝入",
                "19": "而九服夕亂哉"
            }
        },
        "7": {
            "15": {
                "1": "遠惟王莽篡逆之事",
                "2": "近覽董卓擅權之際",
                "3": "億兆悼心",
                "4": "愚智同痛",
                "5": "然周以之存",
                "6": "漢以之亡",
                "7": "夫何故哉",
                "8": "豈世乏曩時之臣",
                "9": "士無匡合之志歟",
                "10": "蓋遠績屈於時異",
                "11": "雄心挫於卑勢耳",
                "12": "故烈士扼腕",
                "13": "終委寇讎之手",
                "14": "中人變節",
                "15": "以助虐國之桀",
                "16": "雖復時有鳩合同志",
                "17": "以謀王室",
                "18": "然上非奧主",
                "19": "下皆市人",
                "20": "師旅無先定之班",
                "21": "君臣無相保之志",
                "22": "是以義兵雲合",
                "23": "無救劫弒之禍",
                "24": "民望未改",
                "25": "而已見大漢之滅矣",
                "26": "或以諸侯世位",
                "27": "不必常全",
                "28": "昏主暴君",
                "29": "有時比迹",
                "30": "故五等所以多亂",
                "31": "今之牧守",
                "32": "皆以官方庸能",
                "33": "雖或失之",
                "34": "其得固多",
                "35": "故郡縣易以爲治",
                "36": "夫德之休明",
                "37": "黜陟日用",
                "38": "長率連屬",
                "39": "咸述其職",
                "40": "而淫昏之君",
                "41": "無所容過",
                "42": "何則其不治哉",
                "43": "故先代有以之興矣",
                "44": "苟或衰陵",
                "45": "百度自悖",
                "46": "鬻官之吏",
                "47": "以貨準才",
                "48": "則貪殘之萌",
                "49": "皆如羣后也",
                "50": "安在其不亂哉",
                "51": "故後王有以之廢矣",
                "52": "且要而言之",
                "53": "五等之君",
                "54": "爲己思治",
                "55": "郡縣之長",
                "56": "爲利圖物",
                "57": "何以徵之",
                "58": "蓋企及進取",
                "59": "仕子之常志",
                "60": "修己安民",
                "61": "良士之所希及",
                "62": "夫進取之情銳",
                "63": "而安民之譽遲",
                "64": "是故侵百姓以利己者",
                "65": "在位所不憚",
                "66": "損實事以養名者",
                "67": "官長所夙夜也",
                "68": "君無卒歲之圖",
                "69": "臣挾一時之志",
                "70": "五等則不然",
                "71": "知國爲己土",
                "72": "眾皆我民",
                "73": "民安己受其利",
                "74": "國傷家嬰其病",
                "75": "故前人欲以垂後",
                "76": "後嗣思其堂構",
                "77": "爲上無苟且之心",
                "78": "羣下知膠固之義",
                "79": "漢書",
                "80": "王嘉上䟽曰",
                "81": "孝文時",
                "82": "吏居官者或長子孫",
                "83": "然後上下相望",
                "84": "莫有苟且之意",
                "85": "莊子曰",
                "86": "待膠漆而固者",
                "87": "是侵其德者也",
                "88": "范曄後漢書",
                "89": "鄭泰曰",
                "90": "以膠固之眾",
                "91": "當解合之勢",
                "92": "使其並賢居治",
                "93": "則功有厚薄",
                "94": "兩愚處亂",
                "95": "則過有深淺",
                "96": "然則八代之制",
                "97": "幾可以一理貫",
                "98": "秦漢之典",
                "99": "殆可以一言蔽矣"
            }
        }
    }
}