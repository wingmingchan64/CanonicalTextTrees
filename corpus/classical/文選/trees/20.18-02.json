{
    "20.18-02": {
        "篇名": "曹子建 送應氏詩二首·其二",
        "1": {
            "3": {
                "1": "清時難屢得",
                "2": "嘉會不可常",
                "3": "天地無終極",
                "4": "人命若朝霜",
                "5": "願得展嬿婉",
                "6": "我友之朔方",
                "7": "親昵並集送",
                "8": "置酒此河陽",
                "9": "中饋豈獨薄",
                "10": "賓飲不盡觴",
                "11": "愛至望苦深",
                "12": "豈不愧中腸",
                "13": "山川阻且遠",
                "14": "別促會日長",
                "15": "願爲比翼鳥",
                "16": "施翮起高翔"
            }
        }
    }
}