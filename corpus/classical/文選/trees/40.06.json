{
    "40.06": {
        "篇名": "陳孔璋 答東阿王牋",
        "1": {
            "3": {
                "1": "琳死罪死罪",
                "2": "昨加恩辱命",
                "3": "幷示龜賦",
                "4": "披覽粲然",
                "5": "君侯體高世之才",
                "6": "秉青蓱干將之器",
                "7": "拂鐘無聲",
                "8": "應機立斷",
                "9": "說苑曰",
                "10": "西閭過東渡河",
                "11": "中流而溺",
                "12": "船人接而出之",
                "13": "問曰",
                "14": "子何之",
                "15": "過曰",
                "16": "欲說東諸侯",
                "17": "船人曰",
                "18": "子渡河而溺",
                "19": "安能說東諸侯乎",
                "20": "過曰",
                "21": "獨不聞干將莫邪",
                "22": "拂鍾不錚",
                "23": "試物不知",
                "24": "然以之綴履",
                "25": "曾不如兩錢之錐",
                "26": "今子持楫乘扁舟",
                "27": "子所能也",
                "28": "若試與子東說諸侯王",
                "29": "見一國之主",
                "30": "子之蒙蒙然無異於未視㺃也",
                "31": "又曰",
                "32": "淳於髡三稱",
                "33": "鄒忌三知之",
                "34": "髡等辭屈而去",
                "35": "故所以尙干將莫邪者",
                "36": "貴於立斷",
                "37": "此乃天然異稟",
                "38": "非鑽仰者所庶幾也",
                "39": "音義旣遠",
                "40": "清辭妙句",
                "41": "焱絕煥炳",
                "42": "譬猶飛兔流星",
                "43": "超山越海",
                "44": "龍驥所不敢追",
                "45": "況於駑馬",
                "46": "可得齊足",
                "47": "夫聽白雪之音",
                "48": "觀綠水之節",
                "49": "然後東野巴人",
                "50": "蚩鄙益著",
                "51": "載歡載笑",
                "52": "欲罷不能",
                "53": "謹韞櫝玩耽",
                "54": "以爲吟頌",
                "55": "琳死罪死罪"
            }
        }
    }
}