{
    "30.28-01": {
        "篇名": "陸士衡 擬古詩十二首·擬行行重行行",
        "1": {
            "3": {
                "1": "悠悠行邁遠",
                "2": "戚戚憂思深",
                "3": "此思亦何思",
                "4": "思君徽與音",
                "5": "音徽日夜離",
                "6": "緬邈若飛沈",
                "7": "王鮪懷河岫",
                "8": "晨風思北林",
                "9": "遊子眇天末",
                "10": "還期不可尋",
                "11": "驚飆褰反信",
                "12": "歸雲難寄音",
                "13": "佇立想萬里",
                "14": "沈憂萃我心",
                "15": "攬衣有餘帶",
                "16": "循形不盈衿",
                "17": "去去遺情累",
                "18": "安處撫清琴"
            }
        }
    }
}