{
    "52.02": {
        "篇名": "魏文帝 典論論文",
        "1": {
            "3": {
                "1": "文人相輕",
                "2": "自古而然",
                "3": "傅毅之於班固",
                "4": "伯仲之間耳",
                "5": "而固小之",
                "6": "與弟超書曰",
                "7": "武仲以能屬文爲蘭臺令史",
                "8": "下筆不能自休",
                "9": "夫人善於自見",
                "10": "而文非一體",
                "11": "鮮能備善",
                "12": "是以各以所長",
                "13": "相輕所短",
                "14": "里語曰",
                "15": "家有敝帚",
                "16": "享之千金",
                "17": "斯不自見之患也"
            }
        },
        "2": {
            "5": {
                "1": "今之文人",
                "2": "魯國孔融文舉",
                "3": "廣陵陳琳孔璋",
                "4": "山陽王粲仲宣",
                "5": "北海徐幹偉長",
                "6": "陳留阮瑀元瑜",
                "7": "汝南應瑒德璉",
                "8": "東平劉楨公幹",
                "9": "斯七子者",
                "10": "於學無所遺",
                "11": "於辭無所假",
                "12": "咸以自騁驥騄於千里",
                "13": "仰齊足而並馳",
                "14": "以此相服",
                "15": "亦良難矣",
                "16": "蓋君子審己以度人",
                "17": "故能免於斯累",
                "18": "而作論文"
            }
        },
        "3": {
            "7": {
                "1": "王粲長於辭賦",
                "2": "徐幹時有齊氣",
                "3": "然粲之匹也",
                "4": "如粲之初征登樓槐賦征思",
                "5": "幹之玄猿漏卮圓扇橘賦",
                "6": "雖張蔡不過也",
                "7": "然於他文未能稱是",
                "8": "琳瑀之章表書記",
                "9": "今之雋也",
                "10": "應瑒和而不壯",
                "11": "劉楨壯而不密",
                "12": "孔融體氣高妙",
                "13": "有過人者",
                "14": "然不能持論",
                "15": "理不勝詞",
                "16": "以至乎雜以嘲戲",
                "17": "及其所善",
                "18": "楊班儔也"
            }
        },
        "4": {
            "9": {
                "1": "常人貴遠賤近",
                "2": "向聲背實",
                "3": "又患闇於自見",
                "4": "謂己爲賢",
                "5": "夫文",
                "6": "本同而末異",
                "7": "蓋奏議宜雅",
                "8": "書論宜理",
                "9": "銘誄尙實",
                "10": "詩賦欲麗",
                "11": "此四科不同",
                "12": "故能之者偏也",
                "13": "唯通才能備其體"
            }
        },
        "5": {
            "11": {
                "1": "文以氣爲主",
                "2": "氣之清濁有體",
                "3": "不可力強而致",
                "4": "譬諸音樂",
                "5": "曲度雖均",
                "6": "節奏同檢",
                "7": "至於引氣不齊",
                "8": "巧拙有素",
                "9": "雖在父兄",
                "10": "不能以移子弟"
            }
        },
        "6": {
            "13": {
                "1": "蓋文章經國之大業",
                "2": "不朽之盛事",
                "3": "年壽有時而盡",
                "4": "榮樂止乎其身",
                "5": "二者必至之常期",
                "6": "未若文章之無窮",
                "7": "是以古之作者",
                "8": "寄身於翰墨",
                "9": "見意於篇籍",
                "10": "不假良史之辭",
                "11": "不託飛馳之勢",
                "12": "而聲名自傳於後",
                "13": "故西伯幽而演易",
                "14": "周旦顯而制禮",
                "15": "不以隱約而弗務",
                "16": "不以康樂而加思",
                "17": "夫然",
                "18": "則古人賤尺璧而重寸陰",
                "19": "懼乎時之過已",
                "20": "而人多不強力",
                "21": "貧賤則懾於飢寒",
                "22": "富貴則流於逸樂",
                "23": "遂營目前之務",
                "24": "而遺千載之功",
                "25": "日月逝於上",
                "26": "體貌衰於下",
                "27": "忽然與萬物遷化",
                "28": "斯志士之大痛也",
                "29": "融等已逝",
                "30": "唯幹著論",
                "31": "成一家言"
            }
        }
    }
}