{
    "29.09-02": {
        "篇名": "曹子建 雜詩六首·其二",
        "1": {
            "3": {
                "1": "轉蓬離本根",
                "2": "飄颻隨長風",
                "3": "何意迴飆舉",
                "4": "吹我入雲中",
                "5": "高高上無極",
                "6": "天路安可窮",
                "7": "類此遊客子",
                "8": "捐軀遠從戎",
                "9": "毛褐不掩形",
                "10": "薇藿常不充",
                "11": "去去莫復道",
                "12": "沈憂令人老"
            }
        }
    }
}