{
    "29.02-01": {
        "篇名": "李少卿 與蘇武詩三首·其一",
        "1": {
            "3": {
                "1": "良時不再至",
                "2": "離別在須臾",
                "3": "屛營衢路側",
                "4": "執手野踟躕",
                "5": "仰視浮雲馳",
                "6": "奄忽互相踰",
                "7": "風波一失所",
                "8": "各在天一隅",
                "9": "長當從此別",
                "10": "且復立斯須",
                "11": "欲因晨風發",
                "12": "送子以賤軀"
            }
        }
    }
