                "5": "百卉具零",
                "6": "剛蟲搏摯",
                "7": "爾乃振天維",
                "8": "衍地絡",
                "9": "蕩川瀆",
                "10": "簸林薄",
                "11": "鳥畢駭",
                "12": "獸咸作",
                "13": "草伏木栖",
                "14": "寓居穴託",
                "15": "起彼集此",
                "16": "霍繹紛泊",
                "17": "在彼靈囿之中",
                "18": "前後無有垠鍔",
                "19": "虞人掌焉",
                "20": "爲之營域",
                "21": "焚萊平場",
                "22": "柞木剪棘",
                "23": "結罝百里",
                "24": "迒杜蹊塞",
                "25": "麀鹿麌麌",
                "26": "騈田偪仄",
                "27": "天子乃駕彫軫",
                "28": "六駿駮",
                "29": "戴翠帽",
                "30": "倚金較",
                "31": "璿弁玉纓",
                "32": "遺光儵爚",
                "33": "建玄弋",
                "34": "樹招搖",
                "35": "栖鳴鳶",
                "36": "曳雲梢",
                "37": "弧旌枉矢",
                "38": "虹𣃼蜺旄",
                "39": "華蓋承辰",
                "40": "天畢前驅",
                "41": "千乘雷動",
                "42": "萬騎龍趨",
                "43": "屬車之簉",
                "44": "載獫猲獢",
                "45": "匪唯翫好",
                "46": "乃有祕書",
                "47": "小說九百",
                "48": "本自虞初",
                "49": "從容之求",
                "50": "寔俟寔儲",
                "51": "於是蚩尤秉鉞",
                "52": "奮鬣被般",
                "53": "禁禦不若",
                "54": "以知神姦",
                "55": "螭魅魍魎",
                "56": "莫能逢旃",
                "57": "陳虎旅於飛廉",
                "58": "正壘壁乎上蘭",
                "59": "結部曲",
                "60": "整行伍",
                "61": "燎京薪",
                "62": "駴雷鼓",
                "63": "縱獵徒",
                "64": "赴長莽",
                "65": "迾卒清候",
                "66": "武士赫怒",
                "67": "緹衣韎韐",
                "68": "睢盱拔扈",
                "69": "光炎燭天庭",
                "70": "囂聲震海浦",
                "71": "河渭爲之波盪",
                "72": "吳嶽爲之陀堵",
                "73": "百禽㥄遽",
                "74": "騤瞿奔觸",
                "75": "喪精亡魂",
                "76": "失歸忘趨",
                "77": "投輪關輻",
                "78": "不邀自遇",
                "79": "飛罕潚箾",
                "80": "流鏑𢶉㩧",
                "81": "矢不虛舍",
                "82": "鋋不苟躍",
                "83": "當足見蹍",
                "84": "値輪被轢",
                "85": "僵禽斃獸",
                "86": "爛若磧礫",
                "87": "但觀罝羅之所羂結",
                "88": "竿殳之所揘畢",
                "89": "叉蔟之所攙捔",
                "90": "徒搏之所撞㧙",
                "91": "白日未及移其晷",
                "92": "已獮其什七八"
            }
        },
        "10": {
            "21": {
                "1": "若夫遊鷮高翬",
                "2": "絕阬踰斥",
                "3": "毚兔聯猭",
                "4": "陵巒超壑",
                "5": "比諸東郭",
                "6": "莫之能獲",
                "7": "乃有迅羽輕足",
                "8": "尋景追括",
                "9": "鳥不暇舉",
                "10": "獸不得發",
                "11": "青骹摯於韝下",
                "12": "韓盧噬於𦁛末",
                "13": "及其猛毅髬髵",
                "14": "隅目高匡",
                "15": "威懾兕虎",
                "16": "莫之敢伉",
                "17": "迺使中黃之士",
                "18": "育獲之儔",
                "19": "朱鬕𩰁髽",
                "20": "植髮如竿",
                "21": "袒裼戟手",
                "22": "奎踽盤桓",
                "23": "鼻赤象",
                "24": "圈巨狿",
                "25": "摣狒猬",
                "26": "㧗窳狻",
                "27": "揩枳落",
                "28": "突棘藩",
                "29": "梗林爲之靡拉",
                "30": "樸叢爲之摧殘",
                "31": "輕銳僄狡趫捷之徒",
                "32": "赴洞穴",
                "33": "探封狐",
                "34": "陵重巘",
                "35": "獵昆駼",
                "36": "杪木末",
                "37": "擭獑猢",
                "38": "超殊榛",
                "39": "摕飛鼯"
            }
        },
        "11": {
            "23": {
                "1": "是時後宮嬖人昭儀之倫",
                "2": "常亞於乘輿",
                "3": "慕賈氏之如皋",
                "4": "樂北風之同車",
                "5": "盤於遊畋",
                "6": "其樂只且",
                "7": "於是鳥獸殫",
                "8": "目觀窮",
                "9": "遷延邪睨",
                "10": "集乎長楊之宮",
                "11": "息行夫",
                "12": "展車馬",
                "13": "收禽舉胔",
                "14": "數課眾寡",
                "15": "置互擺牲",
                "16": "頒賜獲鹵",
                "17": "割鮮野饗",
                "18": "犒勤賞功",
                "19": "五軍六師",
                "20": "千列百重",
                "21": "酒車酌醴",
                "22": "方駕授饔",
                "23": "升觴舉燧",
                "24": "旣釂鳴鐘",
                "25": "膳夫馳騎",
                "26": "察貳廉空",
                "27": "炙炰夥",
                "28": "清酤㩼",
                "29": "皇恩溥",
                "30": "洪德施",
                "31": "徒御悅",
                "32": "士忘罷",
                "33": "巾車命駕",
                "34": "迴旆右移",
                "35": "相羊乎五柞之館",
                "36": "旋憩乎昆明之池",
                "37": "登豫章",
                "38": "簡矰紅",
                "39": "蒲且發",
                "40": "弋高鴻",
                "41": "挂白鵠",
                "42": "聯飛龍",
                "43": "磻不特絓",
                "44": "往必加雙"
            }
        },
        "12": {
            "25": {
                "1": "於是命舟牧",
                "2": "爲水嬉",
                "3": "浮鷁首",
                "4": "翳雲芝",
                "5": "垂翟葆",
                "6": "建羽旗",
                "7": "齊栧女",
                "8": "縱櫂歌",
                "9": "發引和",
                "10": "校鳴葭",
                "11": "奏淮南",
                "12": "度陽阿",
                "13": "感河馮",
                "14": "懷湘娥",
                "15": "驚蝄蜽",
                "16": "憚蛟蛇",
                "17": "然後釣魴鱧",
                "18": "纚鰋鮋",
                "19": "摭紫貝",
                "20": "搏耆龜",
                "21": "搤水豹",
                "22": "馽潛牛",
                "23": "澤虞是濫",
                "24": "何有春秋",
                "25": "擿漻澥",
                "26": "搜川瀆",
                "27": "布九罭",
                "28": "設罜䍡",
                "29": "摷昆鮞",
                "30": "殄水族",
                "31": "蘧藕拔",
                "32": "蜃蛤剝",
                "33": "逞欲畋䰻",
                "34": "效獲麑䴠",
                "35": "摎蓼浶浪",
                "36": "乾池滌藪",
                "37": "上無逸飛",
                "38": "下無遺走",
                "39": "擭胎拾卵",
                "40": "蚳蝝盡取",
                "41": "取樂今日",
                "42": "遑卹我後",
                "43": "旣定且寧",
                "44": "焉知傾陀"
            }
        },
        "13": {
            "27": {
                "1": "大駕幸乎平樂",
                "2": "張甲乙而襲翠被",
                "3": "攢珍寶之玩好",
                "4": "紛瑰麗以奓靡",
                "5": "臨迥望之廣場",
                "6": "程角觝之妙戲",
                "7": "烏獲扛鼎",
                "8": "都盧尋橦",
                "9": "衝狹燕濯",
                "10": "胸突銛鋒",
                "11": "跳丸劍之揮霍",
                "12": "走索上而相逢",
                "13": "華嶽峩峩",
                "14": "岡巒參差",
                "15": "神木靈草",
                "16": "朱實離離",
                "17": "總會仙倡",
                "18": "戲豹舞羆",
                "19": "白虎鼓瑟",
                "20": "蒼龍吹篪",
                "21": "女娥坐而長歌",
                "22": "聲清暢而蜲蛇",
                "23": "洪涯立而指麾",
                "24": "被毛羽之襳襹",
                "25": "度曲未終",
                "26": "雲起雪飛",
                "27": "初若飄飄",
                "28": "後遂霏霏",
                "29": "複陸重閣",
                "30": "轉石成雷",
                "31": "礔礰激而增響",
                "32": "磅礚象乎天威",
                "33": "巨獸百尋",
                "34": "是爲曼延神山崔巍",
                "35": "欻從背見",
                "36": "熊虎升而挐攫",
                "37": "猿狖超而高援",
                "38": "怪獸陸梁",
                "39": "大雀踆踆",
                "40": "白象行孕",
                "41": "垂鼻轔囷",
                "42": "海鱗變而成龍",
                "43": "狀蜿蜿以蝹蝹",
                "44": "含利颬颬",
                "45": "化爲仙車",
                "46": "驪駕四鹿",
                "47": "芝蓋九葩",
                "48": "蟾蜍與龜",
                "49": "水人弄蛇",
                "50": "奇幻儵忽",
                "51": "易貌分形",
                "52": "吞刀吐火",
                "53": "雲霧杳冥",
                "54": "畫地成川",
                "55": "流渭通涇",
                "56": "東海黃公",
                "57": "赤刀粵祝冀厭白虎",
                "58": "卒不能救",
                "59": "挾邪作蠱",
                "60": "於是不售",
                "61": "爾乃建戲車",
                "62": "樹修旃",
                "63": "侲僮程材",
                "64": "上下翩翻",
                "65": "突倒投而跟絓",
                "66": "譬隕絕而復聯",
                "67": "百馬同轡",
                "68": "騁足並馳",
                "69": "橦末之伎",
                "70": "態不可彌",
                "71": "彎弓射乎西羌",
                "72": "又顧發乎鮮卑"
            }
        },
        "14": {
            "29": {
                "1": "於是眾變盡",
                "2": "心酲醉",
                "3": "盤樂極",
                "4": "悵懷萃",
                "5": "陰戒期門",
                "6": "微行要屈",
                "7": "降尊就卑",
                "8": "懷璽藏紱",
                "9": "便旋閭閻",
                "10": "周觀郊遂",
                "11": "若神龍之變化",
                "12": "章后皇之爲貴",
                "13": "然後歷掖庭",
                "14": "適歡館",
                "15": "捐衰色",
                "16": "從嬿婉",
                "17": "促中堂之陿坐",
                "18": "羽觴行而無筭",
                "19": "祕舞更奏",
                "20": "妙材騁伎",
                "21": "妖蠱豔夫夏姬",
                "22": "美聲暢於虞氏",
                "23": "始徐進而羸形",
                "24": "似不任乎羅綺",
                "25": "嚼清商而卻轉",
                "26": "增嬋蜎以此豸紛縱體而迅赴",
                "27": "若驚鶴之羣罷",
                "28": "振朱屣於盤尊",
                "29": "奮長袖之䬃纚",
                "30": "要紹修態",
                "31": "麗服颺菁",
                "32": "眳藐流眄",
                "33": "一顧傾城",
                "34": "展季桑門",
                "35": "誰能不營",
                "36": "列爵十四",
                "37": "競媚取榮",
                "38": "盛衰無常",
                "39": "唯愛所丁",
                "40": "衞后興於鬒髮",
                "41": "飛燕寵於體輕",
                "42": "爾乃逞志究欲",
                "43": "窮身極娛",
                "44": "鑒戒唐詩",
                "45": "他人是媮",
                "46": "自君作故",
                "47": "何禮之拘",
                "48": "增昭儀於婕妤",
                "49": "賢旣公而又侯",
                "50": "許趙氏以無上",
                "51": "思致董於有虞",
                "52": "王閎爭於坐側",
                "53": "漢載安而不渝"
            }
        },
        "15": {
            "31": {
                "1": "高祖創業",
                "2": "繼體承基",
                "3": "暫勞永逸",
                "4": "無爲而治",
                "5": "耽樂是從",
                "6": "何慮何思",
                "7": "多歷年所",
                "8": "二百餘朞",
                "9": "徒以地沃野豐",
                "10": "百物殷阜",
                "11": "巖險周固",
                "12": "衿帶易守",
                "13": "得之者強",
                "14": "據之者久",
                "15": "流長則難竭",
                "16": "柢深則難朽",
                "17": "故奢泰肆情",
                "18": "馨烈彌茂",
                "19": "鄙生生乎三百之外",
                "20": "傳聞於未聞之者",
                "21": "曾髣髴其若夢",
                "22": "未一隅之能睹",
                "23": "此何與於殷人屢遷",
                "24": "前八而後五",
                "25": "居相圮耿",
                "26": "不常厥土",
                "27": "盤庚作誥",
                "28": "帥人以苦",
                "29": "方今聖上同天",
                "30": "號於帝皇",
                "31": "掩四海而爲家",
                "32": "富有之業",
                "33": "莫我大也",
                "34": "徒恨不能以靡麗爲國華",
                "35": "獨儉嗇以齷齪",
                "36": "忘蟋蟀之謂何",
                "37": "豈欲之而不能",
                "38": "將能之而不欲歟",
                "39": "蒙竊惑焉",
                "40": "願聞所以辯之之說也"
            }
        }
    }
}