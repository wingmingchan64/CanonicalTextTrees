{
    "02.01": {
        "篇名": "張平子 西京賦",
        "1": {
            "3": {
                "1": "有憑虛公子者",
                "2": "心奓體忲",
                "3": "雅好博古",
                "4": "學乎舊史氏",
                "5": "是以多識前代之載",
                "6": "言於安處先生",
                "7": "曰",
                "8": "夫人在陽時則舒",
                "9": "在陰時則慘",
                "10": "此牽乎天者也",
                "11": "處沃土則逸",
                "12": "處瘠土則勞",
                "13": "此繫乎地者也",
                "14": "慘則尠於歡",
                "15": "勞則褊於惠",
                "16": "能違之者寡矣",
                "17": "小必有之",
                "18": "大亦宜然",
                "19": "故帝者因天地以致化",
                "20": "兆人承上教以成俗",
                "21": "化俗之本",
                "22": "有與推移",
                "23": "何以覈諸",
                "24": "秦據雍而彊",
                "25": "周卽豫而弱",
                "26": "高祖都西而泰",
                "27": "光武處東而約",
                "28": "政之興衰",
                "29": "恆由此作",
                "30": "先生獨不見西京之事歟",
                "31": "請爲吾子陳之"
            }
        },
        "2": {
            "5": {
                "1": "漢氏初都",
                "2": "在渭之涘",
                "3": "秦里其朔",
                "4": "寔爲咸陽",
                "5": "左有崤函重險",
                "6": "桃林之塞",
                "7": "綴以二華",
                "8": "巨靈贔屓",
                "9": "高掌遠蹠",
                "10": "以流河曲",
                "11": "厥迹猶存",
                "12": "右有隴坻之隘",
                "13": "隔閡華戎",
                "14": "岐梁汧雍",
                "15": "陳寶鳴雞在焉",
                "16": "於前則終南太一",
                "17": "隆崛崔崒",
                "18": "隱轔鬱律",
                "19": "連岡乎嶓冢",
                "20": "抱杜含鄠",
                "21": "欱灃吐鎬",
                "22": "爰有藍田珍玉",
                "23": "是之自出",
                "24": "於後則高陵平原",
                "25": "據渭踞涇",
                "26": "澶漫靡迆",
                "27": "作鎭於近",
                "28": "其遠則九嵕甘泉",
                "29": "涸陰沍寒",
                "30": "日北至而含凍",
                "31": "此焉清暑",
                "32": "爾乃廣衍沃野",
                "33": "厥田上上",
                "34": "寔惟地之奧區神皋",
                "35": "昔者大帝說秦繆公而覲之",
                "36": "饗以鈞天廣樂",
                "37": "帝有醉焉",
                "38": "乃爲金策",
                "39": "錫用此土",
                "40": "而剪諸鶉首",
                "41": "是時也",
                "42": "並爲彊國者有六",
                "43": "然而四海同宅",
                "44": "西秦豈不詭哉"
            }
        },
        "3": {
            "7": {
                "1": "自我高祖之始入也",
                "2": "五緯相汁",
                "3": "以旅於東井",
                "4": "婁敬委輅",
                "5": "幹非其議",
                "6": "天啟其心",
                "7": "人惎之謀",
                "8": "及帝圖時",
                "9": "意亦有慮乎神祇",
                "10": "宜其可定以爲天邑",
                "11": "豈伊不虔思於天衢",
                "12": "豈伊不懷歸於枌楡",
                "13": "天命不滔",
                "14": "疇敢以渝",
                "15": "於是量徑輪",
                "16": "考廣袤",
                "17": "經城洫",
                "18": "營郭郛",
                "19": "取殊裁於八都",
                "20": "豈啟度於往舊",
                "21": "乃覽秦制",
                "22": "跨周法",
                "23": "狹百堵之側陋",
                "24": "增九筵之迫脅",
                "25": "正紫宮於未央",
                "26": "表嶢闕於閶闔",
                "27": "䟽龍首以抗殿",
                "28": "狀巍峩以岌嶪",
                "29": "亙雄虹之長梁",
                "30": "結棼橑以相接",
                "31": "蔕倒茄於藻井",
                "32": "披紅葩之狎獵",
                "33": "飾華榱與璧璫",
                "34": "流景曜之韡曄",
                "35": "雕楹玉磶",
                "36": "繡栭雲楣",
                "37": "三階重軒",
                "38": "鏤檻文㮰",
                "39": "右平左墄",
                "40": "青瑣丹墀",
                "41": "刊層平堂",
                "42": "設切厓隒",
                "43": "坻崿鱗眴",
                "44": "棧齴巉嶮",
                "45": "襄岸夷塗",
                "46": "修路陖險",
                "47": "重門襲固",
                "48": "姦宄是防",
                "49": "仰福帝居",
                "50": "陽曜陰藏",
                "51": "洪鐘萬鈞",
                "52": "猛虡趪趪",
                "53": "負筍業而餘怒",
                "54": "乃奮翅而騰驤",
                "55": "朝堂承東",
                "56": "溫調延北",
                "57": "西有玉臺",
                "58": "聯以昆德",
                "59": "嵳峩崨嶫",
                "60": "罔識所則",
                "61": "若夫長年神仙",
                "62": "宣室玉堂",
                "63": "麒麟朱鳥",
                "64": "龍興含章",
                "65": "譬眾星之環極",
                "66": "叛赫戲以煇煌",
                "67": "正殿路寢",
                "68": "用朝羣辟",
                "69": "大夏耽耽",
                "70": "九戶開闢",
                "71": "嘉木樹庭",
                "72": "芳草如積",
                "73": "高門有閌",
                "74": "列坐金狄",
                "75": "內有常侍謁者",
                "76": "奉命當御",
                "77": "蘭臺金馬",
                "78": "遞宿迭居",
                "79": "次有天祿石渠",
                "80": "校文之處",
                "81": "重以虎威章溝",
                "82": "嚴更之署",
                "83": "徼道外周",
                "84": "千廬內附",
                "85": "衞尉八屯",
                "86": "警夜巡晝",
                "87": "植鎩懸𤟢",
                "88": "用戒不虞"
            }
        },
        "4": {
            "9": {
                "1": "後宮則昭陽飛翔",
                "2": "增成合歡",
                "3": "蘭林披香",
                "4": "鳳皇鴛鸞",
                "5": "羣窈窕之華麗",
                "6": "嗟內顧之所觀",
                "7": "故其館室次舍",
                "8": "采飾纖縟",
                "9": "裛以藻繡",
                "10": "文以朱綠",
                "11": "翡翠火齊",
                "12": "絡以美玉",
                "13": "流懸黎之夜光",
                "14": "綴隨珠以爲燭",
                "15": "金戺玉階",
                "16": "彤庭煇煇",
                "17": "珊瑚琳碧",
                "18": "瓀珉璘彬",
                "19": "珍物羅生",
                "20": "煥若崐崘",
                "21": "雖厥裁之不廣",
                "22": "侈靡踰乎至尊",
                "23": "於是鉤陳之外",
                "24": "閣道穹隆",
                "25": "屬長樂與明光",
                "26": "徑北通乎桂宮",
                "27": "命般爾之巧匠",
                "28": "盡變態乎其中",
                "29": "後宮不移",
                "30": "樂不徙懸",
                "31": "門衞供帳",
                "32": "官以物辨",
                "33": "恣意所幸",
                "34": "下輦成燕",
                "35": "窮年忘歸",
                "36": "猶弗能徧",
                "37": "瑰異日新",
                "38": "殫所未見"
            }
        },
        "5": {
            "11": {
                "1": "惟帝王之神麗",
                "2": "懼尊卑之不殊",
                "3": "雖斯宇之旣坦",
                "4": "心猶憑而未攄",
                "5": "思比象於紫微",
                "6": "恨阿房之不可廬",
                "7": "覛往昔之遺館",
                "8": "獲林光於秦餘",
                "9": "處甘泉之爽塏",
                "10": "乃隆崇而弘敷",
                "11": "旣新作於迎風",
                "12": "增露寒與儲胥",
                "13": "託喬基於山岡",
                "14": "直墆霓以高居",
                "15": "通天訬以竦峙",
                "16": "徑百常而莖擢",
                "17": "上辬華以交紛",
                "18": "下刻陗其若削",
                "19": "翔鶤仰而不逮",
                "20": "況青鳥與黃雀",
                "21": "伏櫺檻而頫聽",
                "22": "聞雷霆之相激",
                "23": "柏梁旣災",
                "24": "越巫陳方",
                "25": "建章是經",
                "26": "用厭火祥",
                "27": "營宇之制",
                "28": "事兼未央",
                "29": "圜闕竦以造天",
                "30": "若雙碣之相望",
                "31": "鳳騫翥於甍標",
                "32": "咸溯風而欲翔",
                "33": "閶闔之內",
                "34": "別風嶕嶢",
                "35": "何工巧之瑰瑋",
                "36": "交綺豁以疏僚",
                "37": "干雲霧而上達",
                "38": "狀亭亭以苕苕",
                "39": "神明崛其特起",
                "40": "井幹疊而百增",
                "41": "跱遊極於浮柱",
                "42": "結重欒以相承",
                "43": "累層構而遂隮",
                "44": "望北辰而高興",
                "45": "消雰埃於中宸",
                "46": "集重陽之清澂",
                "47": "瞰宛虹之長鬐",
                "48": "察雲師之所憑",
                "49": "上飛闥而仰眺",
                "50": "正睹瑤光與玉繩",
                "51": "將乍往而未半",
                "52": "怵悼慄而慫兢",
                "53": "非都盧之輕趫",
                "54": "孰能超而究升",
                "55": "馺娑駘盪",
                "56": "燾奡桔桀",
                "57": "枍詣承光",
                "58": "睽罛庨𧯆",
                "59": "橧桴重棼",
                "60": "鍔鍔列列",
                "61": "反宇業業",
                "62": "飛檐䡾䡾",
                "63": "流景內照",
                "64": "引曜日月",
                "65": "天梁之宮",
                "66": "寔開高闈",
                "67": "旗不脫扃",
                "68": "結駟方蘄",
                "69": "轢輻輕騖",
                "70": "容於一扉",
                "71": "長廊廣廡",
                "72": "途閣雲蔓",
                "73": "閈庭詭異",
                "74": "門千戶萬",
                "75": "重閨幽闥",
                "76": "轉相踰延",
                "77": "望䆗窱以徑廷",
                "78": "眇不知其所返",
                "79": "旣乃珍臺蹇產以極壯",
                "80": "墱道邐倚以正東",
                "81": "似閬風之遐坂",
                "82": "橫西洫而絕金墉",
                "83": "城尉不㢮柝",
                "84": "而內外潛通"
            }
        },
        "6": {
            "13": {
                "1": "前開唐中",
                "2": "彌望廣潒",
                "3": "顧臨太液",
                "4": "滄池漭沆",
                "5": "漸臺立於中央",
                "6": "赫昈昈以弘敞",
                "7": "清淵洋洋",
                "8": "神山峩峩",
                "9": "列瀛洲與方丈",
                "10": "夾蓬萊而騈羅",
                "11": "上林岑以壘㠑",
                "12": "下嶄巖以嵒齬",
                "13": "長風激於別隯",
                "14": "起洪濤而揚波",
