{
    "27.19-02": {
        "篇名": "魏文帝 樂府二首善哉行·其二",
        "1": {
            "3": {
                "1": "上山采薇",
                "2": "薄暮苦飢",
                "3": "谿谷多風",
                "4": "霜露霑衣",
                "5": "野雉羣雊",
                "6": "猴猿相追",
                "7": "還望故鄕",
                "8": "鬱何壘壘",
                "9": "高山有崖",
                "10": "林木有枝",
                "11": "憂來無方",
                "12": "人莫之知",
                "13": "人生如寄",
                "14": "多憂何爲",
                "15": "今我不樂",
                "16": "歲月如馳",
                "17": "湯湯川流",
                "18": "中有行舟",
                "19": "隨波迴轉",
                "20": "有似客遊",
                "21": "策我良馬",
                "22": "被我輕裘",
                "23": "載馳載驅",
                "24": "聊以忘憂"
            }
        }
    }
}