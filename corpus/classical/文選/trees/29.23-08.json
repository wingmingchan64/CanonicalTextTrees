{
    "29.23-08": {
        "篇名": "張景陽 雜詩十首·其八",
        "1": {
            "3": {
                "1": "述職投邊城",
                "2": "羈束戎旅間",
                "3": "下車如昨日",
                "4": "望舒四五圓",
                "5": "借問此何時",
                "6": "胡蝶飛南園",
                "7": "流波戀舊浦",
                "8": "行雲思故山",
                "9": "閩越衣文蛇",
                "10": "胡馬願度燕",
                "11": "土風安所習",
                "12": "由來有固然"
            }
        }
    }
