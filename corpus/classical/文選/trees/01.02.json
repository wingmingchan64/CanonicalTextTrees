        },
        "4": {
            "9": {
                "1": "其宮室也",
                "2": "體象乎天地",
                "3": "經緯乎陰陽",
                "4": "據坤靈之正位",
                "5": "倣太紫之圓方",
                "6": "樹中天之華闕",
                "7": "豐冠山之朱堂",
                "8": "因瓌材而究奇",
                "9": "抗應龍之虹梁",
                "10": "列棼橑以布翼",
                "11": "荷棟桴而高驤",
                "12": "雕玉瑱以居楹",
                "13": "裁金璧以飾璫",
                "14": "發五色之渥彩",
                "15": "光爓朗以景彰",
                "16": "於是左墄右平",
                "17": "重軒三階",
                "18": "閨房周通",
                "19": "門闥洞開",
