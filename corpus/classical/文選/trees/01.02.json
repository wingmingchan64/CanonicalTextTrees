{
    "01.02": {
        "篇名": "班孟堅 西都賦*",
        "1": {
            "3": {
                "1": "有西都賓問於東都主人曰",
                "2": "蓋聞皇漢之初經營也",
                "3": "嘗有意乎都河洛矣",
                "4": "輟而弗康",
                "5": "寔用西遷",
                "6": "作我上都",
                "7": "主人聞其故而覩其制乎",
                "8": "主人曰",
                "9": "未也",
                "10": "願賓攄懷舊之蓄念",
                "11": "發思古之幽情",
                "12": "博我以皇道",
                "13": "弘我以漢京",
                "14": "賓曰",
                "15": "唯唯"
            }
        },
        "2": {
            "5": {
                "1": "漢之西都",
                "2": "在於雍州",
                "3": "寔曰長安",
                "4": "左據函谷二崤之阻",
                "5": "表以太華終南之山",
                "6": "右界襃斜隴首之險",
                "7": "帶以洪河涇渭之川",
                "8": "眾流之隈",
                "9": "汧涌其西",
                "10": "華實之毛",
                "11": "則九州之上腴焉",
                "12": "防禦之阻",
                "13": "則天地之隩區焉",
                "14": "是故橫被六合",
                "15": "三成帝畿",
                "16": "周以龍興",
                "17": "秦以虎視",
                "18": "及至大漢受命而都之也",
                "19": "仰悟東井之精",
                "20": "俯協河圖之靈",
                "21": "奉春建策",
                "22": "留侯演成",
                "23": "天人合應",
                "24": "以發皇明",
                "25": "乃眷西顧",
                "26": "寔惟作京",
                "27": "於是睎秦嶺",
                "28": "睋北阜",
                "29": "挾灃灞",
                "30": "據龍首",
                "31": "圖皇基於億載",
                "32": "度宏規而大起",
                "33": "肇自高而終平",
                "34": "世增飾以崇麗",
                "35": "歷十二之延祚",
                "36": "故窮泰而極侈",
                "37": "建金城而萬雉",
                "38": "呀周池而成淵",
                "39": "披三條之廣路",
                "40": "立十二之通門",
                "41": "內則街衢洞達",
                "42": "閭閻且千",
                "43": "九市開場",
                "44": "貨別隧分",
                "45": "人不得顧",
                "46": "車不得旋",
                "47": "闐城溢郭",
                "48": "旁流百廛",
                "49": "紅塵四合",
                "50": "煙雲相連",
                "51": "於是旣庶且富",
                "52": "娛樂無疆",
                "53": "都人士女",
                "54": "殊異乎五方",
                "55": "遊士擬於公侯",
                "56": "列肆侈於姬姜",
                "57": "鄕曲豪舉",
                "58": "遊俠之雄",
                "59": "節慕原嘗",
                "60": "名亞春陵",
                "61": "連交合眾",
                "62": "騁騖乎其中",
                "63": "若乃觀郊",
                "64": "浮遊近縣",
                "65": "則南望杜霸",
                "66": "北眺五陵",
                "67": "名都對郭",
                "68": "邑居相承",
                "69": "英俊之域",
                "70": "紱冕所興",
                "71": "冠蓋如雲",
                "72": "七相五公",
                "73": "與乎州郡之豪傑",
                "74": "五都之貨殖",
                "75": "三選七遷",
                "76": "充奉陵邑",
                "77": "蓋以強幹弱枝",
                "78": "隆上都而觀萬國也"
            }
        },
        "3": {
            "7": {
                "1": "封畿之內",
                "2": "厥土千里",
                "3": "逴躒諸夏",
                "4": "兼其所有",
