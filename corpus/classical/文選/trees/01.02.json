                "21": "立金人於端闈",
                "22": "仍增崖而衡閾",
                "23": "臨峻路而啟扉",
                "24": "徇以離宮別寢",
                "25": "承以崇臺間館",
                "26": "煥若列宿",
                "27": "紫宮是環",
                "28": "清涼宣溫",
                "29": "神仙長年",
                "30": "金華玉堂",
                "31": "白虎麒麟",
                "32": "區宇若茲",
                "33": "不可殫論",
                "34": "增盤崔嵬",
                "35": "登降炤爛",
                "36": "殊形詭制",
                "37": "每各異觀",
                "38": "乘茵步輦",
                "39": "惟所息宴",
                "40": "後宮則有掖庭椒房",
                "41": "后妃之室",
                "42": "合歡增城",
