{
    "04.02": {
        "篇名": "左太沖 三都賦序",
        "1": {
            "3": {
                "1": "蓋詩有六義焉",
                "2": "曰賦",
                "3": "楊雄曰",
                "4": "詩人之賦麗以則",
                "5": "班固曰",
                "6": "賦者",
                "7": "古詩之流也",
                "8": "先王采焉",
                "9": "以觀土風",
                "10": "見綠竹猗猗",
                "11": "則知衞地淇澳之產",
                "12": "見在其版屋",
                "13": "則知秦野西戎之宅",
                "14": "故能居然而辨八方",
                "15": "然相如賦上林而引盧橘夏熟",
                "16": "楊雄賦甘泉而陳玉樹青蔥",
                "17": "班固賦西都而歎以出比目",
                "18": "張衡賦西京而述以遊海若",
                "19": "假稱珍怪",
                "20": "以爲潤色",
                "21": "若斯之類",
                "22": "匪啻於茲",
                "23": "考之果木",
                "24": "則生非其壤",
                "25": "校之神物",
                "26": "則出非其所",
                "27": "於辭則易爲藻飾",
                "28": "於義則虛而無徵",
                "29": "且夫玉巵無當",
                "30": "雖寶非用",
                "31": "侈言無驗",
                "32": "雖麗非經",
                "33": "而論者莫不詆訐其硏精",
                "34": "作者大氐舉爲憲章",
                "35": "積習生常",
                "36": "有自來矣"
            }
        },
        "2": {
            "5": {
                "1": "余旣思摹二京而賦三都",
                "2": "其山川城邑則稽之地圖",
                "3": "其鳥獸草木則驗之方志",
                "4": "風謠歌舞",
                "5": "各附其俗",
                "6": "魁梧長者",
                "7": "莫非其舊",
                "8": "何則",
                "9": "發言爲詩者",
                "10": "詠其所志也",
                "11": "升高能賦者",
                "12": "頌其所見也",
                "13": "美物者貴依其本",
                "14": "讚事者宜本其實",
                "15": "匪本匪實",
                "16": "覽者奚信",
                "17": "且夫任土作貢",
                "18": "虞書所著",
                "19": "辯物居方",
                "20": "周易所愼",
                "21": "聊舉隅",
                "22": "攝其體統",
                "23": "歸諸詁訓焉"
            }
        }
    }
}