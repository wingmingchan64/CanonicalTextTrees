{
    "40.02": {
        "篇名": "任彥升 奏彈劉整",
        "1": {
            "3": {
                "1": "御史中丞臣任昉稽首言",
                "2": "臣聞馬援奉嫂",
                "3": "不冠不入",
                "4": "泛毓字孤",
                "5": "家無常子",
                "6": "是以義士節夫",
                "7": "聞之有立",
                "8": "千載美談",
                "9": "斯爲稱首"
            }
        },
        "2": {
            "5": {
                "1": "臣昉頓首頓首",
                "2": "死罪死罪",
                "3": "謹案齊故西陽內史劉寅妻范",
                "4": "詣臺訴列稱",
                "5": "出適劉氏",
                "6": "二十許年",
                "7": "劉氏喪亡",
                "8": "撫養孤弱",
                "9": "叔郎整",
                "10": "常欲傷害侵奪",
                "11": "分前奴教子",
                "12": "當伯",
                "13": "幷已入眾",
                "14": "又以錢婢姊妹弟溫",
                "15": "仍留奴自使伯",
                "16": "又奪寅息逡婢綠草",
                "17": "私貨得錢",
                "18": "幷不分逡",
                "19": "寅第二庶息師利",
                "20": "去歲十月往整田上經十二日",
                "21": "整便責范米六砀哺食",
                "22": "米未展送",
                "23": "忽至戶前",
                "24": "隔箔攘拳大罵",
                "25": "突進房中",
                "26": "屛風上取車帷準米去",
                "27": "二月九日夜",
                "28": "婢采音偸車欄夾杖龍牽",
                "29": "范問失物之意",
                "30": "整便打息逡",
                "31": "整及母幷奴婢等六人來至范屋中",
                "32": "高聲大罵",
                "33": "婢采音舉手查范臂",
                "34": "求攝檢",
                "35": "如訴狀"
            }
        },
        "3": {
            "7": {
                "1": "輒攝整亡父舊使奴海蛤到臺辯問",
                "2": "列稱",
                "3": "整亡父興道",
                "4": "先爲零陵郡",
                "5": "得奴婢四人",
                "6": "分財",
                "7": "以奴教子乞大息寅",
                "8": "亡寅後",
                "9": "第二弟整仍奪教子",
                "10": "云應入眾",
                "11": "整便留自使",
                "12": "婢姊及弟各准錢五千文",
                "13": "不分逡",
                "14": "其奴當伯",
                "15": "先是眾奴",
                "16": "整兄弟未分財之前",
                "17": "整兄寅以當伯貼錢七千",
                "18": "共眾作田",
                "19": "寅罷西陽郡還",
                "20": "雖未別火食",
                "21": "寅以私錢七千贖當伯",
                "22": "仍使上廣州去",
                "23": "後寅喪亡",
                "24": "整兄弟後分奴婢",
                "25": "唯餘婢綠草入眾",
                "26": "整復云寅未分財贖當伯",
                "27": "又應屬眾",
                "28": "整意貪得當伯",
                "29": "推綠草與逡",
                "30": "整規當伯還",
                "31": "擬欲自取",
                "32": "當伯遂經七年不返",
                "33": "整疑已死亡不迴",
                "34": "更奪取婢綠草",
                "35": "貨得錢七千",
                "36": "整兄弟及姊共分此錢",
                "37": "又不分逡",
                "38": "寅妻范云",
                "39": "當伯是亡夫私贖",
                "40": "應屬息逡",
                "41": "當伯天監二年六月從廣州還至",
                "42": "整復奪取",
                "43": "云應充眾",
                "44": "准雇借上廣州四年夫直",
                "45": "今在整處使"
            }
        },
        "4": {
            "9": {
                "1": "進責整婢采音",
                "2": "劉整兄寅第二息師利",
                "3": "去年十月十二日忽往整墅停住十二日",
                "4": "整就兄妻范求米六斗哺食",
                "5": "范未得還",
                "6": "整怒",
                "7": "仍自進范所住",
                "8": "屛風上取車帷爲質",
                "9": "范送米六斗",
                "10": "整卽納受",
                "11": "范今年二月九日夜",
                "12": "失車欄子夾杖龍牽等",
                "13": "范及息逡道是采音所偸",
                "14": "整聞聲",
                "15": "仍打逡",
                "16": "范喚問何意打我兒",
                "17": "整母子爾時便同出中庭",
                "18": "隔箔與范相罵",
                "19": "婢采音及奴教子",
                "20": "楚玉",
                "21": "法志等四人",
                "22": "於時在整母子左右",
                "23": "整語采音",
                "24": "其道汝偸車校具",
                "25": "汝何不進裏罵之",
                "26": "旣進爭口",
                "27": "舉手誤查范臂",
                "28": "車欄夾杖龍牽",
                "29": "實非采音所偸"
            }
        },
        "5": {
            "11": {
                "1": "進責寅妻范奴苟奴",
                "2": "列娘去二月九日夜",
                "3": "失車欄夾杖龍牽",
                "4": "疑是整婢采音所偸",
                "5": "苟奴與郎逡往津陽門糴米",
                "6": "遇見采音在津陽門賣車欄龍牽",
                "7": "苟奴登時欲捉取",
                "8": "逡語苟奴已爾不須復取",
                "9": "苟奴隱僻少時",
                "10": "伺視人買龍牽",
                "11": "售五千錢",
                "12": "苟奴仍隨逡歸宅",
                "13": "不見度錢"
            }
        },
        "6": {
            "13": {
                "1": "幷如采音",
                "2": "苟奴等列狀",
                "3": "粗與范訴相應",
                "4": "重覈當伯",
                "5": "教子",
                "6": "列娘被奪",
                "7": "今在整處使",
                "8": "悉與海蛤列不異",
                "9": "以事訴法",
                "10": "令史潘僧尙議",
                "11": "整若輒略兄子逡分前婢貨賣",
                "12": "及奴教子等私使",
                "13": "若無官令",
                "14": "輒收付近獄測治",
                "15": "諸所連逮絓應洗之源",
                "16": "委之獄官",
                "17": "悉以法制從事",
                "18": "如法所稱",
                "19": "整卽主"
            }
        },
        "7": {
            "15": {
                "1": "臣謹案",
                "2": "新除中軍參軍臣劉整",
                "3": "閭閻闟茸",
                "4": "名教所絕",
                "5": "直以前代外戚",
                "6": "仕因紈蔥",
                "7": "惡積釁稔",
                "8": "親舊側目",
                "9": "理絕通問",
                "10": "而妄肆醜辭",
                "11": "終夕不寐",
                "12": "而謬加大杖",
                "13": "薛包分財",
                "14": "取其老弱",
                "15": "高鳳自穢",
                "16": "爭訟寡嫂",
                "17": "未見孟嘗之深心",
                "18": "唯矅文通之僞迹",
                "19": "昔人睦親",
                "20": "衣無常主",
                "21": "整之撫姪",
                "22": "食有故人",
                "23": "何其不能折契鍾庾",
                "24": "而襜帷交質",
                "25": "人之無情",
                "26": "一何至此"
            }
        },
        "8": {
            "17": {
                "1": "臣等參議",
                "2": "請以見事免整所除官",
                "3": "輒勒外收付廷尉法獄治罪",
                "4": "諸所連逮應洗之源",
                "5": "委之獄官",
                "6": "悉以法制從事",
                "7": "婢采音不款偸車龍牽",
                "8": "請付獄測實",
                "9": "其宗長及地界職司",
                "10": "初無糾舉",
                "11": "及諸連逮",
                "12": "請不足申盡",
                "13": "臣昉云云",
                "14": "誠惶誠恐以聞"
            }
        }
    }
}