{
    "29.03-03": {
        "篇名": "蘇子卿 詩四首·其三",
        "1": {
            "3": {
                "1": "結髮爲夫妻",
                "2": "恩愛兩不疑",
                "3": "歡娛在今夕",
                "4": "嬿婉及良時",
                "5": "征夫懷往路",
                "6": "起視夜何其",
                "7": "參辰皆已沒",
                "8": "去去從此辭",
                "9": "行役在戰場",
                "10": "相見未有期",
                "11": "握手一長歎",
                "12": "淚爲生別滋",
                "13": "努力愛春華",
                "14": "莫忘歡樂時",
                "15": "生當復來歸",
                "16": "死當長相思"
            }
        }
    }
}