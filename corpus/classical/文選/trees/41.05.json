{
    "41.05": {
        "篇名": "朱叔元 爲幽州牧與彭寵書",
        "1": {
            "3": {
                "1": "蓋聞智者順時而謀",
                "2": "愚者逆理而動",
                "3": "常竊悲京城太叔以不知足而無賢輔",
                "4": "卒自棄於鄭也",
                "5": "伯通以名字典郡",
                "6": "有佐命之功",
                "7": "臨民親職",
                "8": "愛惜倉庫",
                "9": "而浮秉征伐之任",
                "10": "欲權時救急",
                "11": "二者皆爲國耳",
                "12": "卽疑浮相譖",
                "13": "何不詣闕自陳",
                "14": "而爲滅族之計乎"
            }
        },
        "2": {
            "5": {
                "1": "朝廷之於伯通",
                "2": "恩亦厚矣",
                "3": "委以大郡",
                "4": "任以威武",
                "5": "事有柱石之寄",
                "6": "情同子孫之親",
                "7": "匹夫媵母尙能致命一区",
                "8": "豈有身帶三綬",
                "9": "職典大邦",
                "10": "而不顧恩義",
                "11": "生心外叛者乎",
                "12": "伯通與吏民語",
                "13": "何以爲顏",
                "14": "行步拜起",
                "15": "何以爲容",
                "16": "坐臥念之",
                "17": "何以爲心",
                "18": "引鏡窺景",
                "19": "何以施眉目",
                "20": "舉厝建功",
                "21": "何以爲人",
                "22": "惜乎",
                "23": "棄休令之嘉名",
                "24": "造梟鴟之逆謀",
                "25": "捐傳葉之慶祚",
                "26": "招破敗之重災",
                "27": "高論堯舜之道",
                "28": "不忍桀紂之性",
                "29": "生爲世笑",
                "30": "死爲愚鬼",
                "31": "不亦哀乎"
            }
        },
        "3": {
            "7": {
                "1": "伯通與耿俠遊俱起佐命",
                "2": "同被國恩",
                "3": "俠遊謙讓",
                "4": "屢有降挹之言",
                "5": "而伯通自伐",
                "6": "以爲功高天下",
                "7": "往時遼東有豕",
                "8": "生子白頭",
                "9": "異而獻之",
                "10": "行至河東",
                "11": "見羣豕皆白",
                "12": "懷慚而還",
                "13": "若以子之功高論於朝廷",
                "14": "則爲遼東豕也",
                "15": "今乃愚妄",
                "16": "自比六國",
                "17": "六國之時",
                "18": "其勢各盛",
                "19": "廓土數千里",
                "20": "勝兵將百萬",
                "21": "故能據國相持",
                "22": "多歷年所",
                "23": "今天下幾里",
                "24": "列郡幾城",
                "25": "柰何以區區漁陽而結怨天子",
                "26": "此猶河濱之民",
                "27": "捧土以塞孟津",
                "28": "多見其不知量也"
            }
        },
        "4": {
            "9": {
                "1": "方今天下適定",
                "2": "海內願安",
                "3": "士無賢不肖",
                "4": "皆樂立名於世",
                "5": "而伯通獨中風狂走",
                "6": "自捐盛時",
                "7": "內聽嬌婦之失計",
                "8": "外信讒邪之諛言",
                "9": "長爲羣后惡法",
                "10": "永爲功臣鑒戒",
                "11": "豈不誤哉",
                "12": "定海內者無私讎",
                "13": "勿以前事自疑",
                "14": "願留意顧老母少弟",
                "15": "凡舉事無爲親厚者所痛",
                "16": "而爲見讎者所快"
            }
        }
    }
}