{
    "40.03": {
        "篇名": "沈休文 奏彈王源",
        "1": {
            "3": {
                "1": "給事黃門侍郎兼御史中丞吳興邑中正臣沈約稽首言",
                "2": "臣聞齊大非偶",
                "3": "著乎前誥",
                "4": "辭霍不婚",
                "5": "垂稱往烈",
                "6": "若乃交二族之和",
                "7": "辨伉合之義",
                "8": "升降窳隆",
                "9": "誠非一揆",
                "10": "固宜本其門素",
                "11": "不相奪倫",
                "12": "使秦晉有匹",
                "13": "涇渭無舛",
                "14": "自宋氏失御",
                "15": "禮教雕衰",
                "16": "衣冠之族",
                "17": "日失其序",
                "18": "姻婭淪雜",
                "19": "罔計廝庶",
                "20": "販鬻祖曾",
                "21": "以爲賈道",
                "22": "明目腆顏",
                "23": "曾無愧畏",
                "24": "若夫盛德之胤",
                "25": "世業可懷",
                "26": "欒郤之家",
                "27": "前徽未遠",
                "28": "旣壯而室",
                "29": "竊貲莫非皁隸",
                "30": "結褵以行",
                "31": "箕帚咸失其所",
                "32": "志士聞而傷心",
                "33": "舊老爲之歎息",
                "34": "自宸歷御寓",
                "35": "弘革典憲",
                "36": "雖除舊布新",
                "37": "而斯風未殄",
                "38": "陛下所以負扆興言",
                "39": "思清敝俗者也"
            }
        },
        "2": {
            "5": {
                "1": "臣實儒品",
                "2": "謬掌天憲",
                "3": "雖埋輪之志",
                "4": "無屈權右",
                "5": "而狐鼠微物",
                "6": "亦蠹大猷",
                "7": "風聞東海王源",
                "8": "嫁女與富陽滿氏",
                "9": "源雖人品庸陋",
                "10": "冑實參華",
                "11": "曾祖雅",
                "12": "位登八命",
                "13": "祖少卿",
                "14": "內侍帷幄",
                "15": "父璿",
                "16": "升采儲闈",
                "17": "亦居清顯",
                "18": "源頻叨諸府戎禁",
                "19": "豫班通徹",
                "20": "而託姻結好",
                "21": "唯利是求",
                "22": "玷辱流輩",
                "23": "莫斯爲甚",
                "24": "源人身在遠",
                "25": "輒攝媒人劉嗣之到臺辯問",
                "26": "嗣之列稱",
                "27": "吳郡滿璋之",
                "28": "相承云是高平舊族",
                "29": "寵奮胤胄",
                "30": "家計溫足",
                "31": "見託爲息鸞覓婚",
                "32": "王源見告窮盡",
                "33": "卽索璋之簿閥",
                "34": "見璋之任王國侍郎",
                "35": "鸞又爲王慈吳郡正閤主簿",
                "36": "源父子因共詳議",
                "37": "判與爲婚",
                "38": "璋之下錢五萬",
                "39": "以爲聘禮",
                "40": "源先喪婦",
                "41": "又以所聘餘直納妾",
                "42": "如其所列",
                "43": "則與風聞符同"
            }
        },
        "3": {
            "7": {
                "1": "竊尋璋之姓族",
                "2": "士庶莫辨",
                "3": "滿奮身殞西朝",
                "4": "胤嗣殄沒",
                "5": "武秋之後",
                "6": "無聞東晉",
                "7": "其爲虛託",
                "8": "不言自顯",
                "9": "王滿連姻",
                "10": "寔駭物聽",
                "11": "潘楊之睦",
                "12": "有異於此",
                "13": "且買妾納媵",
                "14": "因聘爲資",
                "15": "施衿之費",
                "16": "化充牀笫",
                "17": "鄙情贅行",
                "18": "造次以之",
                "19": "糾慝繩違",
                "20": "允茲簡裁",
                "21": "源卽主"
            }
        },
        "4": {
            "9": {
                "1": "臣謹案",
                "2": "南郡丞王源",
                "3": "忝藉世資",
                "4": "得參纓冕",
                "5": "同人者貌",
                "6": "異人者心",
                "7": "以彼行媒",
                "8": "同之抱布",
                "9": "且非我族類",
                "10": "往哲格言",
                "11": "薰蕕不雜",
                "12": "聞之前典",
                "13": "豈有六卿之胄",
                "14": "納女於管庫之人",
                "15": "宋子河魴",
                "16": "同穴於輿臺之鬼",
                "17": "高門降衡",
                "18": "雖自己作",
                "19": "蔑祖辱親",
                "20": "於事爲甚",
                "21": "此風弗剪",
                "22": "其源遂開",
                "23": "點世塵家",
                "24": "將被比屋",
                "25": "宜寘以明科",
                "26": "黜之流伍",
                "27": "使已汙之族",
                "28": "永愧於昔辰",
                "29": "方媾之黨",
                "30": "革心於來日"
            }
        },
        "5": {
            "11": {
                "1": "臣等參議",
                "2": "請以見事免源所居官",
                "3": "禁錮終身",
                "4": "輒下禁止視事如故",
                "5": "源官品應黃紙",
                "6": "臣輒奉白簡以聞",
                "7": "臣約誠惶誠恐",
                "8": "云云"
            }
        }
    }
}