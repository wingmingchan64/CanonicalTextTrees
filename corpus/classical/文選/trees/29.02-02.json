{
    "29.02-02": {
        "篇名": "李少卿 與蘇武詩三首·其二",
        "1": {
            "3": {
                "1": "嘉會難再遇",
                "2": "三載爲千秋",
                "3": "臨河濯長纓",
                "4": "念子悵悠悠",
                "5": "遠望悲風至",
                "6": "對酒不能酬",
                "7": "行人懷往路",
                "8": "何以慰我愁",
                "9": "獨有盈觴酒",
                "10": "與子結綢繆"
            }
        }
    }
}