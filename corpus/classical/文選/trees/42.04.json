{
    "42.04": {
        "篇名": "魏文帝 與鍾大理書",
        "1": {
            "3": {
                "1": "丕白",
                "2": "良玉比德君子",
                "3": "珪璋見美詩人",
                "4": "晉之垂棘",
                "5": "魯之璵璠",
                "6": "宋之結綠",
                "7": "楚之和璞",
                "8": "價越萬金",
                "9": "貴重都城",
                "10": "有稱疇昔",
                "11": "流聲將來",
                "12": "是以垂棘出晉",
                "13": "虞虢雙禽",
                "14": "和璧入秦",
                "15": "相如抗節",
                "16": "竊見玉書稱美玉",
                "17": "白如截肪",
                "18": "黑譬純漆",
                "19": "赤擬雞冠",
                "20": "黃侔蒸栗",
                "21": "側聞斯語",
                "22": "未睹厥狀",
                "23": "雖德非君子",
                "24": "義無詩人",
                "25": "高山景行",
                "26": "私所仰慕",
                "27": "然四寶邈焉已遠",
                "28": "秦漢未聞有良比也",
                "29": "求之曠年",
                "30": "不遇厥眞",
                "31": "私願不果",
                "32": "飢渴未副"
            }
        },
        "2": {
            "5": {
                "1": "近日南陽宗惠叔稱君侯昔有美玦",
                "2": "聞之驚喜",
                "3": "笑與抃會",
                "4": "當自白書",
                "5": "恐傳言未審",
                "6": "是以令舍弟子建因荀仲茂時從容喩鄙旨",
                "7": "乃不忽遺",
                "8": "厚見周稱",
                "9": "鄴騎旣到",
                "10": "寶玦初至",
                "11": "捧匣跪發",
                "12": "五內震駭",
                "13": "繩窮匣開",
                "14": "爛然滿目",
                "15": "猥以蒙鄙之姿",
                "16": "得睹希世之寶",
                "17": "不煩一介之使",
                "18": "不損連城之價",
                "19": "旣有秦昭章臺之觀",
                "20": "而無藺生詭奪之誑",
                "21": "嘉貺益腆",
                "22": "敢不欽承",
                "23": "謹奉賦一篇",
                "24": "以讚揚麗質",
                "25": "丕白"
            }
        }
    }
}