{
    "42.07": {
        "篇名": "吳季重 答東阿王書",
        "1": {
            "3": {
                "1": "質白",
                "2": "信到",
                "3": "奉所惠貺",
                "4": "發函伸紙",
                "5": "是何文采之巨麗",
                "6": "而慰喩之綢繆乎",
                "7": "夫登東嶽者",
                "8": "然後知眾山之邐迆也",
                "9": "奉至尊者",
                "10": "然後知百里之卑微也",
                "11": "自旋之初",
                "12": "伏念五六日",
                "13": "至於旬時",
                "14": "精散思越",
                "15": "惘若有失",
                "16": "非敢羨寵光之休",
                "17": "慕猗頓之富",
                "18": "誠以身賤犬馬",
                "19": "德輕鴻毛",
                "20": "至乃歷玄闕",
                "21": "排金門",
                "22": "升玉堂",
                "23": "伏虛檻於前殿",
                "24": "臨曲池而行觴",
                "25": "旣威儀虧替",
                "26": "言辭漏渫雖恃平原養士之懿",
                "27": "愧無毛遂燿穎之才",
                "28": "深蒙薛公折節之禮",
                "29": "而無馮諼三窟之效",
                "30": "屢獲信陵虛左之德",
                "31": "又無侯生可述之美",
                "32": "凡此數者",
                "33": "乃質之所以憤積於胸臆",
                "34": "懷眷而悁邑者也"
            }
        },
        "2": {
            "5": {
                "1": "若追前宴",
                "2": "謂之未究",
                "3": "傾海爲酒",
                "4": "幷山爲肴",
                "5": "伐竹雲夢",
                "6": "斬梓泗濱",
                "7": "然後極雅意",
                "8": "盡歡情",
                "9": "信公子之壯觀",
                "10": "非鄙人之所庶幾也",
                "11": "若質之志",
                "12": "實在所天",
                "13": "思投印釋黻",
                "14": "朝夕侍坐",
                "15": "鑽仲父之遺訓",
                "16": "覽老氏之要言",
                "17": "對清酤而不酌",
                "18": "抑嘉肴而不享",
                "19": "使西施出帷",
                "20": "嫫母侍側",
                "21": "斯盛德之所蹈",
                "22": "明哲之所保也",
                "23": "若乃近者之觀",
                "24": "實盪鄙心",
                "25": "秦箏發徽",
                "26": "二八迭奏",
                "27": "塤簫激於華屋",
                "28": "靈鼓動於座右",
                "29": "耳嘈嘈於無聞",
                "30": "情踊躍於鞍馬",
                "31": "謂可北懾肅愼",
                "32": "使貢其楛矢",
                "33": "南震百越",
                "34": "使獻其白雉",
                "35": "又況權備",
                "36": "夫何足視乎"
            }
        },
        "3": {
            "7": {
                "1": "還治諷采所著",
                "2": "觀省英瑋",
                "3": "實賦頌之宗",
                "4": "作者之師也",
                "5": "眾賢所述",
                "6": "亦各有志",
                "7": "昔趙武過鄭",
                "8": "七子賦詩",
                "9": "春秋載列",
                "10": "以爲美談",
                "11": "質小人也",
                "12": "無以承命",
                "13": "又所答貺",
                "14": "辭醜義陋",
                "15": "申之再三",
                "16": "赧然汗下",
                "17": "此邦之人",
                "18": "閑習辭賦",
                "19": "三事大夫",
                "20": "莫不諷誦",
                "21": "何但小吏之有乎"
            }
        },
        "4": {
            "9": {
                "1": "重惠苦言",
                "2": "訓以政事",
                "3": "惻隱之恩",
                "4": "形乎文墨",
                "5": "墨子迴車",
                "6": "而質四年",
                "7": "雖無德與民",
                "8": "式歌且舞",
                "9": "儒墨不同",
                "10": "固以久矣",
                "11": "然一旅之眾",
                "12": "不足以揚名",
                "13": "步武之間",
                "14": "不足以騁迹",
                "15": "若不改轍易御",
                "16": "將何以效其力哉",
                "17": "今處此而求大功",
                "18": "猶絆良驥之足",
                "19": "而責以千里之任",
                "20": "檻猿猴之勢",
                "21": "而望其巧捷之能者也",
                "22": "不勝見卹",
                "23": "謹附遣白答",
                "24": "不敢繁辭",
                "25": "吳質白"
            }
        }
    }
}