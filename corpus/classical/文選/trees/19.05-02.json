{
    "19.05-02": {
        "篇名": "束廣微 補亡詩六首白華。孝子之絜白也。",
        "1": {
            "3": {
                "1": "白華朱萼",
                "2": "被於幽薄",
                "3": "粲粲門子",
                "4": "如磨如錯",
                "5": "終晨三省",
                "6": "匪惰其恪",
                "7": "白華絳趺",
                "8": "在陵之陬",
                "9": "蒨蒨士子",
                "10": "涅而不渝",
                "11": "竭誠盡敬",
                "12": "亹亹忘劬",
                "13": "白華玄足",
                "14": "在丘之曲",
                "15": "堂堂處子",
                "16": "無營無欲",
                "17": "鮮侔晨葩",
                "18": "莫之點辱"
            }
        }
    }
}