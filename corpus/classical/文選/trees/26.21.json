{
    "26.21": {
        "篇名": "陶淵明 辛丑歲七月赴假還江陵夜行塗口",
        "1": {
            "3": {
                "1": "閑居三十載",
                "2": "遂與塵事冥",
                "3": "詩書敦宿好",
                "4": "林園無世情",
                "5": "如何舍此去",
                "6": "遙遙至西荊",
                "7": "叩栧新秋月",
                "8": "臨流別友生",
                "9": "涼風起將夕",
                "10": "夜景湛虛明",
                "11": "昭昭天宇闊",
                "12": "皛皛川上平",
                "13": "懷役不遑寐",
                "14": "中宵尙孤征",
                "15": "商歌非吾事",
                "16": "依依在耦耕",
                "17": "投冠旋舊墟",
                "18": "不爲好爵榮",
