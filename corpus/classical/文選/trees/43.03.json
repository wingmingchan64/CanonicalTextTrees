{
    "43.03": {
        "篇名": "趙景眞 與嵇茂齊書",
        "1": {
            "3": {
                "1": "安白",
                "2": "昔李叟入秦",
                "3": "及關而歎",
                "4": "梁生適越",
                "5": "登岳長謠",
                "6": "夫以嘉遯之舉",
                "7": "猶懷戀恨",
                "8": "況乎不得已者哉"
            }
        },
        "2": {
            "5": {
                "1": "惟別之後",
                "2": "離羣獨遊",
                "3": "背榮宴",
                "4": "辭倫好",
                "5": "經迥路",
                "6": "涉沙漠",
                "7": "鳴雞戒旦",
                "8": "則飄爾晨征",
                "9": "日薄西山",
                "10": "則馬首靡託",
                "11": "尋歷曲阻",
                "12": "則沈思紆結",
                "13": "乘高遠眺",
                "14": "則山川悠隔",
                "15": "或乃迴飆狂厲",
                "16": "白日寢光",
                "17": "踦肠交錯",
                "18": "陵隰相望",
                "19": "徘徊九皋之內",
                "20": "慷慨重阜之巓 ",
                "21": "進無所依",
                "22": "退無所據",
                "23": "涉澤求蹊",
                "24": "披榛覓路",
                "25": "嘯詠溝渠",
                "26": "良不可度",
                "27": "斯亦行路之艱難",
                "28": "然非吾心之所懼也"
            }
        },
        "3": {
            "7": {
                "1": "至若蘭茞傾頓",
                "2": "桂林移植",
                "3": "根萌未樹",
                "4": "牙淺絃急",
                "5": "常恐風波潛駭",
                "6": "危機密發",
                "7": "斯所以怵惕於長衢",
                "8": "按轡而歎息也",
                "9": "又北土之性",
                "10": "難以託根",
                "11": "投人夜光",
                "12": "鮮不按劍",
                "13": "今將植橘柚於玄朔",
                "14": "蔕華藕於修陵",
                "15": "表龍章於裸壤",
                "16": "奏韶舞於聾俗",
                "17": "固難以取貴矣",
                "18": "夫物不我貴",
                "19": "則莫之與",
                "20": "莫之與",
                "21": "則傷之者至矣",
                "22": "飄颻遠遊之士",
                "23": "託身無人之鄕",
                "24": "摠轡遐路",
                "25": "則有前言之艱",
                "26": "懸鞍陋宇",
                "27": "則有後慮之戒",
                "28": "朝霞啟暉",
                "29": "則身疲於遄征",
                "30": "太陽戢曜",
                "31": "則情劬於夕惕",
                "32": "肆目平隰",
                "33": "則遼廓而無睹",
                "34": "極聽修原",
                "35": "則淹寂而無聞",
                "36": "吁其悲矣",
                "37": "心傷悴矣",
                "38": "然後乃知步驟之士",
                "39": "不足爲貴也"
            }
        },
        "4": {
            "9": {
                "1": "若迺顧影中原",
                "2": "憤氣雲踊",
                "3": "哀物悼世",
                "4": "激情風烈",
                "5": "龍睇大野",
                "6": "虎嘯六合",
                "7": "猛氣紛紜",
                "8": "雄心四據",
                "9": "思躡雲梯",
                "10": "橫奮八極",
                "11": "披艱掃穢",
                "12": "蕩海夷岳",
                "13": "蹴崑崙使西倒",
                "14": "蹋太山令東覆",
                "15": "平滌九區",
                "16": "恢維宇宙",
                "17": "斯亦吾之鄙願也",
                "18": "時不我與",
                "19": "垂翼遠逝",
                "20": "鋒鉅靡加",
                "21": "翅翮摧屈",
                "22": "自非知命",
                "23": "誰能不憤悒者哉"
            }
        },
        "5": {
            "11": {
                "1": "吾子植根芳苑",
                "2": "擢秀清流",
                "3": "布葉華崖",
                "4": "飛藻雲肆",
                "5": "俯據潛龍之淵",
                "6": "仰蔭栖鳳之林",
                "7": "榮曜眩其前",
                "8": "豔色餌其後",
                "9": "良儔交其左",
                "10": "聲名馳其右",
                "11": "翱翔倫黨之間",
                "12": "弄姿帷房之裏",
                "13": "從容顧眄",
                "14": "綽有餘裕",
                "15": "俯仰吟嘯",
                "16": "自以爲得志矣",
                "17": "豈能與吾同大丈夫之憂樂者哉"
            }
        },
        "6": {
            "13": {
                "1": "去矣嵇生",
                "2": "永離隔矣",
                "3": "煢煢飄寄",
                "4": "臨沙漠矣",
                "5": "悠悠三千",
                "6": "路難涉矣",
                "7": "攜手之期",
                "8": "邈無日矣",
                "9": "思心彌結",
                "10": "誰云釋矣",
                "11": "無金玉爾音",
                "12": "而有遐心",
                "13": "身雖胡越",
                "14": "意存斷金",
                "15": "各敬爾儀",
                "16": "敦履璞沈",
                "17": "繁華流蕩",
                "18": "君子弗欽",
                "19": "臨書悢然",
                "20": "知復何云"
            }
        }
    }
}