{
    "29.06": {
        "篇名": "劉公幹 雜詩",
        "1": {
            "3": {
                "1": "職事相塡委",
                "2": "文墨紛消散",
                "3": "馳翰未暇食",
                "4": "日昃不知晏",
                "5": "沈迷簿領書",
                "6": "回回自昏亂",
                "7": "釋此出西城",
                "8": "登高且遊觀",
                "9": "方塘含白水",
                "10": "中有鳧與雁",
                "11": "安得肅肅羽",
                "12": "從爾浮波瀾"
            }
        }
    }
}