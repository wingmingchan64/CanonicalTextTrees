{
    "15.02": {
        "篇名": "張平子 歸田賦",
        "1": {
            "3": {
                "1": "遊都邑以永久",
                "2": "無明略以佐時",
                "3": "徒臨川以羨魚",
                "4": "俟河清乎未期",
                "5": "感蔡子之慷慨",
                "6": "從唐生以決疑",
                "7": "諒天道之微昧",
                "8": "追漁父以同嬉",
                "9": "超埃塵以遐逝",
                "10": "與世事乎長辭"
            }
        },
        "2": {
            "5": {
                "1": "於是仲春令月",
                "2": "時和氣清",
                "3": "原隰鬱茂",
                "4": "百草滋榮",
                "5": "王雎鼓翼",
                "6": "倉庚哀鳴",
                "7": "交頸頡頏",
                "8": "關關嚶嚶",
                "9": "於焉逍遙",
                "10": "聊以娛情",
                "11": "爾乃龍吟方澤",
                "12": "虎嘯山丘",
                "13": "仰飛纖繳",
                "14": "俯釣長流",
                "15": "觸矢而斃",
                "16": "貪餌吞鉤",
                "17": "落雲間之逸禽",
                "18": "懸淵沈之魦鰡"
            }
        },
        "3": {
            "7": {
                "1": "於時曜靈俄景",
                "2": "係以望舒",
                "3": "極般遊之至樂",
                "4": "雖日夕而忘劬",
                "5": "感老氏之遺誡",
                "6": "將迴駕乎蓬廬",
                "7": "彈五絃之妙指",
                "8": "詠周孔之圖書",
                "9": "揮翰墨以奮藻",
                "10": "陳三皇之軌模",
                "11": "苟縱心於物外",
                "12": "安知榮辱之所如"
            }
        }
    }
}