{
    "51.03": {
        "篇名": "王子淵 四子講德論[幷序]",
        "1": {
            "3": {
                "1": "襃旣爲益州刺史王襄作中和樂職宣布之詩",
                "2": "又作傳",
                "3": "名曰四子講德",
                "4": "以明其意焉"
            }
        },
        "2": {
            "5": {
                "1": "微斯文學問於虛儀夫子曰",
                "2": "蓋聞國有道",
                "3": "貧且賤焉",
                "4": "恥也",
                "5": "今夫子閉門距躍",
                "6": "專精趨學有日矣",
                "7": "幸遭聖主平世",
                "8": "而久懷寶",
                "9": "是伯牙去鍾期",
                "10": "而舜",
                "11": "禹遁帝堯也",
                "12": "於是欲顯名號",
                "13": "建功業",
                "14": "不亦難乎"
            }
        },
        "3": {
            "7": {
                "1": "夫子曰",
                "2": "然",
                "3": "有是言也",
                "4": "夫蚊虻終日經營",
                "5": "不能越階序",
                "6": "附驥尾則涉千里",
                "7": "攀鴻翮則翔四海",
                "8": "僕雖嚚頑",
                "9": "願從足下",
                "10": "雖然",
                "11": "何由而自達哉"
            }
        },
        "4": {
            "9": {
                "1": "文學曰",
                "2": "陳懇誠於本朝之上",
                "3": "行話談於公卿之門"
            }
        },
        "5": {
            "11": {
                "1": "夫子曰",
                "2": "無介紹之道",
                "3": "安從行乎公卿"
            }
        },
        "6": {
            "13": {
                "1": "文學曰",
                "2": "何爲其然也",
                "3": "昔寗戚商歌以干齊桓",
                "4": "越石負芻而寤晏嬰",
                "5": "非有積素累舊之歡",
                "6": "皆塗覯卒遇",
                "7": "而以爲親者也",
                "8": "故毛嬙西施",
                "9": "善毀者不能蔽其好",
                "10": "嫫姆倭傀",
                "11": "善譽者不能掩其醜",
                "12": "孫卿子曰",
                "13": "閭𡣞子奢",
                "14": "莫之媒也",
                "15": "嫫姆力父",
                "16": "是之喜也",
                "17": "倭傀",
                "18": "醜女",
                "19": "未詳所見",
                "20": "倭",
                "21": "於爲切",
                "22": "傀",
                "23": "古回切",
                "24": "苟有至道",
                "25": "何必介紹"
            }
        },
        "7": {
            "15": {
                "1": "夫子曰",
                "2": "咨",
                "3": "夫特達而相知者",
                "4": "千載之一遇也",
                "5": "招賢而處友者",
                "6": "眾士之常路也",
                "7": "是以空柯無刃",
                "8": "公輸不能以斲",
                "9": "但懸曼矰",
                "10": "蒲苴不能以射",
                "11": "故膺騰撇波而濟水",
                "12": "不如乘舟之逸也",
                "13": "衝蒙涉田而能致遠",
                "14": "未若遵塗之疾也",
                "15": "才蔽於無人",
                "16": "行衰於寡黨",
                "17": "此古今之患",
                "18": "唯文學慮之"
            }
        },
        "8": {
            "17": {
                "1": "文學曰",
                "2": "唯唯",
                "3": "敬聞命矣"
            }
        },
        "9": {
            "19": {
                "1": "於是相與結侶",
                "2": "攜手俱遊",
                "3": "求賢索友",
                "4": "歷於西州",
                "5": "有二人焉",
                "6": "乘輅而歌",
                "7": "倚輗而聽之",
                "8": "詠歎中雅",
                "9": "轉運中律",
                "10": "嘽緩舒繹",
                "11": "曲折不失節",
                "12": "問歌者爲誰",
                "13": "則所謂浮遊先生陳丘子者也",
                "14": "於是以士相見之禮友焉"
            }
        },
        "10": {
            "21": {
                "1": "禮文旣集",
                "2": "文學",
                "3": "夫子降席而稱曰",
                "4": "俚人不識",
                "5": "寡見尠聞",
                "6": "曩從末路",
                "7": "望聽玉音",
                "8": "竊動心焉",
                "9": "敢問所歌何詩",
                "10": "請聞其說",
                "11": "浮遊先生陳丘子曰",
                "12": "所謂中和樂職宣布之詩",
                "13": "益州刺史之所作也",
                "14": "刺史見太上聖明",
                "15": "股肱竭力",
                "16": "德澤洪茂",
                "17": "黎庶和睦",
                "18": "天人並應",
                "19": "屢降瑞福",
                "20": "故作三篇之詩以歌詠之也"
            }
        },
        "11": {
            "23": {
                "1": "文學曰",
                "2": "君子動作有應",
                "3": "從容得度",
                "4": "南容三復白珪",
                "5": "孔子睹其愼戒",
                "6": "太子擊誦晨風",
                "7": "文侯諭其指意",
                "8": "今吾子何樂此詩而詠之也"
            }
        },
        "12": {
            "25": {
                "1": "先生曰",
                "2": "夫樂者感人密深",
                "3": "而風移俗易",
                "4": "吾所以詠歌之者",
                "5": "美其君術明而臣道得也",
                "6": "君者中心",
                "7": "臣者外體",
                "8": "外體作",
                "9": "然後知心之好惡",
                "10": "臣下動",
                "11": "然後知君之節趨",
                "12": "好惡不形",
                "13": "則是非不分",
                "14": "節趨不立",
                "15": "則功名不宣",
                "16": "故美玉蘊於碔砆",
                "17": "凡人視之怢焉",
                "18": "良工砥之",
                "19": "然後知其和寶也",
                "20": "精練藏於鑛朴",
                "21": "庸人視之忽焉",
                "22": "巧冶鑄之",
                "23": "然後知其幹也",
                "24": "況乎聖德巍巍蕩蕩",
                "25": "民氓所不能命哉",
                "26": "是以刺史推而詠之",
                "27": "揚君德美",
                "28": "深乎洋洋",
                "29": "罔不覆載",
                "30": "紛紜天地",
                "31": "寂寥宇宙",
                "32": "明君之惠顯",
                "33": "忠臣之節究",
                "34": "皇唐之世",
                "35": "何以加茲",
                "36": "是以每歌之",
                "37": "不知老之將至也"
            }
        },
        "13": {
            "27": {
                "1": "文學曰",
                "2": "書云",
                "3": "迪一人使四方若卜筮",
                "4": "夫忠賢之臣",
                "5": "導主志",
                "6": "承君惠",
                "7": "攄盛德而化洪",
                "8": "天下安瀾",
                "9": "比屋可封",
                "10": "何必歌詠詩賦可以揚君哉",
                "11": "愚竊惑焉"
            }
        },
        "14": {
            "29": {
                "1": "浮遊先生色勃眥溢",
                "2": "曰",
                "3": "是何言與",
                "4": "昔周公詠文王之德而作清廟",
                "5": "建爲頌首",
                "6": "吉甫歎宣王穆如清風",
                "7": "列於大雅",
                "8": "夫世衰道微",
                "9": "僞臣虛稱者",
                "10": "殆也",
                "11": "世平道明",
                "12": "臣子不宣者",
                "13": "鄙也",
                "14": "鄙殆之累",
                "15": "傷乎王道",
                "16": "故自刺史之來也",
                "17": "宣布詔書",
                "18": "勞來不怠",
                "19": "令百姓遍曉聖德",
                "20": "莫不霑濡",
                "21": "厖眉耆耇之老",
                "22": "咸愛惜朝夕",
                "23": "願濟須臾",
                "24": "且觀大化之淳流",
                "25": "於是皇澤豐沛",
                "26": "主恩滿溢",
                "27": "百姓歡欣",
                "28": "中和感發",
                "29": "是以作歌而詠之也",
                "30": "傳曰",
                "31": "詩人感而後思",
                "32": "思而後積",
                "33": "積而後滿",
                "34": "滿而後作",
                "35": "言之不足",
                "36": "故嗟歎之",
                "37": "嗟歎之不足",
                "38": "故詠歌之",
                "39": "詠歌之不厭",
                "40": "不知手之舞之足之蹈之也",
                "41": "此臣子於君父之常義",
                "42": "古今一也",
                "43": "今子執分寸而罔億度",
                "44": "處把握而卻寥廓",
                "45": "乃欲圖大人之樞機",
                "46": "道方伯之失得",
                "47": "不亦遠乎"
            }
        },
        "15": {
            "31": {
                "1": "陳丘子見先生言切",
                "2": "恐二客慚",
                "3": "膝步而前曰",
                "4": "先生詳之",
                "5": "行潦暴集",
                "6": "江海不以爲多",
                "7": "鰌鱓並逃",
                "8": "九罭不以爲虛",
                "9": "是以許由匿堯而深隱",
                "10": "唐氏不以衰",
                "11": "夷齊恥周而遠餓",
                "12": "文武不以卑",
                "13": "夫青蠅不能穢垂棘",
                "14": "邪論不能惑孔墨",
                "15": "今刺史質敏以流惠",
                "16": "舒化以揚名",
                "17": "采詩以顯至德",
                "18": "歌詠以董其文",
                "19": "受命如絲",
                "20": "明之如緍",
                "21": "甘棠之風",
                "22": "可倚而俟也",
                "23": "二客雖窒計沮議",
                "24": "何傷",
                "25": "顧謂文學夫子曰",
                "26": "先生微矜於談道",
                "27": "又不讓乎當仁",
                "28": "亦未巨過也",
                "29": "願二子措意焉"
            }
        },
        "16": {
            "33": {
                "1": "夫子曰",
                "2": "否",
                "3": "夫雷霆必發",
                "4": "而潛底震動",
                "5": "枹鼓鏗鏘",
                "6": "而介士奮竦",
                "7": "故物不震不發",
                "8": "士不激不勇",
                "9": "今文學之言",
                "10": "欲以議愚感敵",
                "11": "舒先生之憤",
                "12": "願二生亦勿疑",
                "13": "於是文繹復集",
                "14": "及始講德"
            }
        },
        "17": {
            "35": {
                "1": "文學夫子曰",
                "2": "昔成康之世",
                "3": "君之德與",
                "4": "臣之力也"
            }
        },
        "18": {
            "37": {
                "1": "先生曰",
                "2": "非有聖智之君",
                "3": "惡有甘棠之臣",
                "4": "故虎嘯而風寥戾",
                "5": "龍起而致雲氣",
                "6": "蟋蟀俟秋吟",
                "7": "蜉蝣出以陰",
                "8": "易曰",
                "9": "飛龍在天",
                "10": "利見大人",
                "11": "鳴聲相應",
                "12": "仇偶相從",
                "13": "人由意合",
                "14": "物以類同",
                "15": "是以聖主不遍窺望而視以明",
                "16": "不殫傾耳而聽以聰",
                "17": "何則",
                "18": "淑人君子",
                "19": "人就者眾也",
                "20": "故千金之裘",
                "21": "非一狐之腋",
                "22": "大廈之材",
                "23": "非一丘之木",
                "24": "太平之功",
                "25": "非一人之略也"
            }
        },
        "19": {
            "39": {
                "1": "蓋君爲元首",
                "2": "臣爲股肱",
                "3": "明其一體",
                "4": "相待而成",
                "5": "有君而無臣",
                "6": "春秋刺焉",
                "7": "三代以上",
                "8": "皆有師傅",
                "9": "五伯以下",
                "10": "各自取友",
                "11": "齊桓有管鮑隰寗",
                "12": "九合諸侯",
                "13": "一匡天下",
                "14": "晉文公有咎犯趙衰",
                "15": "取威定霸",
                "16": "以尊天子",
                "17": "秦穆有王由五羖",
                "18": "攘卻西戎",
                "19": "始開帝緒",
                "20": "楚莊有叔孫子反",
                "21": "兼定江淮",
                "22": "威震諸夏",
                "23": "句踐有種蠡渫庸",
                "24": "剋滅彊吳",
                "25": "雪會稽之恥",
                "26": "魏文有段干田翟",
                "27": "秦人寢兵",
                "28": "折衝萬里",
                "29": "燕昭有郭隗樂毅",
                "30": "夷破彊齊",
                "31": "困閔於莒",
                "32": "夫以諸侯之細",
                "33": "功名猶尙若此",
                "34": "而況帝王選於四海",
                "35": "羽翼百姓哉"
            }
        },
        "20": {
            "41": {
                "1": "故有賢聖之君",
                "2": "必有明智之臣",
                "3": "欲以積德",
                "4": "則天下不足平也",
                "5": "欲以立威",
                "6": "則百蠻不足攘也",
                "7": "今聖主冠道德",
                "8": "履純仁",
                "9": "被六藝",
                "10": "佩禮文",
                "11": "屢下明詔",
                "12": "舉賢良",
                "13": "求術士",
                "14": "招異倫",
                "15": "拔俊茂",
                "16": "是以海內歡慕",
                "17": "莫不風馳雨集",
                "18": "襲雜並至",
                "19": "塡庭溢闕",
                "20": "含淳詠德之聲盈耳",
                "21": "登降揖讓之禮極目",
                "22": "進者樂其條暢",
                "23": "怠者欲罷不能",
                "24": "偃息匍匐乎詩書之門",
                "25": "遊觀乎道德之域",
                "26": "咸絜身修思",
                "27": "吐情素而披心腹",
                "28": "各悉精銳以貢忠誠",
                "29": "允願推主上",
                "30": "弘風俗而騁太平",
                "31": "濟濟乎多士",
                "32": "文王所以寧也"
            }
        },
        "21": {
            "43": {
                "1": "若乃美政所施",
                "2": "洪恩所潤",
                "3": "不可究陳",
                "4": "舉孝以篤行",
                "5": "崇能以招賢",
                "6": "去煩蠲苛以綏百姓",
                "7": "祿勤增奉以厲貞廉",
                "8": "減膳食",
                "9": "卑宮觀",
                "10": "省田官",
                "11": "損諸苑",
                "12": "疏繇役",
                "13": "振乏困",
                "14": "卹民災害",
                "15": "不遑遊宴",
                "16": "閔耄老之逢辜",
                "17": "憐縗絰之服事",
                "18": "側隱身死之腐人",
                "19": "悽愴子弟之縲匿",
                "20": "恩及飛鳥",
                "21": "惠加走獸",
                "22": "胎卵得以成育",
                "23": "草木遂其零茂",
                "24": "愷悌君子",
                "25": "民之父母",
                "26": "豈不然哉"
            }
        },
        "22": {
            "45": {
                "1": "先生獨不聞秦之時耶",
                "2": "違三王",
                "3": "背五帝",
                "4": "滅詩書",
                "5": "壞禮義",
                "6": "信任羣小",
                "7": "憎惡仁智",
                "8": "詐僞者進達",
                "9": "佞諂者容入",
                "10": "宰相刻峭",
                "11": "大理峻法",
                "12": "處位而任政者",
                "13": "皆短於仁義",
                "14": "長於酷虐",
                "15": "狼摯虎攫",
                "16": "懷殘秉賊",
                "17": "其所臨蒞",
                "18": "莫不肌栗慴伏",
                "19": "吹毛求疵",
                "20": "並施螫毒",
                "21": "百姓征彸",
                "22": "無所措其手足",
                "23": "嗷嗷愁怨",
                "24": "遂亡秦族",
                "25": "是以養雞者不畜貍",
                "26": "牧獸者不育豺",
                "27": "樹木者憂其蠹",
                "28": "保民者除其賊",
                "29": "故大漢之爲政也",
                "30": "崇簡易",
                "31": "尙寬柔",
                "32": "進淳仁",
                "33": "舉賢才",
                "34": "上下無怨",
                "35": "民用和睦"
            }
        },
        "23": {
            "47": {
                "1": "今海內樂業",
                "2": "朝廷淑清",
                "3": "天符旣章",
                "4": "人瑞又明",
                "5": "品物咸亨",
                "6": "山川降靈",
                "7": "神光燿暉",
                "8": "洪洞朗天",
                "9": "鳳皇來儀",
                "10": "翼翼邕邕",
                "11": "羣鳥並從",
                "12": "舞德垂容",
                "13": "神雀仍集",
                "14": "麒麟自至",
                "15": "甘靈滋液",
                "16": "嘉禾櫛比",
                "17": "大化隆洽",
                "18": "男女條暢",
                "19": "家給年豐",
                "20": "咸則三壤",
                "21": "豈不盛哉",
                "22": "昔文王應九尾狐而東夷歸周",
                "23": "武王獲白魚而諸侯同辭",
                "24": "周公受秬鬯而鬼方臣",
                "25": "宣王得白狼而夷狄賓",
                "26": "夫名自正而事自定也",
                "27": "今南郡獲白虎",
                "28": "亦偃武興文之應也",
                "29": "獲之者張武",
                "30": "武張而猛服也",
                "31": "是以北狄賓洽",
                "32": "邊不卹寇",
                "33": "甲士寢而旌旗仆也"
            }
        },
        "24": {
            "49": {
                "1": "文學夫子曰",
                "2": "天符旣聞命矣",
                "3": "敢問人瑞"
            }
        },
        "25": {
            "51": {
                "1": "先生曰",
                "2": "夫匈奴者",
                "3": "百蠻之最彊者也",
                "4": "天性憍蹇",
                "5": "習俗傑暴",
                "6": "賤老貴壯",
                "7": "氣力相高",
                "8": "業在攻伐",
                "9": "事在獵射",
                "10": "兒能騎羊",
                "11": "走箭飛鏃",
                "12": "逐水隨畜",
                "13": "都無常處",
                "14": "鳥集獸散",
                "15": "往來馳騖",
                "16": "周流曠野",
                "17": "以濟嗜欲",
                "18": "其耒耜則弓矢鞍馬",
                "19": "播種則扞弦掌拊",
                "20": "收秋則奔狐馳兔",
                "21": "穫刈則顚倒殪仆",
                "22": "追之則奔遁",
                "23": "釋之則爲寇",
                "24": "是以三王不能懷",
                "25": "五伯不能綏",
                "26": "驚邊扤士",
                "27": "屢犯芻蕘",
                "28": "詩人所歌",
                "29": "自古患之",
                "30": "今聖德隆盛",
                "31": "威靈外覆",
                "32": "日逐舉國而歸德",
                "33": "單於稱臣而朝賀",
                "34": "乾坤之所開",
                "35": "陰陽之所接",
                "36": "編結沮顏",
                "37": "燋齒梟瞯",
                "38": "剪髮黥首",
                "39": "文身裸袒之國",
                "40": "靡不奔走貢獻",
                "41": "歡忻來附",
                "42": "婆娑嘔吟",
                "43": "鼓掖而笑",
                "44": "夫鴻均之世",
                "45": "何物不樂",
                "46": "飛鳥翕翼",
                "47": "泉魚奮躍",
                "48": "是以刺史感懣舒音",
                "49": "而詠至德",
                "50": "鄙人黭淺",
                "51": "不能究識",
                "52": "敬遵所聞",
                "53": "未剋殫焉"
            }
        },
        "26": {
            "53": {
                "1": "於是二客醉於仁義",
                "2": "飽於盛德",
                "3": "終日仰歎",
                "4": "怡懌而悅服"
            }
        }
    }
