{
    "01.01": {
        "篇名": "班孟堅 兩都賦序*",
        "1": {
            "3": {
                "1": "或曰",
                "2": "賦者",
                "3": "古詩之流也",
                "4": "昔成康沒而頌聲寢",
                "5": "王澤竭而詩不作",
                "6": "大漢初定",
                "7": "日不暇給",
                "8": "至於武宣之世",
                "9": "乃崇禮官",
                "10": "考文章",
                "11": "內設金馬石渠之署",
                "12": "外興樂府協律之事",
                "13": "以興廢繼絕",
                "14": "潤色鴻業",
                "15": "是以眾庶悅豫",
                "16": "福應尤盛",
                "17": "白麟赤雁芝房寶鼎之歌",
                "18": "薦於郊廟",
                "19": "神雀五鳳甘露黃龍之瑞",
                "20": "以爲年紀",
                "21": "故言語侍從之臣",
                "22": "若司馬相如虞丘壽王東方朔枚皋王襃劉向之屬",
                "23": "朝夕論思",
                "24": "日月獻納",
                "25": "而公卿大臣",
                "26": "御史大夫倪寬",
                "27": "太常孔臧",
                "28": "太中大夫董仲舒",
                "29": "宗正劉德",
                "30": "太子太傅蕭望之等",
                "31": "時時間作",
                "32": "或以抒下情而通諷諭",
                "33": "或以宣上德而盡忠孝",
                "34": "雍容揄揚",
                "35": "著於後嗣",
                "36": "抑亦雅頌之亞也",
                "37": "故孝成之世",
                "38": "論而錄之",
                "39": "蓋奏御者千有餘篇",
                "40": "而後大漢之文章",
                "41": "炳焉與三代同風"
            }
        },
        "2": {
            "5": {
                "1": "且夫道有夷隆",
                "2": "學有粗密",
                "3": "因時而建德者",
                "4": "不以遠近易則",
                "5": "故皋陶歌虞",
                "6": "奚斯頌魯",
                "7": "同見采於孔氏",
                "8": "列於詩書",
                "9": "其義一也",
                "10": "稽之上古則如彼",
                "11": "考之漢室又如此",
                "12": "斯事雖細",
                "13": "然先臣之舊式",
                "14": "國家之遺美",
                "15": "不可闕也",
                "16": "臣竊見海內清平",
                "17": "朝廷無事",
                "18": "京師修宮室",
                "19": "浚城隍",
                "20": "起苑囿",
                "21": "以備制度",
                "22": "西土耆老",
                "23": "咸懷怨思",
                "24": "冀上之睠顧",
                "25": "而盛稱長安舊制",
                "26": "有陋雒邑之議",
                "27": "故臣作兩都賦",
                "28": "以極眾人之所眩曜",
                "29": "折以今之法度",
                "30": "其詞曰"
            }
        }
    }
}