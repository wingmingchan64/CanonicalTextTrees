{
    "42.03": {
        "篇名": "魏文帝 與吳質書",
        "1": {
            "3": {
                "1": "二月三日",
                "2": "丕白",
                "3": "歲月易得",
                "4": "別來行復四年",
                "5": "三年不見",
                "6": "東山猶歎其遠",
                "7": "況乃過之",
                "8": "思何可支",
                "9": "雖書疏往返",
                "10": "未足解其勞結"
            }
        },
        "2": {
            "5": {
                "1": "昔年疾疫",
                "2": "親故多離其災",
                "3": "徐陳應劉",
                "4": "一時俱逝",
                "5": "痛可言邪",
                "6": "昔日遊處",
                "7": "行則連輿",
                "8": "止則接席",
                "9": "何曾須臾相失",
                "10": "每至觴酌流行",
                "11": "絲竹並奏",
                "12": "酒酣耳熱",
                "13": "仰而賦詩",
                "14": "當此之時",
                "15": "忽然不自知樂也",
                "16": "謂百年己分",
                "17": "可長共相保",
                "18": "何圖數年之間",
                "19": "零落略盡",
                "20": "言之傷心",
                "21": "頃撰其遺文",
                "22": "都爲一集",
                "23": "觀其姓名",
                "24": "已爲鬼錄",
                "25": "追思昔遊",
                "26": "猶在心目",
                "27": "而此諸子",
                "28": "化爲糞壤",
                "29": "可復道哉"
            }
        },
        "3": {
            "7": {
                "1": "觀古今文人",
                "2": "類不護細行",
                "3": "鮮能以名節自立",
                "4": "而偉長獨懷文抱質",
                "5": "恬惔寡欲",
                "6": "有箕山之志",
                "7": "可謂彬彬君子者矣",
                "8": "著中論二十餘篇",
                "9": "成一家之言",
                "10": "辭義典雅",
                "11": "足傳於後",
                "12": "此子爲不朽矣",
                "13": "德璉常斐然有述作之意",
                "14": "其才學足以著書",
                "15": "美志不遂",
                "16": "良可痛惜",
                "17": "間者歷覽諸子之文",
                "18": "對之抆淚",
                "19": "旣痛逝者",
                "20": "行自念也",
                "21": "孔璋章表殊健",
                "22": "微爲繁富",
                "23": "公幹有逸氣",
                "24": "但未遒耳",
                "25": "其五言詩之善者",
                "26": "妙絕時人",
                "27": "元瑜書記翩翩",
                "28": "致足樂也",
                "29": "仲宣續自善於辭賦",
                "30": "惜其體弱",
                "31": "不足起其文",
                "32": "至於所善",
                "33": "古人無以遠過",
                "34": "昔伯牙絕絃於鍾期",
                "35": "仲尼覆醢於子路",
                "36": "痛知音之難遇",
                "37": "傷門人之莫逮",
                "38": "諸子但爲未及古人",
                "39": "自一時之雋也",
                "40": "今之存者",
                "41": "已不逮矣",
                "42": "後生可畏",
                "43": "來者難誣",
                "44": "然恐吾與足下不及見也"
            }
        },
        "4": {
            "9": {
                "1": "年行已長大",
                "2": "所懷萬端",
                "3": "時有所慮",
                "4": "至通夜不瞑",
                "5": "志意何時復類昔日",
                "6": "已成老翁",
                "7": "但未白頭耳",
                "8": "光武言年三十餘",
                "9": "在兵中十歲",
                "10": "所更非一",
                "11": "吾德不及之",
                "12": "年與之齊矣",
                "13": "以犬羊之質",
                "14": "服虎豹之文",
                "15": "無眾星之明",
                "16": "假日月之光",
                "17": "動見瞻觀",
                "18": "何時易乎",
                "19": "恐永不復得爲昔日遊也",
                "20": "少壯眞當努力",
                "21": "年一過往",
                "22": "何可攀援",
                "23": "古人思炳燭夜遊",
                "24": "良有以也",
                "25": "頃何以自娛",
                "26": "頗復有所述造不",
                "27": "東望於邑",
                "28": "裁書敍心",
                "29": "丕白"
            }
        }
    }
}