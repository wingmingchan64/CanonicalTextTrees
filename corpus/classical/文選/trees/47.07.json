{
    "47.07": {
        "篇名": "袁彥伯 三國名臣序贊",
        "1": {
            "3": {
                "1": "夫百姓不能自治",
                "2": "故立君以治之",
                "3": "明君不能獨治",
                "4": "則爲臣以佐之",
                "5": "然則三五迭隆",
                "6": "歷世承基",
                "7": "揖讓之與干戈",
                "8": "文德之與武功",
                "9": "莫不宗匠陶鈞而羣才緝熙",
                "10": "元首經略而股肱肆力",
                "11": "遭離不同",
                "12": "迹有優劣",
                "13": "至於體分冥固",
                "14": "道契不墜",
                "15": "風美所扇",
                "16": "訓革千載",
                "17": "其揆一也",
                "18": "故二八升而唐朝盛",
                "19": "伊呂用而湯武寧",
                "20": "三賢進而小白興",
                "21": "五臣顯而重耳霸",
                "22": "中古凌犀",
                "23": "斯道替矣",
                "24": "居上者不以至公理物",
                "25": "爲下者必以私路期榮",
                "26": "御圓者不以信誠率眾",
                "27": "執方者必以權謀自顯",
                "28": "於是君臣離而名教薄",
                "29": "世多亂而時不治",
                "30": "故蘧寗以之卷舒",
                "31": "柳下以之三黜",
                "32": "接輿以之行歌",
                "33": "魯連以之赴海",
                "34": "衰世之中",
                "35": "保持名節",
                "36": "君臣相體",
                "37": "若合符契",
                "38": "則燕昭樂毅",
                "39": "古之流也",
                "40": "夫未遇伯樂",
                "41": "則千載無一驥",
                "42": "時値龍顏",
                "43": "則當年控三傑",
                "44": "漢之得材",
                "45": "於斯爲貴",
                "46": "高祖雖不以道勝御物",
                "47": "羣下得盡其忠",
                "48": "蕭曹雖不以三代事主",
                "49": "百姓不失其業",
                "50": "靜亂庇人",
                "51": "抑亦其次"
            }
        },
        "2": {
            "5": {
                "1": "夫時方顚沛",
                "2": "則顯不如隱",
                "3": "萬物思治",
                "4": "則默不如語",
                "5": "是以古之居子",
                "6": "不患弘道難",
                "7": "遭時難",
                "8": "遭時匪難",
                "9": "遇君難",
                "10": "故有道無時",
                "11": "孟子所以咨嗟",
                "12": "有時無君",
                "13": "賈生所以垂泣",
                "14": "夫萬歲一期",
                "15": "有生之通塗",
                "16": "千載一遇",
                "17": "賢智之嘉會",
                "18": "遇之不能無欣",
                "19": "喪之何能無慨",
                "20": "古人之言",
                "21": "信有情哉",
                "22": "余以暇日",
                "23": "常覽國志",
                "24": "考其君臣",
                "25": "比其行事",
                "26": "雖道謝先代",
                "27": "亦異世一時也"
            }
        },
        "3": {
            "7": {
                "1": "文若懷獨見之明",
                "2": "而有救世之心",
                "3": "論時則民方塗炭",
                "4": "計能則莫出魏武",
                "5": "故委面霸朝",
                "6": "豫議世事",
                "7": "舉才不以標鑒",
                "8": "故久之而後顯",
                "9": "籌畫不以要功",
                "10": "故事至而後定",
                "11": "雖亡身明順",
                "12": "識亦高矣"
            }
        },
        "4": {
            "9": {
                "1": "董卓之亂",
                "2": "神器遷逼",
                "3": "公達慨然",
                "4": "志在致命",
                "5": "由斯而談",
                "6": "故以大存名節",
                "7": "至如身爲漢隸",
                "8": "而迹入魏幕",
                "9": "源流趣舍",
                "10": "其亦文若之謂",
                "11": "所以存亡殊致",
                "12": "始終不同",
                "13": "將以文若旣明",
                "14": "名教有寄乎",
                "15": "夫仁義不可不明",
                "16": "則時宗舉其致",
                "17": "生理不可不全",
                "18": "故達識攝其契",
                "19": "相與弘道",
                "20": "豈不遠哉"
            }
        },
        "5": {
            "11": {
                "1": "崔生高朗",
                "2": "折而不撓",
                "3": "所以策名魏武",
                "4": "執笏霸朝者",
                "5": "蓋以漢主當陽",
                "6": "魏后北面者哉",
                "7": "若乃一旦進璽",
                "8": "君臣易位",
                "9": "則崔子所不與",
                "10": "魏武所不容",
                "11": "夫江湖所以濟舟",
                "12": "亦所以覆舟",
                "13": "仁義所以全身",
                "14": "亦所以亡身",
                "15": "然而先賢玉摧於前",
                "16": "來哲攘袂於後",
                "17": "豈非天懷發中",
                "18": "而名教束物者乎"
            }
        },
        "6": {
            "13": {
                "1": "孔明盤桓",
                "2": "俟時而動",
                "3": "遐想管樂",
                "4": "遠明風流",
                "5": "治國以體",
                "6": "民無怨聲",
                "7": "刑罰不濫",
                "8": "沒有餘泣",
                "9": "雖古之遺愛",
                "10": "何以加茲",
                "11": "及其臨終顧託",
                "12": "受遺作相",
                "13": "劉后授之無疑心",
                "14": "武侯處之無懼色",
                "15": "繼體納之無貳情",
                "16": "百姓信之無異辭",
                "17": "君臣之際",
                "18": "良可詠矣",
                "19": "公瑾卓爾",
                "20": "逸志不羣",
                "21": "總角料主",
                "22": "則素契於伯符",
                "23": "晚節曜奇",
                "24": "則參分於赤壁",
                "25": "惜其齡促",
                "26": "志未可量"
            }
        },
        "7": {
            "15": {
                "1": "子布佐策",
                "2": "致延譽之美",
                "3": "輟哭止哀",
                "4": "有翼戴之功",
                "5": "神情所涉",
                "6": "豈徒蹇愕而已哉",
                "7": "然而杜門不用",
                "8": "登壇受譏",
                "9": "夫一人之身",
                "10": "所照未異",
                "11": "而用舍之間",
                "12": "俄有不同",
                "13": "況沈迹溝壑",
                "14": "遇與不遇者乎"
            }
        },
        "8": {
            "17": {
                "1": "夫詩頌之作",
                "2": "有自來矣",
                "3": "或以吟詠情性",
                "4": "或以述德顯功",
                "5": "雖大旨同歸",
                "6": "所託或乖",
                "7": "若夫出處有道",
                "8": "名體不滯",
                "9": "風軌德音",
                "10": "爲世作範",
                "11": "不可廢也",
                "12": "故復撰序所懷",
                "13": "以爲之讚云"
            }
        },
