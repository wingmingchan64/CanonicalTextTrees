{
    "42.05": {
        "篇名": "曹子建 與楊德祖書",
        "1": {
            "3": {
                "1": "植白",
                "2": "數日不見",
                "3": "思子爲勞",
                "4": "想同之也",
                "5": "僕少小好爲文章",
                "6": "迄至於今",
                "7": "二十有五年矣",
                "8": "然今世作者",
                "9": "可略而言也",
                "10": "昔仲宣獨步於漢南",
                "11": "孔璋鷹揚於河朔",
                "12": "偉長擅名於青土",
                "13": "公幹振藻於海隅",
                "14": "德璉發迹於此魏",
                "15": "足下高視於上京",
                "16": "當此之時",
                "17": "人人自謂握靈蛇之珠",
                "18": "家家自謂抱荊山之玉",
                "19": "吾王於是設天網以該之",
                "20": "頓八紘以掩之",
                "21": "今悉集茲國矣",
                "22": "然此數子",
                "23": "猶復不能飛軒絕迹",
                "24": "一舉千里",
                "25": "以孔璋之才",
                "26": "不閑於辭賦",
                "27": "而多自謂能與司馬長卿同風",
                "28": "譬畫虎不成",
                "29": "反爲狗也",
                "30": "前書嘲之",
                "31": "反作論盛道僕讚其文",
                "32": "夫鍾期不失聽",
                "33": "於今稱之",
                "34": "吾亦不能忘歎者",
                "35": "畏後世之嗤余也"
            }
        },
        "2": {
            "5": {
                "1": "世人之著述",
                "2": "不能無病",
                "3": "僕常好人譏彈其文",
                "4": "有不善者",
                "5": "應時改定",
                "6": "昔丁敬禮常作小文",
                "7": "使僕潤飾之",
                "8": "僕自以才不過若人",
                "9": "辭不爲也",
                "10": "敬禮謂僕",
                "11": "卿何所疑難",
                "12": "文之佳惡",
                "13": "吾自得之",
                "14": "後世誰相知定吾文者邪",
                "15": "吾常歎此達言",
                "16": "以爲美談",
                "17": "昔尼父之文辭",
                "18": "與人通流",
                "19": "至於制春秋",
                "20": "遊夏之徒乃不能措一辭",
                "21": "過此而言不病者",
                "22": "吾未之見也",
                "23": "蓋有南威之容",
                "24": "乃可以論其淑媛有龍泉之利",
                "25": "乃可以議其斷割",
                "26": "劉季緒才不能逮於作者",
                "27": "而好詆訶文章",
                "28": "掎摭利病",
                "29": "昔田巴毀五帝",
                "30": "罪三王",
                "31": "呰五霸於稷下",
                "32": "一旦而服千人",
                "33": "魯連一說",
                "34": "使終身杜口",
                "35": "劉生之辯",
                "36": "未若田氏",
                "37": "今之仲連",
                "38": "求之不難",
                "39": "可無息乎",
                "40": "人各有好尙",
                "41": "蘭茞蓀蕙之芳",
                "42": "眾人所好",
                "43": "而海畔有逐臭之夫",
                "44": "咸池六莖之發",
                "45": "眾人所共樂",
                "46": "而墨翟有非之之論",
                "47": "豈可同哉"
            }
        },
        "3": {
            "7": {
                "1": "今往僕少小所著辭賦一通相與",
                "2": "夫街談巷說",
                "3": "必有可采",
                "4": "擊轅之歌",
                "5": "有應風雅",
                "6": "匹夫之思",
                "7": "未易輕棄也",
                "8": "辭賦小道",
                "9": "固未足以揄揚大義",
                "10": "彰示來世也",
                "11": "昔楊子雲先朝執戟之臣耳",
                "12": "猶稱壯夫不爲也",
                "13": "吾雖德薄",
                "14": "位爲蕃侯",
                "15": "猶庶幾勠力上國",
                "16": "流惠下民",
                "17": "建永世之業",
                "18": "留金石之功",
                "19": "豈徒以翰墨爲勳績",
                "20": "辭賦爲君子哉",
                "21": "若吾志未果",
                "22": "吾道不行",
                "23": "則將采庶官之實錄",
                "24": "辯時俗之得失",
                "25": "定仁義之衷",
                "26": "成一家之言",
                "27": "雖未能藏之於名山",
                "28": "將以傳之於同好",
                "29": "非要之皓首",
                "30": "豈今日之論乎",
                "31": "其言之不慚",
                "32": "恃惠子之知我也",
                "33": "明早相迎",
                "34": "書不盡懷",
                "35": "植白"
            }
        }
    }
}