{
    "44.05": {
        "篇名": "司馬長卿 難蜀父老",
        "1": {
            "3": {
                "1": "漢興七十有八載",
                "2": "德茂存乎六世",
                "3": "威武紛紜",
                "4": "湛恩汪濊",
                "5": "羣生霑濡",
                "6": "洋溢乎方外",
                "7": "於是乃命使西征",
                "8": "隨流而攘",
                "9": "風之所被",
                "10": "罔不披靡",
                "11": "因朝冉從駹",
                "12": "定笮存邛",
                "13": "略斯楡",
                "14": "舉苞蒲",
                "15": "結軌還轅",
                "16": "東鄕將報",
                "17": "至於蜀都",
                "18": "耆老大夫搢紳先生之徒二十有七人",
                "19": "儼然造焉",
                "20": "辭畢",
                "21": "進曰",
                "22": "蓋聞天子之牧夷狄也",
                "23": "其義羈縻勿絕而已",
                "24": "今罷三郡之士",
                "25": "通夜郎之塗",
                "26": "三年於茲",
                "27": "而功不竟",
                "28": "士卒勞倦",
                "29": "萬民不贍",
                "30": "今又接之以西夷",
                "31": "百姓力屈",
                "32": "恐不能卒業",
                "33": "此亦使者之累也",
                "34": "竊爲左右患之",
                "35": "且夫邛笮西夷之與中國並也",
                "36": "歷年茲多",
                "37": "不可記已",
                "38": "仁者不以德來",
                "39": "強者不以力幷",
                "40": "意者其殆不可乎",
                "41": "今割齊民以附夷狄",
                "42": "敝所恃以事無用",
                "43": "鄙人固陋",
                "44": "不識所謂",
                "45": "使者曰",
                "46": "烏謂此乎",
                "47": "必若所云",
                "48": "則是蜀不變服而巴不化俗也",
                "49": "僕常惡聞若說",
                "50": "然斯事體大",
                "51": "固非觀者之所覯也",
                "52": "余之行急",
                "53": "其詳不可得聞已",
                "54": "請爲大夫粗陳其略"
            }
        },
        "2": {
            "5": {
                "1": "蓋世必有非常之人",
                "2": "然後有非常之事",
                "3": "有非常之事",
                "4": "然後有非常之功",
                "5": "夫非常者",
                "6": "固常人之所異也",
                "7": "故曰",
                "8": "非常之原",
                "9": "黎民懼焉",
                "10": "及臻厥成",
                "11": "天下晏如也",
                "12": "昔者洪水沸出",
                "13": "泛濫衍溢",
                "14": "民人升降移徙",
                "15": "崎嶇而不安",
                "16": "夏后氏慼之",
                "17": "乃堙洪塞源",
                "18": "決江疏河",
                "19": "灑沈澹災",
                "20": "東歸之於海",
                "21": "而天下永寧",
                "22": "當斯之勤",
                "23": "豈惟民哉",
                "24": "心煩於慮",
                "25": "而身親其勞",
                "26": "躬腠胝無胈",
                "27": "膚不生毛",
                "28": "張晏曰",
                "29": "躬",
                "30": "體也",
                "31": "孟康曰",
                "32": "腠",
                "33": "腠理也",
                "34": "韋昭曰",
                "35": "胈",
                "36": "其中小毛也",
                "37": "蒲葛切",
                "38": "郭璞三蒼解詁曰",
                "39": "胝",
                "40": "𨇿也",
                "41": "竹施切",
                "42": "莊子曰",
                "43": "兩袒女浣於白水之上者",
                "44": "禹過之而趨",
                "45": "曰",
                "46": "治天下柰何",
                "47": "女曰",
                "48": "股無胈",
                "49": "脛不生毛",
                "50": "顏色烈凍",
                "51": "手足胼胝",
                "52": "何以至是也",
                "53": "胼",
                "54": "步千切",
                "55": "故休烈顯乎無窮",
                "56": "聲稱浹乎於茲"
            }
        },
        "3": {
            "7": {
                "1": "且夫賢君之踐位也",
                "2": "豈特委瑣喔𪘏",
                "3": "拘文牽俗",
                "4": "修誦習傳",
                "5": "當世取說云爾哉",
                "6": "必將崇論吰議",
                "7": "故馳騖乎兼容幷包",
                "8": "而勤思乎參天貳地",
                "9": "且詩不云乎",
                "10": "普天之下",
                "11": "莫非王土",
                "12": "率土之濱",
                "13": "莫非王臣",
                "14": "是以六合之內",
                "15": "八方之外",
                "16": "浸淫衍溢",
                "17": "懷生之物有不浸潤於澤者",
                "18": "賢君恥之",
                "19": "今封疆之內",
                "20": "冠帶之倫",
                "21": "咸獲嘉祉",
                "22": "靡有闕遺矣",
                "23": "而夷狄殊俗之國",
                "24": "遼絕異黨之域",
                "25": "舟車不通",
                "26": "人迹罕至",
                "27": "政教未加",
                "28": "流風猶微",
                "29": "內之則時犯義侵禮於邊境",
                "30": "外之則邪行橫作",
                "31": "放殺其上",
                "32": "君臣易位",
                "33": "尊卑失序",
                "34": "父老不辜",
                "35": "幼孤爲奴虜",
                "36": "係縲號泣",
                "37": "內嚮而怨",
                "38": "曰",
                "39": "蓋聞中國有至仁焉",
                "40": "德洋恩普",
                "41": "物靡不得其所",
                "42": "今獨曷爲遺己",
                "43": "舉踵思慕",
                "44": "若枯旱之望雨",
                "45": "戾夫爲之垂涕",
                "46": "況乎上聖",
                "47": "又焉能已",
                "48": "故北出師以討強胡",
                "49": "南馳使以誚勁越",
                "50": "四面風德",
                "51": "二方之君",
                "52": "鱗集仰流",
                "53": "願得受號者以億計",
                "54": "故乃關沬若",
                "55": "徼牂牁",
                "56": "鏤靈山",
                "57": "梁孫原",
                "58": "創道德之塗",
                "59": "垂仁義之統",
                "60": "將博恩廣施",
                "61": "遠撫長駕",
                "62": "使疏逖不閉",
                "63": "曶爽闇昧",
                "64": "得耀乎光明",
                "65": "以偃甲兵於此",
                "66": "而息討伐於彼",
                "67": "遐邇一體",
                "68": "中外禔福",
                "69": "不亦康乎",
                "70": "夫拯民於沈溺",
                "71": "奉至尊之休德",
                "72": "反衰世之陵夷",
                "73": "繼周氏之絕業",
                "74": "天子之亟務也",
                "75": "百姓雖勞",
                "76": "又惡可以已乎哉"
            }
        },
        "4": {
            "9": {
                "1": "且夫王者固未有不始於憂勤",
                "2": "而終於逸樂者也",
                "3": "然則受命之符",
                "4": "合在於此",
                "5": "方將增太山之封",
                "6": "加梁父之事",
                "7": "鳴和鸞",
                "8": "揚樂頌",
                "9": "上減五",
                "10": "下登三",
                "11": "觀者未睹旨",
                "12": "聽者未聞音",
                "13": "猶鷦敕已翔乎寥廓之宇",
                "14": "而羅者猶視乎藪澤",
                "15": "悲夫"
            }
        },
        "5": {
            "11": {
                "1": "於是諸大夫茫然喪其所懷來",
                "2": "失厥所以進",
                "3": "喟然並稱曰",
                "4": "允哉漢德",
                "5": "此鄙人之所願聞也",
                "6": "百姓雖勞",
                "7": "請以身先之",
                "8": "敞罔靡徙",
                "9": "遷延而辭避"
            }
        }
    }
}