{
    "23.16-02": {
        "篇名": "劉公幹 贈五官中郎將四首·其二",
        "1": {
            "3": {
                "1": "余嬰沈痼疾",
                "2": "竄身清漳濱",
                "3": "自夏涉玄冬",
                "4": "彌曠十餘旬",
                "5": "常恐遊岱宗",
                "6": "不復見故人",
                "7": "所親一何篤",
                "8": "步趾慰我身",
                "9": "清談同日夕",
                "10": "情眄敍憂勤",
                "11": "便復爲別辭",
                "12": "遊車歸西鄰",
                "13": "素葉隨風起",
                "14": "廣路揚埃塵",
                "15": "逝者如流水",
                "16": "哀此遂離分",
                "17": "追問何時會",
                "18": "要我以陽春",
                "19": "望慕結不解",
                "20": "貽爾新詩文",
                "21": "勉哉修令德",
                "22": "北面自寵珍"
            }
        }
    }
}