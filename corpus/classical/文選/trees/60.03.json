{
    "60.03": {
        "篇名": "陸士衡 弔魏武帝文[幷序]",
        "1": {
            "3": {
                "1": "元康八年",
                "2": "機始以臺郎出補著作",
                "3": "遊乎祕閣",
                "4": "而見魏武帝遺令",
                "5": "愾然歎息",
                "6": "傷懷者久之"
            }
        },
        "2": {
            "5": {
                "1": "客曰",
                "2": "夫始終者",
                "3": "萬物之大歸",
                "4": "死生者",
                "5": "性命之區域",
                "6": "是以臨喪殯而後悲",
                "7": "睹陳根而絕哭",
                "8": "今乃傷心百年之際",
                "9": "興哀無情之地",
                "10": "意者無乃知哀之可有",
                "11": "而未識情之可無乎"
            }
        },
        "3": {
            "7": {
                "1": "機答之曰",
                "2": "夫日食由乎交分",
                "3": "山崩起於朽壤",
                "4": "亦云數而已矣",
                "5": "然百姓怪焉者",
                "6": "豈不以資高明之質",
                "7": "而不免卑濁之累",
                "8": "居常安之勢",
                "9": "而終嬰傾離之患故乎",
                "10": "夫以迴天倒日之力",
                "11": "而不能振形骸之內",
                "12": "濟世夷難之智",
                "13": "而受困魏闕之下",
                "14": "已而格乎上下者",
                "15": "藏於區區之木",
                "16": "光於四表者",
                "17": "翳乎蕞爾之土",
                "18": "雄心摧於弱情",
                "19": "壯圖終於哀志",
                "20": "長筭屈於短日",
                "21": "遠迹頓於促路",
                "22": "嗚呼",
                "23": "豈特瞽史之異闕景",
                "24": "黔黎之怪頹岸乎",
                "25": "觀其所以顧命冢嗣",
                "26": "貽謀四子",
                "27": "經國之略旣遠",
                "28": "隆家之訓亦弘",
                "29": "又云",
                "30": "吾在軍中",
                "31": "持法是也",
                "32": "至小忿怒",
                "33": "大過失",
                "34": "不當效也",
                "35": "善乎達人之讜言矣",
                "36": "持姬女而指季豹以示四子曰",
                "37": "以累汝",
                "38": "因泣下",
                "39": "傷哉",
                "40": "曩以天下自任",
                "41": "今以愛子託人",
                "42": "同乎盡者無餘",
                "43": "而得乎亡者無存",
                "44": "然而婉孌房闥之內",
                "45": "綢繆家人之務",
                "46": "則幾乎密與",
                "47": "又曰",
                "48": "吾婕妤妓人",
                "49": "皆著銅爵臺",
                "50": "於臺堂上施八尺牀",
                "51": "繐帳",
                "52": "朝晡上脯糒之屬",
                "53": "月朝十五",
                "54": "輒向帳作妓",
                "55": "汝等時時登銅爵臺",
                "56": "望吾西陵墓田",
                "57": "又云",
                "58": "餘香可分與諸夫人",
                "59": "諸舍中無所爲",
                "60": "學作履組賣也",
                "61": "吾歷官所得綬",
                "62": "皆著藏中",
                "63": "吾餘衣裘",
                "64": "可別爲一藏",
                "65": "不能者兄弟可共分之",
                "66": "旣而竟分焉",
                "67": "亡者可以勿求",
                "68": "存者可以勿違",
                "69": "求與違不其兩傷乎",
                "70": "悲夫",
                "71": "愛有大而必失",
                "72": "惡有甚而必得",
                "73": "智惠不能去其惡",
                "74": "威力不能全其愛",
                "75": "故前識所不用心",
                "76": "而聖人罕言焉",
                "77": "若乃繫情累於外物",
                "78": "留曲念於閨房",
                "79": "亦賢俊之所宜廢乎",
                "80": "於是遂憤懣而獻弔云爾"
            }
        },
        "4": {
            "9": {
                "1": "接皇漢之末緒",
                "2": "値王途之多違",
                "3": "佇重淵以育鱗",
                "4": "撫慶雲而遐飛",
                "5": "運神道以載德",
                "6": "乘靈風而扇威",
                "7": "摧羣雄而電擊",
                "8": "舉勍敵其如遺",
                "9": "指八極以遠略",
                "10": "必剪焉而後綏",
                "11": "釐三才之闕典",
                "12": "啟天地之禁闈",
                "13": "舉修網之絕紀",
                "14": "紐大音之解徽",
                "15": "掃雲物以貞觀",
                "16": "要萬途而來歸",
                "17": "丕大德以宏覆",
                "18": "援日月而齊暉",
                "19": "濟元功於九有",
                "20": "固舉世之所推"
            }
        },
        "5": {
            "11": {
                "1": "彼人事之大造",
                "2": "夫何往而不臻",
                "3": "將覆簣於浚谷",
                "4": "擠爲山乎九天",
                "5": "苟理窮而性盡",
                "6": "豈長筭之所硏",
                "7": "悟臨川之有悲",
                "8": "固梁木其必顚",
                "9": "當建安之三八",
                "10": "實大命之所艱",
                "11": "雖光昭於曩載",
                "12": "將稅駕於此年"
            }
        },
        "6": {
            "13": {
                "1": "惟降神之綿邈",
                "2": "眇千載而遠期",
                "3": "信斯武之未喪",
                "4": "膺靈符而在茲",
                "5": "雖龍飛於文昌",
                "6": "非王心之所怡",
                "7": "憤西夏以鞠旅",
                "8": "泝秦川而舉旗",
                "9": "踰鎬京而不豫",
                "10": "臨渭濱而有疑",
                "11": "冀翌日之云瘳",
                "12": "彌四旬而成災",
                "13": "詠歸途以反旆",
                "14": "登崤澠而朅來",
                "15": "次洛汭而大漸",
                "16": "指六軍曰念哉"
            }
        },
        "7": {
            "15": {
                "1": "伊君王之赫奕",
                "2": "寔終古之所難",
                "3": "威先天而蓋世",
                "4": "力盪海而拔山",
                "5": "厄奚險而弗濟",
                "6": "敵何彊而不殘",
                "7": "每因禍以禔福",
                "8": "亦踐危而必安",
                "9": "迄在茲而蒙昧",
                "10": "慮噤閉而無端",
                "11": "委軀命以待難",
                "12": "痛沒世而永言",
                "13": "撫四子以深念",
                "14": "循膚體而頹歎",
                "15": "迨營魄之未離",
                "16": "假餘息乎音翰",
                "17": "執姬女以嚬瘁",
                "18": "指季豹而漼焉",
                "19": "孟子曰",
                "20": "嚬蹙而言",
                "21": "嚬蹙",
                "22": "謂人頻眉蹙𩕬",
                "23": "憂貌也",
                "24": "漼",
                "25": "泣涕垂貌",
                "26": "氣衝襟以鳴咽",
                "27": "涕垂睫而汍瀾"
            }
        },
        "8": {
            "17": {
                "1": "違率土以靖寐",
                "2": "戢彌天乎一棺",
                "3": "咨宏度之峻邈",
                "4": "壯大業之允昌",
                "5": "思居終而卹始",
                "6": "命臨沒而肇揚",
                "7": "援貞咎以惎悔",
                "8": "雖在我而不臧",
                "9": "惜內顧之纏綿",
                "10": "恨末命之微詳",
                "11": "紆廣念於履組",
                "12": "塵清慮於餘香",
                "13": "結遺情之婉孌",
                "14": "何命促而意長",
                "15": "陳法服於帷座",
                "16": "陪窈窕於玉房",
                "17": "宣備物於虛器",
                "18": "發哀音於舊倡",
                "19": "矯慼容以赴節",
                "20": "掩零淚而薦觴",
                "21": "物無微而不存",
                "22": "體無惠而不亡",
                "23": "庶聖靈之響像",
                "24": "想幽神之復光",
                "25": "苟形聲之翳沒",
                "26": "雖音景其必藏",
                "27": "徽清絃而獨奏",
                "28": "進脯糒而誰嘗",
                "29": "悼繐帳之冥漠",
                "30": "怨西陵之茫茫",
                "31": "登爵臺而羣悲",
                "32": "眝美目其何望",
                "33": "旣晞古以遺累",
                "34": "信簡禮而薄葬",
                "35": "彼裘紱於何有",
                "36": "貽塵謗於後王",
                "37": "嗟大戀之所存",
                "38": "故雖哲而不忘",
                "39": "覽見遺籍以慷慨",
                "40": "獻茲文而悽傷"
            }
        }
    }
}