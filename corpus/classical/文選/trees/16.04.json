{
    "16.04": {
        "篇名": "陸士衡 歎逝賦[幷序]",
        "1": {
            "3": {
                "1": "昔每聞長老追計平生同時親故",
                "2": "或凋落已盡",
                "3": "或僅有存者",
                "4": "余年方四十",
                "5": "而懿親戚屬",
                "6": "亡多存寡",
                "7": "昵交密友",
                "8": "亦不半在",
                "9": "或所曾共遊一塗",
                "10": "同宴一室",
                "11": "十年之外",
                "12": "索然已盡",
                "13": "以是思哀",
                "14": "哀可知矣",
                "15": "乃作賦曰"
            }
        },
        "2": {
            "5": {
                "1": "伊天地之運流",
                "2": "紛升降而相襲",
                "3": "日望空以駿驅",
                "4": "節循虛而警立",
                "5": "嗟人生之短期",
                "6": "孰長年之能執",
                "7": "時飄忽其不再",
                "8": "老晼晚其將及",
                "9": "懟瓊橤之無徵",
                "10": "恨朝霞之難挹",
                "11": "望湯谷以企予",
                "12": "惜此景之屢戢"
            }
        },
        "3": {
            "7": {
                "1": "悲夫",
                "2": "川閱水以成川",
                "3": "水滔滔而日度",
                "4": "世閱人而爲世",
                "5": "人冉冉而行暮",
                "6": "人何世而弗新",
                "7": "世何人之能故",
                "8": "野每春其必華",
                "9": "草無朝而遺露",
                "10": "經終古而常然",
                "11": "率品物其如素",
                "12": "譬日及之在條",
                "13": "恆雖盡而弗寤",
                "14": "雖不寤其可悲",
                "15": "心惆焉而自傷",
                "16": "亮造化之若茲",
                "17": "吾安取夫久長",
                "18": "痛靈根之夙隕",
                "19": "怨具爾之多喪",
                "20": "悼堂搆之隤瘁",
                "21": "慜城闕之丘荒",
                "22": "親彌懿其已逝",
                "23": "交何戚而不忘",
                "24": "咨余今之方殆",
                "25": "何視天之芒芒",
                "26": "傷懷悽其多念",
                "27": "戚貌瘁而尠歡",
                "28": "幽情發而成緒",
                "29": "滯思叩而興端",
                "30": "慘此世之無樂",
                "31": "詠在昔而爲言"
            }
        },
        "4": {
            "9": {
                "1": "居充堂而衍宇",
                "2": "行連駕而比軒",
                "3": "彌年時其詎幾",
                "4": "夫何往而不殘",
                "5": "或冥邈而旣盡",
                "6": "或寥廓而僅半",
                "7": "信松茂而柏悅",
                "8": "嗟芝焚而蕙歎",
                "9": "苟性命之弗殊",
                "10": "豈同波而異瀾",
                "11": "瞻前軌之旣覆",
                "12": "知此路之良難",
                "13": "啟四體而深悼",
                "14": "懼茲形之將然",
                "15": "毒娛情而寡方",
                "16": "怨感目之多顏"
            }
        },
        "5": {
            "11": {
                "1": "諒多顏之感目",
                "2": "神何適而獲怡",
                "3": "尋平生於響像",
                "4": "覽前物而懷之",
                "5": "步寒林以悽惻",
                "6": "翫春翹而有思",
                "7": "觸萬類以生悲",
                "8": "歎同節而異時",
                "9": "年彌往而念廣",
                "10": "塗薄暮而意迮",
                "11": "親落落而日稀",
                "12": "友靡靡而愈索",
                "13": "顧舊要於遺存",
                "14": "得十一於千百",
                "15": "樂隤心其如忘",
                "16": "哀緣情而來宅",
                "17": "託末契於後生",
                "18": "余將老而爲客"
            }
        },
        "6": {
            "13": {
                "1": "然後弭節安懷",
                "2": "妙思天造",
                "3": "精浮神淪",
                "4": "忽在世表",
                "5": "寤大暮之同寐",
                "6": "何矜晚以怨早",
                "7": "指彼日之方除",
                "8": "豈茲情之足攪",
                "9": "感秋華於衰木",
                "10": "瘁零露於豐草",
                "11": "在殷憂而弗違",
                "12": "夫何云乎識道",
                "13": "將頤天地之大德",
                "14": "遺聖人之洪寶",
                "15": "解心累於末迹",
                "16": "聊優遊以娛老"
            }
        }
    }
}