{
    "12.02": {
        "篇名": "郭景純 江賦",
        "1": {
            "3": {
                "1": "咨五才之並用",
                "2": "寔水德之靈長",
                "3": "惟岷山之導江",
                "4": "初發源乎濫觴",
                "5": "聿經始於洛沬",
                "6": "攏萬川乎巴梁",
                "7": "衝巫峽以迅激",
                "8": "躋江津而起漲",
                "9": "極泓量而海運",
                "10": "狀滔天以淼茫",
                "11": "總括漢泗",
                "12": "兼包淮湘",
                "13": "幷吞沅澧",
                "14": "汲引沮漳",
                "15": "源二分於崌崍",
                "16": "流九派乎潯陽",
                "17": "鼓洪濤於赤岸",
                "18": "淪餘波乎柴桑",
                "19": "綱絡羣流",
                "20": "商搉涓澮表神委於江都",
                "21": "混流宗而東會",
                "22": "注五湖以漫漭",
                "23": "灌三江而漰沛",
                "24": "滈汗六州之域",
                "25": "經營炎景之外",
                "26": "所以作限於華裔",
                "27": "壯天地之嶮介"
            }
        },
        "2": {
            "5": {
                "1": "呼吸萬里",
                "2": "吐納靈潮",
                "3": "自然往復",
                "4": "或夕或朝",
                "5": "激逸勢以前驅",
                "6": "乃鼓怒而作濤",
                "7": "峨嵋爲泉陽之揭",
                "8": "玉壘作東別之標",
                "9": "衡霍磊落以連鎭",
                "10": "巫廬嵬崫而比嶠",
                "11": "協靈通氣",
                "12": "濆薄相陶",
                "13": "流風蒸雷",
                "14": "騰虹揚霄",
                "15": "出信陽而長邁",
                "16": "淙大壑與沃焦"
            }
        },
        "3": {
            "7": {
                "1": "若乃巴東之峽",
                "2": "夏后疏鑿",
                "3": "絕岸萬丈",
                "4": "壁立赮駮",
                "5": "虎牙嵥豎以屹崒",
                "6": "荊門闕竦而磐礡",
                "7": "圓淵九回以懸騰",
                "8": "湓流雷呴而電激",
                "9": "駭浪暴灑",
                "10": "驚波飛薄",
                "11": "迅澓增澆",
                "12": "涌湍疊躍",
                "13": "砯巖鼓作",
                "14": "漰湱澩灂",
                "15": "㵗㶔𤃫𣸎",
                "16": "潰濩㳚漷",
                "17": "潏湟淴泱",
                "18": "㶖㴸㶒瀹",
                "19": "漩澴滎瀯",
                "20": "渨㵽濆瀑",
                "21": "溭淢濜涓",
                "22": "龍鱗結絡",
                "23": "碧沙瀢𣵺而往來",
                "24": "巨石硉矹以前卻",
                "25": "潛演之所汩淈",
                "26": "奔溜之所磢錯",
                "27": "厓隒爲之泐嵃",
                "28": "碕嶺爲之嵒崿",
                "29": "幽𧯑積岨",
                "30": "礐硞䃕礭"
            }
        },
        "4": {
            "9": {
                "1": "若乃曾潭之府",
                "2": "靈湖之淵",
                "3": "澄澹汪洸",
                "4": "瀇滉囦泫",
                "5": "泓汯浻澋",
                "6": "涒鄰㘤潾",
                "7": "混澣灦渙",
                "8": "流映揚焆",
                "9": "溟漭渺湎",
                "10": "汗汗沺沺",
                "11": "察之無象",
                "12": "尋之無邊",
                "13": "氣滃渤以霧杳",
                "14": "時鬱律其如煙",
                "15": "類肧渾之未凝",
                "16": "象太極之構天",
                "17": "長波浹渫",
                "18": "峻湍崔嵬",
                "19": "盤渦谷轉",
                "20": "淩濤山頹",
                "21": "陽侯砐硪以岸起",
                "22": "洪瀾涴演而雲迴",
                "23": "峾淪溛瀤",
                "24": "乍浥乍堆",
                "25": "豃如地裂",
                "26": "豁若天開",
                "27": "觸曲厓以縈繞",
                "28": "駭崩浪而相礧",
                "29": "鼓㕉窟以漰渤",
                "30": "乃湓湧而駕隈"
            }
        },
        "5": {
            "11": {
                "1": "魚則江豚海狶",
                "2": "叔鮪王鱣",
                "3": "䱻鰊𩺭鮋",
                "4": "鯪鰩鯩鰱",
                "5": "或鹿觡象鼻",
                "6": "或虎狀龍顏",
                "7": "鱗甲鏙錯",
                "8": "煥爛錦斑",
                "9": "揚鰭掉尾",
                "10": "噴浪飛唌",
                "11": "排流呼哈",
                "12": "隨波遊延",
                "13": "或爆采以晃淵",
                "14": "或嚇鰓乎巖間",
                "15": "介鯨乘濤以出入",
                "16": "鯼鮆順時而往還"
            }
        },
        "6": {
            "13": {
                "1": "爾其水物怪錯",
                "2": "則有潛鵠魚牛",
                "3": "虎蛟鉤蛇",
                "4": "蜦𧐕鱟蝞",
                "5": "鱝𪓛𪓬𪓹",
                "6": "王珧海月",
                "7": "土肉石華",
                "8": "三蝬𧉈江",
                "9": "鸚螺蜁蝸",
                "10": "璅蛣腹蟹",
                "11": "水母目蝦",
                "12": "紫蚢如渠",
                "13": "洪蚶專車",
                "14": "瓊蚌晞曜以瑩珠",
                "15": "石砝應節而揚葩",
                "16": "蜛蝫森衰以垂翹",
                "17": "玄蠣磈磥而碨䃁",
                "18": "或泛瀲於潮波",
                "19": "或混淪乎泥沙"
            }
        },
        "7": {
            "15": {
                "1": "若乃龍鯉一角",
                "2": "奇鶬九頭",
                "3": "有鱉三足",
                "4": "有龜六眸",
                "5": "赬蟞胏躍而吐璣",
                "6": "文魮磬鳴以孕璆",
                "7": "䖺䗤拂翼而掣耀",
                "8": "神蜧蝹蜦以沈遊",
                "9": "𩣡馬騰波以噓蹀",
                "10": "水兕雷咆乎陽侯",
                "11": "淵客築室於巖底",
                "12": "鮫人構館於懸流",
                "13": "雹布餘糧",
                "14": "星離沙鏡",
                "15": "青綸競糾",
                "16": "縟組爭映",
                "17": "紫菜熒曄以叢被",
                "18": "綠苔鬖髿乎硏上",
                "19": "石帆蒙籠以蓋嶼",
                "20": "蓱實時出而漂泳"
            }
        },
        "8": {
            "17": {
                "1": "其下則金礦丹礫",
                "2": "雲精爥銀",
                "3": "珕珋璿瑰",
                "4": "水碧潛琘",
                "5": "鳴石列於陽渚",
                "6": "浮磬肆乎陰濱",
                "7": "或熲彩輕漣",
                "8": "或焆曜崖鄰",
                "9": "林無不溽",
                "10": "岸無不津"
            }
        },
        "9": {
            "19": {
                "1": "其羽族也",
                "2": "則有晨鵠天雞",
                "3": "鴢鷔鷗𩿁",
                "4": "陽鳥爰翔",
                "5": "於以玄月",
                "6": "千類萬聲",
                "7": "自相喧聒",
                "8": "濯翮疏風",
                "9": "鼓翅𦒑䎀",
                "10": "揮弄灑珠",
                "11": "拊拂瀑沫",
                "12": "集若霞布",
                "13": "散如雲豁",
                "14": "產毻積羽",
                "15": "往來勃碣"
            }
        },
        "10": {
            "21": {
                "1": "橉杞稹薄於潯涘",
                "2": "栛槤森嶺而羅峯",
                "3": "桃枝篔簹",
                "4": "實繁有叢",
                "5": "葭蒲雲蔓",
                "6": "䙬以蘭紅",
                "7": "揚皜毦",
                "8": "擢紫茸",
                "9": "蔭潭隩",
                "10": "被長江",
                "11": "繁蔚芳蘺",
                "12": "隱藹水松",
                "13": "涯灌芊萰",
                "14": "潛薈蔥蘢"
            }
        },
        "11": {
            "23": {
                "1": "鯪鯥䟸跼於垠隒",
                "2": "獱獺𦖠瞲乎厱空",
                "3": "迅蜼臨虛以騁巧",
                "4": "孤玃登危而雍容",
                "5": "夔㸸翹踛於夕陽",
                "6": "鴛雛弄翮乎山東"
            }
        },
        "12": {
            "25": {
                "1": "因岐成渚",
                "2": "觸澗開渠",
                "3": "漱壑生浦",
                "4": "區別作湖",
                "5": "磴之以瀿瀷",
                "6": "渫之以尾閭",
                "7": "標之以翠蘙",
                "8": "泛之以遊菰",
                "9": "播匪藝之芒種",
                "10": "挺自然之嘉蔬",
                "11": "鱗被菱荷",
                "12": "攢布水蓏",
                "13": "翹莖瀵橤",
                "14": "濯穎散裹",
                "15": "隨風猗萎",
                "16": "與波潭遝",
                "17": "流光潛映",
                "18": "景炎霞火"
            }
        },
        "13": {
            "27": {
                "1": "其旁則有雲夢雷池",
                "2": "彭蠡青草",
                "3": "具區洮滆",
                "4": "朱滻丹漅",
                "5": "極望數百",
                "6": "沆瀁皛溔",
                "7": "爰有包山洞庭",
                "8": "巴陵地道",
                "9": "潛逵傍通",
                "10": "幽岫窈窕",
                "11": "金精玉英瑱其裏",
                "12": "瑤珠怪石琗其表",
                "13": "驪虯摎其址",
                "14": "梢雲冠其㟽",
                "15": "海童之所巡遊",
                "16": "琴高之所靈矯",
                "17": "冰夷倚浪以傲睨",
                "18": "江妃含嚬而矊眇",
                "19": "撫淩波而鳧躍",
                "20": "吸翠霞而夭矯"
            }
        },
        "14": {
            "29": {
                "1": "若乃宇宙澄寂",
                "2": "八風不翔",
                "3": "舟子於是搦棹",
                "4": "涉人於是㩘榜",
                "5": "漂飛雲",
                "6": "運艅艎",
                "7": "舳艫相屬",
                "8": "萬里連檣",
                "9": "泝洄沿流",
                "10": "或漁或商",
                "11": "赴交益",
                "12": "投幽浪",
                "13": "竭南極",
                "14": "窮東荒",
                "15": "爾乃𥉆雰祲於清旭",
                "16": "覘五兩之動靜",
                "17": "長風颹以增扇",
                "18": "廣莫䬅而氣整",
                "19": "徐而不䬐",
                "20": "疾而不猛",
                "21": "鼓帆迅越",
                "22": "䞟漲截泂",
                "23": "淩波縱舵",
                "24": "電往杳溟",
                "25": "䨴如晨霞孤征",
                "26": "眇若雲翼絕嶺",
                "27": "倏忽數百",
                "28": "千里俄頃",
                "29": "飛廉無以睎其蹤",
                "30": "渠黃不能企其景"
            }
        },
        "15": {
            "31": {
                "1": "於是蘆人漁子",
                "2": "擯落江山",
                "3": "衣則羽褐",
                "4": "食惟蔬鱻",
                "5": "栫澱爲涔",
                "6": "夾潀羅筌",
                "7": "筩灑連鋒",
                "8": "罾䍣比船",
                "9": "或揮輪於懸碕",
                "10": "或中瀨而橫旋",
                "11": "忽忘夕而宵歸",
                "12": "詠采菱以叩舷",
                "13": "傲自足於一嘔",
                "14": "尋風波以窮年"
            }
        },
        "16": {
            "33": {
                "1": "爾乃域之以盤巖",
                "2": "豁之以洞壑",
                "3": "疏之以遝汜",
                "4": "鼓之以朝夕",
                "5": "川流之所歸湊",
                "6": "雲霧之所蒸液",
                "7": "珍怪之所化產",
                "8": "傀奇之所窟宅",
                "9": "納隱淪之列眞",
                "10": "挺異人乎精魄",
                "11": "播靈潤於千里",
                "12": "越岱宗之觸石",
                "13": "及其譎變儵怳",
                "14": "符祥非一",
                "15": "動應無方",
                "16": "感事而出",
                "17": "經紀天地",
                "18": "錯綜人術",
                "19": "妙不可盡之於言",
                "20": "事不可窮之於筆"
            }
        },
        "17": {
            "35": {
                "1": "若乃岷精垂曜於東井",
                "2": "陽侯遯形乎大波",
                "3": "奇相得道而宅神",
                "4": "乃協靈爽於湘娥",
                "5": "駭黃龍之負舟",
                "6": "識伯禹之仰嗟",
                "7": "壯荊飛之擒蛟",
                "8": "終成氣乎太阿",
                "9": "悍要離之圖慶",
                "10": "在中流而推戈",
                "11": "悲靈均之任石",
                "12": "歎漁父之櫂歌",
                "13": "想周穆之濟師",
                "14": "驅八駿於黿鼉",
                "15": "感交甫之喪珮",
                "16": "愍神使之嬰羅",
                "17": "煥大塊之流形",
                "18": "混萬盡於一科",
                "19": "保不虧而永固",
                "20": "稟元氣於靈和",
                "21": "考川瀆而妙觀",
                "22": "實莫著於江河"
            }
        }
    }
}