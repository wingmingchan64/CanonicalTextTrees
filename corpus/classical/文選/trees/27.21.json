{
    "27.21": {
        "篇名": "石季倫 王明君詞[幷序]",
        "1": {
            "3": {
                "1": "王明君者",
                "2": "本是王昭君",
                "3": "以觸文帝諱改焉",
                "4": "匈奴盛",
                "5": "請婚於漢",
                "6": "元帝以後宮良家子昭君配焉",
                "7": "昔公主嫁烏孫",
                "8": "令琵琶馬上作樂",
                "9": "以慰其道路之思",
                "10": "其送明君",
                "11": "亦必爾也",
                "12": "其造新曲",
                "13": "多哀怨之聲",
                "14": "故敍之於紙云爾"
            }
        },
        "2": {
            "5": {
                "1": "我本漢家子",
                "2": "將適單於庭",
                "3": "辭訣未及終",
                "4": "前驅已抗旌",
                "5": "僕御涕流離",
                "6": "轅馬悲且鳴",
                "7": "哀鬱傷五內",
                "8": "泣淚濕朱纓",
                "9": "行行日已遠",
                "10": "遂造匈奴城",
                "11": "延我於穹廬",
                "12": "加我閼氏名",
                "13": "漢書曰",
                "14": "烏孫公主作歌曰",
                "15": "吾家嫁我兮天一方",
                "16": "遠託異國兮烏孫王",
                "17": "穹廬爲室兮𣃼爲牆",
                "18": "音義曰",
                "19": "𣃼",
                "20": "帳也",
                "21": "蘇林曰",
                "22": "閼氏",
                "23": "音焉支",
                "24": "如漢皇后",
                "25": "殊類非所安",
                "26": "雖貴非所榮",
                "27": "父子見陵辱",
                "28": "對之慚且驚",
                "29": "漢書曰",
                "30": "呼韓邪死",
                "31": "子雕陶莫皋立",
                "32": "爲復系若�單於",
                "33": "復妻王昭君",
                "34": "生二女也",
                "35": "殺身良不易",
                "36": "默默以苟生",
                "37": "苟生亦何聊",
                "38": "積思常憤盈",
                "39": "願假飛鴻翼",
                "40": "乘之以遐征",
                "41": "飛鴻不我顧",
                "42": "佇立以屛營",
                "43": "昔爲匣中玉",
                "44": "今爲糞上英",
                "45": "朝華不足歡",
                "46": "甘與秋草幷",
                "47": "傳語後世人",
                "48": "遠嫁難爲情"
            }
        },
        "3": {
            "7": {
                "1": "文選考異"
            }
        }
    }
}