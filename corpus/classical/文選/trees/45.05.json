{
    "45.05": {
        "篇名": "漢武帝 秋風辭[幷序]",
        "1": {
            "3": {
                "1": "上行幸河東",
                "2": "祠后土",
                "3": "顧視帝京欣然",
                "4": "中流與羣臣飲燕",
                "5": "上歡甚",
                "6": "乃自作秋風辭曰"
            }
        },
        "2": {
            "5": {
                "1": "秋風起兮白雲飛",
                "2": "草木黃落兮雁南歸",
                "3": "蘭有秀兮菊有芳",
                "4": "攜佳人兮不能忘",
                "5": "泛樓船兮濟汾河",
                "6": "橫中流兮揚素波",
                "7": "簫鼓鳴兮發棹歌",
                "8": "歡樂極兮哀情多",
                "9": "少壯幾時兮柰老何"
            }
        }
    }
}