{
    "52.03": {
        "篇名": "曹元首 六代論",
        "1": {
            "3": {
                "1": "昔夏殷周之歷世數十",
                "2": "而秦二世而亡",
                "3": "何則",
                "4": "三代之君與天下共其民",
                "5": "故天下同其憂",
                "6": "秦王獨制其民",
                "7": "故傾危而莫救",
                "8": "夫與人共其樂者",
                "9": "人必憂其憂",
                "10": "與人同其安者",
                "11": "人必拯其危",
                "12": "先王知獨治之不能久也",
                "13": "故與人共治之",
                "14": "知獨守之不能固也",
                "15": "故與人共守之",
                "16": "兼親疏而兩用",
                "17": "參同異而並進",
                "18": "是以輕重足以相鎭",
                "19": "親疏足以相衞",
                "20": "幷兼路塞",
                "21": "逆節不生",
                "22": "及其衰也",
                "23": "桓文帥禮",
                "24": "苞茅不貢",
                "25": "齊師伐楚",
                "26": "宋不城周",
                "27": "晉戮其宰",
                "28": "王綱弛而復張",
                "29": "諸侯傲而復肅",
                "30": "二霸之後",
                "31": "寖以陵遲",
                "32": "吳楚憑江",
                "33": "負固方城",
                "34": "雖心希九鼎",
                "35": "而畏迫宗姬",
                "36": "姦情散於胸懷",
                "37": "逆謀消於脣吻",
                "38": "斯豈非信重親戚",
                "39": "任用賢能",
                "40": "枝葉碩茂",
                "41": "本根賴之與",
                "42": "自此之後",
                "43": "轉相攻伐",
                "44": "吳幷於越",
                "45": "晉分爲三",
                "46": "魯滅於楚",
                "47": "鄭兼於韓",
                "48": "曁乎戰國",
                "49": "諸姬微矣",
                "50": "唯燕衞獨存",
                "51": "然皆弱小",
                "52": "西迫強秦",
                "53": "南畏齊",
                "54": "楚",
                "55": "救於滅亡",
                "56": "匪遑相卹",
                "57": "至於王赧",
                "58": "降爲庶人",
                "59": "猶枝幹相持",
                "60": "得居虛位",
                "61": "海內無主",
                "62": "四十餘年",
                "63": "秦據勢勝之地",
                "64": "騁譎詐之術",
                "65": "征伐關東",
                "66": "蠶食九國",
                "67": "至於始皇",
                "68": "乃定天位",
                "69": "曠日若彼",
                "70": "用力若此",
                "71": "豈非深根固蔕",
                "72": "不拔之道乎",
                "73": "易曰",
                "74": "其亡其亡",
                "75": "繫於苞桑",
                "76": "周德其可謂當之矣"
            }
        },
        "2": {
            "5": {
                "1": "秦觀周之敝",
                "2": "將以爲以弱見奪",
                "3": "於是廢五等之爵",
                "4": "立郡縣之官",
                "5": "棄禮樂之教",
                "6": "任苛刻之政",
                "7": "子弟無尺寸之封",
                "8": "功臣無立錐之土",
                "9": "內無宗子以自毗輔",
                "10": "外無諸侯以爲蕃衞",
                "11": "仁心不加於親戚",
                "12": "惠澤不流於枝葉",
                "13": "譬猶芟刈股肱",
                "14": "獨任胸腹",
                "15": "浮舟江海",
                "16": "捐棄楫櫂",
                "17": "觀者爲之寒心",
                "18": "而始皇晏然",
                "19": "自以爲關中之固",
                "20": "金城千里",
                "21": "子孫帝王萬世之業也",
                "22": "豈不悖哉",
                "23": "是時",
                "24": "淳於越諫曰",
                "25": "臣聞殷",
                "26": "周之王",
                "27": "封子弟功臣",
                "28": "千有餘歲",
                "29": "今陛下君有海內",
                "30": "而子弟爲匹夫",
                "31": "卒有田常六卿之臣",
                "32": "而無輔弼",
                "33": "何以相救",
                "34": "事不師古而能長久者",
                "35": "非所聞也",
                "36": "始皇聽李斯偏說而絀其義",
                "37": "至身死之日",
                "38": "無所寄付",
                "39": "委天下之重於凡夫之手",
                "40": "託廢立之命於姦臣之口",
                "41": "至令趙高之徒",
                "42": "誅鋤宗室",
                "43": "胡亥少習剋薄之教",
                "44": "長遵凶父之業",
                "45": "不能改制易法",
                "46": "寵任兄弟",
                "47": "而乃師謨申商",
                "48": "諮謀趙高",
                "49": "自幽深宮",
                "50": "委政讒賊",
                "51": "身殘望夷",
                "52": "求爲黔首",
                "53": "豈可得哉",
                "54": "遂乃郡國離心",
                "55": "眾庶潰叛",
                "56": "勝廣唱之於前",
                "57": "劉項斃之於後",
                "58": "向使始皇納淳於之策",
                "59": "抑李斯之論",
                "60": "割裂州國",
                "61": "分王子弟",
                "62": "封三代之後",
                "63": "報功臣之勞",
                "64": "土有常君",
                "65": "民有定主",
                "66": "枝葉相扶",
                "67": "首尾爲用",
                "68": "雖使子孫有失道之行",
                "69": "時人無湯武之賢",
                "70": "姦謀未發",
                "71": "而身已屠戮",
                "72": "何區區之陳項",
                "73": "而復得措其手足哉",
                "74": "故漢祖奮三尺之劍",
                "75": "驅烏集之眾",
                "76": "五年之中",
                "77": "而成帝業",
                "78": "自開闢以來",
                "79": "其興功立勳",
                "80": "未有若漢祖之易者也",
                "81": "夫伐深根者難爲功",
                "82": "摧枯朽者易爲力",
                "83": "理勢然也"
            }
        },
        "3": {
            "7": {
                "1": "漢鑒秦之失",
                "2": "封植子弟",
                "3": "及諸呂擅權",
                "4": "圖危劉氏",
                "5": "而天下所以不能傾動",
                "6": "百姓所以不易心者",
                "7": "徒以諸侯強大",
                "8": "盤石膠固",
                "9": "東牟朱虛授命於內",
                "10": "齊代吳楚作衞於外故也",
                "11": "向使高祖踵亡秦之法",
                "12": "忽先王之制",
                "13": "則天下已傳",
                "14": "非劉氏有也",
                "15": "然高祖封建",
                "16": "地過古制",
                "17": "大者跨州兼域",
                "18": "小者連城數十",
                "19": "上下無別",
                "20": "權侔京室",
                "21": "故有吳楚七國之患",
                "22": "賈誼曰",
                "23": "諸侯強盛",
                "24": "長亂起姦",
                "25": "夫欲天下之治安",
                "26": "莫若眾建諸侯而少其力",
                "27": "令海內之勢",
                "28": "若身之使臂",
                "29": "臂之使指",
                "30": "則下無背叛之心",
                "31": "上無誅伐之事",
                "32": "文帝不從",
                "33": "至於孝景猥用朝錯之計",
                "34": "削黜諸侯",
                "35": "親者怨恨",
                "36": "疏者震恐",
                "37": "吳楚唱謀",
                "38": "五國從風",
                "39": "兆發高祖",
                "40": "釁成文景",
                "41": "由寬之過制",
                "42": "急之不漸故也",
                "43": "所謂末大必折",
                "44": "尾大難掉",
                "45": "尾同於體",
                "46": "猶或不從",
                "47": "況乎非體之尾",
                "48": "其可掉哉"
            }
        },
        "4": {
            "9": {
                "1": "武帝從主父之策",
                "2": "下推恩之命",
                "3": "自是之後",
                "4": "齊分爲七",
                "5": "趙分爲六",
                "6": "淮南三割",
                "7": "梁代五分",
                "8": "遂以陵遲",
                "9": "子孫微弱",
                "10": "衣食租稅",
                "11": "不豫政事",
                "12": "或以酎金免削",
                "13": "或以無後國除",
                "14": "至於成帝",
                "15": "王氏擅朝",
                "16": "劉向諫曰",
                "17": "臣聞公族者",
                "18": "國之枝葉",
                "19": "枝葉落",
                "20": "則本根無所庇蔭",
                "21": "方今同姓疏遠",
                "22": "母黨專政",
                "23": "排擯宗室",
                "24": "孤弱公族",
                "25": "非所以保守社稷",
                "26": "安固國嗣也",
                "27": "其言深切",
                "28": "多所稱引",
                "29": "成帝雖悲傷歎息而不能用",
                "30": "至乎哀平",
                "31": "異姓秉權",
                "32": "假周公之事",
                "33": "而爲田常之亂",
                "34": "高拱而竊天位",
                "35": "一朝而臣四海",
                "36": "漢宗室王侯",
                "37": "解印釋綬",
                "38": "貢奉社稷",
                "39": "猶懼不得爲臣妾",
                "40": "或乃爲之符命",
                "41": "頌莽恩德",
                "42": "豈不哀哉",
                "43": "由斯言之",
                "44": "非宗子獨忠孝於惠文之間",
                "45": "而叛逆於哀平之際也",
                "46": "徒以權輕勢弱",
                "47": "不能有定耳"
            }
        },
        "5": {
            "11": {
                "1": "賴光武皇帝挺不世之姿",
                "2": "禽王莽於已成",
                "3": "紹漢祀於旣絕",
                "4": "斯豈非宗子之力耶",
                "5": "而曾不鑒秦之失策",
                "6": "襲周之舊制",
                "7": "踵亡國之法",
                "8": "而僥倖無疆之期",
                "9": "至於桓靈",
                "10": "奄豎執衡",
                "11": "朝無死難之臣",
                "12": "外無同憂之國",
                "13": "君孤立於上",
                "14": "臣弄權於下",
                "15": "本末不能相御",
                "16": "身手不能相使",
                "17": "由是天下鼎沸",
                "18": "姦凶並爭",
                "19": "宗廟焚爲灰燼",
                "20": "宮室變爲蓁藪",
                "21": "居九州之地",
                "22": "而身無所安處",
                "23": "悲夫"
            }
        },
        "6": {
            "13": {
                "1": "魏太祖武皇帝",
                "2": "躬聖明之資",
                "3": "兼神武之略",
                "4": "恥王綱之廢絕",
                "5": "愍漢室之傾覆",
                "6": "龍飛譙沛",
                "7": "鳳翔兗豫",
                "8": "掃除凶逆",
                "9": "剪滅鯨鯢",
                "10": "迎帝西京",
                "11": "定都潁邑",
                "12": "德動天地",
                "13": "義感人神",
                "14": "漢氏奉天",
                "15": "禪位大魏",
                "16": "大魏之興",
                "17": "於今二十有四年矣",
                "18": "觀五代之存亡",
                "19": "而不用其長策",
                "20": "睹前車之傾覆",
                "21": "而不改其轍迹",
                "22": "子弟王空虛之地",
                "23": "君有不使之民",
                "24": "宗室竄於閭閻",
                "25": "不聞邦國之政",
                "26": "權均匹夫",
                "27": "勢齊凡庶",
                "28": "內無深根不拔之固",
                "29": "外無盤石宗盟之助",
                "30": "非所以安社稷爲萬代之業也",
                "31": "且今之州牧",
                "32": "郡守",
                "33": "古之方伯",
                "34": "諸侯",
                "35": "皆跨有千里之土",
                "36": "兼軍武之任",
                "37": "或比國數人",
                "38": "或兄弟並據",
                "39": "而宗室子弟",
                "40": "曾無一人間廁其間",
                "41": "與相維持",
                "42": "非所以強榦弱枝",
                "43": "備萬一之慮也",
                "44": "今之用賢",
                "45": "或超爲名都之主",
                "46": "或爲偏師之帥",
                "47": "而宗室有文者必限以小縣之宰",
                "48": "有武者必置於百人之上",
                "49": "使夫廉高之士",
                "50": "畢志於衡軛之內",
                "51": "才能之人",
                "52": "恥與非類爲伍",
                "53": "非所以勸進賢能",
                "54": "襃異宗族之禮也"
            }
        },
        "7": {
            "15": {
                "1": "夫泉竭則流涸",
                "2": "根朽則葉枯",
                "3": "枝繁者蔭根",
                "4": "條落者本孤",
                "5": "故語曰",
                "6": "百足之蟲",
                "7": "至死不僵",
                "8": "扶之者眾也",
                "9": "此言雖小",
                "10": "可以譬大",
                "11": "且墉基不可倉卒而成",
                "12": "威名不可一朝而立",
                "13": "皆爲之有漸",
                "14": "建之有素",
                "15": "譬之種樹",
                "16": "久則深固其根本",
                "17": "茂盛其枝葉",
                "18": "若造次徙於山林之中",
                "19": "植於宮闕之下",
                "20": "雖壅之以黑墳",
                "21": "暖之以春日",
                "22": "猶不救於枯槁",
                "23": "何暇繁育哉",
                "24": "夫樹猶親戚",
                "25": "土猶士民",
                "26": "建置不久",
                "27": "則輕下慢上",
                "28": "平居猶懼其離叛",
                "29": "危急將如之何",
                "30": "是聖王安而不逸",
                "31": "以慮危也",
                "32": "存而設備",
                "33": "以懼亡也",
                "34": "故疾風卒至",
                "35": "而無摧拔之憂",
                "36": "天下有變",
                "37": "而無傾危之患矣"
            }
        }
    }
}