{
    "42.09": {
        "篇名": "應休璉 與侍郎曹長思書",
        "1": {
            "3": {
                "1": "璩白",
                "2": "足下去後",
                "3": "甚相思想",
                "4": "叔田有無人之歌",
                "5": "闉闍有匪存之思",
                "6": "風人之作",
                "7": "豈虛也哉"
            }
        },
        "2": {
            "5": {
                "1": "王肅以宿德顯授",
                "2": "何曾以後進見拔",
                "3": "皆鷹揚虎視",
                "4": "有萬里之望",
                "5": "薄援助者",
                "6": "不能追參於高妙",
                "7": "復斂翼於故枝",
                "8": "塊然獨處",
                "9": "有離羣之志",
                "10": "汲黯樂在郎署",
                "11": "何武恥爲宰相",
                "12": "千載揆之",
                "13": "知其有由也",
                "14": "德非陳平",
                "15": "門無結駟之迹",
                "16": "學非楊雄",
                "17": "堂無好事之客",
                "18": "才劣仲舒",
                "19": "無下帷之思",
                "20": "家貧孟公",
                "21": "無置酒之樂",
                "22": "悲風起於閨闥",
                "23": "紅塵蔽於机榻",
                "24": "幸有袁生",
                "25": "時步玉趾",
                "26": "樵蘇不爨",
                "27": "清談而已",
                "28": "有似周黨之過閔子"
            }
        },
        "3": {
            "7": {
                "1": "夫皮朽者毛落",
                "2": "川涸者魚逝",
                "3": "春生者繁華",
                "4": "秋榮者零悴",
                "5": "自然之數",
                "6": "豈有恨哉",
                "7": "聊爲大弟陳其苦懷耳",
                "8": "想還在近",
                "9": "故不益言",
                "10": "璩白"
            }
        }
    }
}