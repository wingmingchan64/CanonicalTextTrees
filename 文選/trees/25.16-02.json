{
    "25.16-02": {
        "篇名": "謝靈運 酬從弟惠連·其二",
        "1": {
            "3": {
                "1": "心胸旣云披",
                "2": "意得咸在斯",
                "3": "凌澗尋我室",
                "4": "散帙問所知",
                "5": "夕慮曉月流",
                "6": "朝忌曛日馳",
                "7": "悟對無厭歇",
                "8": "聚散成分離"
            }
        }
    }
}