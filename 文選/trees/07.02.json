{
    "07.02": {
        "篇名": "潘安仁 藉田賦",
        "1": {
            "3": {
                "1": "伊晉之四年正月丁未",
                "2": "皇帝親率羣後籍於千畝之甸",
                "3": "禮也",
                "4": "於是乃使甸師清畿",
                "5": "野廬掃路",
                "6": "封人壝宮",
                "7": "掌舍設枑",
                "8": "青壇蔚其嶽立兮",
                "9": "翠幕黕以雲布",
                "10": "結崇基之靈址兮",
                "11": "啟四塗之廣阼",
                "12": "沃野墳腴",
                "13": "膏壤平砥",
                "14": "清洛濁渠",
                "15": "引流激水",
                "16": "遐阡繩直",
                "17": "邇陌如矢",
                "18": "蔥犗服於縹軛兮",
                "19": "紺轅綴於黛耜",
                "20": "儼儲駕於廛左兮",
                "21": "俟萬乘之躬履",
                "22": "百僚先置",
                "23": "位以職分",
                "24": "自上下下",
                "25": "具惟命臣",
                "26": "襲春服之萋萋兮",
                "27": "接遊車之轔轔",
                "28": "微風生於輕幰兮",
                "29": "纖埃起於朱輪",
                "30": "森奉璋以偕列兮",
                "31": "望皇軒而肅震",
                "32": "若湛露之晞朝陽兮",
                "33": "眾星之拱北辰也",
                "34": "於是前驅魚麗",
                "35": "屬車鱗萃",
                "36": "閶闔洞起",
                "37": "參塗方駟",
                "38": "常伯陪乘",
                "39": "太僕秉轡",
                "40": "后妃獻穜稑之種",
                "41": "司農撰播殖之器",
                "42": "挈壺掌升降之節",
                "43": "宮正設門閭之蹕",
                "44": "天子乃御玉輦",
                "45": "蔭華蓋",
                "46": "衝牙錚鎗",
                "47": "綃紈綷䌨",
                "48": "金根照耀以烱晃兮",
                "49": "龍驥騰驤而沛艾",
                "50": "表朱玄於離坎",
                "51": "飛青縞於震兌中黃曄以發暉兮",
                "52": "方綵紛其繁會",
                "53": "五輅鳴鑾",
                "54": "九旗揚旆",
                "55": "瓊鈒入蕊",
                "56": "雲罕晻藹",
                "57": "簫管嘲𠹗以啾嘈兮",
                "58": "鼓鼙硡歷以砰𮁌",
                "59": "筍虡嶷以軒翥兮",
                "60": "洪鍾越乎區外",
                "61": "震震塡塡",
                "62": "塵騖連天",
                "63": "以幸乎籍田"
            }
        },
        "2": {
            "5": {
                "1": "蟬冕頻以灼灼兮",
                "2": "碧色肅其千千",
                "3": "似夜光之剖荊璞兮",
                "4": "若茂松之依山巓也",
                "5": "於是我皇乃降靈壇",
                "6": "撫御耦",
                "7": "遊場染屨",
                "8": "洪縻在手",
                "9": "三推而舍",
                "10": "庻人終畆",
                "11": "貴賤以班",
                "12": "或五或九",
                "13": "於斯時也",
                "14": "居靡都鄙",
                "15": "民無華裔",
                "16": "長幼雜遝以交集",
                "17": "士女頒斌而咸戾",
                "18": "被褐振裾",
                "19": "垂髫總䯻",
                "20": "躡踵側肩",
                "21": "掎裳連襼",
                "22": "黃塵爲之四合兮",
                "23": "陽光爲之潛翳",
                "24": "動容發音",
                "25": "而觀者莫不抃舞乎康衢",
                "26": "謳吟乎聖世",
                "27": "情欣樂乎昏作兮",
                "28": "慮盡力乎樹藝",
                "29": "靡推督而常勤兮",
                "30": "莫之課而自勵",
                "31": "躬先勞以悅使兮",
                "32": "豈嚴刑而猛制哉",
                "33": "有邑老田父",
                "34": "或進而稱曰",
                "35": "蓋損益隨時",
                "36": "理有常然",
                "37": "高以下爲基",
                "38": "民以食爲天",
                "39": "正其末者端其本",
                "40": "善其後者愼其先",
                "41": "夫九土之宜弗任",
                "42": "四民之務不一",
                "43": "野有菜蔬之色",
                "44": "朝乏代耕之秩",
                "45": "無儲蓄以虞災",
                "46": "徒望歲以自畢",
                "47": "三代之衰皆此物也",
                "48": "今聖上昧旦丕顯",
                "49": "夕惕若慄",
                "50": "圖匱於豐",
                "51": "防儉於逸",
                "52": "欽哉欽哉",
                "53": "惟穀之卹",
                "54": "展三時之弘務",
                "55": "致倉廩於盈溢",
                "56": "固堯",
                "57": "湯之用心",
                "58": "而存救之要術也",
                "59": "若乃廟祧有事",
                "60": "祝宗諏日",
                "61": "簠簋普淖",
                "62": "此之自實",
                "63": "縮鬯蕭茅",
                "64": "又於是乎出",
                "65": "黍稷馨香",
                "66": "旨酒嘉栗",
                "67": "宜其時和年登",
                "68": "而神降之吉也"
            }
        },
        "3": {
            "7": {
                "1": "古人有言曰",
                "2": "聖人之得無以加於孝乎",
                "3": "夫孝者",
                "4": "天地之性",
                "5": "人之所由靈也",
                "6": "昔者明王以孝治天下",
                "7": "其或繼之者鮮哉希矣",
                "8": "逮我皇晉",
                "9": "實光斯道",
                "10": "儀刑孚於萬國",
                "11": "愛敬盡於祖考",
                "12": "故躬稼以供粢盛",
                "13": "所以致孝也",
                "14": "勸穡以足百姓",
                "15": "所以固本也",
                "16": "能本而孝",
                "17": "盛德大業至矣哉",
                "18": "此一役也",
                "19": "而二美具焉",
                "20": "不亦遠乎",
                "21": "不亦重乎",
                "22": "敢作頌曰"
            }
        },
        "4": {
            "9": {
                "1": "思樂甸畿",
                "2": "薄采其茅",
                "3": "大君戾止",
                "4": "言藉其農",
                "5": "其農三推",
                "6": "萬方以祇",
                "7": "耨我公田",
                "8": "遂及我私",
                "9": "我簠斯盛",
                "10": "我簋斯齊",
                "11": "我倉如陵",
                "12": "我瘐如坻",
                "13": "念茲在茲",
                "14": "永言孝思",
                "15": "人力普存",
                "16": "祝史正辭",
                "17": "神祇攸歆",
                "18": "逸豫無期",
                "19": "一人有慶",
                "20": "兆民頼之"
            }
        }
    }
}