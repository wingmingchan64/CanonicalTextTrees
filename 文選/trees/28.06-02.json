{
    "28.06-02": {
        "篇名": "陸士衡 輓歌詩三首·其二",
        "1": {
            "3": {
                "1": "重阜何崔嵬",
                "2": "玄廬竄其間",
                "3": "旁薄立四極",
                "4": "穹隆放蒼天",
                "5": "側聽陰溝涌",
                "6": "臥觀天井懸",
                "7": "廣霄何寥廓",
                "8": "大暮安可晨",
                "9": "人往有反歲",
                "10": "我行無歸年",
                "11": "昔居四民宅",
                "12": "今託萬鬼鄰",
                "13": "昔爲七尺軀",
                "14": "今成灰與塵",
                "15": "金玉素所佩",
                "16": "鴻毛今不振",
                "17": "豐肌饗螻蟻",
                "18": "姸姿永夷泯",
                "19": "壽堂延螭魅",
                "20": "虛無自相賓",
                "21": "螻蟻爾何怨",
                "22": "螭魅我何親",
                "23": "拊心痛荼毒",
                "24": "永歎莫爲陳"
            }
        }
    }
}