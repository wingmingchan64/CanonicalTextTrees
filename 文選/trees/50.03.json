{
    "50.03": {
        "篇名": "范蔚宗 逸民傳論",
        "1": {
            "3": {
                "1": "易稱遯之時義大矣哉",
                "2": "又曰",
                "3": "不事王侯",
                "4": "高尙其事",
                "5": "是以堯稱則天",
                "6": "而不屈潁陽之高",
                "7": "武盡美矣",
                "8": "終全孤竹之絜",
                "9": "自茲以降",
                "10": "風流彌繁",
                "11": "長往之軌未殊",
                "12": "而感致之數匪一",
                "13": "或隱居以求其志",
                "14": "或迴避以全其道",
                "15": "或靜己以鎭其躁",
                "16": "或去危以圖其安",
                "17": "或垢俗以動其槪",
                "18": "或疵物以激其清",
                "19": "然觀其甘心畎畝之中",
                "20": "憔悴江海之上",
                "21": "豈必親魚鳥樂林草哉",
                "22": "亦云介性所至而已",
                "23": "故蒙恥之賓",
                "24": "屢黜不去其國",
                "25": "蹈海之節",
                "26": "千乘莫移其情",
                "27": "適使矯易去就",
                "28": "則不能相爲矣",
                "29": "彼雖硜硜有類沽名者",
                "30": "然而蟬蛻囂埃之中",
                "31": "自致寰區之外",
                "32": "異夫飾智巧以逐浮利者乎",
                "33": "荀卿有言曰志意修則驕富貴",
                "34": "道義重則輕王公也"
            }
        },
        "2": {
            "5": {
                "1": "漢室中微",
                "2": "王莽篡位",
                "3": "士之蘊藉義憤甚矣",
                "4": "是時裂冠毀冕",
                "5": "相攜持而去之者",
                "6": "蓋不可勝數",
                "7": "揚雄曰",
                "8": "鴻飛冥冥",
                "9": "弋人何篡焉",
                "10": "言其違患之遠也",
                "11": "光武側席幽人",
                "12": "求之若不及",
                "13": "旌帛蒲車之所徵賁",
                "14": "相望於巖中矣",
                "15": "若薛方逄萌聘而不肯至",
                "16": "嚴光周黨王霸至而不能屈",
                "17": "羣方咸遂",
                "18": "志士懷仁",
                "19": "斯固所謂舉逸人則天下歸心者乎",
                "20": "肅宗亦禮鄭均而徵高鳳",
                "21": "以成其節",
                "22": "自後帝德稍衰",
                "23": "邪孼當朝",
                "24": "處子耿介",
                "25": "與卿相等列",
                "26": "至乃抗憤而不顧",
                "27": "多失其中行焉",
                "28": "蓋錄其絕塵不及",
                "29": "同夫作者",
                "30": "列之此篇"
            }
        }
    }
}