{
    "20.05": {
        "篇名": "王仲宣 公讌詩",
        "1": {
            "3": {
                "1": "昊天降豐澤",
                "2": "百卉挺葳蕤",
                "3": "涼風撤蒸暑",
                "4": "清雲卻炎暉",
                "5": "高會君子堂",
                "6": "並坐蔭華榱",
                "7": "嘉肴充圓方",
                "8": "旨酒盈金罍",
                "9": "管絃發徽音",
                "10": "曲度清且悲",
                "11": "合坐同所樂",
                "12": "但愬杯行遲",
                "13": "常聞詩人語",
                "14": "不醉且無歸",
                "15": "今日不極歡",
                "16": "含情慾待誰",
                "17": "見眷良不翅",
                "18": "守分豈能違",
                "19": "古人有遺言",
                "20": "君子福所綏",
                "21": "願我賢主人",
                "22": "與天享巍巍",
                "23": "克符周公業",
                "24": "奕世不可追"
            }
        }
    }
