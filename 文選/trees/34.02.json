{
    "34.02": {
        "篇名": "曹子建 七啟八首[幷序]",
        "1": {
            "3": {
                "1": "昔枚乘作七發",
                "2": "傅毅作七激",
                "3": "張衡作七辯",
                "4": "崔駰作七依",
                "5": "辭各美麗",
                "6": "余有慕之焉",
                "7": "遂作七啟",
                "8": "幷命王粲作焉"
            }
        },
        "2": {
            "5": {
                "1": "玄微子隱居大荒之庭",
                "2": "飛遯離俗",
                "3": "澄神定靈",
                "4": "輕祿傲貴",
                "5": "與物無營",
                "6": "耽虛好靜",
                "7": "羨此永生",
                "8": "獨馳思於天雲之際",
                "9": "無物象而能傾",
                "10": "於是鏡機子聞而將往說焉",
                "11": "駕超野之駟",
                "12": "乘追風之輿",
                "13": "經迥漠",
                "14": "出幽墟",
                "15": "入乎泱漭之野",
                "16": "遂屆玄微子之所居",
                "17": "其居也",
                "18": "左激水",
                "19": "右高岑",
                "20": "背洞溪",
                "21": "對芳林",
                "22": "冠皮弁",
                "23": "被文裘",
                "24": "出山岫之潛穴",
                "25": "倚峻崖而嬉遊",
                "26": "志飄颻焉",
                "27": "嶢嶢焉",
                "28": "似若狹六合而隘九州",
                "29": "若將飛而未逝",
                "30": "若舉翼而中留",
                "31": "於是鏡機子攀葛藟而登",
                "32": "距巖而立",
                "33": "順風而稱曰",
                "34": "予聞君子不遯俗而遺名",
                "35": "智士不背世而滅勳",
                "36": "今吾子棄道藝之華",
                "37": "遺仁義之英",
                "38": "耗精神乎虛廓",
                "39": "廢人事之紀經",
                "40": "譬若畫形於無象",
                "41": "造響於無聲",
                "42": "未之思乎",
                "43": "何所規之不通也",
                "44": "玄微子俯而應之曰",
                "45": "譆",
                "46": "有是言乎",
                "47": "夫太極之初",
                "48": "渾沌未分",
                "49": "萬物紛錯",
                "50": "與道俱隆",
                "51": "蓋有形必朽",
                "52": "有迹必窮",
                "53": "芒芒元氣",
                "54": "誰知其終",
                "55": "名穢我身",
                "56": "位累我躬",
                "57": "竊慕古人之所志",
                "58": "仰老莊之遺風",
                "59": "假靈龜以託喩",
                "60": "寧掉尾於塗中"
            }
        },
        "3": {
            "7": {
                "1": "鏡機子曰",
                "2": "夫辯言之豔",
                "3": "能使窮澤生流",
                "4": "枯木發榮",
                "5": "庶感靈而激神",
                "6": "況近在乎人情",
                "7": "僕將爲吾子說遊觀之至娛",
                "8": "演聲色之妖靡",
                "9": "論變化之至妙",
                "10": "敷道德之弘麗",
                "11": "願聞之乎",
                "12": "玄微子曰",
                "13": "吾子整身倦世",
                "14": "探隱拯沈",
                "15": "不遠遐路",
                "16": "幸見光臨",
                "17": "將敬滌耳",
                "18": "以聽玉音"
            }
        },
        "4": {
            "9": {
                "1": "鏡機子曰",
                "2": "芳菰精粺",
                "3": "霜蓄露葵",
                "4": "玄熊素膚",
                "5": "肥豢膿肌",
                "6": "蟬翼之割",
                "7": "剖纖析微",
                "8": "累如疊縠",
                "9": "離若散雪",
                "10": "輕隨風飛",
                "11": "刃不轉切",
                "12": "山鵽斥鷃",
                "13": "珠翠之珍",
                "14": "寒芳苓之巢龜",
                "15": "膾西海之飛鱗",
                "16": "寒",
                "17": "今𦙫肉也",
                "18": "鹽鐵論曰",
                "19": "煎魚切肝",
                "20": "羊淹雞寒",
                "21": "劉熙釋名曰",
                "22": "韓雞",
                "23": "本出韓國所爲",
                "24": "寒與韓同",
                "25": "史記曰",
                "26": "有神龜在江南嘉林中",
                "27": "常巢於芳蓮之上",
                "28": "苓與蓮同",
                "29": "西海飛鱗",
                "30": "卽文鰩也",
                "31": "山海經曰",
                "32": "泰器之山",
                "33": "濩水出焉",
                "34": "是多鰩魚",
                "35": "常行西海",
                "36": "而遊於東海",
                "37": "夜飛而行",
                "38": "臛江東之潛鼉",
                "39": "臇漢南之鳴鶉",
                "40": "糅以芳酸",
                "41": "甘和旣醇",
                "42": "玄冥適鹹",
                "43": "蓐收調辛",
                "44": "紫蘭丹椒",
                "45": "施和必節",
                "46": "滋味旣殊",
                "47": "遺芳射越",
                "48": "乃有春清縹酒",
                "49": "康狄所營",
                "50": "應化則變",
                "51": "感氣而成",
                "52": "彈徵則苦發",
                "53": "叩宮則甘生",
                "54": "於是盛以翠尊",
                "55": "酌以彫觴",
                "56": "浮蟻鼎沸",
                "57": "酷烈馨香",
                "58": "可以和神",
                "59": "可以娛腸",
                "60": "此肴饌之妙也",
                "61": "子能從我而食之乎",
                "62": "玄微子曰",
                "63": "予甘藜藿",
                "64": "未暇此食也"
            }
        },
        "5": {
            "11": {
                "1": "鏡機子曰",
                "2": "步光之劍",
                "3": "華藻繁縟",
                "4": "飾以文犀",
                "5": "彫以翠綠",
                "6": "綴以驪龍之珠",
                "7": "錯以荊山之玉",
                "8": "陸斷犀象",
                "9": "未足稱雋",
                "10": "隨波截鴻",
                "11": "水不漸刃",
                "12": "九旒之冕",
                "13": "散耀垂文",
                "14": "華組之纓",
                "15": "從風紛紜",
                "16": "佩則結綠懸黎",
                "17": "寶之妙微",
                "18": "符采照爛",
                "19": "流景揚煇",
                "20": "黼黻之服",
                "21": "紗縠之裳",
                "22": "金華之舄",
                "23": "動趾遺光",
                "24": "繁飾參差",
                "25": "微鮮若霜",
                "26": "緄佩綢繆",
                "27": "或彫或錯",
                "28": "薰以幽若",
                "29": "流芳肆布",
                "30": "雍容閑步",
                "31": "周旋馳燿",
                "32": "南威爲之解顏",
                "33": "西施爲之巧笑",
                "34": "此容飾之妙也",
                "35": "子能從我而服之乎",
                "36": "玄微子曰",
                "37": "予好毛褐",
                "38": "未暇此服也"
            }
        },
        "6": {
            "13": {
                "1": "鏡機子曰",
                "2": "馳騁足用蕩思",
                "3": "遊獵可以娛情",
                "4": "僕將爲吾子駕雲龍之飛駟",
                "5": "飾玉路之繁纓",
                "6": "垂宛虹之長緌",
                "7": "抗招搖之華旍",
                "8": "捷忘歸之矢",
                "9": "秉繁弱之弓",
                "10": "忽躡景而輕騖",
                "11": "逸奔驥而超遺風",
                "12": "於是磎塡谷塞",
                "13": "榛藪平夷",
                "14": "緣山置罝",
                "15": "彌野張罘",
                "16": "下無滿迹",
                "17": "上無逸飛",
                "18": "鳥集獸屯",
                "19": "然後會圍",
                "20": "獠徒雲布",
                "21": "武騎霧散",
                "22": "丹旗燿野",
                "23": "戈殳皓旰",
                "24": "曳文狐",
                "25": "揜狡兔",
                "26": "捎鷫鷞",
                "27": "拂振鷺",
                "28": "當軌見藉",
                "29": "値足遇踐",
                "30": "飛軒電逝",
                "31": "獸隨輪轉",
                "32": "翼不暇張",
                "33": "足不及騰",
                "34": "動觸飛鋒",
                "35": "舉挂輕罾",
                "36": "搜林索險",
                "37": "探薄窮阻",
                "38": "騰山赴壑",
                "39": "風厲焱舉",
                "40": "機不虛發",
                "41": "中必飲羽",
                "42": "於是人稠網密",
                "43": "地逼勢脅",
                "44": "哮闞之獸",
                "45": "張牙奮鬣",
                "46": "志在觸突",
                "47": "猛氣不慴",
                "48": "乃使北宮東郭之疇",
                "49": "生抽豹尾",
                "50": "分裂貙肩",
                "51": "形不抗手",
                "52": "骨不隱拳",
                "53": "批熊碎掌",
                "54": "拉虎摧斑",
                "55": "野無毛類",
                "56": "林無羽羣",
                "57": "積獸如陵",
                "58": "飛翮成雲",
                "59": "於是駴鍾鳴鼓",
                "60": "收旌弛旆",
                "61": "頓綱縱網",
                "62": "羆獠回邁",
                "63": "駿騄齊驤",
                "64": "揚鑾飛沫",
                "65": "俯倚金較",
                "66": "仰撫翠蓋",
                "67": "雍容暇豫",
                "68": "娛志方外",
                "69": "此羽獵之妙也",
                "70": "子能從我而觀之乎",
                "71": "玄微子曰",
                "72": "予樂恬靜",
                "73": "未暇此觀也"
            }
        },
        "7": {
            "15": {
                "1": "鏡機子曰",
                "2": "閑宮顯敞",
                "3": "雲屋皓旰",
                "4": "崇景山之高基",
                "5": "迎清風而立觀",
                "6": "彤軒紫柱",
                "7": "文榱華梁",
                "8": "綺井含葩",
                "9": "金墀玉箱",
                "10": "溫房則冬服絺𥿭",
                "11": "清室則中夏含霜",
                "12": "華閣緣雲",
                "13": "飛陛陵虛",
                "14": "頫眺流星",
                "15": "仰觀八隅",
                "16": "升龍攀而不逮",
                "17": "眇天際而高居",
                "18": "繁巧神怪",
                "19": "變名異形",
                "20": "班輸無所措其斧斤",
                "21": "離婁爲之失睛",
                "22": "麗草交植",
                "23": "殊品詭類",
                "24": "綠葉朱榮",
                "25": "熙天曜日",
                "26": "素水盈沼",
                "27": "叢木成林",
                "28": "飛翮凌高",
                "29": "鱗甲隱深",
                "30": "於是逍遙暇豫",
                "31": "忽若忘歸",
                "32": "乃使任子垂釣",
                "33": "魏氏發機",
                "34": "芳餌沈水",
                "35": "輕繳弋飛",
                "36": "落翳雲之翔鳥",
                "37": "援九淵之靈龜",
                "38": "然後采菱華",
                "39": "擢水蘋",
                "40": "弄珠蚌",
                "41": "戲鮫人",
                "42": "諷漢廣之所詠",
                "43": "覿遊女於水濱",
                "44": "燿神景於中沚",
                "45": "被輕縠之纖羅",
                "46": "遺芳烈而靖步",
                "47": "抗皓手而清歌",
                "48": "歌曰",
                "49": "望雲際兮有好仇",
                "50": "天路長兮往無由",
                "51": "佩蘭蕙兮爲誰修",
                "52": "宴婉絕兮我心愁",
                "53": "此宮館之妙也",
                "54": "子能從我而居之乎",
                "55": "玄微子曰",
                "56": "予耽巖穴",
                "57": "未暇此居也"
            }
        },
        "8": {
            "17": {
                "1": "鏡機子曰",
                "2": "旣遊觀中原",
                "3": "逍遙閑宮",
                "4": "情放志蕩",
                "5": "淫樂未終",
                "6": "亦將有才人妙妓",
                "7": "遺世越俗",
                "8": "揚北里之流聲",
                "9": "紹陽阿之妙曲",
                "10": "爾乃御文軒",
                "11": "臨洞庭",
                "12": "琴瑟交揮",
                "13": "左篪右笙",
                "14": "鍾鼓俱振",
                "15": "簫管齊鳴",
                "16": "然後姣人乃被文縠之華褂",
                "17": "振輕綺之飄颻",
                "18": "戴金搖之熠燿",
                "19": "揚翠羽之雙翹",
                "20": "揮流芳",
                "21": "燿飛文",
                "22": "歷盤鼓",
                "23": "煥繽紛",
                "24": "長裾隨風",
                "25": "悲歌入雲",
                "26": "蹻捷若飛",
                "27": "蹈虛遠蹠",
                "28": "凌躍超驤",
                "29": "蜿蟬揮霍",
                "30": "翔爾鴻翥",
                "31": "濈然鳧沒",
                "32": "縱輕體以迅赴",
                "33": "景追形而不逮",
                "34": "飛聲激塵",
                "35": "依違厲響",
                "36": "才捷若神",
                "37": "形難爲象",
                "38": "於是爲歡未渫",
                "39": "白日西頹",
                "40": "散樂變飾",
                "41": "微步中閨",
                "42": "玄眉弛兮鉛華落",
                "43": "收亂髮兮拂蘭澤",
                "44": "形媠服兮揚幽若",
                "45": "紅顏宜笑",
                "46": "睇眄流光",
                "47": "時與吾子",
                "48": "攜手同行",
                "49": "踐飛除",
                "50": "卽閑房",
                "51": "華燭爛",
                "52": "幄幙張",
                "53": "動朱脣",
                "54": "發清商",
                "55": "揚羅袂",
                "56": "振華裳",
                "57": "九秋之夕",
                "58": "爲歡未央",
                "59": "此聲色之妙也",
                "60": "子能從我而遊之乎",
                "61": "玄微子曰",
                "62": "予願清虛",
                "63": "未暇此遊也"
            }
        },
        "9": {
            "19": {
                "1": "鏡機子曰",
                "2": "予聞君子樂奮節以顯義",
                "3": "烈士甘危軀以成仁",
                "4": "是以雄俊之徒",
                "5": "交黨結倫",
                "6": "重氣輕命",
                "7": "感分遺身",
                "8": "故田光伏劍於北燕",
                "9": "公叔畢命於西秦",
                "10": "果毅輕斷",
                "11": "虎步谷風",
                "12": "威慴萬乘",
                "13": "華夏稱雄",
                "14": "辭未及終",
                "15": "而玄微子曰",
                "16": "善"
            }
        },
        "10": {
            "21": {
                "1": "鏡機子曰",
                "2": "此乃遊俠之徒耳",
                "3": "未足稱妙也",
                "4": "若夫田文無忌之儔",
                "5": "乃上古之俊公子也",
                "6": "皆飛仁揚義",
                "7": "騰躍道藝",
                "8": "遊心無方",
                "9": "抗志雲際",
                "10": "凌轢諸侯",
                "11": "駈馳當世",
                "12": "揮袂則九野生風",
                "13": "慷慨則氣成虹蜺",
                "14": "吾子若當此之時",
                "15": "能從我而友之乎",
                "16": "玄微子曰",
                "17": "子亮願焉",
                "18": "然方於大道",
                "19": "有累如何"
            }
        },
        "11": {
            "23": {
                "1": "鏡機子曰",
                "2": "世有聖宰",
                "3": "翼帝霸世",
                "4": "同量乾坤",
                "5": "等曜日月",
                "6": "玄化參神",
                "7": "與靈合契",
                "8": "惠澤播於黎苗",
                "9": "威靈震乎無外",
                "10": "超隆平於殷周",
                "11": "踵羲皇而齊泰",
                "12": "顯朝惟清",
                "13": "王道遐均",
                "14": "民望如草",
                "15": "我澤如春",
                "16": "河濱無洗耳之士",
                "17": "喬岳無巢居之民",
                "18": "是以俊乂來仕",
                "19": "觀國之光",
                "20": "舉不遺才",
                "21": "進各異方",
                "22": "讚典禮於辟雍",
                "23": "講文德於明堂",
                "24": "正流俗之華說",
                "25": "綜孔氏之舊章",
                "26": "散樂移風",
                "27": "國富民康",
                "28": "神應休臻",
                "29": "屢獲嘉祥",
                "30": "故甘靈紛而晨降",
                "31": "景星宵而舒光",
                "32": "觀遊龍於神淵",
                "33": "聆鳴鳳於高岡",
                "34": "此霸道之至隆",
                "35": "而雍熙之盛際",
                "36": "然主上猶以沈恩之未廣",
                "37": "懼聲教之未厲",
                "38": "采英奇於仄陋",
                "39": "宣皇明於巖穴",
                "40": "此甯子商歌之秋",
                "41": "而呂望所以投綸而逝也",
                "42": "吾子爲太和之民",
                "43": "不欲仕陶唐之世乎",
                "44": "於是玄微子攘袂而興曰",
                "45": "𩏧哉言乎",
                "46": "近者吾子",
                "47": "所述華淫",
                "48": "欲以厲我",
                "49": "祇攪予心",
                "50": "至聞天下穆清",
                "51": "明君蒞國",
                "52": "覽盈虛之正義",
                "53": "知頑素之迷惑",
                "54": "今予廓爾",
                "55": "身輕若飛",
                "56": "願反初服",
                "57": "從子而歸"
            }
        }
    }
}