{
    "25.13-01": {
        "篇名": "謝惠連 西陵遇風獻康樂·其一",
        "1": {
            "3": {
                "1": "我行指孟春",
                "2": "春仲尙未發",
                "3": "趣途遠有期",
                "4": "念離情無歇",
                "5": "成裝候良辰",
                "6": "漾舟陶嘉月",
                "7": "瞻塗意少悰",
                "8": "還顧情多闕"
            }
        }
    }
}