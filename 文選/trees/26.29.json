{
    "26.29": {
        "篇名": "謝靈運 道路憶山中",
        "1": {
            "3": {
                "1": "采菱調易急",
                "2": "江南歌不緩",
                "3": "楚人心昔絕",
                "4": "越客腸今斷",
                "5": "斷絕雖殊念",
                "6": "俱爲歸慮款",
                "7": "存鄕爾思積",
                "8": "憶山我憤懣",
                "9": "追尋栖息時",
                "10": "偃臥任縱誕",
                "11": "得性非外求",
                "12": "自已爲誰纂",
                "13": "不怨秋夕長",
                "14": "常苦夏日短",
                "15": "濯流激浮湍",
                "16": "息陰倚密竿",
                "17": "懷故叵新歡",
                "18": "含悲忘春㬉",
                "19": "言春㬉當喜",
                "20": "爲含悲而忘之",
                "21": "書曰",
                "22": "叵",
                "23": "不可也",
                "24": "莊子曰",
                "25": "暖然似春",
                "26": "悽悽明月吹",
                "27": "惻惻廣陵散",
                "28": "殷勤訴危柱",
                "29": "慷慨命促管"
            }
        }
    }
}