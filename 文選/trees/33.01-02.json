{
    "33.01-02": {
        "篇名": "屈平 九歌二首·山鬼",
        "1": {
            "3": {
                "1": "若有人兮山之阿",
                "2": "被薜荔兮帶女蘿",
                "3": "旣含睇兮又宜笑",
                "4": "子慕予兮善窈窕",
                "5": "乘赤豹兮從文貍",
                "6": "辛夷車兮結桂旗",
                "7": "被石蘭兮帶杜衡",
                "8": "折芳馨兮遺所思",
                "9": "余處幽篁兮終不見天",
                "10": "路險難兮獨後來",
                "11": "表獨立兮山之上",
                "12": "雲容容兮而在下",
                "13": "杳冥冥兮羌晝晦",
                "14": "東風飄兮神靈雨",
                "15": "留靈修兮憺忘歸",
                "16": "歲旣晏兮孰華予",
                "17": "采三秀兮於山間",
                "18": "石磊磊兮葛蔓蔓",
                "19": "怨公子兮悵忘歸",
                "20": "君思我兮不得間",
                "21": "山中人兮芳杜若",
                "22": "飲石泉兮蔭松柏",
                "23": "君思我兮然疑作",
                "24": "雷塡塡兮雨冥冥",
                "25": "猿啾啾兮狖夜鳴",
                "26": "風颯颯兮木蕭蕭",
                "27": "思公子兮徒離憂"
            }
        }
    }
}