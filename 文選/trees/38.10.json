{
    "38.10": {
        "篇名": "任彥升 爲褚諮議蓁讓代兄襲封表",
        "1": {
            "3": {
                "1": "臣蓁言",
                "2": "昨被司徒符",
                "3": "仰稱詔旨",
                "4": "許臣兄賁所請",
                "5": "以臣襲封南康郡公",
                "6": "臣門籍勳蔭",
                "7": "光錫土宇",
                "8": "臣賁世載承家",
                "9": "允膺長德",
                "10": "而深鑒止足",
                "11": "脫屣千乘",
                "12": "遂乃遠謬推恩",
                "13": "近萃庸薄",
                "14": "能以國讓",
                "15": "弘義有歸",
                "16": "匹夫難奪",
                "17": "守以勿貳",
                "18": "昔武始迫家臣之策",
                "19": "陵陽感鮑生之言",
                "20": "張以誠請",
                "21": "丁爲理屈",
                "22": "且先臣以大宗絕緒",
                "23": "命臣出纂傍統",
                "24": "稟承在昔",
                "25": "理絕終天",
                "26": "永惟情事",
                "27": "觸目崩殞",
                "28": "若使賁高延陵之風",
                "29": "臣忘子臧之節",
                "30": "是廢德舉",
                "31": "豈曰能賢",
                "32": "陛下察其丹款",
                "33": "特賜停絕",
                "34": "不然",
                "35": "投身草澤",
                "36": "苟遂愚誠耳",
                "37": "不勝丹慊之至",
                "38": "謹詣闕拜表以聞",
                "39": "臣誠惶誠恐以下"
            }
        }
    }
}