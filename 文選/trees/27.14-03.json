{
    "27.14-03": {
        "篇名": "王仲宣 從軍詩五首·其三",
        "1": {
            "3": {
                "1": "從軍征遐路",
                "2": "討彼東南夷",
                "3": "方舟順廣川",
                "4": "薄暮未安坻",
                "5": "白日半西山",
                "6": "桑梓有餘暉",
                "7": "蟋蟀夾岸鳴",
                "8": "孤鳥翩翩飛",
                "9": "征夫心多懷",
                "10": "惻愴令吾悲",
                "11": "下船登高防",
                "12": "草露霑我衣",
                "13": "迴身赴牀寢",
                "14": "此悉當告誰",
                "15": "身服干戈事",
                "16": "豈得念所私",
                "17": "卽戎有授命",
                "18": "茲理不可違"
            }
        }
    }
}