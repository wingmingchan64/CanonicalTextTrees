{
    "54.02": {
        "篇名": "劉孝標 辯命論",
        "1": {
            "3": {
                "1": "主上嘗與諸名賢言及管輅",
                "2": "歎其有奇才而位不達",
                "3": "時有在赤墀之下豫聞斯議",
                "4": "歸以告余",
                "5": "余謂士之窮通",
                "6": "無非命也",
                "7": "故謹述天旨",
                "8": "因言其致云"
            }
        },
        "2": {
            "5": {
                "1": "臣觀管輅",
                "2": "天才英偉",
                "3": "珪璋特秀",
                "4": "實海內之名傑",
                "5": "豈日者卜祝之流乎",
                "6": "而官止少府丞",
                "7": "年終四十八",
                "8": "天之報施",
                "9": "何其寡與",
                "10": "然則高才而無貴仕",
                "11": "饕餮而居大位",
                "12": "自古所歎",
                "13": "焉獨公明而已哉",
                "14": "故性命之道",
                "15": "窮通之數",
                "16": "夭閼紛綸",
                "17": "莫知其辯",
                "18": "仲任蔽其源",
                "19": "子長闡其惑",
                "20": "至於鶡冠甕牖",
                "21": "必以懸天有期",
                "22": "鼎貴高門",
                "23": "則曰唯人所召",
                "24": "譊譊讙咋",
                "25": "異端斯起",
                "26": "蕭遠論其本而不暢其流",
                "27": "子玄語其流而未詳其本",
                "28": "嘗試言之曰",
                "29": "夫通生萬物",
                "30": "則謂之道",
                "31": "生而無主",
                "32": "謂之自然",
                "33": "自然者",
                "34": "物見其然",
                "35": "不知所以然",
                "36": "同焉皆得",
                "37": "不知所以得",
                "38": "鼓動陶鑄而不爲功",
                "39": "庶類混成而非其力",
                "40": "生之無亭毒之心",
                "41": "死之豈虔劉之志",
                "42": "墜之淵泉非其怒",
                "43": "升之霄漢非其悅",
                "44": "蕩乎大乎",
                "45": "萬寶以之化",
                "46": "確乎純乎",
                "47": "一化而不易",
                "48": "化而不易",
                "49": "則謂之命",
                "50": "命也者",
                "51": "自天之命也",
                "52": "定於冥兆",
                "53": "終然不變",
                "54": "鬼神莫能預",
                "55": "聖哲不能謀",
                "56": "觸山之力無以抗",
                "57": "倒日之誠弗能感",
                "58": "淮南子曰",
                "59": "昔共工之力",
                "60": "怒𧢻不周之山",
                "61": "使地東南傾",
                "62": "與高辛爭爲帝",
                "63": "許愼曰",
                "64": "昔共工",
                "65": "古諸侯之強者也",
                "66": "不周之山",
                "67": "西北之山也",
                "68": "陸機弔魏武文曰",
                "69": "夫以迴天倒日之力",
                "70": "而不能振形骸之內",
                "71": "短則不可緩之於寸陰",
                "72": "長則不可急之於箭漏",
                "73": "至德未能踰",
                "74": "上智所不免",
                "75": "是以放勛之世",
                "76": "浩浩襄陵",
                "77": "天乙之時",
                "78": "焦金流石",
                "79": "文公𨆫其尾",
                "80": "宣尼絕其糧",
                "81": "傅子曰",
                "82": "周文王子公旦有聖德",
                "83": "謚曰文",
                "84": "毛詩曰",
                "85": "狼跋",
                "86": "美周公也",
                "87": "狼跋其胡",
                "88": "載疐其尾",
                "89": "毛萇曰",
                "90": "疐",
                "91": "跲也",
                "92": "𨆫音致",
                "93": "漢書平紀曰",
                "94": "追謚孔子曰宣尼公",
                "95": "論語曰",
                "96": "子在陳絕糧",
                "97": "從者病",
                "98": "莫能興",
                "99": "顏回敗其叢蘭",
                "100": "冉耕歌其芣衞",
                "101": "夷叔斃淑媛之言",
                "102": "子輿困臧倉之訴",
                "103": "聖賢且猶若此",
                "104": "而況庸庸者乎",
                "105": "至乃伍員浮尸於江流",
                "106": "三閭沈骸於湘渚",
                "107": "賈大夫沮志於長沙",
                "108": "馮都尉皓髮於郎署",
                "109": "君山鴻漸",
                "110": "鎩羽儀於高雲",
                "111": "敬通鳳起",
                "112": "摧迅翮於風穴",
                "113": "此豈才不足而行有遺哉"
            }
        },
        "3": {
            "7": {
                "1": "近世有沛國劉瓛",
                "2": "瓛弟璡",
                "3": "並一時之秀士也",
                "4": "瓛則關西孔子",
                "5": "通涉六經",
                "6": "循循善誘",
                "7": "服膺儒行",
                "8": "璡則志烈秋霜",
                "9": "心貞崑玉",
                "10": "亭亭高竦",
                "11": "不雜風塵",
                "12": "皆毓德於衡門",
                "13": "並馳聲於天地",
                "14": "而官有微於侍郎",
                "15": "位不登於執戟",
                "16": "相次殂落",
                "17": "宗祀無饗",
                "18": "因斯兩賢以言古",
                "19": "則昔之玉質金相",
                "20": "英髦秀達",
                "21": "皆擯斥於當年",
                "22": "韞奇才而莫用",
                "23": "徼草木以共彫",
                "24": "與麋鹿而同死",
                "25": "膏塗平原",
                "26": "骨塡川谷",
                "27": "堙滅而無聞者",
                "28": "豈可勝道哉",
                "29": "此則宰衡之與皁隸",
                "30": "容彭之與殤子",
                "31": "猗頓之與黔婁",
                "32": "陽文之與敦洽",
                "33": "咸得之於自然",
                "34": "不假道於才智",
                "35": "故曰死生有命",
                "36": "富貴在天",
                "37": "其斯之謂矣"
            }
        },
        "4": {
            "9": {
                "1": "然命體周流",
                "2": "變化非一",
                "3": "或先號後笑",
                "4": "或始吉終凶",
                "5": "或不召自來",
                "6": "或因人以濟",
                "7": "交錯糾紛",
                "8": "迴還倚伏",
                "9": "非可以一理徵",
                "10": "非可以一途驗",
                "11": "而其道密微",
                "12": "寂寥忽慌",
                "13": "無形可以見",
                "14": "無聲可以聞",
                "15": "必御物以效靈",
                "16": "亦憑人而成象",
                "17": "譬天王之冕旒",
                "18": "任百官以司職",
                "19": "而或者睹湯武之龍躍",
                "20": "謂龕亂在神功",
                "21": "聞孔墨之挺生",
                "22": "謂英睿擅奇響",
                "23": "視彭韓之豹變",
                "24": "謂鷙猛致人爵",
                "25": "見張桓之朱紱",
                "26": "謂明經拾青紫",
                "27": "豈知有力者運之而趨乎",
                "28": "故言而非命",
                "29": "有六蔽焉爾",
                "30": "請陳其梗槪"
            }
        },
        "5": {
            "11": {
                "1": "夫靡顏膩理",
                "2": "哆噅顣頞形之異也",
                "3": "朝秀晨終",
                "4": "龜鵠千歲",
                "5": "年之殊也",
                "6": "聞言如響",
                "7": "智昏菽麥",
                "8": "神之辨也",
                "9": "同知三者定乎造化榮辱之境",
                "10": "獨曰由人",
                "11": "是知二五而未識於十",
                "12": "其蔽一也"
            }
        },
        "6": {
            "13": {
                "1": "龍犀日角",
                "2": "帝王之表",
                "3": "河目龜文",
                "4": "公侯之相",
                "5": "撫鏡知其將刑",
                "6": "壓紐顯其膺錄",
                "7": "星虹樞電",
                "8": "昭聖德之符",
                "9": "夜哭聚雲",
                "10": "鬱興王之瑞",
                "11": "皆兆發於前期",
                "12": "渙汗於後葉",
                "13": "若謂驅貔虎",
                "14": "奮尺劍",
                "15": "入紫微",
                "16": "升帝道",
                "17": "則未達窅冥之情",
                "18": "未測神明之數",
                "19": "其蔽二也"
            }
        },
        "7": {
            "15": {
                "1": "空桑之里",
                "2": "變成洪川",
                "3": "歷陽之都",
                "4": "化爲魚鱉",
                "5": "楚師屠漢卒",
                "6": "睢河鯁其流",
                "7": "秦人坑趙士",
                "8": "沸聲若雷震",
                "9": "火炎崑嶽",
                "10": "礫石與琬琰俱焚",
                "11": "嚴霜夜零",
                "12": "蕭艾與芝蘭共盡",
                "13": "雖遊夏之英才伊顏之殆庶",
                "14": "焉能抗之哉",
                "15": "其蔽三也"
            }
        },
        "8": {
            "17": {
                "1": "或曰明月之珠",
                "2": "不能無纇",
                "3": "夏后之璜",
                "4": "不能無考",
                "5": "故亭伯死於縣長",
                "6": "相如卒於園令",
                "7": "才非不傑也",
                "8": "主非不明也",
                "9": "而碎結綠之鴻輝",
                "10": "殘懸黎之夜色",
                "11": "抑尺之量有短哉",
                "12": "若然者",
                "13": "主父偃公孫弘對策不升第",
                "14": "歷說而不入",
                "15": "牧豕淄原",
                "16": "見棄州部",
                "17": "設令忽如過隙",
                "18": "溘死霜露",
                "19": "其爲詬恥",
                "20": "豈崔馬之流乎",
                "21": "及至開東閤",
                "22": "列五鼎",
                "23": "電照風行",
                "24": "聲馳海外",
                "25": "寧前愚而後智",
                "26": "先非而終是",
                "27": "將榮悴有定數",
                "28": "天命有至極",
                "29": "而謬生姸蚩",
                "30": "其蔽四也"
            }
        },
        "9": {
            "19": {
                "1": "夫虎嘯風馳",
                "2": "龍興雲屬",
                "3": "故重華立而元凱升",
                "4": "辛受生而飛廉進",
                "5": "然則天下善人少",
                "6": "惡人多",
                "7": "闇主眾",
                "8": "明君寡",
                "9": "而薰蕕不同器",
                "10": "梟鸞不接翼",
                "11": "是使渾敦檮杌踵武於雲臺之上",
                "12": "仲容庭堅耕耘於巖石之下",
                "13": "橫謂廢興在我",
                "14": "無繫於天",
                "15": "其蔽五也"
            }
        },
        "10": {
            "21": {
                "1": "彼戎狄者",
                "2": "人面獸心",
                "3": "宴安鴆毒",
                "4": "以誅殺爲道德",
                "5": "以蒸報爲仁義",
                "6": "雖大風立於青丘",
                "7": "鑿齒奮於華野",
                "8": "比於狼戾",
                "9": "曾何足喩",
                "10": "自金行不競",
                "11": "天地板蕩",
                "12": "左帶沸脣",
                "13": "乘間電發",
                "14": "遂覆瀍洛",
                "15": "傾五都",
                "16": "居先王之桑梓",
                "17": "竊名號於中縣",
                "18": "與三皇競其萌黎",
                "19": "五帝角其區宇",
                "20": "種落繁熾",
                "21": "充仞神州",
                "22": "嗚呼",
                "23": "福善禍淫",
                "24": "徒虛言耳",
                "25": "豈非否泰相傾",
                "26": "盈縮遞運",
                "27": "而汩之以人",
                "28": "其蔽六也"
            }
        },
        "11": {
            "23": {
                "1": "然所謂命者",
                "2": "死生焉",
                "3": "貴賤焉",
                "4": "貧富焉",
                "5": "治亂焉",
                "6": "禍福焉",
                "7": "此十者",
                "8": "天之所賦也",
                "9": "愚智善惡",
                "10": "此四者",
                "11": "人之所行也",
                "12": "夫神非舜禹",
                "13": "心異朱均",
                "14": "才絓中庸",
                "15": "在於所習",
                "16": "是以素絲無恆",
                "17": "玄黃代起",
                "18": "鮑魚芳蘭",
                "19": "入而自變",
                "20": "故季路學於仲尼",
                "21": "厲風霜之節",
                "22": "楚穆謀於潘崇",
                "23": "成殺逆之禍",
                "24": "而商臣之惡",
                "25": "盛業光於後嗣",
                "26": "仲由之善",
                "27": "不能息其結纓",
                "28": "楚之後業皆商臣之子孫",
                "29": "周易曰",
                "30": "盛德大業",
                "31": "至矣哉",
                "32": "尙書曰",
                "33": "在今後嗣王",
                "34": "左氏傳曰",
                "35": "衞渾良夫與太子入舍於孔氏之外圃",
                "36": "欲劫孔悝而納太子",
                "37": "季子曰",
                "38": "太子無勇",
                "39": "若燔臺半",
                "40": "必舍孔叔",
                "41": "太子聞之",
                "42": "懼",
                "43": "下召石乞",
                "44": "盂𪒞敵子路",
                "45": "以戈擊之",
                "46": "斷纓",
                "47": "子路曰",
                "48": "君子死",
                "49": "冠不免",
                "50": "結纓而死",
                "51": "杜預曰",
                "52": "季子",
                "53": "子路是也",
                "54": "斯則邪正由於人",
                "55": "吉凶在乎命"
            }
        },
        "12": {
            "25": {
                "1": "或以鬼神害盈",
                "2": "皇天輔德",
                "3": "故宋公一言",
                "4": "法星三徙",
                "5": "殷帝自剪",
                "6": "千里來雲",
                "7": "若使善惡無徵",
                "8": "未洽斯義",
                "9": "且於公高門以待封",
                "10": "嚴母掃墓以望喪",
                "11": "此君子所以自彊不息也",
                "12": "如使仁而無報",
                "13": "奚爲修善立名乎",
                "14": "斯徑廷之辭也"
            }
        },
        "13": {
            "27": {
                "1": "夫聖人之言顯而晦",
                "2": "微而婉",
                "3": "幽遠而難聞",
                "4": "河漢而不測",
                "5": "或立教以進庸怠",
                "6": "或言命以窮性靈",
                "7": "積善餘慶",
                "8": "立教也",
                "9": "鳳鳥不至",
                "10": "言命也",
                "11": "今以其片言辯其要趣",
                "12": "何異乎夕死之類而論春秋之變哉",
                "13": "且荊昭德音",
                "14": "丹雲不卷",
                "15": "周宣祈雨",
                "16": "珪璧斯罄",
                "17": "於叟種德",
                "18": "不逮勛華之高",
                "19": "延年殘獷",
                "20": "未甚東陵之酷",
                "21": "爲善一",
                "22": "爲惡均",
                "23": "而禍福異其流",
                "24": "廢興殊其迹",
                "25": "蕩蕩上帝",
                "26": "豈如是乎",
                "27": "詩云",
                "28": "風雨如晦",
                "29": "雞鳴不已",
                "30": "故善人爲善",
                "31": "焉有息哉"
            }
        },
        "14": {
            "29": {
                "1": "夫食稻粱",
                "2": "進芻豢",
                "3": "衣狐貉",
                "4": "襲冰紈",
                "5": "觀窈眇之奇儛",
                "6": "聽雲和之琴瑟",
                "7": "此生人之所急",
                "8": "非有求而爲也",
                "9": "修道德",
                "10": "習仁義",
                "11": "敦孝悌",
                "12": "立忠貞",
                "13": "漸禮樂之腴潤",
                "14": "蹈先王之盛則",
                "15": "此君子之所急",
                "16": "非有求而爲也",
                "17": "然則君子居正體道",
                "18": "樂天知命",
                "19": "明其無可柰何",
                "20": "識其不由智力",
                "21": "逝而不召",
                "22": "來而不距",
                "23": "生而不喜",
                "24": "死而不慼",
                "25": "瑤臺夏屋",
                "26": "不能悅其神",
                "27": "土室編蓬",
                "28": "未足憂其慮",
                "29": "不充詘於富貴",
                "30": "不遑遑於所欲",
                "31": "豈有史公董相不遇之文乎"
            }
        }
    }
}