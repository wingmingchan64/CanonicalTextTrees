{
    "40.04": {
        "篇名": "楊德祖 答臨淄侯牋",
        "1": {
            "3": {
                "1": "修死罪死罪",
                "2": "不侍數日",
                "3": "若彌年載",
                "4": "豈由愛顧之隆",
                "5": "使係仰之情深邪",
                "6": "損辱嘉命",
                "7": "蔚矣其文",
                "8": "誦讀反覆",
                "9": "雖諷雅頌",
                "10": "不復過此",
                "11": "若仲宣之擅漢表",
                "12": "陳氏之跨冀域",
                "13": "徐劉之顯青豫",
                "14": "應生之發魏國",
                "15": "斯皆然矣",
                "16": "至於修者",
                "17": "聽采風聲",
                "18": "仰德不暇",
                "19": "自周章於省覽",
                "20": "何遑高視哉"
            }
        },
        "2": {
            "5": {
                "1": "伏惟君侯",
                "2": "少長貴盛",
                "3": "體發旦之資",
                "4": "有聖善之教",
                "5": "遠近觀者",
                "6": "徒謂能宣昭懿德",
                "7": "光贊大業而已",
                "8": "不復謂能兼覽傳記",
                "9": "留思文章",
                "10": "今乃含王超陳",
                "11": "度越數子矣",
                "12": "觀者駭視而拭目",
                "13": "聽者傾首而竦耳",
                "14": "非夫體通性達",
                "15": "受之自然",
                "16": "其孰能至於此乎",
                "17": "又嘗親見執事",
                "18": "握牘持筆",
                "19": "有所造作",
                "20": "若成誦在心",
                "21": "借書於手",
                "22": "曾不斯須少留思慮",
                "23": "仲尼日月",
                "24": "無得踰焉",
                "25": "修之仰望",
                "26": "殆如此矣",
                "27": "是以對鶡而辭",
                "28": "作暑賦彌日而不獻",
                "29": "見西施之容",
                "30": "歸增其貌者也"
            }
        },
        "3": {
            "7": {
                "1": "伏想執事",
                "2": "不知其然",
                "3": "猥受顧錫",
                "4": "教使刊定",
                "5": "春秋之成",
                "6": "莫能損益",
                "7": "呂氏淮南",
                "8": "字直千金",
                "9": "然而弟子箝口",
                "10": "市人拱手者",
                "11": "聖賢卓犖",
                "12": "固所以殊絕凡庸也",
                "13": "今之賦頌",
                "14": "古詩之流",
                "15": "不更孔公",
                "16": "風雅無別耳",
                "17": "修家子雲",
                "18": "老不曉事",
                "19": "強著一書",
                "20": "悔其少作",
                "21": "若此仲山周旦之儔",
                "22": "爲皆有伥邪",
                "23": "君侯忘聖賢之顯迹",
                "24": "述鄙宗之過言",
                "25": "竊以爲未之思也"
            }
        },
        "4": {
            "9": {
                "1": "若乃不忘經國之大美",
                "2": "流千載之英聲",
                "3": "銘功景鍾",
                "4": "書名竹帛",
                "5": "斯自雅量",
                "6": "素所畜也",
                "7": "豈與文章相妨害哉",
                "8": "輒受所惠",
                "9": "竊備矇瞍誦詠而已",
                "10": "敢望惠施以忝莊氏",
                "11": "季緒璅璅",
                "12": "何足以云",
                "13": "反答造次",
                "14": "不能宣備",
                "15": "修死罪死罪"
            }
        }
    }
}