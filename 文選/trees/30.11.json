{
    "30.11": {
        "篇名": "王景玄 雜詩",
        "1": {
            "3": {
                "1": "思婦臨高臺",
                "2": "長想憑華軒",
                "3": "弄絃不成曲",
                "4": "哀歌送苦言",
                "5": "箕帚留江介",
                "6": "良人處雁門",
                "7": "詎憶無衣苦",
                "8": "但知狐白溫",
                "9": "日闇牛羊下",
                "10": "野雀滿空園",
                "11": "孟冬寒風起",
                "12": "東壁正中昏",
                "13": "朱火獨照人",
                "14": "抱景自愁怨",
                "15": "誰知心曲亂",
                "16": "所思不可論"
            }
        }
    }
}