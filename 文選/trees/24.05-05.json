{
    "24.05-05": {
        "篇名": "曹子建 贈白馬王彪·其五",
        "1": {
            "3": {
                "1": "太息將何爲",
                "2": "天命與我違",
                "3": "柰何念同生",
                "4": "一往形不歸",
                "5": "孤魂翔故城",
                "6": "靈柩寄京師",
                "7": "存者忽復過",
                "8": "亡沒身自衰",
                "9": "人生處一世",
                "10": "去若朝露晞",
                "11": "年在桑楡間",
                "12": "影響不能追",
                "13": "自顧非金石",
                "14": "咄唶令心悲"
            }
        }
    }
}