{
    "16.05": {
        "篇名": "潘安仁 懷舊賦[幷序]",
        "1": {
            "3": {
                "1": "余十二而獲見於父友東武戴侯楊君",
                "2": "始見知名",
                "3": "遂申之以婚姻",
                "4": "而道元公嗣",
                "5": "亦隆世親之愛",
                "6": "不幸短命",
                "7": "父子凋殞",
                "8": "余旣有私艱",
                "9": "且尋役於外",
                "10": "不歷嵩丘之山者",
                "11": "九年於茲矣",
                "12": "今而經焉",
                "13": "慨然懷舊而賦之曰"
            }
        },
        "2": {
            "5": {
                "1": "啟開陽而朝邁",
                "2": "濟清洛以徑渡",
                "3": "晨風淒以激冷",
                "4": "夕雪暠以掩路",
                "5": "轍含冰以滅軌",
                "6": "水漸軔以凝冱",
                "7": "塗艱屯其難進",
                "8": "日晼晚而將暮",
                "9": "仰睎歸雲",
                "10": "俯鏡泉流",
                "11": "前瞻太室",
                "12": "傍眺嵩丘",
                "13": "東武託焉",
                "14": "建塋啟疇",
                "15": "巖巖雙表",
                "16": "列列行楸",
                "17": "望彼楸矣",
                "18": "感於予思",
                "19": "旣興慕於戴侯",
                "20": "亦悼元而哀嗣",
                "21": "墳壘壘而接壟",
                "22": "柏森森以攢植",
                "23": "何逝沒之相尋",
                "24": "曾舊草之未異"
            }
        },
        "3": {
            "7": {
                "1": "余總角而獲見",
                "2": "承戴侯之清塵",
                "3": "名余以國士",
                "4": "眷余以嘉姻",
                "5": "自祖考而隆好",
                "6": "逮二子而世親",
                "7": "歡攜手以偕老",
                "8": "庶報德之有鄰",
                "9": "今九載而一來",
                "10": "空館閴其無人",
                "11": "陳荄被於堂除",
                "12": "舊圃化而爲薪",
                "13": "步庭廡以徘徊",
                "14": "涕泫流而霑巾",
                "15": "宵展轉而不寐",
                "16": "驟長歎以達晨",
                "17": "獨鬱結其誰語",
                "18": "聊綴思於斯文"
            }
        }
    }
}