{
    "44.01": {
        "篇名": "司馬長卿 喩巴蜀檄",
        "1": {
            "3": {
                "1": "告巴蜀太守",
                "2": "蠻夷自擅",
                "3": "不討之日久矣",
                "4": "時侵犯邊境",
                "5": "勞士大夫",
                "6": "陛下卽位",
                "7": "存撫天下",
                "8": "安集中國",
                "9": "然後興師出兵",
                "10": "北征匈奴",
                "11": "單於怖駭",
                "12": "交臂受事",
                "13": "屈膝請和",
                "14": "康居西域",
                "15": "重譯納貢",
                "16": "稽顙來享",
                "17": "移師東指",
                "18": "閩越相誅",
                "19": "右弔番禺",
                "20": "太子入朝",
                "21": "南夷之君",
                "22": "西僰之長",
                "23": "常效貢職",
                "24": "不敢墯怠",
                "25": "延頸舉踵喁喁然",
                "26": "皆嚮風慕義",
                "27": "欲爲臣妾",
                "28": "道里遼遠",
                "29": "山川阻深",
                "30": "不能自致",
                "31": "夫不順者已誅",
                "32": "而爲善者未賞",
                "33": "故遣中郎將往賓之",
                "34": "發巴蜀之士各五百人",
                "35": "以奉幣帛",
                "36": "衞使者不然",
                "37": "靡有兵革之事",
                "38": "戰鬭之患",
                "39": "今聞其乃發軍興制",
                "40": "驚懼子弟",
                "41": "憂患長老",
                "42": "郡又擅爲轉粟運輸",
                "43": "皆非陛下之意也",
                "44": "當行者或亡逃自賊殺",
                "45": "亦非人臣之節也"
            }
        },
        "2": {
            "5": {
                "1": "夫邊郡之士",
                "2": "聞烽舉燧燔",
                "3": "皆攝弓而馳",
                "4": "荷兵而走",
                "5": "流汗相屬",
                "6": "唯恐居後",
                "7": "觸白刃",
                "8": "冒流矢",
                "9": "議不反顧",
                "10": "計不旋踵",
                "11": "人懷怒心",
                "12": "如報私讎",
                "13": "彼豈樂死惡生",
                "14": "非編列之民",
                "15": "而與巴蜀異主哉",
                "16": "計深慮遠",
                "17": "急國家之難",
                "18": "而樂盡人臣之道也",
                "19": "故有剖符之封",
                "20": "析珪而爵",
                "21": "位爲通侯",
                "22": "處列東第",
                "23": "終則遺顯號於後世",
                "24": "傳土地於子孫",
                "25": "行事甚忠敬",
                "26": "居位甚安逸",
                "27": "名聲施於無窮",
                "28": "功烈著而不滅",
                "29": "是以賢人君子",
                "30": "肝腦塗中原",
                "31": "膏液潤野草而不辭也",
                "32": "今奉幣役至南夷",
                "33": "卽自賊殺",
                "34": "或亡逃抵誅",
                "35": "身死無名",
                "36": "謚爲至愚",
                "37": "恥及父母",
                "38": "爲天下笑",
                "39": "人之度量相越",
                "40": "豈不遠哉",
                "41": "然此非獨行者之罪也",
                "42": "父兄之教不先",
                "43": "子弟之率不謹",
                "44": "寡廉鮮恥",
                "45": "而俗不長厚也",
                "46": "其被刑戮",
                "47": "不亦宜乎"
            }
        },
        "3": {
            "7": {
                "1": "陛下患使者有司之若彼",
                "2": "悼不肖愚民之如此",
                "3": "故遣信使",
                "4": "曉諭百姓以發卒之事",
                "5": "因數之以不忠死亡之罪",
                "6": "讓三老孝悌以不教誨之過",
                "7": "方今田時",
                "8": "重煩百姓",
                "9": "已親見近縣",
                "10": "恐遠所谿谷山澤之民不徧聞",
                "11": "檄到",
                "12": "亟下縣道",
                "13": "使咸喩陛下之意",
                "14": "無忽"
            }
        }
    }
}