{
    "18.03": {
        "篇名": "潘安仁 笙賦",
        "1": {
            "3": {
                "1": "河汾之寶",
                "2": "有曲沃之懸匏焉",
                "3": "鄒魯之珍",
                "4": "有汶陽之孤篠焉",
                "5": "若乃綿蔓紛敷之麗",
                "6": "浸潤靈液之滋",
                "7": "隅隈夷險之勢",
                "8": "禽鳥翔集之嬉",
                "9": "固眾作者之所詳",
                "10": "余可得而略之也",
                "11": "徒觀其制器也",
                "12": "則審洪纖",
                "13": "面短長",
                "14": "戾生幹",
                "15": "裁熟簧",
                "16": "設宮分羽",
                "17": "經徵列商",
                "18": "泄之反謐",
                "19": "厭焉乃揚",
                "20": "管攢羅而表列",
                "21": "音要妙而含清",
                "22": "各守一以司應",
                "23": "統大魁以爲笙",
                "24": "基黃鍾以舉韻",
                "25": "望儀鳳以擢形",
                "26": "寫皇翼以插羽",
                "27": "摹鸞音以厲聲",
                "28": "如鳥斯企",
                "29": "翾翾岐岐",
                "30": "明珠在咮",
                "31": "若衘若垂",
                "32": "修撾內辟",
                "33": "餘蕭外逶",
                "34": "騈田獵麗",
                "35": "魻鰈參差"
            }
        },
        "2": {
            "5": {
                "1": "於是乃有始泰終約",
                "2": "前榮後悴",
                "3": "激憤於今賤",
                "4": "永懷乎故貴",
                "5": "眾滿堂而飲酒",
                "6": "獨向隅而掩淚",
                "7": "援鳴笙而將吹",
                "8": "先嗢噦以理氣",
                "9": "初雍容以安暇",
                "10": "中佛鬱以怫㥜",
                "11": "終嵬峨以蹇諤",
                "12": "又颯遝而繁沸",
                "13": "罔浪孟以惆悵",
                "14": "若欲絕而復肆",
                "15": "懰憿耀以奔邀",
                "16": "似將放而終匱",
                "17": "愀愴惻淢",
                "18": "虺𦾛煜熠",
                "19": "泛淫泛灩",
                "20": "霅熚岌岌",
                "21": "或案衍夷靡",
                "22": "或竦勇剽急",
                "23": "或旣往不反",
                "24": "或己出復入",
                "25": "徘徊布獲",
                "26": "渙衍葺襲",
                "27": "舞旣蹈而中輟",
                "28": "節將撫而不及",
                "29": "樂聲發而盡室歡",
                "30": "悲音奏而列坐泣",
                "31": "㩶纖翮以震幽簧",
                "32": "越上筩而通下管",
                "33": "應吹嗡以往來",
                "34": "隨抑揚以虛滿",
                "35": "勃慷慨以摎亮",
                "36": "顧躊躇以舒緩",
                "37": "輟張女之哀彈",
                "38": "流廣陵之名散",
                "39": "詠園桃之夭夭",
                "40": "歌棗下之篡篡",
                "41": "歌曰"
            }
        },
        "3": {
            "7": {
                "1": "棗下篡篡",
                "2": "朱實離離",
                "3": "宛其處矣",
                "4": "化爲枯枝",
                "5": "人生不能以行樂",
                "6": "死何以虛諡爲"
            }
        },
        "4": {
            "9": {
                "1": "爾乃引飛龍",
                "2": "鳴雉雞",
                "3": "雙鴻翔",
                "4": "白鶴飛",
                "5": "子喬輕舉",
                "6": "明君懷歸",
                "7": "荊王喟其長吟",
                "8": "楚妃歎而增悲",
                "9": "夫其悽唳辛酸",
                "10": "嚶嚶關關",
                "11": "若離鴻之鳴子也",
                "12": "含㗅嘽諧",
                "13": "雍雍喈喈",
                "14": "若羣雛之從母也",
                "15": "郁捋劫悟",
                "16": "泓宏融裔",
                "17": "哇咬嘲𠹗",
                "18": "壹何察慧",
                "19": "訣厲悄切",
                "20": "又何磬折"
            }
        },
        "5": {
            "11": {
                "1": "若夫時陽初暖",
                "2": "臨川送離",
                "3": "酒酣徒擾",
                "4": "樂闋日移",
                "5": "疏克始闌",
                "6": "主人微疲",
                "7": "弛絃韜籥",
                "8": "徹塤屛箎"
            }
        },
        "6": {
            "13": {
                "1": "爾乃促中筵",
                "2": "攜友生",
                "3": "解嚴顏",
                "4": "擢幽情",
                "5": "披黃苞以授甘",
                "6": "傾縹瓷以酌醽",
                "7": "光岐儼其階列",
                "8": "雙鳳嘈以和鳴",
                "9": "普野悚而投琴",
                "10": "況齊瑟與秦箏",
                "11": "新聲變曲",
                "12": "奇韻橫逸",
                "13": "縈纏歌鼓",
                "14": "網羅鍾律",
                "15": "爛熠鑰以放豔",
                "16": "鬱蓬勃以氣出",
                "17": "秋風詠於燕路",
                "18": "天光重於朝日",
                "19": "大不踰宮",
                "20": "細不過羽",
                "21": "唱發章夏",
                "22": "導揚韶武",
                "23": "協和陳宋",
                "24": "混一齊楚",
                "25": "邇不逼而遠吾攜",
                "26": "聲成文而節有序"
            }
        },
        "7": {
            "15": {
                "1": "彼政有失得",
                "2": "而化以醇薄",
                "3": "樂所以移風於善",
                "4": "亦所以易俗於惡",
                "5": "故絲竹之器未改",
                "6": "而桑濮之流已作",
                "7": "惟簧也能硏羣聲之清",
                "8": "惟笙也能眾清之林",
                "9": "衞無所措其邪",
                "10": "鄭無容其淫",
                "11": "非天下之和樂",
                "12": "不易之德音",
                "13": "其孰能於此乎"
            }
        }
    }
}