{
    "41.01": {
        "篇名": "李少卿 答蘇武書",
        "1": {
            "3": {
                "1": "子卿足下",
                "2": "勤宣令德",
                "3": "策名清時",
                "4": "榮問休暢",
                "5": "幸甚幸甚",
                "6": "遠託異國",
                "7": "昔人所悲",
                "8": "望風懷想",
                "9": "能不依依",
                "10": "昔者不遺",
                "11": "遠辱還答",
                "12": "慰誨懃懃",
                "13": "有踰骨肉",
                "14": "陵雖不敏",
                "15": "能不慨然"
            }
        },
        "2": {
            "5": {
                "1": "自從初降",
                "2": "以至今日",
                "3": "身之窮困",
                "4": "獨坐愁苦",
                "5": "終日無覩",
                "6": "但見異類",
                "7": "韋韝毳幙",
                "8": "以禦風雨",
                "9": "羶肉酪漿",
                "10": "以充飢渴",
                "11": "舉目言笑",
                "12": "誰與爲歡",
                "13": "胡地玄冰",
                "14": "邊土慘裂",
                "15": "但聞悲風蕭條之聲",
                "16": "涼秋九月",
                "17": "塞外草衰",
                "18": "夜不能寐",
                "19": "側耳遠聽",
                "20": "胡笳互動",
                "21": "牧馬悲鳴",
                "22": "吟嘯成羣",
                "23": "邊聲四起",
                "24": "晨坐聽之",
                "25": "不覺淚下",
                "26": "嗟乎子卿",
                "27": "陵獨何心",
                "28": "能不悲哉",
                "29": "與子別後",
                "30": "益復無聊",
                "31": "上念老母",
                "32": "臨年被戮",
                "33": "妻子無辜",
                "34": "並爲鯨鯢",
                "35": "身負國恩",
                "36": "爲世所悲",
                "37": "子歸受榮",
                "38": "我留受辱",
                "39": "命也如何",
                "40": "身出禮義之鄕",
                "41": "而入無知之俗",
                "42": "違棄君親之恩",
                "43": "長爲蠻夷之域",
                "44": "傷已",
                "45": "令先君之嗣",
                "46": "更成戎狄之族",
                "47": "又自悲矣",
                "48": "功大罪小",
                "49": "不蒙明察",
                "50": "孤負陵心",
                "51": "區區之意",
                "52": "每一念至",
                "53": "忽然忘生",
                "54": "陵不難刺心以自明",
                "55": "刎頸以見志",
                "56": "顧國家於我已矣",
                "57": "殺身無益",
                "58": "適足增羞",
                "59": "故每攘臂忍辱",
                "60": "輒復苟活",
                "61": "左右之人",
                "62": "見陵如此",
                "63": "以爲不入耳之歡",
                "64": "來相勸勉",
                "65": "異方之樂",
                "66": "祇令人悲",
                "67": "增忉怛耳",
                "68": "嗟乎子卿",
                "69": "人之相知",
                "70": "貴相知心",
                "71": "前書倉卒未盡所懷",
                "72": "故復略而言之"
            }
        },
        "3": {
            "7": {
                "1": "昔先帝授陵步卒五千",
                "2": "出征絕域",
                "3": "五將失道",
                "4": "陵獨遇戰",
                "5": "而裹萬里之糧",
                "6": "帥徒步之師",
                "7": "出天漢之外",
                "8": "入強胡之域",
                "9": "以五千之眾",
                "10": "對十萬之軍",
                "11": "策疲乏之兵",
                "12": "當新羈之馬",
                "13": "然猶斬將搴旗",
                "14": "追奔逐北",
                "15": "滅迹掃塵",
                "16": "斬其梟帥",
                "17": "使三軍之士",
                "18": "視死如歸",
                "19": "陵也不才",
                "20": "希當大任",
                "21": "意謂此時",
                "22": "功難堪矣",
                "23": "匈奴旣敗",
                "24": "舉國興師",
                "25": "更練精兵",
                "26": "強踰十萬",
                "27": "單於臨陣",
                "28": "親自合圍",
                "29": "客主之形",
                "30": "旣不相如步馬之勢",
                "31": "又甚懸絕",
                "32": "疲兵再戰",
                "33": "一以當千",
                "34": "然猶扶乘創痛",
                "35": "決命爭首",
                "36": "死傷積野",
                "37": "餘不滿百",
                "38": "而皆扶病",
                "39": "不任干戈",
                "40": "然陵振臂一呼",
                "41": "創病皆起",
                "42": "舉刃指虜",
                "43": "胡馬奔走",
                "44": "兵盡矢窮",
                "45": "人無尺鐵",
                "46": "猶復徒首奮呼爭爲先登",
                "47": "當此時也",
                "48": "天地爲陵震怒",
                "49": "戰士爲陵飲血",
                "50": "單於謂陵不可復得",
                "51": "便欲引還",
                "52": "而賊臣教之",
                "53": "遂便復戰",
                "54": "故陵不免耳"
            }
        },
        "4": {
            "9": {
                "1": "昔高皇帝以三十萬眾",
                "2": "困於平城",
                "3": "當此之時",
                "4": "猛將如雲",
                "5": "謀臣如雨",
                "6": "然猶七日不食",
                "7": "僅乃得免",
                "8": "況當陵者",
                "9": "豈易爲力哉",
                "10": "而執事者云云",
                "11": "苟怨陵以不死",
                "12": "然陵不死",
                "13": "罪也",
                "14": "子卿視陵",
                "15": "豈偸生之士",
                "16": "而惜死之人哉",
                "17": "寧有背君親",
                "18": "捐妻子",
                "19": "而反爲利者乎",
                "20": "然陵不死",
                "21": "有所爲也",
                "22": "故欲如前書之言",
                "23": "報恩於國主耳",
                "24": "誠以虛死不如立節",
                "25": "滅名不如報德也",
                "26": "昔范蠡不殉會稽之恥",
                "27": "曹沬不死三敗之辱",
                "28": "卒復句踐之讎",
                "29": "報魯國之羞",
                "30": "區區之心",
                "31": "切慕此耳",
                "32": "何圖志未立而怨已成",
                "33": "計未從而骨肉受刑",
                "34": "此陵所以仰天椎心而泣血也"
            }
        },
        "5": {
            "11": {
                "1": "足下又云",
                "2": "漢與功臣不薄",
                "3": "子爲漢臣",
                "4": "安得不云爾乎",
                "5": "昔蕭樊囚縶",
                "6": "韓彭葅醢",
                "7": "鼂錯受戮",
                "8": "周魏見辜",
                "9": "其餘佐命立功之士",
                "10": "賈誼亞夫之徒",
                "11": "皆信命世之才",
                "12": "抱將相之具",
                "13": "而受小人之讒",
                "14": "並受禍敗之辱",
                "15": "卒使懷才受謗",
                "16": "能不得展",
                "17": "彼二子之遐舉",
                "18": "誰不爲之痛心哉",
                "19": "陵先將軍",
                "20": "功略蓋天地",
                "21": "義勇冠三軍",
                "22": "徒失貴臣之意",
                "23": "剄身絕域之表",
                "24": "此功臣義士所以負戟而長歎者也",
                "25": "何謂不薄哉"
            }
        },
        "6": {
            "13": {
                "1": "且足下昔以單車之使",
                "2": "適萬乘之虜",
                "3": "遭時不遇",
                "4": "至於伏劍不顧",
                "5": "流離辛苦",
                "6": "幾死朔北之野",
                "7": "丁年奉使",
                "8": "皓首而歸",
                "9": "老母終堂",
                "10": "生妻去帷",
                "11": "此天下所希聞",
                "12": "古今所未有也",
                "13": "蠻貊之人",
                "14": "尙猶嘉子之節",
                "15": "況爲天下之主乎",
                "16": "陵謂足下",
                "17": "當享茅土之薦",
                "18": "受千乘之賞",
                "19": "聞子之歸",
                "20": "賜不過二百萬",
                "21": "位不過典屬國",
                "22": "無尺土之封",
                "23": "加子之勤",
                "24": "而妨功害能之臣",
                "25": "盡爲萬戶侯",
                "26": "親戚貪佞之類",
                "27": "悉爲廊廟宰",
                "28": "子尙如此",
                "29": "陵復何望哉",
                "30": "且漢厚誅陵以不死",
                "31": "薄賞子以守節",
                "32": "欲使遠聽之臣",
                "33": "望風馳命",
                "34": "此實難矣",
                "35": "所以每顧而不悔者也",
                "36": "陵雖孤恩",
                "37": "漢亦負德",
                "38": "昔人有言",
                "39": "雖忠不烈",
                "40": "視死如歸",
                "41": "陵誠能安",
                "42": "而主豈復能眷眷乎",
                "43": "男兒生以不成名",
                "44": "死則葬蠻夷中",
                "45": "誰復能屈身稽顙",
                "46": "還向北闕",
                "47": "使刀筆之吏",
                "48": "弄其文墨邪",
                "49": "願足下勿復望陵"
            }
        },
        "7": {
            "15": {
                "1": "嗟乎子卿",
                "2": "夫復何言",
                "3": "相去萬里",
                "4": "人絕路殊",
                "5": "生爲別世之人",
                "6": "死爲異域之鬼",
                "7": "長與足下生死辭矣",
                "8": "幸謝故人",
                "9": "勉事聖君",
                "10": "足下胤子無恙",
                "11": "勿以爲念",
                "12": "努力自愛",
                "13": "時因北風",
                "14": "復惠德音",
                "15": "李陵頓首"
            }
        }
    }
}