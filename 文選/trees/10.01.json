{
    "10.01": {
        "篇名": "潘安仁 西征賦",
        "1": {
            "3": {
                "1": "歲次玄枵",
                "2": "月旅蕤賓",
                "3": "丙丁統日",
                "4": "乙未御辰",
                "5": "潘子憑軾西征",
                "6": "自京徂秦",
                "7": "迺喟然歎曰"
            }
        },
        "2": {
            "5": {
                "1": "古往今來",
                "2": "邈矣悠哉",
                "3": "寥廓惚恍",
                "4": "化一氣而甄三才",
                "5": "此三才者",
                "6": "天地人道",
                "7": "唯生與位",
                "8": "謂之大寶",
                "9": "生有修短之命",
                "10": "位有通塞之遇",
                "11": "鬼神莫能要",
                "12": "聖智弗能豫"
            }
        },
        "3": {
            "7": {
                "1": "當休明之盛世",
                "2": "託菲薄之陋質",
                "3": "納旌弓於鉉台",
                "4": "讚庶績於帝室",
                "5": "嗟鄙夫之常累",
                "6": "固旣得而患失",
                "7": "無柳季之直道",
                "8": "佐士師而一黜"
            }
        },
        "4": {
            "9": {
                "1": "武皇忽其升遐",
                "2": "八音遏於四海",
                "3": "天子寢於諒闇",
                "4": "百官聽於冢宰",
                "5": "彼負荷之殊重",
                "6": "雖伊周其猶殆",
                "7": "窺七貴於漢庭",
                "8": "譸一姓之或在",
                "9": "無危明以安位",
                "10": "祇居逼以示專",
                "11": "陷亂逆以受戮",
                "12": "匪禍降之自天",
                "13": "孔隨時以行藏",
                "14": "蘧與國而舒卷",
                "15": "苟蔽微以繆章",
                "16": "患過辟之未遠",
                "17": "悟山潛之逸士",
                "18": "卓長往而不反",
                "19": "陋吾人之拘攣",
                "20": "飄萍浮而蓬轉",
                "21": "僚位儡其隆替",
                "22": "名節漼以隳落",
                "23": "危素卵之累殼",
                "24": "甚玄燕之巢幕",
                "25": "心戰懼以兢悚",
                "26": "如臨深而履薄",
                "27": "夕獲歸於都外",
                "28": "宵未中而難作",
                "29": "匪擇木以栖集",
                "30": "尠林焚而鳥存",
                "31": "遭千載之嘉會",
                "32": "皇合德於乾坤",
                "33": "弛秋霜之嚴威",
                "34": "流春澤之渥恩",
                "35": "甄大義以明責",
                "36": "反初服於私門"
            }
        },
        "5": {
            "11": {
                "1": "皇鑒揆余之忠誠",
                "2": "俄命余以末班",
                "3": "牧疲人於西夏",
                "4": "攜老幼而入關",
                "5": "丘去魯而顧歎",
                "6": "季過沛而涕零",
                "7": "伊故鄕之可懷",
                "8": "疚聖達之幽情",
                "9": "矧匹夫之安土",
                "10": "邈投身於鎬京",
                "11": "猶犬馬之戀主",
                "12": "竊託慕於闕庭",
                "13": "眷鞏洛而掩涕",
                "14": "思纏綿於墳塋"
            }
        },
        "6": {
            "13": {
                "1": "爾乃越平樂",
                "2": "過街郵",
                "3": "秣馬皋門",
                "4": "稅駕西周",
                "5": "遠矣姬德",
                "6": "興自高辛",
                "7": "思文后稷",
                "8": "厥初生民",
                "9": "率西水滸",
                "10": "化流岐豳",
                "11": "祚隆昌發",
                "12": "舊邦惟新",
                "13": "旋牧野而歷茲",
                "14": "愈守柔以執競",
                "15": "夜申旦而不寐",
                "16": "憂天保之未定",
                "17": "惟泰山其猶危",
                "18": "祀八百而餘慶",
                "19": "鑒亡王之驕淫",
                "20": "竄南巢以投命",
                "21": "坐積薪以待然",
                "22": "方指日而比盛",
                "23": "人度量之乖舛",
                "24": "何相越之遼迥"
            }
        },
        "7": {
            "15": {
                "1": "考土中於斯邑",
                "2": "成建都而營築",
                "3": "旣定鼎於郟鄏",
                "4": "遂鑽龜而啟繇",
                "5": "平失道而來遷",
                "6": "繄二國而是祐",
                "7": "豈時王之無僻",
                "8": "賴先哲以長懋",
                "9": "望圉北之兩門",
                "10": "感虢鄭之納惠",
                "11": "討子頹之樂禍",
                "12": "尤闕西之效戾",
                "13": "重戮帶以定襄",
                "14": "弘大順以霸世",
                "15": "靈壅川以止鬥",
                "16": "晉演義以獻說",
                "17": "咨景悼以迄丐",
                "18": "政凌遲而彌季",
                "19": "俾庶朝之構逆",
                "20": "歷兩王而干位",
                "21": "踰十葉以逮赧",
                "22": "邦分崩而爲二",
                "23": "竟橫噬於虎口",
                "24": "輸文武之神器"
            }
        },
        "8": {
            "17": {
                "1": "澡孝水而濯纓",
                "2": "嘉美名之在茲",
                "3": "夭赤子於新安",
                "4": "坎路側而瘞之",
                "5": "亭有千秋之號",
                "6": "子無七旬之期",
                "7": "雖勉勵於延吳",
                "8": "實潛慟乎余慈"
            }
        },
        "9": {
            "19": {
                "1": "眄山川以懷古",
                "2": "悵攬轡於中塗",
                "3": "虐項氏之肆暴",
                "4": "坑降卒之無辜",
                "5": "激秦人以歸德",
                "6": "成劉后之來蘇",
                "7": "事回泬而好還",
                "8": "卒宗滅而身屠"
            }
        },
        "10": {
            "21": {
                "1": "經澠池而長想",
                "2": "停余車而不進",
                "3": "秦虎狼之彊國",
                "4": "趙侵弱之餘燼",
                "5": "超入險而高會",
                "6": "杖命世之英藺",
                "7": "恥東瑟之偏鼓",
                "8": "提西缶而接刃",
                "9": "辱十城之虛壽",
                "10": "奄咸陽以取儁",
                "11": "出申威於河外",
                "12": "何猛氣之咆勃",
                "13": "入屈節於廉公",
                "14": "若四體之無骨",
                "15": "處智勇之淵偉",
                "16": "方鄙吝之忿悁",
                "17": "雖改日而易歲",
                "18": "無等級以寄言"
            }
        },
        "11": {
            "23": {
                "1": "當光武之蒙塵",
                "2": "致王誅於赤眉",
                "3": "異奉辭以伐罪",
                "4": "初垂翅於回谿",
                "5": "不尤眚以掩德",
                "6": "終奮翼而高揮",
                "7": "建佐命之元勳",
                "8": "振皇綱而更維"
            }
        },
        "12": {
            "25": {
                "1": "登崤阪之威夷",
                "2": "仰崇嶺之嵯峨",
                "3": "皋記墳於南陵",
                "4": "文違風於北阿",
                "5": "蹇哭孟以審敗",
                "6": "襄墨縗以授戈",
                "7": "曾隻輪之不反",
                "8": "緤三帥以濟河",
                "9": "値庸主之矜愎",
                "10": "殆肆叔於朝市",
                "11": "任好綽其餘裕",
                "12": "獨引過以歸己",
                "13": "明三敗而不黜",
                "14": "卒陵晉以雪恥",
                "15": "豈虛名之可立",
                "16": "良致霸其有以"
            }
        },
        "13": {
            "27": {
                "1": "降曲崤而憐虢",
                "2": "託與國於亡虞",
                "3": "貪誘賂以賣鄰",
                "4": "不及臘而就拘",
                "5": "垂棘反於故府",
                "6": "屈產服於晉輿",
                "7": "德不建而民無援",
                "8": "仲雍之祀忽諸"
            }
        },
        "14": {
            "29": {
                "1": "我徂安陽",
                "2": "言陟陝郛",
                "3": "行乎漫瀆之口",
                "4": "憩乎曹陽之墟",
                "5": "美哉邈乎",
                "6": "茲土之舊也",
                "7": "固乃周邵之所分",
                "8": "二南之所交",
                "9": "麟趾信於關雎",
                "10": "騶虞應乎鵲巢"
            }
        },
        "15": {
            "31": {
                "1": "愍漢氏之剝亂",
                "2": "朝流亡以離析",
                "3": "卓滔天以大滌",
                "4": "劫宮廟而遷迹",
                "5": "俾萬乘之盛尊",
                "6": "降遙思於征役",
                "7": "顧請旋於傕泛",
                "8": "旣獲許而中惕",
                "9": "追皇駕而驟戰",
                "10": "望玉輅而縱鏑",
                "11": "痛百僚之勤王",
                "12": "咸畢力以致死",
                "13": "分身首於鋒刃",
                "14": "洞胸腋以流矢",
                "15": "有褰裳以投岸",
                "16": "或攘袂以赴水",
                "17": "傷桴楫之褊小",
                "18": "撮舟中而掬指"
            }
        },
        "16": {
            "33": {
                "1": "升曲沃而惆悵",
                "2": "惜兆亂而兄替",
                "3": "枝末大而本披",
                "4": "都偶國而禍結",
                "5": "臧札飄其高厲",
                "6": "委曹吳而成節",
                "7": "何莊武之無恥",
                "8": "徒利開而義閉"
            }
        },
        "17": {
            "35": {
                "1": "躡函谷之重阻",
                "2": "看天險之衿帶",
                "3": "迹諸侯之勇怯",
                "4": "筭嬴氏之利害",
                "5": "或開關以延敵",
                "6": "競遯逃以奔竄",
                "7": "有噤門而莫啟",
                "8": "不窺兵於山外",
                "9": "連雞互而不栖",
                "10": "小國合而成大",
                "11": "豈地勢之安危",
                "12": "信人事之否泰"
            }
        },
        "18": {
            "37": {
                "1": "漢六葉而拓畿",
                "2": "縣弘農而遠關",
                "3": "厭紫極之閑敞",
                "4": "甘微行以遊盤",
                "5": "長傲賓於柏谷",
                "6": "妻睹貌而獻餐",
                "7": "疇匹婦其已泰",
                "8": "胡厥夫之繆官",
                "9": "昔明王之巡幸",
                "10": "固清道而後往",
                "11": "懼銜橜之或變",
                "12": "峻徒御以誅賞",
                "13": "彼白龍之魚服",
                "14": "挂豫且之密網",
                "15": "輕帝重於天下",
                "16": "奚斯漸之可長"
            }
        },
        "19": {
            "39": {
                "1": "弔戾園於湖邑",
                "2": "諒遭世之巫蠱",
                "3": "探隱伏於難明",
                "4": "委讒賊之趙虜",
                "5": "加顯戮於儲貳",
                "6": "絕肌膚而不顧",
                "7": "作歸來之悲臺",
                "8": "徒望思其何補"
            }
        },
        "20": {
            "41": {
                "1": "紛吾旣邁此全節",
                "2": "又繼之以盤桓",
                "3": "問休牛之故林",
                "4": "感徵名於桃園",
                "5": "發閿鄕而警策",
                "6": "愬黃巷以濟潼",
                "7": "眺華岳之陰崖",
                "8": "覿高掌之遺蹤",
                "9": "憶江使之反璧",
                "10": "告亡期於祖龍",
                "11": "不語怪以徵異",
                "12": "我聞之於孔公"
            }
        },
        "21": {
            "43": {
                "1": "慍韓馬之大憝",
                "2": "阻關谷以稱亂",
                "3": "魏武赫以霆震",
                "4": "奉義辭以伐叛",
                "5": "彼雖眾其焉用",
                "6": "故制勝於廟筭",
                "7": "砰揚桴以振塵",
                "8": "繣瓦解而冰泮",
                "9": "超遂遁而奔狄",
                "10": "甲卒化爲京觀"
            }
        },
        "22": {
            "45": {
                "1": "倦狹路之迫隘",
                "2": "軌踦嶇以低仰",
                "3": "蹈秦郊而始闢",
                "4": "豁爽塏以宏壯",
                "5": "黃壤千里",
                "6": "沃野彌望",
                "7": "華實紛敷",
                "8": "桑麻條暢",
                "9": "邪界襃斜",
                "10": "右濱汧隴",
                "11": "寶雞前鳴",
                "12": "甘泉後涌",
                "13": "面終南而背雲陽",
                "14": "跨平原而連嶓冢",
                "15": "九嵕嶻嶭",
                "16": "太一巃嵷",
                "17": "吐清風之飂戾",
                "18": "納歸雲之鬱蓊",
                "19": "南有玄灞素滻",
                "20": "湯井溫谷",
                "21": "北有清渭濁涇",
                "22": "蘭池周曲",
                "23": "浸決鄭白之渠",
                "24": "漕引淮海之粟",
                "25": "林茂有鄠之竹",
                "26": "山挺藍田之玉",
                "27": "班述陸海珍藏",
                "28": "張敍神皋隩區",
                "29": "此西賓所以言於東主",
                "30": "安處所以聽於憑虛也",
                "31": "可不謂然乎"
            }
        },
        "23": {
            "47": {
                "1": "勁松彰於歲寒",
                "2": "貞臣見於國危",
                "3": "入鄭都而抵掌",
                "4": "義桓友之忠規",
                "5": "竭股肱於昏主",
                "6": "赴塗炭而不移",
                "7": "世善職於司徒",
                "8": "緇衣敝而改爲"
            }
        },
        "24": {
            "49": {
                "1": "履犬戎之侵地",
                "2": "疾幽后之詭惑",
                "3": "舉僞烽以沮眾",
                "4": "淫嬖襃以縱慝",
                "5": "軍敗戲水之上",
                "6": "身死驪山之北",
                "7": "赫赫宗周",
                "8": "烕爲亡國"
            }
        },
        "25": {
            "51": {
                "1": "又有繼於此者",
                "2": "異哉秦始皇之爲君也",
                "3": "傾天下以厚葬",
                "4": "自開闢而未聞",
                "5": "匠人勞而弗圖",
                "6": "俾生埋以報勤",
                "7": "外罹西楚之禍",
                "8": "內受牧豎之焚",
                "9": "語曰",
                "10": "行無禮必自及",
                "11": "此非其效與"
            }
        },
        "26": {
            "53": {
                "1": "乾坤以有親可久",
                "2": "君子以厚德載物",
                "3": "觀夫漢高之興也",
                "4": "非徒聰明神武",
                "5": "豁達大度而已也",
                "6": "乃實愼終追舊",
                "7": "篤誠款愛",
                "8": "澤靡不漸",
                "9": "恩無不逮",
                "10": "率土且弗遣",
                "11": "而況於鄰里乎",
                "12": "況於卿士乎"
            }
        },
        "27": {
            "55": {
                "1": "於斯時也",
                "2": "乃摹寫舊豐",
                "3": "制造新邑",
                "4": "故社易置",
                "5": "枌楡遷立",
                "6": "街衢如一",
                "7": "庭宇相襲",
                "8": "渾雞犬而亂放",
                "9": "各識家而競入"
            }
        },
        "28": {
            "57": {
                "1": "籍含怒於鴻門",
                "2": "沛跼蹐而來王",
                "3": "范謀害而弗許",
                "4": "陰授劍以約莊",
                "5": "撛白刃以萬舞",
                "6": "危冬葉之待霜",
                "7": "履虎尾而不噬",
                "8": "實要伯於子房",
                "9": "樊抗憤以卮酒",
                "10": "咀彘肩以激揚",
                "11": "忽蛇變而龍攄",
                "12": "雄霸上而高驤",
                "13": "曾遷怒而橫撞",
                "14": "碎玉斗其何傷"
            }
        },
        "29": {
            "59": {
                "1": "嬰罥組於軹塗",
                "2": "投素車而肉袒",
                "3": "疏飲餞於東都",
                "4": "畏極位之盛滿",
                "5": "金墉鬱其萬雉",
                "6": "峻嵃峭以繩直",
                "7": "戾飲馬之陽橋",
                "8": "踐宣平之清閾",
                "9": "都中雜遝",
                "10": "戶千人億",
                "11": "華夷士女",
                "12": "騈田逼側",
                "13": "展名京之初儀",
                "14": "卽新館而蒞職",
                "15": "勵疲鈍以臨朝",
                "16": "勖自強而不息"
            }
        },
        "30": {
            "61": {
                "1": "於是孟秋爰謝",
                "2": "聽覽餘日",
                "3": "巡省農功",
                "4": "周行廬室",
                "5": "街里蕭條",
                "6": "邑居散逸",
                "7": "營宇寺署",
                "8": "肆廛管庫",
                "9": "蕞芮於城隅者",
                "10": "百不處一",
                "11": "所謂尙冠修成",
                "12": "黃棘宣明",
                "13": "建陽昌陰",
                "14": "北煥南平",
                "15": "皆夷漫滌蕩",
                "16": "亡其處而有其名",
                "17": "爾乃階長樂",
                "18": "登未央",
                "19": "泛太液",
                "20": "凌建章",
                "21": "縈馺娑而款駘盪",
                "22": "轥枍詣而轢承光",
                "23": "徘徊桂宮",
                "24": "惆悵柏梁",
                "25": "鷩雉雊於臺陂",
                "26": "狐兔窟於殿傍",
                "27": "何黍苗之離離",
                "28": "而余思之芒芒",
                "29": "洪鍾頓於毀廟",
                "30": "乘風廢而弗縣",
                "31": "禁省鞠爲茂草",
                "32": "金狄遷於灞川"
            }
        },
        "31": {
            "63": {
                "1": "懷夫蕭曹魏邴之相",
                "2": "辛李衞霍之將",
                "3": "銜使則蘇屬國",
                "4": "震遠則張博望",
                "5": "教敷而彝倫敍",
                "6": "兵舉而皇威暢",
                "7": "臨危而智勇奮",
                "8": "投命而高節亮",
                "9": "曁乎秺侯之忠孝淳深",
                "10": "陸賈之優遊宴喜",
                "11": "長卿淵雲之文",
                "12": "子長政駿之史",
                "13": "趙張三王之尹京",
                "14": "定國釋之之聽理",
                "15": "汲長孺之正直",
                "16": "鄭當時之推士",
                "17": "終童山東之英妙",
                "18": "賈生洛陽之才子",
                "19": "飛翠緌",
                "20": "拖鳴玉",
                "21": "以出入禁門者眾矣",
                "22": "或被髮左衽",
                "23": "奮迅泥滓",
                "24": "或從容傅會",
                "25": "望表知裏",
                "26": "或著顯績而嬰時戮",
                "27": "或有大才而無貴仕",
                "28": "皆揚清風於上烈",
                "29": "垂令聞而不已",
                "30": "想珮聲之遺響",
                "31": "若鏗鏘之在耳",
                "32": "當音鳳恭顯之任勢也",
                "33": "乃熏灼四方",
                "34": "震耀都鄙",
                "35": "而死之日",
                "36": "曾不得與夫十餘公之徒隸齒",
                "37": "才難",
                "38": "不其然乎"
            }
        },
        "32": {
            "65": {
                "1": "望漸臺而扼晼",
                "2": "梟巨猾而餘怒",
                "3": "揖不疑於北闕",
                "4": "軾樗里於武庫",
                "5": "酒池鑒於商辛",
                "6": "追覆車而不寤",
                "7": "曲陽僭於白虎",
                "8": "化奢淫而無度",
                "9": "命有始而必終",
                "10": "孰長生而久視",
                "11": "武雄略其焉在",
                "12": "近惑文成而溺五利",
                "13": "侔造化以制作",
                "14": "窮山海之奧祕",
                "15": "靈若翔於神島",
                "16": "奔鯨浪而失水",
                "17": "爆鱗骼於漫沙",
                "18": "隕明月以雙墜",
                "19": "擢仙掌以承露",
                "20": "干雲漢而上至",
                "21": "致邛蒟其奚難",
                "22": "惟余欲而是恣",
                "23": "縱逸遊於角觝",
                "24": "絡甲乙以珠翠",
                "25": "忍生民之減半",
                "26": "勒東岳以虛美",
                "27": "超長懷以遐念",
                "28": "若循環之無賜"
            }
        },
        "33": {
            "67": {
                "1": "較面朝之煥炳",
                "2": "次後庭之猗靡",
                "3": "壯當熊之忠勇",
                "4": "深辭輦之明智",
                "5": "衞鬒髮以光鑒",
                "6": "趙輕體之纖麗",
                "7": "咸善立而聲流",
                "8": "亦寵極而禍侈"
            }
        },
        "34": {
            "69": {
                "1": "津便門以右轉",
                "2": "究吾境之所曁",
                "3": "掩細柳而撫劍",
                "4": "快孝文之命帥",
                "5": "周受命以忘身",
                "6": "明戎政之果毅",
                "7": "距華蓋於壘和",
                "8": "案乘輿之尊轡",
                "9": "肅天威之臨顏",
                "10": "率軍禮以長撎",
                "11": "輕棘霸之兒戲",
                "12": "重條侯之倨貴"
            }
        },
        "35": {
            "71": {
                "1": "索杜郵其焉在",
                "2": "云孝里之前號",
                "3": "惘輟駕而容與",
                "4": "哀武安以興悼",
                "5": "爭伐趙以徇國",
                "6": "定廟筭之勝負",
                "7": "扞矢言而不納",
                "8": "反推怨以歸咎",
                "9": "未十里於遷路",
                "10": "尋賜劍以刎首",
                "11": "嗟主闇而臣嫉",
                "12": "禍於何而不有"
            }
        },
        "36": {
            "73": {
                "1": "窺秦墟於渭城",
                "2": "冀闕緬其堙盡",
                "3": "覓陛殿之餘基",
                "4": "裁岥岮以隱嶙",
                "5": "想趙使之抱璧",
                "6": "瀏睨楹以抗憤",
                "7": "燕圖窮而荊發",
                "8": "紛絕袖而自引",
                "9": "筑聲厲而高奮",
                "10": "狙潛鉛以脫臏",
                "11": "據天位其若茲",
                "12": "亦狼狽而可愍",
                "13": "簡良人以自輔",
                "14": "謂斯忠而鞅賢",
                "15": "寄苛制於捐灰",
                "16": "矯扶蘇於朔邊",
                "17": "儒林塡於坑穽",
                "18": "詩書煬而爲煙",
                "19": "國滅亡以斷後",
                "20": "身刑轘以啟前",
                "21": "商法焉得以宿",
                "22": "黃犬何可復牽",
                "23": "野蒲變而成脯",
                "24": "苑鹿化以爲馬",
                "25": "假讒逆以天權",
                "26": "鉗眾口而寄坐",
                "27": "兵在頸而顧問",
                "28": "何不早而告我",
                "29": "願黔黎其誰聽",
                "30": "惟請死而獲可",
                "31": "健子嬰之果決",
                "32": "敢討賊以紓禍",
                "33": "勢土崩而莫振",
                "34": "作降王於路左",
                "35": "蕭收圖以相劉",
                "36": "料險易與眾寡",
                "37": "羽天與而弗取",
                "38": "冠沐猴而縱火",
                "39": "貫三光而洞九泉",
                "40": "曾未足以喩其高下也"
            }
        },
        "37": {
            "75": {
                "1": "感市閭之菆井",
                "2": "歎尸韓之舊處",
                "3": "丞屬號而守闕",
                "4": "人百身以納贖",
                "5": "豈生命之易投",
                "6": "誠惠愛之洽著",
                "7": "訐望之以求直",
                "8": "亦余心之所惡",
                "9": "思夫人之政術",
                "10": "實幹時之良具",
                "11": "苟明法以釋憾",
                "12": "不愛才以成務",
                "13": "弘大體以高貴",
                "14": "非所望於蕭傅"
            }
        },
        "38": {
            "77": {
                "1": "造長山而慷慨",
                "2": "偉龍顏之英主",
                "3": "胸中豁其洞開",
                "4": "羣善湊而必舉",
                "5": "存威格乎天區",
                "6": "亡墳掘而莫禦",
                "7": "臨揜坎而累抃",
                "8": "步毀垣以延佇"
            }
        },
        "39": {
            "79": {
                "1": "越安陵而無譏",
                "2": "諒惠聲之寂寞",
                "3": "弔爰絲之正義",
                "4": "伏梁劍於東郭",
                "5": "訊景皇於陽丘",
                "6": "奚信譖而矜謔",
                "7": "隕吳嗣於局下",
                "8": "蓋發怒於一博",
                "9": "成七國之稱亂",
                "10": "翻助逆以誅錯",
                "11": "恨過聽而無討",
                "12": "茲沮善而勸惡"
            }
        },
        "40": {
            "81": {
                "1": "呰孝元於渭塋",
                "2": "執奄尹以明貶",
                "3": "襃夫君之善行",
                "4": "廢園邑以崇儉",
                "5": "過延門而責成",
                "6": "忠何辜而爲戮",
                "7": "陷社稷之王章",
                "8": "俾幽死而莫鞠",
                "9": "忲淫嬖之匈忍",
                "10": "勦皇統之孕育",
                "11": "張舅氏之姦漸",
                "12": "貽漢宗以傾覆"
            }
        },
        "41": {
            "83": {
                "1": "刺哀主於義域",
                "2": "僭天爵於高安",
                "3": "欲法堯而承羞",
                "4": "永終古而不刊",
                "5": "瞰康園之孤墳",
                "6": "悲平后之專絜",
                "7": "殃厥父之簒逆",
                "8": "蒙漢恥而不雪",
                "9": "激義誠而引決",
                "10": "赴丹爓以明節",
                "11": "投宮火而焦糜",
                "12": "從灰熛而俱滅"
            }
        },
        "42": {
            "85": {
                "1": "騖橫橋而旋軫",
                "2": "歷敝邑之南垂",
                "3": "門礠石而梁木蘭兮",
                "4": "構阿房之屈奇",
                "5": "疏南山以表闕",
                "6": "倬樊川以激池",
                "7": "役鬼傭其猶否",
                "8": "矧人力之所爲",
                "9": "工徒斲而未息",
                "10": "義兵紛以交馳",
                "11": "宗祧汙而爲沼",
                "12": "豈斯宇之獨隳"
            }
        },
        "43": {
            "87": {
                "1": "由僞新之九廟",
                "2": "夸宗虞而祖黃",
                "3": "驅吁嗟而妖臨",
                "4": "搜佞哀以拜郎",
                "5": "誦六藝以飾姦",
                "6": "焚詩書而面牆",
                "7": "心不則於德義",
                "8": "雖異術而同亡"
            }
        },
        "44": {
            "89": {
                "1": "宗孝宣於樂遊",
                "2": "紹衰緒以中興",
                "3": "不獲事於敬養",
                "4": "盡加隆於園陵",
                "5": "兆惟奉明",
                "6": "邑號千人",
                "7": "訊諸故老",
                "8": "造自帝詢",
                "9": "隱王母之非命",
                "10": "縱聲樂以娛神",
                "11": "雖靡率於舊典",
                "12": "亦觀過而知仁"
            }
        },
        "45": {
            "91": {
                "1": "憑高望之陽隈",
                "2": "體川陸之汙隆",
                "3": "開襟乎清暑之館",
                "4": "遊目乎五柞之宮",
                "5": "交渠引漕",
                "6": "激湍生風",
                "7": "乃有昆明池乎其中",
                "8": "其池則湯湯汗汗",
                "9": "滉瀁彌漫",
                "10": "浩如河漢",
                "11": "日月麗天",
                "12": "出入乎東西",
                "13": "旦似湯谷",
                "14": "夕類虞淵",
                "15": "昔豫章之名宇",
                "16": "披玄流而特起",
                "17": "儀景星於天漢",
                "18": "列牛女以雙峙",
                "19": "圖萬載而不傾",
                "20": "奄摧落於十紀",
                "21": "擢百尋之層觀",
                "22": "今數仞之餘趾",
                "23": "振鷺於飛",
                "24": "鳧躍鴻漸",
                "25": "乘雲頡頏",
                "26": "隨波澹淡",
                "27": "瀺灂驚波",
                "28": "唼喋菱芡",
                "29": "華蓮爛於淥沼",
                "30": "青蕃蔚乎翠瀲"
            }
        },
        "46": {
            "93": {
                "1": "伊茲池之肇穿",
                "2": "肄水戰於荒服",
                "3": "志勤遠以極武",
                "4": "良無要於後福",
                "5": "而菜蔬芼實",
                "6": "水物惟錯",
                "7": "乃有贍乎原陸",
                "8": "在皇代而物土",
                "9": "故毀之而又復",
                "10": "凡厥僚司",
                "11": "旣富而教",
                "12": "咸帥貧惰",
                "13": "同整楫棹",
                "14": "收罟課獲",
                "15": "引繳舉效",
                "16": "鰥夫有室",
                "17": "愁民以樂",
                "18": "徒觀其鼓枻迴輪",
                "19": "灑釣投網",
                "20": "垂餌出入",
                "21": "挺叉來往",
                "22": "纖經連白",
                "23": "鳴桹厲響",
                "24": "貫鰓𦉹尾",
                "25": "掣三牽兩",
                "26": "於是弛青鯤於網鉅",
                "27": "解赬鯉於黏徽",
                "28": "華魴躍鱗",
                "29": "素鱮揚鬐",
                "30": "饔人縷切",
                "31": "鸞刀若飛",
                "32": "應刃落俎",
                "33": "靃靃霏霏",
                "34": "紅鮮紛其初載",
                "35": "賓旅竦而遲御",
                "36": "旣餐服以屬厭",
                "37": "泊恬靜以無欲",
                "38": "迴小人之腹",
                "39": "爲君子之慮"
            }
        },
        "47": {
            "95": {
                "1": "爾乃端策拂茵",
                "2": "彈冠振衣",
                "3": "徘徊酆鎬",
                "4": "如渴如飢",
                "5": "心翹懃以仰止",
                "6": "不加敬而自祇",
                "7": "豈三聖之敢夢",
                "8": "竊十亂之或希",
                "9": "經始靈臺",
                "10": "成之不日",
                "11": "惟酆及鄗",
                "12": "仍京其室",
                "13": "庶人子來",
                "14": "神降之吉",
                "15": "積德延祚",
                "16": "莫二",
                "17": "永惟此邦",
                "18": "云誰之識",
                "19": "越可略聞",
                "20": "而難臻其極",
                "21": "子贏鋤以借父",
                "22": "訓秦法而著色",
                "23": "耕讓畔以閑田",
                "24": "霑姬化而生棘",
                "25": "蘇張喜而詐騁",
                "26": "虞芮愧而訟息",
                "27": "由此觀之",
                "28": "土無常俗",
                "29": "而教有定式",
                "30": "上之遷下",
                "31": "均之埏埴",
                "32": "五方雜會",
                "33": "風流溷淆",
                "34": "惰農好利",
                "35": "不昏作勞",
                "36": "密邇獫狁",
                "37": "戎馬生郊",
                "38": "而制者必割",
                "39": "實存操刀",
                "40": "人之升降",
                "41": "與政隆替",
                "42": "杖信則莫不用情",
                "43": "無欲則賞之不竊",
                "44": "雖智弗能理",
                "45": "明弗能察",
                "46": "信此心也",
                "47": "庶免夫戾",
                "48": "如其禮樂",
                "49": "以俟來哲"
            }
        }
    }
}