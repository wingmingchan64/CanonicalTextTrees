{
    "28.01-11": {
        "篇名": "陸士衡 樂府十七首長歌行·其十一",
        "1": {
            "3": {
                "1": "逝矣經天日",
                "2": "悲哉帶地川",
                "3": "寸陰無停晷",
                "4": "尺波豈徒旋",
                "5": "年往迅勁矢",
                "6": "時來亮急絃",
                "7": "遠期鮮克及",
                "8": "盈數固希全",
                "9": "容華夙夜零",
                "10": "體澤坐自捐",
                "11": "茲物苟難停",
                "12": "吾壽安得延",
                "13": "俛仰逝將過",
                "14": "倏忽幾何間",
                "15": "慷慨亦焉訴",
                "16": "天道良自然",
                "17": "但恨功名薄",
                "18": "竹帛無所宣",
                "19": "迨及歲未暮",
                "20": "長歌承我閑"
            }
        }
    }
