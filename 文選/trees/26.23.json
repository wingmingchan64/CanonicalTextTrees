{
    "26.23": {
        "篇名": "謝靈運 過始寧墅",
        "1": {
            "3": {
                "1": "束髮懷耿介",
                "2": "逐物遂推遷",
                "3": "違志似如昨",
                "4": "二紀及茲年",
                "5": "淄磷謝清曠",
                "6": "疲薾慚貞堅",
                "7": "拙疾相倚薄",
                "8": "還得靜者便",
                "9": "剖竹守滄海",
                "10": "枉帆過舊山",
                "11": "山行窮登頓",
                "12": "水涉盡洄沿",
                "13": "巖峭嶺稠疊",
                "14": "洲縈渚連綿",
                "15": "白雲抱幽石",
                "16": "綠篠媚清漣",
                "17": "葺宇臨迴江",
                "18": "築觀基曾巓 ",
                "19": "揮手告鄕曲",
                "20": "三載期歸旋",
                "21": "且爲樹枌檟",
                "22": "無令孤願言"
            }
        }
    }
}