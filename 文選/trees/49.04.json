{
    "49.04": {
        "篇名": "范蔚宗 後漢書·皇后紀論",
        "1": {
            "3": {
                "1": "夏殷以上",
                "2": "后妃之制",
                "3": "其文略矣",
                "4": "周禮",
                "5": "王者立后",
                "6": "三夫人",
                "7": "九嬪",
                "8": "二十七世婦",
                "9": "八十一女御",
                "10": "以備內職焉",
                "11": "后正位宮闈",
                "12": "同體天王",
                "13": "夫人坐論婦禮",
                "14": "九嬪掌教四德",
                "15": "世婦主知喪",
                "16": "祭",
                "17": "賓客",
                "18": "女御序於王之燕寢",
                "19": "頒官分務",
                "20": "各有典司",
                "21": "女史彤管",
                "22": "記功書過",
                "23": "居有保阿之訓",
                "24": "動有環珮之響",
                "25": "進賢才以輔佐君子",
                "26": "哀窈窕而不淫其色",
                "27": "所以能述宣陰化",
                "28": "修成內則",
                "29": "閨房肅雍",
                "30": "險謁不行者也",
                "31": "故康王晚朝",
                "32": "關雎作諷",
                "33": "宣后晏起",
                "34": "姜氏請諐",
                "35": "及周室東遷",
                "36": "禮序凋缺",
                "37": "諸侯僭縱",
                "38": "軌制無章",
                "39": "齊桓有如夫人者六人",
                "40": "晉獻升戎女爲元妃",
                "41": "終於五子作亂",
                "42": "冢嗣遘屯",
                "43": "爰逮戰國",
                "44": "風憲愈薄",
                "45": "適情任欲",
                "46": "顚倒衣裳",
                "47": "以至破國亡身",
                "48": "不可勝數",
                "49": "斯固輕禮弛防",
                "50": "先色後德者也"
            }
        },
        "2": {
            "5": {
                "1": "秦幷天下",
                "2": "多自驕大",
                "3": "官備七國",
                "4": "爵列八品",
                "5": "漢興",
                "6": "因循其號",
                "7": "而婦制莫釐",
                "8": "高祖帷薄不修",
                "9": "孝文衽席無辨",
                "10": "然而選納尙簡",
                "11": "飾玩華少",
                "12": "自武元之後",
                "13": "世增淫費",
                "14": "至乃掖庭三千",
                "15": "增級十四",
                "16": "妖倖毀政之符",
                "17": "外姻亂邦之迹",
                "18": "前史載之詳矣"
            }
        },
        "3": {
            "7": {
                "1": "及光武中興",
                "2": "斲雕爲朴",
                "3": "六宮稱號",
                "4": "惟皇后貴人",
                "5": "金印紫綬",
                "6": "俸不過粟數十斛",
                "7": "又置美人宮人采女三等",
                "8": "並無爵秩",
                "9": "歲時賞賜充給而已",
                "10": "漢法常因八月筭民",
                "11": "遣中大夫與掖庭丞及相工",
                "12": "於洛陽鄕中閱視良家童女",
                "13": "年十三以上",
                "14": "二十以下",
                "15": "恣色端麗",
                "16": "合法相者",
                "17": "載還後宮",
                "18": "擇視可否",
                "19": "乃用登御",
                "20": "所以明愼聘納",
                "21": "詳求淑哲",
                "22": "明帝聿遵先旨",
                "23": "宮教頗修",
                "24": "登建嬪后",
                "25": "必先令德",
                "26": "內無出閫之言",
                "27": "權無私溺之授",
                "28": "可謂矯其敝矣",
                "29": "向使因設外戚之禁",
                "30": "編著甲令",
                "31": "改正后妃之制",
                "32": "貽厥方來",
                "33": "豈不休哉",
                "34": "雖御己有度",
                "35": "而防閑未篤",
                "36": "故孝章以下",
                "37": "漸用色授",
                "38": "恩隆好合",
                "39": "遂忘濇蠹"
            }
        },
        "4": {
            "9": {
                "1": "自古雖主幼時艱",
                "2": "王家多釁",
                "3": "委成冢宰",
                "4": "簡求忠貞",
                "5": "未有專任婦人",
                "6": "斷割重器",
                "7": "唯秦羋太后始攝政事",
                "8": "故穰侯權重於昭王",
                "9": "家富於嬴國",
                "10": "漢仍其謬",
                "11": "知患莫改",
                "12": "東京皇統屢絕",
                "13": "權歸女主",
                "14": "外立者四帝",
                "15": "臨朝者六后",
                "16": "莫不定策帷帟",
                "17": "委事父兄",
                "18": "貪孩童以久其政",
                "19": "抑明賢以專其威",
                "20": "任重道悠",
                "21": "利深禍速",
                "22": "身犯霧露於雲臺之上",
                "23": "家纓縲紲於圄犴之下",
                "24": "湮滅連踵",
                "25": "傾輈繼路",
                "26": "而赴蹈不息",
                "27": "燋爛爲期",
                "28": "終於陵夷大運",
                "29": "淪亡神寶",
                "30": "詩書所歎",
                "31": "略同一揆",
                "32": "故考列行迹",
                "33": "以爲皇后本紀",
                "34": "雖成敗事異",
                "35": "而同居正號者",
                "36": "並列於篇",
                "37": "其以恩私追尊",
                "38": "非當世所奉者",
                "39": "則隨他事附出",
                "40": "親屬別事",
                "41": "各依列傳",
                "42": "其餘無所見",
                "43": "則係之此紀",
                "44": "以纘西京外戚云爾"
            }
        }
    }
}