{
    "23.06-01": {
        "篇名": "王仲宣 七哀詩二首·其一",
        "1": {
            "3": {
                "1": "西京亂無象",
                "2": "豺虎方遘患",
                "3": "復棄中國去",
                "4": "遠身適荊蠻",
                "5": "親戚對我悲",
                "6": "朋友相追攀",
                "7": "出門無所見",
                "8": "白骨蔽平原",
                "9": "路有飢婦人",
                "10": "抱子棄草間",
                "11": "顧聞號泣聲",
                "12": "揮涕獨不還",
                "13": "未知身死處",
                "14": "何能兩相完",
                "15": "驅馬棄之去",
                "16": "不忍聽此言",
                "17": "南登霸陵岸",
                "18": "迴首望長安",
                "19": "悟彼下泉人",
                "20": "喟然傷心肝"
            }
        }
    }
}