{
    "46.01": {
        "篇名": "陸士衡 豪士賦序",
        "1": {
            "3": {
                "1": "夫立德之基有常",
                "2": "而建功之路不一",
                "3": "何則",
                "4": "循心以爲量者存乎我",
                "5": "因物以成務者繫乎彼",
                "6": "存夫我者",
                "7": "隆殺止乎其域",
                "8": "繫乎物者",
                "9": "豐約唯所遭遇",
                "10": "落葉俟微風以隕",
                "11": "而風之力蓋寡",
                "12": "孟嘗遭雍門而泣",
                "13": "而琴之感以末",
                "14": "何者",
                "15": "欲隕之葉",
                "16": "無所假烈風",
                "17": "將墜之泣",
                "18": "不足繁哀響也",
                "19": "是故苟時啟於天",
                "20": "理盡於民",
                "21": "庸夫可以濟聖賢之功",
                "22": "斗筲可以定烈士之業",
                "23": "故曰才不半古",
                "24": "而功已倍之",
                "25": "蓋得之於時勢也",
                "26": "歷觀古今",
                "27": "徼一時之功",
                "28": "而居伊周之位者有矣",
                "29": "夫我之自我",
                "30": "智士猶嬰其累",
                "31": "物之相物",
                "32": "昆蟲皆有此情",
                "33": "夫以自我之量",
                "34": "而挾非常之勳",
                "35": "神器暉其顧盼",
                "36": "萬物隨其俯仰",
                "37": "心玩居常之安",
                "38": "耳飽從諛之說",
                "39": "豈識乎功在身外",
                "40": "任出才表者哉"
            }
        },
        "2": {
            "5": {
                "1": "且好榮惡辱",
                "2": "有生之所大期",
                "3": "忌盈害上",
                "4": "鬼神猶且不免",
                "5": "人主操其常柄",
                "6": "天下服其大節",
                "7": "故曰天可讎乎",
                "8": "而時有袨服荷戟",
                "9": "立於廟門之下",
                "10": "援旗誓眾",
                "11": "奮於阡陌之上",
                "12": "況乎代主制命",
                "13": "自下財物者哉",
                "14": "廣樹恩不足以敵怨",
                "15": "勤興利不足以補害",
                "16": "故曰代大匠斲者",
                "17": "必傷其手",
                "18": "且夫政由寗氏",
                "19": "忠臣所爲慷慨",
                "20": "祭則寡人",
                "21": "人主所不久堪",
                "22": "是以君奭鞅鞅",
                "23": "不悅公旦之舉",
                "24": "高平師師",
                "25": "側目博陸之勢",
                "26": "而成王不遣嫌吝於懷",
                "27": "宣帝若負芒刺於背",
                "28": "非其然者與﹖嗟乎",
                "29": "光於四表",
                "30": "德莫富焉",
                "31": "王曰叔父",
                "32": "親莫昵焉",
                "33": "登帝大位",
                "34": "功莫厚焉",
                "35": "守節沒齒",
                "36": "忠莫至焉",
                "37": "而傾側顚沛",
                "38": "僅而自全",
                "39": "則伊生抱明允以嬰戮",
                "40": "文子懷忠敬而齒劍",
                "41": "固其所也"
            }
        },
        "3": {
            "7": {
                "1": "因斯以言",
                "2": "夫以篤聖穆親",
                "3": "如彼之懿",
                "4": "大德至忠",
                "5": "如此之盛",
                "6": "尙不能取信於人主之懷",
                "7": "止謗於眾多之口",
                "8": "過此以往",
                "9": "惡睹其可",
                "10": "安危之理",
                "11": "斷可識矣",
                "12": "又況乎饕大名以冒道家之忌",
                "13": "運短才而易聖哲所難者哉",
                "14": "身危由於勢過",
                "15": "而不知去勢以求安",
                "16": "禍積起於寵盛",
                "17": "而不知辭寵以招福",
                "18": "見百姓之謀己",
                "19": "則申宮警守",
                "20": "以崇不畜之威",
                "21": "懼萬民之不服",
                "22": "則嚴刑峻制",
                "23": "以賈傷心之怨",
                "24": "然後威窮乎震主",
                "25": "而怨行乎上下",
                "26": "眾心日陊",
                "27": "危機將發",
                "28": "而方偃仰瞪眄",
                "29": "謂足以夸世",
                "30": "笑古人之未工",
                "31": "亡己事之已拙",
                "32": "知曩勳之可矜",
                "33": "暗成敗之有會",
                "34": "是以事窮運盡",
                "35": "必於顚仆",
                "36": "風起塵合",
                "37": "而禍至常酷也",
                "38": "聖人忌功名之過己",
                "39": "惡寵祿之踰量",
                "40": "蓋爲此也"
            }
        },
        "4": {
            "9": {
                "1": "夫惡欲之大端",
                "2": "賢愚所共有",
                "3": "而遊子殉高位於生前",
                "4": "志士思垂名於身後",
                "5": "受生之分",
                "6": "唯此而已",
                "7": "夫蓋世之業",
                "8": "名莫大焉",
                "9": "震主之勢",
                "10": "位莫盛焉",
                "11": "率意無違",
                "12": "欲莫順焉",
                "13": "借使伊人頗覽天道",
                "14": "知盡不可益",
                "15": "盈難久持",
                "16": "超然自引",
                "17": "高揖而退",
                "18": "則巍巍之盛",
                "19": "仰邈前賢",
                "20": "洋洋之風",
                "21": "俯冠來籍",
                "22": "而大欲不乏於身",
                "23": "至樂無愆乎舊",
                "24": "節彌效而德彌廣",
                "25": "身逾逸而名逾劭",
                "26": "此之不爲",
                "27": "彼之必昧",
                "28": "然後河海之迹堙爲窮流",
                "29": "一簣之舋積成山岳",
                "30": "名編凶頑之條",
                "31": "身厭荼毒之痛",
                "32": "豈不謬哉",
                "33": "故聊賦焉",
                "34": "庶使百世少有寤云"
            }
        },
        "5": [],
        "6": []
    }
}