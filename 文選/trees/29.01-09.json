{
    "29.01-09": {
        "篇名": "古詩一十九首·庭中有奇樹",
        "1": {
            "3": {
                "1": "庭中有奇樹",
                "2": "綠葉發華滋",
                "3": "攀條折其榮",
                "4": "將以遺所思",
                "5": "馨香盈懷袖",
                "6": "路遠莫致之",
                "7": "此物何足貢",
                "8": "但感別經時"
            }
        }
    }
}