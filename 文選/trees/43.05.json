{
    "43.05": {
        "篇名": "劉孝標 重答劉秣陵沼書",
        "1": {
            "3": {
                "1": "劉侯旣重有斯難",
                "2": "値余有天倫之戚",
                "3": "竟未之致也",
                "4": "尋而此君長逝",
                "5": "化爲異物",
                "6": "緒言餘論",
                "7": "蘊而莫傳",
                "8": "或有自其家得而示余者",
                "9": "余悲其音徽未沬",
                "10": "而其人已亡",
                "11": "青簡尙新",
                "12": "而宿草將列",
                "13": "泫然不知涕之無從也",
                "14": "雖隙駟不留",
                "15": "尺波電謝",
                "16": "而秋菊春蘭",
                "17": "英華靡絕",
                "18": "故存其梗槪",
                "19": "更酬其旨",
                "20": "若使墨翟之言無爽",
                "21": "宣室之談有徵",
                "22": "冀東平之樹",
                "23": "望咸陽而西靡",
                "24": "蓋山之泉",
                "25": "聞絃歌而赴節",
                "26": "但懸劍空壟",
                "27": "有恨如何"
            }
        }
    }
}