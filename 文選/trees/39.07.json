{
    "39.07": {
        "篇名": "江文通 詣建平王上書",
        "1": {
            "3": {
                "1": "昔者賤臣叩心",
                "2": "飛霜擊於燕地",
                "3": "庶女告天",
                "4": "振風襲於齊臺",
                "5": "下官每讀其書",
                "6": "未嘗不廢卷流涕",
                "7": "何者",
                "8": "士有一定之論",
                "9": "女有不易之行",
                "10": "信而見疑",
                "11": "貞而爲戮",
                "12": "是以壯夫義士",
                "13": "伏死而不顧者此也",
                "14": "下官聞仁不可恃",
                "15": "善不可依",
                "16": "謂徒虛語",
                "17": "乃今知之",
                "18": "伏願大王暫停左右",
                "19": "少加憐察"
            }
        },
        "2": {
            "5": {
                "1": "下官本蓬戶桑樞之人",
                "2": "布衣韋帶之士",
                "3": "退不飾詩書以驚愚",
                "4": "進不買名聲於天下",
                "5": "日者",
                "6": "謬得升降承明之闕",
                "7": "出入金華之殿",
                "8": "何常不局影凝嚴",
                "9": "側身扃禁者乎",
                "10": "竊慕大王之義",
                "11": "復爲門下之賓",
                "12": "備鳴盜淺術之餘",
                "13": "豫三五賤伎之末",
                "14": "大王惠以恩光",
                "15": "顧以顏色",
                "16": "實佩荊卿黃金之賜",
                "17": "竊感豫讓國士之分矣",
                "18": "常欲結纓伏劍",
                "19": "少謝萬一",
                "20": "剖心摩踵",
                "21": "以報所天",
                "22": "不圖小人固陋",
                "23": "坐貽謗雾",
                "24": "迹墜昭憲",
                "25": "身恨幽圄",
                "26": "履影弔心",
                "27": "酸鼻痛骨"
            }
        },
        "3": {
            "7": {
                "1": "下官聞虧名爲辱",
                "2": "虧形次之",
                "3": "是以每一念來",
                "4": "忽若有遺",
                "5": "加以涉旬月",
                "6": "迫季秋",
                "7": "天光沈陰",
                "8": "左右無色",
                "9": "身非木石",
                "10": "與獄吏爲伍",
                "11": "此少卿所以仰天槌心",
                "12": "泣盡而繼之以血也"
            }
        },
        "4": {
            "9": {
                "1": "下官雖乏鄕曲之譽",
                "2": "然嘗聞君子之行矣",
                "3": "其上則隱於簾肆之間",
                "4": "臥於巖石之下",
                "5": "次則結綬金馬之庭",
                "6": "高議雲臺之上",
                "7": "退則虜南越之君",
                "8": "係單於之頸",
                "9": "俱啟丹冊",
                "10": "並圖青史",
                "11": "寧當爭分寸之末",
                "12": "競錐刀之利哉"
            }
        },
        "5": {
            "11": {
                "1": "下官聞積毀銷金",
                "2": "積讒磨骨",
                "3": "遠則直生取疑於盜金",
                "4": "近則伯魚被名於不義",
                "5": "彼之二子",
                "6": "猶或如是",
                "7": "況在下官",
                "8": "焉能自免",
                "9": "昔上將之恥",
                "10": "絳侯幽獄",
                "11": "名臣之羞",
                "12": "史遷下室",
                "13": "至如下官",
                "14": "當何言哉",
                "15": "夫魯連之智",
                "16": "辭祿而不返",
                "17": "接輿之賢",
                "18": "行歌而忘歸",
                "19": "子陵閉關於東越",
                "20": "仲蔚杜門於西秦",
                "21": "亦良可知也",
                "22": "若使下官事非其虛",
                "23": "罪得其實",
                "24": "亦當鉗口吞舌",
                "25": "伏匕首以殞身",
                "26": "何以見齊魯奇節之人",
                "27": "燕趙悲歌之士乎"
            }
        },
        "6": {
            "13": {
                "1": "方今聖曆欽明",
                "2": "天下樂業",
                "3": "青雲浮雒",
                "4": "榮光塞河",
                "5": "西洎臨洮狄道",
                "6": "北距飛狐陽原",
                "7": "莫不浸仁沐義",
                "8": "照景飲醴而已",
                "9": "而下官抱痛圓門",
                "10": "含憤獄戶",
                "11": "一物之微",
                "12": "有足悲者",
                "13": "仰惟大王",
                "14": "少垂明白",
                "15": "則梧丘之魂",
                "16": "不愧於沈首",
                "17": "鵠亭之鬼",
                "18": "無恨於灰骨",
                "19": "不任肝膽之切",
                "20": "敬因執事以聞"
            }
        }
    }
}