{
    "47.06": {
        "篇名": "夏侯孝若 東方朔畫贊[幷序]",
        "1": {
            "3": {
                "1": "大夫諱朔",
                "2": "字曼倩",
                "3": "平原厭次人也",
                "4": "魏建安中",
                "5": "分厭次以爲樂陵郡",
                "6": "故又爲郡人焉",
                "7": "事漢武帝",
                "8": "漢書具載其事"
            }
        },
        "2": {
            "5": {
                "1": "先生瑰瑋博達",
                "2": "思周變通",
                "3": "以爲濁世不可以富貴也",
                "4": "故薄遊以取位",
                "5": "苟出不可以直道也",
                "6": "故頡頏以傲世",
                "7": "傲世不可以垂訓也",
                "8": "故正諫以明節",
                "9": "明節不可以久安也",
                "10": "故詼諧以取容",
                "11": "潔其道而穢其迹",
                "12": "清其質而濁其文",
                "13": "弛張而不爲邪",
                "14": "進退而不離羣",
                "15": "若乃遠心曠度",
                "16": "贍智宏材",
                "17": "倜儻博物",
                "18": "觸類多能",
                "19": "合變以明笇",
                "20": "幽贊以知來",
                "21": "自三墳五典八索九丘",
                "22": "陰陽圖緯之學",
                "23": "百家眾流之論",
                "24": "周給敏捷之辯",
                "25": "支離覆逆之數",
                "26": "經脈藥石之藝",
                "27": "射御書計之術",
                "28": "乃硏精而究其理",
                "29": "不習而盡其功",
                "30": "經目而諷於口",
                "31": "過耳而闇於心",
                "32": "夫其明濟開豁",
                "33": "包含弘大",
                "34": "凌轢卿相",
                "35": "謿哂豪桀",
                "36": "籠罩靡前",
                "37": "跆籍貴勢",
                "38": "出不休顯",
                "39": "賤不憂戚",
                "40": "戲萬乘若僚友",
                "41": "視儔列如草芥",
                "42": "雄節邁倫",
                "43": "高氣蓋世",
                "44": "可謂拔乎其萃",
                "45": "遊方之外者已"
            }
        },
        "3": {
            "7": {
                "1": "談者又以先生噓吸沖和",
                "2": "吐故納新",
                "3": "蟬蛻龍變",
                "4": "棄俗登仙",
                "5": "神交造化",
                "6": "靈爲星辰",
                "7": "此又奇怪惚恍",
                "8": "不可備論者也"
            }
        },
        "4": {
            "9": {
                "1": "大人來守此國",
                "2": "僕自京都言歸定省",
                "3": "睹先生之縣邑",
                "4": "想先生之高風",
                "5": "徘徊路寢",
                "6": "見先生之遺像",
                "7": "逍遙城郭",
                "8": "觀先生之祠宇",
                "9": "慨然有懷",
                "10": "乃作頌焉",
                "11": "其辭曰"
            }
        },
        "5": {
            "11": {
                "1": "矯矯先生",
                "2": "肥遯居貞",
                "3": "退不終否",
                "4": "進亦避榮",
                "5": "臨世濯足",
                "6": "希古振纓",
                "7": "涅而無滓",
                "8": "旣濁能清",
                "9": "無滓伊何",
                "10": "高明克柔",
                "11": "能清伊何",
                "12": "視汙若浮",
                "13": "樂在必行",
                "14": "處淪罔憂",
                "15": "跨世凌時",
                "16": "遠蹈獨遊",
                "17": "瞻望往代",
                "18": "爰想遐蹤",
                "19": "邈邈先生",
                "20": "其道猶龍",
                "21": "染迹朝隱",
                "22": "和而不同",
                "23": "栖遲下位",
                "24": "聊以從容"
            }
        },
        "6": {
            "13": {
                "1": "我來自東",
                "2": "言適茲邑",
                "3": "敬問墟墳",
                "4": "企佇原隰",
                "5": "墟墓徒存",
                "6": "精靈永戢",
                "7": "民思其軌",
                "8": "祠宇斯立",
                "9": "徘徊寺寢",
                "10": "遺像在圖",
                "11": "周旋祠宇",
                "12": "庭序荒蕪",
                "13": "榱棟傾落",
                "14": "草萊弗除",
                "15": "肅肅先生",
                "16": "豈焉是居",
                "17": "是居弗形",
                "18": "悠悠我情",
                "19": "昔在有德",
                "20": "罔不遺靈",
                "21": "天秩有禮",
                "22": "神監孔明",
                "23": "彷彿風塵",
                "24": "用垂頌聲"
            }
        }
    }
}