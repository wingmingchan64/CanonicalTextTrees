{
    "43.02": {
        "篇名": "孫子荊 爲石仲容與孫皓書",
        "1": {
            "3": {
                "1": "苞白",
                "2": "蓋聞見機而作",
                "3": "周易所貴",
                "4": "小不事大",
                "5": "春秋所誅",
                "6": "此乃吉凶之萌兆",
                "7": "榮辱之所由興也",
                "8": "是故許鄭以銜璧全國",
                "9": "曹譚以無禮取滅",
                "10": "載籍旣記其成敗",
                "11": "古今又著其愚智矣",
                "12": "不復廣引譬類",
                "13": "崇飾浮辭",
                "14": "苟以夸大爲名",
                "15": "更喪忠告之實",
                "16": "今粗論事勢",
                "17": "以相覺悟"
            }
        },
        "2": {
            "5": {
                "1": "昔炎精幽昧",
                "2": "曆數將終",
                "3": "桓靈失德",
                "4": "災釁並興",
                "5": "豺狼抗爪牙之毒",
                "6": "生人陷荼炭之艱",
                "7": "於是九州絕貫",
                "8": "皇綱解紐",
                "9": "四海蕭條",
                "10": "非復漢有",
                "11": "太祖承運",
                "12": "神武應期",
                "13": "征討暴亂",
                "14": "克寧區夏",
                "15": "協建靈符",
                "16": "天命旣集",
                "17": "遂廓洪基",
                "18": "奄有魏域",
                "19": "土則神州中岳",
                "20": "器則九鼎猶存",
                "21": "世載淑美",
                "22": "重光相襲",
                "23": "固知四隩之攸同",
                "24": "天下之壯觀也"
            }
        },
        "3": {
            "7": {
                "1": "公孫淵承籍父兄",
                "2": "世居東裔",
                "3": "擁帶燕胡",
                "4": "馮凌險遠",
                "5": "講武盤桓",
                "6": "不供職貢",
                "7": "內傲帝命",
                "8": "外通南國",
                "9": "乘桴滄流",
                "10": "交疇貨賄",
                "11": "葛越布於朔土",
                "12": "貂馬延乎吳會",
                "13": "自以爲控弦十萬",
                "14": "奔走足用",
                "15": "信能右折燕齊",
                "16": "左振扶桑",
                "17": "凌轢沙漠",
                "18": "南面稱王也",
                "19": "宣王薄伐",
                "20": "猛銳長驅",
                "21": "師次遼陽",
                "22": "而城池不守",
                "23": "桴鼓一震",
                "24": "而元凶折首",
                "25": "然後遠迹疆埸",
                "26": "列郡大荒",
                "27": "收離聚散",
                "28": "咸安其居",
                "29": "民庶悅服",
                "30": "殊俗款附",
                "31": "自茲遂隆",
                "32": "九野清泰",
                "33": "東夷獻其樂器",
                "34": "肅愼貢其楛矢",
                "35": "曠世不羈",
                "36": "應化而至",
                "37": "巍巍蕩蕩",
                "38": "想所具聞"
            }
        },
        "4": {
            "9": {
                "1": "吳之先主",
                "2": "起自荊州",
                "3": "遭時擾攘",
                "4": "播潛江表",
                "5": "劉備震懼",
                "6": "亦逃巴岷",
                "7": "遂依丘陵積石之固",
                "8": "三江五湖",
                "9": "浩汗無涯",
                "10": "假氣遊魂",
                "11": "迄於四紀",
                "12": "二邦合從",
                "13": "東西唱和",
                "14": "互相扇動",
                "15": "距捍中國",
                "16": "自謂三分鼎足之勢",
                "17": "可與泰山共相終始",
                "18": "相國晉王",
                "19": "輔相帝室",
                "20": "文武桓桓",
                "21": "志厲秋霜",
                "22": "廟勝之筭",
                "23": "應變無窮",
                "24": "獨見之鑒",
                "25": "與眾絕慮",
                "26": "主上欽明",
                "27": "委以萬機",
                "28": "長轡遠御",
                "29": "妙略潛授",
                "30": "偏師同心",
                "31": "上下用力",
                "32": "稜威奮伐",
                "33": "铪入其阻",
                "34": "幷敵一向",
                "35": "奪其膽氣",
                "36": "小戰江介",
                "37": "則成都自潰",
                "38": "曜兵劍閣",
                "39": "而姜維面縛",
                "40": "開地五千",
                "41": "列郡三十",
                "42": "師不踰時",
                "43": "梁益肅清",
                "44": "使竊號之雄",
                "45": "稽顙絳闕",
                "46": "球琳重錦",
                "47": "充於府庫",
                "48": "夫虢滅虞亡",
                "49": "韓幷魏徙",
                "50": "此皆前鑒之驗",
                "51": "後事之師也",
                "52": "又南中呂興",
                "53": "深睹天命",
                "54": "蟬蛻內向",
                "55": "願爲臣妾",
                "56": "外失輔車脣齒之援",
                "57": "內有毛羽零落之漸",
                "58": "而徘徊危國",
                "59": "冀延日月",
                "60": "此猶魏武侯卻指河山以自強大",
                "61": "殊不知物有興亡",
                "62": "則所美非其地也"
            }
        },
        "5": {
            "11": {
                "1": "方今百僚濟濟",
                "2": "俊乂盈朝",
                "3": "虎臣武將",
                "4": "折衝萬里",
                "5": "國富兵強",
                "6": "六軍精練",
                "7": "思復翰飛",
                "8": "飲馬南海",
                "9": "自頃國家",
                "10": "整治器械",
                "11": "修造舟楫",
                "12": "簡習水戰",
                "13": "伐樹北山",
                "14": "則太行木盡",
                "15": "濬決河洛",
                "16": "則百川通流",
                "17": "樓船萬艘千里相望",
                "18": "自刳木以來",
                "19": "舟車之用",
                "20": "未有如今日之盛者也",
                "21": "驍勇百萬",
                "22": "畜力待時",
                "23": "役不再舉",
                "24": "今日之謂也",
                "25": "然主上眷眷",
                "26": "未便電邁者",
                "27": "以爲愛民治國",
                "28": "道家所尙",
                "29": "崇城自卑",
                "30": "文王退舍",
                "31": "故先開示大信",
                "32": "喩以存亡",
                "33": "殷勤之旨",
                "34": "往使所究"
            }
        },
        "6": {
            "13": {
                "1": "若能審識安危",
                "2": "自求多福",
                "3": "蹶然改容",
                "4": "祇承往告",
                "5": "追慕南越",
                "6": "嬰齊入侍",
                "7": "北面稱臣",
                "8": "伏聽告策",
                "9": "則世祚江表",
                "10": "永爲藩輔",
                "11": "豐報顯賞",
                "12": "隆於今日矣",
                "13": "若侮慢不式王命",
                "14": "然後謀力雲合",
                "15": "指麾風從",
                "16": "雍益二州",
                "17": "順流而東",
                "18": "青徐戰士",
                "19": "列江而西",
                "20": "荊楊兗豫",
                "21": "爭驅八衝",
                "22": "征東甲卒",
                "23": "虎步秣陵",
                "24": "爾乃皇輿整駕",
                "25": "六師徐征",
                "26": "羽檄燭日",
                "27": "旌旗流星",
                "28": "遊龍曜路",
                "29": "歌吹盈耳",
                "30": "士卒奔邁",
                "31": "其會如林",
                "32": "煙塵俱起",
                "33": "震天駭地",
                "34": "渴賞之士",
                "35": "鋒鏑爭先",
                "36": "忽然一旦身首橫分",
                "37": "宗祀屠覆",
                "38": "取誡萬世",
                "39": "引領南望",
                "40": "良以寒心"
            }
        },
        "7": {
            "15": {
                "1": "夫治膏肓者必進苦口之藥",
                "2": "決狐疑者必告逆耳之言",
                "3": "如其迷謬",
                "4": "未知所投",
                "5": "恐兪附見其已困",
                "6": "扁鵲知其無功也",
                "7": "勉思良圖",
                "8": "惟所去就",
                "9": "石苞白"
            }
        }
    }
}