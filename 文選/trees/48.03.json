{
    "48.03": {
        "篇名": "班孟堅 典引一首",
        "1": {
            "3": {
                "1": "臣固言",
                "2": "永平十七年",
                "3": "臣與賈逵傅毅杜矩展隆郗萌等",
                "4": "召詣雲龍門",
                "5": "小黃門趙宣持秦始皇帝本紀問臣等曰",
                "6": "太史遷下贊語中",
                "7": "寧有非耶",
                "8": "臣對",
                "9": "此贊賈誼過秦篇云",
                "10": "向使子嬰有庸主之才",
                "11": "僅得中佐",
                "12": "秦之社稷未宜絕也",
                "13": "此言非是",
                "14": "卽召臣入",
                "15": "問",
                "16": "本聞此論非耶",
                "17": "將見問意開寤耶",
                "18": "臣具對素聞知狀",
                "19": "詔因曰",
                "20": "司馬遷著書成一家之言",
                "21": "揚名後世",
                "22": "至以身陷刑之故",
                "23": "反微文刺譏",
                "24": "貶損當世",
                "25": "非誼士也",
                "26": "司馬相如洿行無節",
                "27": "但有浮華之辭",
                "28": "不周於用",
                "29": "至於疾病而遺忠",
                "30": "主上求取其書",
                "31": "竟得頌述功德",
                "32": "言封禪事",
                "33": "忠臣效也",
                "34": "至是賢遷遠矣",
                "35": "臣固常伏刻誦聖論",
                "36": "昭明好惡",
                "37": "不遺微細",
                "38": "緣事斷誼",
                "39": "動有規矩",
                "40": "雖仲尼之因史見意",
                "41": "亦無以加",
                "42": "臣固被學最舊",
                "43": "受恩浸深",
                "44": "誠思畢力竭情",
                "45": "昊天罔極",
                "46": "臣固頓首頓首",
                "47": "伏惟相如封禪",
                "48": "靡而不典",
                "49": "楊雄美新",
                "50": "典而亡實",
                "51": "然皆遊揚後世",
                "52": "垂爲舊式",
                "53": "臣固才朽不及前人",
                "54": "蓋詠雲門者難爲音",
                "55": "觀隋和者難爲珍",
                "56": "不勝區區",
                "57": "竊作典引一篇",
                "58": "雖不足雍容明盛萬分之一",
                "59": "猶啟發憤滿",
                "60": "覺悟童蒙",
                "61": "光揚大漢",
                "62": "軼聲前代",
                "63": "然後退入溝壑",
                "64": "死而不朽",
                "65": "臣固愚戇",
                "66": "頓首頓首",
                "67": "曰",
                "68": "太極之元",
                "69": "兩儀始分",
                "70": "煙煙熅熅",
                "71": "有沈而奧",
                "72": "有浮而清",
                "73": "沈浮交錯",
                "74": "庶類混成",
                "75": "肇命民主",
                "76": "五德初始",
                "77": "同於草昧",
                "78": "玄混之中",
                "79": "踰繩越契",
                "80": "寂寥而亡詔者",
                "81": "系不得而綴也",
                "82": "厥有氏號",
                "83": "紹天闡繹",
                "84": "莫不開元於太昊皇初之首",
                "85": "上哉敻乎",
                "86": "其書猶得而修也",
                "87": "亞斯之代",
                "88": "通變神化",
                "89": "函光而未曜"
            }
        },
        "2": {
            "5": {
                "1": "若夫上稽乾則",
                "2": "降承龍翼",
                "3": "而炳諸典謨",
                "4": "以冠德卓絕者",
                "5": "莫崇乎陶唐",
                "6": "陶唐舍胤而禪有虞",
                "7": "有虞亦命夏后",
                "8": "稷契熙載",
                "9": "越成湯武",
                "10": "股肱旣周",
                "11": "天迺歸功元首",
                "12": "將授漢劉",
                "13": "俾其承三季之荒末",
                "14": "値亢龍之災孼",
                "15": "縣象闇而恆文乖",
                "16": "彝倫斁而舊章缺",
                "17": "故先命玄聖",
                "18": "使綴學立制",
                "19": "宏亮洪業",
                "20": "表相祖宗",
                "21": "贊揚迪喆",
                "22": "備哉粲爛",
                "23": "眞神明之式也",
                "24": "雖皋夔衡旦密勿之輔",
                "25": "比茲褊矣",
                "26": "是以高光二聖",
                "27": "宸居其域",
                "28": "時至氣動",
                "29": "乃龍見淵躍",
                "30": "拊翼而未舉",
                "31": "則威靈紛紜",
                "32": "海內雲蒸",
                "33": "雷動電熛",
                "34": "胡縊莽分",
                "35": "尙不蒞其誅",
                "36": "然後欽若上下",
                "37": "恭揖羣后",
                "38": "正位度宗",
                "39": "有於德不台淵穆之讓",
                "40": "靡號師矢敦奮撝之容",
                "41": "蓋以膺當天之正統",
                "42": "受克讓之歸運",
                "43": "蓄炎上之烈精",
                "44": "蘊孔佐之弘陳云爾"
            }
        },
        "3": {
            "7": {
                "1": "洋洋乎若德",
                "2": "帝者之上儀",
                "3": "誥誓所不及已",
                "4": "鋪觀二代洪纖之度",
                "5": "其賾可探也",
                "6": "並開迹於一匱",
                "7": "同受侯甸之服",
                "8": "奕世勤民",
                "9": "以方伯統牧",
                "10": "乘其命賜彤弧黃鉞之威",
                "11": "用討韋顧黎崇之不恪",
                "12": "至於參五華夏",
                "13": "京遷鎬亳",
                "14": "遂自北面",
                "15": "虎螭其師",
                "16": "革滅天邑",
                "17": "是故誼士華而不敦",
                "18": "武稱未盡",
                "19": "護有慚德",
                "20": "不其然歟﹖亦猶於穆猗那",
                "21": "翕純皦繹",
                "22": "以崇嚴祖考",
                "23": "殷薦宗配帝",
                "24": "發祥流慶",
                "25": "對越天地者",
                "26": "舄奕乎千載",
                "27": "豈不克自神明哉",
                "28": "誕略有常",
                "29": "審言行於篇籍",
                "30": "光藻朗而不渝耳"
            }
        },
        "4": {
            "9": {
                "1": "矧夫赫赫聖漢",
                "2": "巍巍唐基",
                "3": "泝測其源",
                "4": "乃先孕虞育夏",
                "5": "甄殷陶周",
                "6": "然後宣二祖之重光",
                "7": "襲四宗之緝熙",
                "8": "神靈日照",
                "9": "光被六幽",
                "10": "仁風翔乎海表",
                "11": "威靈行乎鬼區",
                "12": "匿亡回而不泯",
                "13": "微胡瑣而不頤",
                "14": "故夫顯定三才昭登之績",
                "15": "匪堯不興",
                "16": "鋪聞遺策在下之訓",
                "17": "匪漢不弘厥道",
                "18": "至於經緯乾坤",
                "19": "出入三光",
                "20": "外運渾元",
                "21": "內霑豪芒",
                "22": "性類循理",
                "23": "品物咸亨",
                "24": "其已久矣"
            }
        },
        "5": {
            "11": {
                "1": "盛哉",
                "2": "皇家帝世",
                "3": "德臣列辟",
                "4": "功君百王",
                "5": "榮鏡宇宙",
                "6": "尊亡與亢",
                "7": "乃始虔鞏勞謙",
                "8": "兢兢業業",
                "9": "貶成抑定",
                "10": "不敢論制作",
                "11": "至令遷正黜色賓監之事",
                "12": "渙揚寓內",
                "13": "而禮官儒林屯用篤誨之士",
                "14": "不傳祖宗之髣彿",
                "15": "雖云優愼",
                "16": "無乃葸與"
            }
        },
        "6": {
            "13": {
                "1": "於是三事嶽牧之僚",
                "2": "僉爾而進曰",
                "3": "陛下仰監唐典",
                "4": "中述祖則",
                "5": "俯蹈宗軌",
                "6": "躬奉天經",
                "7": "惇睦辨章之化洽",
                "8": "巡靖黎蒸",
                "9": "懷保鰥寡之惠浹",
                "10": "燔瘞縣沈",
                "11": "肅祇羣神之禮備",
                "12": "是以來儀集羽族於觀魏",
                "13": "肉角馴毛宗於外囿",
                "14": "擾緇文皓質於郊",
                "15": "升黃輝采鱗於沼",
                "16": "甘露宵零於豐草",
                "17": "三足軒翥於茂樹",
                "18": "若乃嘉穀靈草",
                "19": "奇獸神禽",
                "20": "應圖合諜",
                "21": "窮祥極瑞者",
                "22": "朝夕坰牧",
                "23": "日月邦畿",
                "24": "卓犖乎方州",
                "25": "洋溢乎要荒",
                "26": "昔姬有素雉",
                "27": "朱烏",
                "28": "玄秬",
                "29": "黃𪍓之事耳",
                "30": "素雉",
                "31": "白雉也",
                "32": "已見東都主人",
                "33": "朱烏",
                "34": "火流爲烏也",
                "35": "毛詩曰",
                "36": "誕降嘉種",
                "37": "惟秬惟秠",
                "38": "爾雅曰",
                "39": "秬",
                "40": "黑黍也",
                "41": "韓詩外傳曰",
                "42": "貽我嘉𪍓",
                "43": "薛君曰",
                "44": "𪍓",
                "45": "大麥也",
                "46": "音莫侯切",
                "47": "君臣動色",
                "48": "左右相趣",
                "49": "濟濟翼翼",
                "50": "峨峨如也",
                "51": "蓋用昭明寅畏",
                "52": "承聿懷之福",
                "53": "亦以寵靈文武",
                "54": "貽燕後昆",
                "55": "覆以懿鑠",
                "56": "豈其爲身而有顓辭也﹖若然受之",
                "57": "亦宜懃恁旅力",
                "58": "以充厥道",
                "59": "啟恭館之金縢",
                "60": "御東序之祕寶",
                "61": "以流其占"
            }
        },
        "7": {
            "15": {
                "1": "夫圖書亮章",
                "2": "天哲也",
                "3": "孔猷先命",
                "4": "聖孚也",
                "5": "體行德本",
                "6": "正性也",
                "7": "逢吉丁辰",
                "8": "景命也",
                "9": "順命以創制",
                "10": "因定以和神",
                "11": "答三靈之蕃祉",
                "12": "展放唐之明文",
                "13": "茲事體大",
                "14": "而允寤寐次於心",
                "15": "瞻前顧後",
                "16": "豈薎清廟憚敕天命也﹖伊考自遂古",
                "17": "乃降戾爰茲",
                "18": "作者七十有四人",
                "19": "有不俾而假素",
                "20": "罔光度而遺章",
                "21": "今其如台而獨闕也"
            }
        },
        "8": {
            "17": {
                "1": "是時聖上固以垂精遊神",
                "2": "苞舉藝文",
                "3": "屢訪羣儒",
                "4": "諭咨故老",
                "5": "與之斟酌道德之淵源",
                "6": "肴覈仁誼之林藪",
                "7": "以望元符之臻焉",
                "8": "旣感羣后之讜辭",
                "9": "又悉經五繇之碩慮矣",
                "10": "將絣萬嗣",
                "11": "揚洪輝",
                "12": "奮景炎",
                "13": "扇遺風",
                "14": "播芳烈",
                "15": "久而愈新",
                "16": "用而不竭",
                "17": "汪汪乎丕天之大律",
                "18": "其疇能亙之哉﹖唐哉皇哉",
                "19": "皇哉唐哉"
            }
        }
    }
}