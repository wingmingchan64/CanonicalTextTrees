{
    "41.06": {
        "篇名": "陳孔璋 爲曹洪與魏文帝書",
        "1": {
            "3": {
                "1": "十一月五日",
                "2": "洪白",
                "3": "前初破賊",
                "4": "情奓意奢",
                "5": "說事頗過其實",
                "6": "得九月二十日書",
                "7": "讀之喜笑",
                "8": "把玩無厭",
                "9": "亦欲令陳琳作報",
                "10": "琳頃多事",
                "11": "不能得爲",
                "12": "念欲遠以爲歡",
                "13": "故自竭老夫之思",
                "14": "辭多不可一一",
                "15": "粗舉大綱",
                "16": "以當談笑"
            }
        },
        "2": {
            "5": {
                "1": "漢中地形",
                "2": "實有險固",
                "3": "四嶽三塗",
                "4": "皆不及也",
                "5": "彼有精甲數萬",
                "6": "臨高守要",
                "7": "一人揮戟",
                "8": "萬夫不得進",
                "9": "而我軍過之",
                "10": "若駭鯨之決細網",
                "11": "奔兕之觸魯縞",
                "12": "未足以喩其易",
                "13": "雖云王者之師",
                "14": "有征無戰",
                "15": "不義而強",
                "16": "古人常有",
                "17": "故唐虞之世",
                "18": "蠻夷猾夏",
                "19": "周宣之盛",
                "20": "亦讎大邦",
                "21": "詩書歎載",
                "22": "言其難也",
                "23": "斯皆憑阻恃遠",
                "24": "故使其然",
                "25": "是以察茲地勢",
                "26": "謂爲中才處之",
                "27": "殆難倉卒",
                "28": "來命陳彼妖惑之罪",
                "29": "敍王師曠蕩之德",
                "30": "豈不信然",
                "31": "是夏殷所以喪",
                "32": "苗扈所以斃",
                "33": "我之所以克",
                "34": "彼之所以敗也",
                "35": "不然",
                "36": "商周何以不敵哉",
                "37": "昔鬼方聾昧",
                "38": "崇虎讒凶",
                "39": "殷辛暴虐",
                "40": "三者皆下科也",
                "41": "然高宗有三年之征",
                "42": "文王有退修之軍",
                "43": "盟津有再駕之役",
                "44": "然後殪戎勝殷",
                "45": "有此武功",
                "46": "焉有星流景集",
                "47": "飆奪霆擊",
                "48": "長驅山河",
                "49": "朝至暮捷",
                "50": "若今者也"
            }
        },
        "3": {
            "7": {
                "1": "由此觀之",
                "2": "彼固不逮下愚",
                "3": "則中才之守",
                "4": "不然明矣",
                "5": "在中才則謂不然",
                "6": "而來示乃以爲彼之惡稔",
                "7": "雖有孫田墨氂猶無所救",
                "8": "竊又疑焉",
                "9": "何者",
                "10": "古之用兵",
                "11": "敵國雖亂",
                "12": "尙有賢人",
                "13": "則不伐也",
                "14": "是故三仁未去",
                "15": "武王還師",
                "16": "宮奇在虞",
                "17": "晉不加戎",
                "18": "季梁猶在",
                "19": "強楚挫謀",
                "20": "曁至眾賢奔絀",
                "21": "三國爲墟",
                "22": "明其無道有人",
                "23": "猶可救也",
                "24": "且夫墨子之守",
                "25": "縈帶爲垣",
                "26": "高不可登",
                "27": "折箸爲械",
                "28": "堅不可入",
                "29": "若乃距陽平",
                "30": "據石門",
                "31": "攄八陣之列",
                "32": "騁奔牛之權",
                "33": "焉肯土崩魚爛哉",
                "34": "設令守無巧拙",
                "35": "皆可攀附",
                "36": "則公輸已陵宋城",
                "37": "樂毅已拔卽墨矣",
                "38": "墨翟之術何稱",
                "39": "田單之智何貴",
                "40": "老夫不敏",
                "41": "未之前聞"
            }
        },
        "4": {
            "9": {
                "1": "蓋聞過高唐者",
                "2": "效王豹之謳",
                "3": "遊睢渙者",
                "4": "學藻繢之綵",
                "5": "間自入益部",
                "6": "仰司馬楊王遺風",
                "7": "有子勝斐然之志",
                "8": "故頗奮文辭",
                "9": "異於他日",
                "10": "怪乃輕其家丘",
                "11": "謂爲倩人",
                "12": "是何言歟",
                "13": "夫綠驥垂耳於林埛",
                "14": "鴻雀戢翼於汙池",
                "15": "褻之者固以爲園囿之凡鳥",
                "16": "外廏之下乘也",
                "17": "及整蘭筋",
                "18": "揮勁翮",
                "19": "陵厲清浮",
                "20": "顧盼千里",
                "21": "豈可謂其借翰於晨風",
                "22": "假足於六駮哉",
                "23": "恐猶未信丘言",
                "24": "必大噱也",
                "25": "洪白"
            }
        }
    }
}