{
    "53.01": {
        "篇名": "嵇叔夜 養生論",
        "1": {
            "3": {
                "1": "世或有謂神仙可以學得",
                "2": "不死可以力致者",
                "3": "或云上壽百二十",
                "4": "古今所同",
                "5": "過此以往",
                "6": "莫非妖妄者",
                "7": "此皆兩失其情",
                "8": "請試粗論之"
            }
        },
        "2": {
            "5": {
                "1": "夫神仙雖不目見",
                "2": "然記籍所載",
                "3": "前史所傳",
                "4": "較而論之",
                "5": "其有必矣",
                "6": "似特受異氣",
                "7": "稟之自然",
                "8": "非積學所能致也",
                "9": "至於導養得理",
                "10": "以盡性命",
                "11": "上獲千餘歲",
                "12": "下可數百年",
                "13": "可有之耳",
                "14": "而世皆不精",
                "15": "故莫能得之",
                "16": "何以言之",
                "17": "夫服藥求汗",
                "18": "或有弗獲",
                "19": "而愧情一集",
                "20": "渙然流離",
                "21": "終朝未餐",
                "22": "則囂然思食",
                "23": "而曾子銜哀",
                "24": "七日不飢",
                "25": "夜分而坐",
                "26": "則低迷思寢",
                "27": "內懷殷憂",
                "28": "則達旦不瞑勁刷理鬢",
                "29": "醇醴發顏",
                "30": "僅乃得之",
                "31": "壯士之怒",
                "32": "赫然殊觀",
                "33": "植髮衝冠",
                "34": "由此言之",
                "35": "精神之於形骸",
                "36": "猶國之有君也",
                "37": "神躁於中",
                "38": "而形喪於外",
                "39": "猶君昏於上",
                "40": "國亂於下也"
            }
        },
        "3": {
            "7": {
                "1": "夫爲稼於湯之世",
                "2": "偏有一漑之功者",
                "3": "雖終歸燋爛",
                "4": "必一漑者後枯",
                "5": "然則一漑之益",
                "6": "固不可誣也",
                "7": "而世常謂一怒不足以侵性",
                "8": "一哀不足以傷身",
                "9": "輕而肆之",
                "10": "是猶不識一漑之益",
                "11": "而望嘉穀於旱苗者也",
                "12": "是以君子知形恃神以立",
                "13": "神須形以存",
                "14": "悟生理之易失",
                "15": "知一過之害生",
                "16": "故修性以保神",
                "17": "安心以全身",
                "18": "愛憎不栖於情",
                "19": "憂喜不留於意",
                "20": "泊然無感",
                "21": "而體氣和平",
                "22": "又呼吸吐納",
                "23": "服食養身",
                "24": "使形神相親",
                "25": "表裏俱濟也"
            }
        },
        "4": {
            "9": {
                "1": "夫田種者",
                "2": "一畝十斛",
                "3": "謂之良田",
                "4": "此天下之通稱也",
                "5": "不知區種可百餘斛",
                "6": "田種一也",
                "7": "至於樹養不同",
                "8": "則功收相懸",
                "9": "謂商無十倍之價",
                "10": "農無百斛之望",
                "11": "此守常而不變者也",
                "12": "且豆令人重",
                "13": "楡令人瞑",
                "14": "合歡蠲忿",
                "15": "萱草忘憂",
                "16": "愚智所共知也",
                "17": "薰辛害目",
                "18": "豚魚不養",
                "19": "常世所識也",
                "20": "養生要曰",
                "21": "大蒜勿食",
                "22": "葷辛害目",
                "23": "又",
                "24": "神農曰",
                "25": "豬肉虛人",
                "26": "不可久食",
                "27": "又曰",
                "28": "㹠肉損人",
                "29": "與豬同",
                "30": "說文曰",
                "31": "蒜",
                "32": "葷菜也",
                "33": "薰與葷同",
                "34": "豚魚無血",
                "35": "食之皆不利人也",
                "36": "蝨處頭而黑",
                "37": "麝食柏而香",
                "38": "頸處險而癭",
                "39": "齒居晉而黃",
                "40": "推此而言",
                "41": "凡所食之氣",
                "42": "蒸性染身",
                "43": "莫不相應",
                "44": "豈惟蒸之使重而無使輕",
                "45": "害之使闇而無使明",
                "46": "薰之使黃而無使堅",
                "47": "芬之使香而無使延哉",
                "48": "故神農曰上藥養命",
                "49": "中藥養性者",
                "50": "誠知性命之理",
                "51": "因輔養以通也",
                "52": "而世人不察",
                "53": "惟五穀是見",
                "54": "聲色是耽",
                "55": "目惑玄黃",
                "56": "耳務淫哇",
                "57": "滋味煎其府藏",
                "58": "醴醪鬻其腸胃",
                "59": "香芳腐其骨髓",
                "60": "喜怒悖其正氣",
                "61": "思慮銷其精神",
                "62": "哀樂殃其平粹"
            }
        },
        "5": {
            "11": {
                "1": "夫以蕞爾之軀",
                "2": "攻之者非一塗",
                "3": "易竭之身",
                "4": "而外內受敵",
                "5": "身非木石",
                "6": "其能久乎",
                "7": "其自用甚者",
                "8": "飲食不節",
                "9": "以生百病",
                "10": "好色不倦",
                "11": "以致乏絕",
                "12": "風寒所災",
                "13": "百毒所傷",
                "14": "中道夭於眾難",
                "15": "世皆知笑悼",
                "16": "謂之不善持生也",
                "17": "至於措身失理",
                "18": "亡之於微",
                "19": "積微成損",
                "20": "積損成衰",
                "21": "從衰得白",
                "22": "從白得老",
                "23": "從老得終",
                "24": "悶若無端",
                "25": "中智以下",
                "26": "謂之自然",
                "27": "縱少覺悟",
                "28": "咸歎恨於所遇之初",
                "29": "而不知愼眾險於未兆",
                "30": "是由桓侯抱將死之疾",
                "31": "而怒扁鵲之先見",
                "32": "以覺痛之日",
                "33": "爲受病之始也",
                "34": "害成於微而救之於著",
                "35": "故有無功之治",
                "36": "馳騁常人之域",
                "37": "故有一切之壽",
                "38": "仰觀俯察",
                "39": "莫不皆然",
                "40": "以多自證",
                "41": "以同自慰",
                "42": "謂天地之理盡此而已矣",
                "43": "縱聞養生之事",
                "44": "則斷以所見",
                "45": "謂之不然",
                "46": "其次狐疑",
                "47": "雖少庶幾",
                "48": "莫知所由",
                "49": "其次",
                "50": "自力服藥",
                "51": "半年一年",
                "52": "勞而未驗",
                "53": "志以厭衰",
                "54": "中路復廢",
                "55": "或益之以畎澮",
                "56": "而泄之以尾閭",
                "57": "欲坐望顯報者",
                "58": "或抑情忍欲",
                "59": "割棄榮願",
                "60": "而嗜好常在耳目之前",
                "61": "所希在數十年之後",
                "62": "又恐兩失",
                "63": "內懷猶豫",
                "64": "心戰於內",
                "65": "物誘於外",
                "66": "交賒相傾",
                "67": "如此復敗者"
            }
        },
        "6": {
            "13": {
                "1": "夫至物微妙",
                "2": "可以理知",
                "3": "難以目識",
                "4": "譬猶豫章",
                "5": "生七年然後可覺耳",
                "6": "淮南子曰",
                "7": "豫章之生",
                "8": "七年可知",
                "9": "延叔堅曰",
                "10": "豫章與𣏞木相似",
                "11": "須七年乃可別耳",
                "12": "𣏞音尤",
                "13": "今以躁競之心",
                "14": "涉希靜之塗",
                "15": "意速而事遲",
                "16": "望近而應遠",
                "17": "故莫能相終",
                "18": "夫悠悠者旣以未效不求",
                "19": "而求者以不專喪業",
                "20": "偏恃者以不兼無功",
                "21": "追術者以小道自溺",
                "22": "凡若此類",
                "23": "故欲之者萬無一能成也",
                "24": "善養生者則不然矣",
                "25": "清虛靜泰",
                "26": "少私寡欲",
                "27": "知名位之傷德",
                "28": "故忽而不營",
                "29": "非欲而彊禁也",
                "30": "識厚味之害性",
                "31": "故棄而弗顧",
                "32": "非貪而後抑也",
                "33": "外物以累心不存",
                "34": "神氣以醇白獨著",
                "35": "曠然無憂患",
                "36": "寂然無思慮",
                "37": "又守之以一",
                "38": "養之以和",
                "39": "和理日濟",
                "40": "同乎大順",
                "41": "然後蒸以靈芝",
                "42": "潤以醴泉",
                "43": "晞以朝陽",
                "44": "綏以五絃",
                "45": "無爲自得",
                "46": "體妙心玄",
                "47": "忘歡而後樂足",
                "48": "遺生而後身存",
                "49": "若此以往",
                "50": "恕可與羨門比壽",
                "51": "王喬爭年",
                "52": "何爲其無有哉"
            }
        }
    }
}