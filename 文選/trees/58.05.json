{
    "58.05": {
        "篇名": "王仲寶 褚淵碑文[幷序]",
        "1": {
            "3": {
                "1": "夫太上有立德",
                "2": "其次有立功",
                "3": "此之謂不朽",
                "4": "所以子產云亡",
                "5": "宣尼泣其遺愛",
                "6": "隨武旣沒",
                "7": "趙文懷其餘風",
                "8": "於文簡公見之矣",
                "9": "公諱淵",
                "10": "字彥回",
                "11": "河南陽翟人也",
                "12": "微子以至仁開基",
                "13": "宋段以功高命氏",
                "14": "爰逮兩漢",
                "15": "儒雅繼及",
                "16": "魏晉以降",
                "17": "奕世重暉",
                "18": "乃祖太傅元穆公",
                "19": "德合當時",
                "20": "行比州壤",
                "21": "深識臧否",
                "22": "不以毀譽形言",
                "23": "亮采王室",
                "24": "每懷沖虛之道",
                "25": "可謂婉而成章",
                "26": "志而晦者矣"
            }
        },
        "2": {
            "5": {
                "1": "自茲厥後",
                "2": "無替前規",
                "3": "建官惟賢",
                "4": "軒冕相襲",
                "5": "公稟川嶽之靈暉",
                "6": "含珪璋而挺曜",
                "7": "和順內凝",
                "8": "英華外發",
                "9": "神茂初學",
                "10": "業隆弱冠",
                "11": "是以仁經義緯",
                "12": "敦穆於閨庭",
                "13": "金聲玉振",
                "14": "寥亮於區寓",
                "15": "孝敬淳深",
                "16": "率由斯至",
                "17": "盡歡朝夕",
                "18": "人無間言",
                "19": "逍遙乎文雅之囿",
                "20": "翱翔乎禮樂之場",
                "21": "風儀與秋月齊明",
                "22": "音徽與春雲等潤",
                "23": "韻宇弘深",
                "24": "喜慍莫見其際",
                "25": "心明通亮",
                "26": "用人言必由於己",
                "27": "汪汪焉",
                "28": "洋洋焉",
                "29": "可謂澄之不清",
                "30": "撓之不濁",
                "31": "袁陽源才氣高奇",
                "32": "綜覈精裁",
                "33": "宋文帝端明臨朝",
                "34": "鑒賞無昧",
                "35": "袁旣延譽於遐邇",
                "36": "文亦定婚於皇家",
                "37": "選尙餘姚公主",
                "38": "拜駙馬都尉",
                "39": "漢結叔高",
                "40": "晉姻武子",
                "41": "方斯蔑如也"
            }
        },
        "3": {
            "7": {
                "1": "釋褐著作佐郎",
                "2": "轉太子舍人",
                "3": "濯纓登朝",
                "4": "冠冕當世",
                "5": "升降兩宮",
                "6": "實惟時寶",
                "7": "具瞻之範旣著",
                "8": "台衡之望斯集",
                "9": "出參太宰軍事",
                "10": "入爲太子洗馬",
                "11": "俄遷祕書丞",
                "12": "贊道槐庭",
                "13": "司文天閣",
                "14": "光昭諸侯",
                "15": "風流籍甚",
                "16": "以父憂去職",
                "17": "喪過乎哀",
                "18": "幾將毀滅",
                "19": "有識留感",
                "20": "行路傷情"
            }
        },
        "4": {
            "9": {
                "1": "服闋",
                "2": "除中書侍郎",
                "3": "王言如絲",
                "4": "其出如綸",
                "5": "恪居官次",
                "6": "智效惟穆",
                "7": "於時新安王寵冠列蕃",
                "8": "越敷邦教",
                "9": "毗佐之選",
                "10": "妙盡國華",
                "11": "出爲司徒右長史",
                "12": "轉尙書吏部郎",
                "13": "執銓以平",
                "14": "御煩以簡",
                "15": "裴楷清通",
                "16": "王戎簡要",
                "17": "復存於茲",
                "18": "泰始之初",
                "19": "入爲侍中",
                "20": "曾不移朔",
                "21": "遷吏部尙書",
                "22": "是時天步初夷",
                "23": "王途尙阻",
                "24": "元戎啟行",
                "25": "衣冠未緝",
                "26": "內贊謀謨",
                "27": "外康流品",
                "28": "制勝旣遠",
                "29": "涇渭斯明",
                "30": "賞不失勞",
                "31": "舉無失德",
                "32": "績簡帝心",
                "33": "聲敷物聽",
                "34": "事寧",
                "35": "領太子右衞率",
                "36": "固讓不拜",
                "37": "尋領驍騎將軍",
                "38": "以帷幄之功",
                "39": "膺庸祇之秩",
                "40": "封雩都縣開國伯",
                "41": "食邑五百戶",
                "42": "旣秉辭梁之分",
                "43": "又懷寢丘之志",
                "44": "所受田邑",
                "45": "不盈百井"
            }
        },
        "5": {
            "11": {
                "1": "久之",
                "2": "重爲侍中",
                "3": "領右衞將軍",
                "4": "盡規獻替",
                "5": "均山甫之庸",
                "6": "緝熙王旅",
                "7": "兼方叔之望",
                "8": "丹陽京輔",
                "9": "遠近攸則",
                "10": "吳興襟帶",
                "11": "實惟股肱",
                "12": "頻作二守",
                "13": "並加蟬冕",
                "14": "政以禮成",
                "15": "民是以息",
                "16": "明皇不豫",
                "17": "儲后幼沖",
                "18": "貽厥之寄",
                "19": "允屬時望",
                "20": "徵爲吏部尙書",
                "21": "領衞尉",
                "22": "固讓不拜",
                "23": "改授尙書右僕射",
                "24": "端流平衡",
                "25": "外寬內直",
                "26": "弘二八之高謩",
                "27": "宣由庚而垂詠",
                "28": "太宗卽世",
                "29": "遺命以公爲散騎常侍",
                "30": "中書令",
                "31": "護軍將軍",
                "32": "送往事居",
                "33": "忠貞允亮",
                "34": "秉國之均",
                "35": "四方是維",
                "36": "百官象物而動",
                "37": "軍政不戒而備",
                "38": "公之登太階而尹天下",
                "39": "君子以爲美談",
                "40": "亦猶孟軻致欣於樂正",
                "41": "羊職悅賞於士伯者也"
            }
        },
        "6": {
            "13": {
                "1": "丁所生母憂",
                "2": "謝職",
                "3": "毀疾之重",
                "4": "因心則至",
                "5": "朝議以有爲爲之",
                "6": "魯侯垂式",
                "7": "存公忘私",
                "8": "方進明準",
                "9": "爰降詔書",
                "10": "敦還攝任",
                "11": "固請移歲",
                "12": "表奏相望",
                "13": "事不我與",
                "14": "屈己弘化",
                "15": "屬値三季在辰",
                "16": "戚蕃內侮",
                "17": "桂陽失圖",
                "18": "窺窬神器",
                "19": "鼓棹則滄波振蕩",
                "20": "建旗則日月蔽虧",
                "21": "出江派而風翔",
                "22": "入京師而雷動",
                "23": "鳴控弦於宗稷",
                "24": "流鋒鏃於象魏",
                "25": "雖英宰臨戎",
                "26": "元渠時殄",
                "27": "而餘黨寔繁",
                "28": "宮廟憂逼",
                "29": "公乃摠熊羆之士",
                "30": "不貳心之臣",
                "31": "戮力盡規",
                "32": "克寧禍亂",
                "33": "康國祚於綴旒",
                "34": "拯王維於已墜",
                "35": "誠由太祖之威風",
                "36": "抑亦仁公之翼佐",
                "37": "可謂德刑詳",
                "38": "禮義信",
                "39": "戰之器也",
                "40": "以靜難之功",
                "41": "進爵爲侯",
                "42": "兼授尙書令",
                "43": "中軍將軍",
                "44": "給班劍二十人",
                "45": "功成弗有",
                "46": "固秉撝挹",
                "47": "改授侍中",
                "48": "中書監",
                "49": "護軍如故",
                "50": "又以居母艱去官",
                "51": "雖事緣義感",
                "52": "而情均天屬",
                "53": "顏丁之合禮",
                "54": "二連之善喪",
                "55": "亦曷以踰"
            }
        },
        "7": {
            "15": {
                "1": "天厭宋德",
                "2": "水運告謝",
                "3": "嗣王荒怠於天位",
                "4": "彊臣憑陵於荊楚",
                "5": "廢昏繼統之功",
                "6": "龕亂寧民之德",
                "7": "公實仰贊宏規",
                "8": "參聞神筭",
                "9": "雖無受脤出車之庸",
                "10": "亦有甘寢秉羽之績",
                "11": "乃作司空",
                "12": "山川攸序",
                "13": "兼授衞軍",
                "14": "戎政輯睦"
            }
        },
        "8": {
            "17": {
                "1": "旣而齊德龍興",
                "2": "順皇高禪",
                "3": "深達先天之運",
                "4": "匡贊奉時之業",
                "5": "弼諧允正",
                "6": "徽猷弘遠",
                "7": "樹之風聲",
                "8": "著之話言",
                "9": "亦猶稷契之臣虞夏",
                "10": "荀裴之奉魏晉",
                "11": "自非坦懷至公",
                "12": "永鑒崇替",
                "13": "孰能光輔五君",
                "14": "寅亮二代者哉",
                "15": "大啟南康",
                "16": "爰登中鉉",
                "17": "時膺土宇",
                "18": "固辭邦教",
                "19": "今之尙書令",
                "20": "古之冢宰",
                "21": "雖秩輕於衮司",
                "22": "而任隆於百辟",
                "23": "暫遂沖旨",
                "24": "改授朝端",
                "25": "邇無異言",
                "26": "遠無異望",
                "27": "帝嘉茂庸",
                "28": "重申前冊",
                "29": "執五禮以正民",
                "30": "簡八刑而罕用",
                "31": "故能騁績康衢",
                "32": "延慈哲后",
                "33": "義在資敬",
                "34": "情同布衣",
                "35": "出陪鑾躅",
                "36": "入奉帷殿",
                "37": "仰南風之高詠",
                "38": "餐東野之祕寶",
                "39": "雅議於聽政之晨",
                "40": "披文於宴私之夕",
                "41": "參以酒德",
                "42": "間以琴心",
                "43": "曖有餘暉",
                "44": "遙然留想",
                "45": "君垂冬日之溫",
                "46": "臣盡秋霜之戒",
                "47": "肅肅焉",
                "48": "穆穆焉",
                "49": "於是見君親之同致",
                "50": "知在三之如一",
                "51": "太祖升遐",
                "52": "綢繆遺寄",
                "53": "以侍中",
                "54": "司徒錄尙書事",
                "55": "稟玉几之顧",
                "56": "奉綴衣之禮",
                "57": "擇皇齊之令典",
                "58": "致聲化於雍熙",
                "59": "內平外成",
                "60": "實昭舊職",
                "61": "增給班劍三十人",
                "62": "物有其容",
                "63": "徽章斯允",
                "64": "位尊而禮卑",
                "65": "居高而思降",
                "66": "自夏徂秋",
                "67": "以疾陳退",
                "68": "朝廷重違謙光之旨",
                "69": "用申超世之尙",
                "70": "改授司空",
                "71": "領驃騎大將軍",
                "72": "侍中錄尙書如故"
            }
        },
        "9": {
            "19": {
                "1": "景命不永",
                "2": "大漸彌留",
                "3": "建元四年八月二十一日薨於私第",
                "4": "春秋四十有八",
                "5": "昔柳莊疾棘",
                "6": "衞君當祭而輟禮",
                "7": "晏嬰旣往",
                "8": "齊君趍車而行哭",
                "9": "公之云亡",
                "10": "聖朝震悼於上",
                "11": "羣后恇動於下",
                "12": "豈唯哀纏一國",
                "13": "痛深一主而已哉",
                "14": "追贈太宰",
                "15": "侍中錄尙書如故",
                "16": "給節羽葆鼓吹班劍爲六十人",
                "17": "謚曰文簡",
                "18": "禮也"
            }
        },
        "10": {
            "21": {
                "1": "夫乘德而處",
                "2": "萬物不能害其貞",
                "3": "虛己以遊",
                "4": "當世不能擾其度",
                "5": "均貴賤於條風",
                "6": "忘榮辱於彼我",
                "7": "淮南子曰",
                "8": "夫貴賤之於身也",
                "9": "猶條風之時麗也",
                "10": "毀譽之於己",
                "11": "猶蚊蝱之一過也",
                "12": "莊子",
                "13": "肩吾問於孫叔敖曰",
                "14": "子三爲令尹而不榮華",
                "15": "三去之而無憂色",
                "16": "何也",
                "17": "孫叔敖曰",
                "18": "不知其在彼乎",
                "19": "其在我乎",
                "20": "其在彼邪亡乎我",
                "21": "其在我邪亡乎彼",
                "22": "何暇至乎人貴人賤哉",
                "23": "然後可兼善天下",
                "24": "聊以卒歲",
                "25": "經始圖終",
                "26": "式免祇悔",
                "27": "誰云克備",
                "28": "公實有焉",
                "29": "是以義結君子",
                "30": "惠霑庶類",
                "31": "言象所未形",
                "32": "述詠所不盡",
                "33": "故吏某甲等",
                "34": "感逝川之無捨",
                "35": "哀清暉之眇默",
                "36": "餐輿誦於丘里",
                "37": "瞻雅詠於京國",
                "38": "思衞鼎之垂文",
                "39": "想晉鍾之遺則",
                "40": "方高山而仰止",
                "41": "刊玄石以表德",
                "42": "其辭曰"
            }
        },
        "11": {
            "23": {
                "1": "辰精感運",
                "2": "昴靈發祥",
                "3": "元首惟明",
                "4": "股肱惟良",
                "5": "天鑒璿曜",
                "6": "踵武前王",
                "7": "欽若元輔",
                "8": "體微知章",
                "9": "永言必孝",
                "10": "因心則友",
                "11": "仁洽兼濟",
                "12": "愛深善誘",
                "13": "觀海齊量",
                "14": "登嶽均厚",
                "15": "五臣茲六",
                "16": "八元斯九",
                "17": "內謨帷幄",
                "18": "外曜台階",
                "19": "遠無不肅",
                "20": "邇無不懷",
                "21": "如風之偃",
                "22": "如樂之諧",
                "23": "光我帝典",
                "24": "緝彼民黎",
                "25": "率禮蹈謙",
                "26": "諒實身幹",
                "27": "迹屈朱軒",
                "28": "志隆衡館",
                "29": "眇眇玄宗",
                "30": "萋萋辭翰",
                "31": "義旣川流",
                "32": "文亦霧散",
                "33": "嵩構云頹",
                "34": "梁陰載缺",
                "35": "德猷靡嗣",
                "36": "儀形長遞",
                "37": "怊悵餘徽",
                "38": "鏘洋遺烈",
                "39": "久而彌新",
                "40": "用而不竭"
            }
        }
    }
}