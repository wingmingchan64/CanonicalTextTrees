{
    "23.06-02": {
        "篇名": "王仲宣 七哀詩二首·其二",
        "1": {
            "3": {
                "1": "荊蠻非我鄕",
                "2": "何爲久滯淫",
                "3": "方舟溯大江",
                "4": "日暮愁我心",
                "5": "山崗有餘暎",
                "6": "巖阿增重陰",
                "7": "狐狸馳赴穴",
                "8": "飛鳥翔故林",
                "9": "流波激清響",
                "10": "猴猿臨岸吟",
                "11": "迅風拂裳袂",
                "12": "白露霑衣衿",
                "13": "獨夜不能寐",
                "14": "攝衣起撫琴",
                "15": "絲桐感人情",
                "16": "爲我發悲音",
                "17": "羈旅無終極",
                "18": "憂思壯難任"
            }
        }
    }
}