{
    "45.02": {
        "篇名": "東方曼倩 答客難",
        "1": {
            "3": {
                "1": "客難東方朔曰",
                "2": "蘇秦張儀壹當萬乘之主",
                "3": "而身都卿相之位",
                "4": "澤及後世",
                "5": "今子大夫修先生之術",
                "6": "慕聖人之義",
                "7": "諷誦詩書百家之言",
                "8": "不可勝記",
                "9": "著於竹帛",
                "10": "脣腐齒落",
                "11": "服膺而不可釋",
                "12": "好學樂道之效",
                "13": "明白甚矣",
                "14": "自以爲智能海內無雙",
                "15": "則可謂博聞辯智矣",
                "16": "然悉力盡忠",
                "17": "以事聖帝",
                "18": "曠日持久",
                "19": "積數十年",
                "20": "官不過侍郎",
                "21": "位不過執戟",
                "22": "意者尙有遺行邪",
                "23": "同胞之徒",
                "24": "無所容居",
                "25": "其故何也"
            }
        },
        "2": {
            "5": {
                "1": "東方先生喟然長息",
                "2": "仰而應之曰",
                "3": "是故非子之所能備",
                "4": "彼一時也",
                "5": "此一時也",
                "6": "豈可同哉",
                "7": "夫蘇秦張儀之時",
                "8": "周室大壞",
                "9": "諸侯不朝",
                "10": "力政爭權",
                "11": "相擒以兵",
                "12": "幷爲十二國",
                "13": "未有雌雄",
                "14": "得士者強",
                "15": "失士者亡",
                "16": "故說得行焉",
                "17": "身處尊位",
                "18": "珍寶充內",
                "19": "外有倉廩",
                "20": "澤及後世",
                "21": "子孫長享",
                "22": "今則不然",
                "23": "聖帝德流",
                "24": "天下震慴",
                "25": "諸侯賓服",
                "26": "連四海之外以爲帶",
                "27": "安於覆盂",
                "28": "天下平均",
                "29": "合爲一家",
                "30": "動發舉事",
                "31": "猶運之掌",
                "32": "賢與不肖",
                "33": "何以異哉",
                "34": "遵天之道",
                "35": "順地之理",
                "36": "物無不得其所",
                "37": "故綏之則安",
                "38": "動之則苦",
                "39": "尊之則爲將",
                "40": "卑之則爲虜",
                "41": "抗之則在青雲之上",
                "42": "抑之則在深淵之下",
                "43": "用之則爲虎",
                "44": "不用則爲鼠",
                "45": "雖欲盡節效情",
                "46": "安知前後",
                "47": "夫天地之大",
                "48": "士民之眾",
                "49": "竭精馳說",
                "50": "並進輻湊者",
                "51": "不可勝數",
                "52": "悉力慕之",
                "53": "困於衣食",
                "54": "或失門戶",
                "55": "使蘇秦張儀與僕並生於今之世",
                "56": "曾不得掌故",
                "57": "安敢望侍郎乎",
                "58": "傳曰",
                "59": "天下無害",
                "60": "雖有聖人無所施才",
                "61": "上下和同",
                "62": "雖有賢者無所立功",
                "63": "故曰時異事異"
            }
        },
        "3": {
            "7": {
                "1": "雖然",
                "2": "安可以不務修身乎哉",
                "3": "詩曰",
                "4": "鼓鍾於宮",
                "5": "聲聞於外",
                "6": "鶴鳴九皋",
                "7": "聲聞於天",
                "8": "苟能修身",
                "9": "何患不榮",
                "10": "太公體行仁義",
                "11": "七十有二",
                "12": "乃設用於文武",
                "13": "得信厥說",
                "14": "封於齊",
                "15": "七百歲而不絕",
                "16": "此士所以日夜孳孳",
                "17": "修學敏行而不敢怠也",
                "18": "譬若鶺鴒",
                "19": "飛且鳴矣",
                "20": "傳曰",
                "21": "天不爲人之惡寒而輟其冬",
                "22": "地不爲人之惡險而輟其廣",
                "23": "君子不爲小人之匈匈而易其行",
                "24": "天有常度",
                "25": "地有常形",
                "26": "君子有常行",
                "27": "君子道其常",
                "28": "小人計其功",
                "29": "詩云",
                "30": "禮義之不愆",
                "31": "何卹人之言",
                "32": "水至清則無魚",
                "33": "人至察則無徒",
                "34": "冕而前旒",
                "35": "所以蔽明",
                "36": "黈纊充耳",
                "37": "所以塞聰",
                "38": "明有所不見",
                "39": "聰有所不聞",
                "40": "舉大德",
                "41": "赦小過",
                "42": "無求備於一人之義也",
                "43": "枉而直之",
                "44": "使自得之",
                "45": "優而柔之",
                "46": "使自求之",
                "47": "揆而度之",
                "48": "使自索之",
                "49": "蓋聖人之教化如此",
                "50": "欲其自得之",
                "51": "自得之",
                "52": "則敏且廣矣"
            }
        },
        "4": {
            "9": {
                "1": "今世之處士",
                "2": "時雖不用",
                "3": "塊然無徒",
                "4": "廓然獨居",
                "5": "上觀許由",
                "6": "下察接輿",
                "7": "計同范蠡",
                "8": "忠合子胥",
                "9": "天下和平",
                "10": "與義相扶",
                "11": "寡偶少徒",
                "12": "固其宜也",
                "13": "子何疑於予哉",
                "14": "若夫燕之用樂毅",
                "15": "秦之任李斯",
                "16": "酈食其之下齊",
                "17": "說行如流",
                "18": "曲從如環",
                "19": "所欲必得",
                "20": "功若丘山",
                "21": "海內定",
                "22": "國家安",
                "23": "是遇其時者也",
                "24": "子又何怪之邪",
                "25": "語曰",
                "26": "以筦窺天",
                "27": "以蠡測海",
                "28": "以筳撞鍾",
                "29": "豈能通其條貫",
                "30": "考其文理",
                "31": "發其音聲哉",
                "32": "猶是觀之",
                "33": "譬由鼱鼩之襲狗",
                "34": "孤豚之咋虎",
                "35": "至則靡耳",
                "36": "何功之有",
                "37": "今以下愚而非處士",
                "38": "雖欲勿困",
                "39": "固不得已",
                "40": "此適足以明其不知權變",
                "41": "而終惑於大道也"
            }
        }
    }
}