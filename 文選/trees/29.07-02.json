{
    "29.07-02": {
        "篇名": "魏文帝 雜詩二首·其二",
        "1": {
            "3": {
                "1": "西北有浮雲",
                "2": "亭亭如車蓋",
                "3": "惜哉時不遇",
                "4": "適與飄風會",
                "5": "吹我東南行",
                "6": "南行至吳會",
                "7": "吳會非我鄕",
                "8": "安能久留滯",
                "9": "棄置勿復陳",
                "10": "客子常畏人"
            }
        }
    }
}