{
    "37.04": {
        "篇名": "曹子建 求通親親表",
        "1": {
            "3": {
                "1": "臣植言",
                "2": "臣聞天稱其高者",
                "3": "以無不覆",
                "4": "地稱其廣者",
                "5": "以無不載",
                "6": "日月稱其明者",
                "7": "以無不照",
                "8": "江海稱其大者",
                "9": "以無不容",
                "10": "故孔子曰",
                "11": "大哉堯之爲君",
                "12": "惟天爲大",
                "13": "惟堯則之",
                "14": "夫天德之於萬物",
                "15": "可謂弘廣矣",
                "16": "蓋堯之爲教",
                "17": "先親後疏",
                "18": "自近及遠",
                "19": "其傳曰",
                "20": "克明俊德",
                "21": "以親九族",
                "22": "九族旣睦",
                "23": "平章百姓",
                "24": "及周之文王",
                "25": "亦崇厥化",
                "26": "其詩曰",
                "27": "刑於寡妻",
                "28": "至於兄弟",
                "29": "以御於家邦",
                "30": "是以雍雍穆穆",
                "31": "風人詠之",
                "32": "昔周公弔管蔡之不咸",
                "33": "廣封懿親",
                "34": "以藩屛王室",
                "35": "傳曰",
                "36": "周之宗盟",
                "37": "異姓爲後",
                "38": "誠骨肉之恩",
                "39": "爽而不離",
                "40": "親親之義",
                "41": "寔在敦固",
                "42": "未有義而後其君",
                "43": "仁而遺其親者也"
            }
        },
        "2": {
            "5": {
                "1": "伏惟陛下",
                "2": "咨帝唐欽明之德",
                "3": "體文王翼翼之仁",
                "4": "惠洽椒房",
                "5": "恩昭九親",
                "6": "羣后百僚",
                "7": "番休遞上",
                "8": "執政不廢於公朝",
                "9": "下情得展於私室",
                "10": "親理之路通",
                "11": "慶弔之情展",
                "12": "誠可謂恕己治人",
                "13": "推惠施恩者矣",
                "14": "至於臣者",
                "15": "人道絕緒",
                "16": "禁固明時",
                "17": "臣竊自傷也",
                "18": "不敢乃望交氣類",
                "19": "修人事",
                "20": "敍人倫",
                "21": "近且婚媾不通",
                "22": "兄弟永絕",
                "23": "吉凶之問塞",
                "24": "慶弔之禮廢",
                "25": "恩紀之違",
                "26": "甚於路人",
                "27": "隔閡之異",
                "28": "殊於胡越",
                "29": "今臣以一切之制",
                "30": "永無朝覲之望",
                "31": "至於注心皇極",
                "32": "結情紫闥",
                "33": "神明知之矣",
                "34": "然天寔爲之",
                "35": "謂之何哉",
                "36": "退省諸王常有戚戚具爾之心",
                "37": "願陛下沛然垂詔",
                "38": "使諸國慶問",
                "39": "四節得展",
                "40": "以敍骨肉之歡恩",
                "41": "全怡怡之篤義",
                "42": "妃妾之家",
                "43": "膏沐之遺",
                "44": "歲得再通",
                "45": "齊義於貴宗",
                "46": "等惠於百司",
                "47": "如此",
                "48": "則古人之所歎",
                "49": "風雅之所詠",
                "50": "復存於聖世矣"
            }
        },
        "3": {
            "7": {
                "1": "臣伏自思惟",
                "2": "豈無錐刀之用",
                "3": "及觀陛下之所拔授",
                "4": "若臣爲異姓",
                "5": "竊自料度",
                "6": "不後於朝士矣",
                "7": "若得辭遠遊",
                "8": "戴武弁",
                "9": "解朱組",
                "10": "佩青紱",
                "11": "駙馬奉車",
                "12": "趣得一號",
                "13": "安宅京室",
                "14": "執鞭珥筆",
                "15": "出從華蓋",
                "16": "入侍輦轂",
                "17": "承答聖問",
                "18": "拾遺左右",
                "19": "乃臣丹情之至願",
                "20": "不離於夢想者也",
                "21": "遠慕鹿鳴君臣之宴",
                "22": "中詠棠棣匪他之誡",
                "23": "下思伐木友生之義",
                "24": "終懷蓼莪罔極之哀",
                "25": "每四節之會",
                "26": "塊然獨處",
                "27": "左右惟僕隸",
                "28": "所對惟妻子",
                "29": "高談無所與陳",
                "30": "發義無所與展",
                "31": "未嘗不聞樂而拊心",
                "32": "臨觴而歎息也",
                "33": "臣伏以爲犬馬之誠",
                "34": "不能動人",
                "35": "譬人之誠不能動天",
                "36": "崩城隕霜",
                "37": "臣初信之",
                "38": "以臣心況",
                "39": "徒虛語耳",
                "40": "若葵藿之傾葉",
                "41": "太陽雖不爲之迴光",
                "42": "然終向之者",
                "43": "誠也",
                "44": "臣竊自比葵藿",
                "45": "若降天地之施",
                "46": "垂三光之明者",
                "47": "寔在陛下"
            }
        },
        "4": {
            "9": {
                "1": "臣聞文子曰",
                "2": "不爲福始",
                "3": "不爲禍先",
                "4": "今之否隔",
                "5": "友於同憂",
                "6": "而臣獨唱言者",
                "7": "何也",
                "8": "竊不願於聖代使有不蒙施之物",
                "9": "有不蒙施之物",
                "10": "必有慘毒之懷",
                "11": "故柏舟有天只之怨",
                "12": "谷風有棄予之歎",
                "13": "伊尹恥其君不爲堯舜",
                "14": "孟子曰",
                "15": "不以舜之所以事堯事其君者",
                "16": "不敬其君者也",
                "17": "臣之愚蔽",
                "18": "固非虞伊",
                "19": "至於欲使陛下崇光被時雍之美",
                "20": "宣緝熙章明之德者",
                "21": "是臣慺慺之誠",
                "22": "竊所獨守",
                "23": "寔懷鶴立企佇之心",
                "24": "敢復陳聞者",
                "25": "冀陛下儻發天聰而垂神聽也"
            }
        }
    }
}