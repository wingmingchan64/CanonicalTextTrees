{
    "20.24": {
        "篇名": "沈休文 別范安成詩",
        "1": {
            "3": {
                "1": "生平少年日",
                "2": "分手易前期",
                "3": "及爾同衰暮",
                "4": "非復別離時",
                "5": "勿言一尊酒",
                "6": "明日難重持",
                "7": "夢中不識路",
                "8": "何以慰相思"
            }
        }
    }
