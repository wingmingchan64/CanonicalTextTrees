{
    "29.04-03": {
        "篇名": "張平子 四愁詩四首[幷序]",
        "1": {
            "3": {
                "1": "三思曰",
                "2": "我所思兮在漢陽",
                "3": "欲往從之隴阪長",
                "4": "側身西望涕霑裳",
                "5": "美人贈我貂襜褕",
                "6": "何以報之明月珠",
                "7": "路遠莫致倚踟躕",
                "8": "何爲懷憂心煩紆"
            }
        }
    }
}