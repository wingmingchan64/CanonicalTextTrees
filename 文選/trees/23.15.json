{
    "23.15": {
        "篇名": "王仲宣 贈文叔良",
        "1": {
            "3": {
                "1": "翩翩者鴻",
                "2": "率彼江濱",
                "3": "君子於征",
                "4": "爰聘西鄰",
                "5": "臨此洪渚",
                "6": "伊思梁岷",
                "7": "爾往孔邈",
                "8": "如何勿勤",
                "9": "君子敬始",
                "10": "愼爾所主",
                "11": "謀言必賢",
                "12": "錯說申輔",
                "13": "延陵有作",
                "14": "僑肸是與",
                "15": "先民遺迹",
                "16": "來世之矩",
                "17": "旣愼爾主",
                "18": "亦迪知幾",
                "19": "探情以華",
                "20": "睹著知微",
                "21": "視明聽聰",
                "22": "靡事不惟",
                "23": "董褐荷名",
                "24": "胡寧不師",
                "25": "眾不可蓋",
                "26": "無尙我言",
                "27": "梧宮致辯",
                "28": "齊楚構患",
                "29": "成功有要",
                "30": "在眾思歡",
                "31": "人之多忌",
                "32": "掩之實難",
                "33": "瞻彼黑水",
                "34": "滔滔其流",
                "35": "江漢有卷",
                "36": "允來厥休",
                "37": "二邦若否",
                "38": "職汝之由",
                "39": "緬彼行人",
                "40": "鮮克弗留",
                "41": "尙哉君子",
                "42": "於異他仇",
                "43": "人誰不勤",
                "44": "無厚我憂",
                "45": "惟詩作贈",
                "46": "敢詠在舟"
            }
        }
    }
