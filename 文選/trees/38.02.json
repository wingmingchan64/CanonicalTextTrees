{
    "38.02": {
        "篇名": "庾元規 讓中書令表",
        "1": {
            "3": {
                "1": "臣亮言",
                "2": "臣凡庸固陋",
                "3": "少無檢操",
                "4": "昔以中州多故",
                "5": "舊邦喪亂",
                "6": "隨侍先臣",
                "7": "遠庇有道",
                "8": "爰客逃難",
                "9": "求食而已",
                "10": "不悟徼時之福",
                "11": "遭遇嘉運",
                "12": "先帝龍興",
                "13": "乘異常之顧",
                "14": "旣眷同國士",
                "15": "又申之婚姻",
                "16": "遂階親寵",
                "17": "累忝非服",
                "18": "弱冠濯纓",
                "19": "沐浴玄風",
                "20": "頻繁省闥",
                "21": "出總六軍",
                "22": "十餘年間",
                "23": "位超先達",
                "24": "無勞被遇",
                "25": "無與臣比",
                "26": "小人祿薄",
                "27": "福過災生",
                "28": "止足之分",
                "29": "臣所宜守",
                "30": "而偸榮昧進",
                "31": "日爾一日",
                "32": "謗讟旣集",
                "33": "上塵聖朝",
                "34": "始欲自聞",
                "35": "而先帝登遐",
                "36": "區區微誠",
                "37": "竟未上達"
            }
        },
        "2": {
            "5": {
                "1": "陛下踐祚",
                "2": "聖政維新",
                "3": "宰輔賢明",
                "4": "庶僚咸允",
                "5": "康哉之歌",
                "6": "實在至公",
                "7": "而國恩不已",
                "8": "復以臣領中書",
                "9": "臣領中書",
                "10": "則示天下以私矣",
                "11": "何者",
                "12": "臣於陛下",
                "13": "后之兄也",
                "14": "姻婭之嫌",
                "15": "實與骨肉中表不同",
                "16": "雖太上至公",
                "17": "聖德無私",
                "18": "然世之喪道",
                "19": "有自來矣",
                "20": "悠悠六合",
                "21": "皆私其姻者也",
                "22": "人皆有私",
                "23": "則謂天下無公矣",
                "24": "是以前後二漢",
                "25": "咸以抑后黨安",
                "26": "進婚族危",
                "27": "向使西京七族",
                "28": "東京六姓",
                "29": "皆非姻黨",
                "30": "各以平進",
                "31": "縱不悉全",
                "32": "決不盡敗",
                "33": "今之盡敗",
                "34": "更由姻昵",
                "35": "臣歷觀庶姓在世",
                "36": "無黨於朝",
                "37": "無援於時",
                "38": "植根之本",
                "39": "輕也薄也",
                "40": "苟無大瑕",
                "41": "猶或見容",
                "42": "至於外戚",
                "43": "憑託天地",
                "44": "勢連四時",
                "45": "根援扶疏",
                "46": "重矣大矣",
                "47": "而財居權寵",
                "48": "四海側目",
                "49": "事有不允",
                "50": "罪不容誅",
                "51": "身旣招殃",
                "52": "國爲之敝",
                "53": "其故何邪",
                "54": "直由婚媾之私",
                "55": "羣情之所不能免",
                "56": "故率其所嫌而嫌之於國",
                "57": "是以疏附則信",
                "58": "姻進則疑",
                "59": "疑積於百姓之心",
                "60": "則禍成重闥之內矣",
                "61": "此皆往代成鑒",
                "62": "可爲寒心者也"
            }
        },
        "3": {
            "7": {
                "1": "夫萬物之所不通",
                "2": "聖賢因而不奪",
                "3": "冒親以求一才之用",
                "4": "未若防嫌以明公道",
                "5": "今以臣之才",
                "6": "兼如此之嫌",
                "7": "而使內處心膂",
                "8": "外總兵權",
                "9": "以此求治",
                "10": "未之聞也",
                "11": "以此招禍",
                "12": "可立待也",
                "13": "雖陛下二相",
                "14": "明其愚款",
                "15": "朝士百僚",
                "16": "頗識其情",
                "17": "天下之人",
                "18": "何可門到戶說",
                "19": "使皆坦然邪",
                "20": "夫富貴寵榮",
                "21": "臣所不能忘也",
                "22": "刑罰貧賤",
                "23": "臣所不能甘也",
                "24": "今恭命則愈",
                "25": "違命則苦",
                "26": "臣雖不達",
                "27": "何事背時違上",
                "28": "自貽患責邪",
                "29": "實仰覽殷鑒",
                "30": "量己知敝",
                "31": "身不足惜",
                "32": "爲國取悔",
                "33": "是以悾悾",
                "34": "屢陳丹款",
                "35": "而微誠淺薄",
                "36": "未垂察諒",
                "37": "憂惶屛營",
                "38": "不知所厝",
                "39": "以臣今地",
                "40": "不可以進明矣",
                "41": "且違命已久",
                "42": "臣之罪又積矣",
                "43": "歸骸私門",
                "44": "以待刑書",
                "45": "願陛下垂天地之鑒",
                "46": "察臣之愚",
                "47": "則雖死之日",
                "48": "猶生之年矣"
            }
        }
    }
}