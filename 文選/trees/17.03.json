{
    "17.03": {
        "篇名": "傅武仲 舞賦[幷序]",
        "1": {
            "3": {
                "1": "楚襄王旣遊雲夢",
                "2": "使宋玉賦高唐之事",
                "3": "將置酒宴飲",
                "4": "謂宋玉曰",
                "5": "寡人欲觴羣臣",
                "6": "何以娛之",
                "7": "玉曰",
                "8": "臣聞歌以詠言",
                "9": "舞以盡意",
                "10": "是以論其詩不如聽其聲",
                "11": "聽其聲不如察其形",
                "12": "激楚結風陽阿之舞",
                "13": "材人之窮觀",
                "14": "天下之至妙",
                "15": "噫",
                "16": "可以進乎",
                "17": "王曰",
                "18": "其如鄭何",
                "19": "玉曰",
                "20": "小大殊用",
                "21": "鄭雅異宜",
                "22": "弛張之度",
                "23": "聖哲所施",
                "24": "是以樂記干戚之容",
                "25": "雅美蹲蹲之舞",
                "26": "禮設三爵之制",
                "27": "頌有醉歸之歌",
                "28": "夫咸池六英",
                "29": "所以陳清廟",
                "30": "協神人也",
                "31": "鄭",
                "32": "衞之樂",
                "33": "所以娛密坐",
                "34": "接歡欣也",
                "35": "餘日怡蕩",
                "36": "非以風民也",
                "37": "其何害哉",
                "38": "王曰",
                "39": "試爲寡人賦之",
                "40": "玉曰",
                "41": "唯唯"
            }
        },
        "2": {
            "5": {
                "1": "夫何皎皎之間夜兮",
                "2": "明月爛以施光",
                "3": "朱火曄其延起兮",
                "4": "燿華屋而熺洞房",
                "5": "黼帳祛而結組兮",
                "6": "鋪首炳以焜煌",
                "7": "陳茵席而設坐兮",
                "8": "溢金罍而列玉觴",
                "9": "騰觚爵之斟酌兮",
                "10": "漫旣醉其樂康",
                "11": "嚴顏和而怡懌兮",
                "12": "幽情形而外揚",
                "13": "文人不能懷其藻兮",
                "14": "武毅不能隱其剛",
                "15": "簡惰跳踃",
                "16": "般紛挐兮",
                "17": "淵塞沈蕩",
                "18": "改恆常兮",
                "19": "於是鄭女出進",
                "20": "二八徐侍",
                "21": "姣服極麗",
                "22": "姁媮致態",
                "23": "貌嫽妙以妖蠱兮",
                "24": "紅顏曄其揚華",
                "25": "眉連娟以增繞兮",
                "26": "目流睇而橫波",
                "27": "珠翠的皪而炤燿兮",
                "28": "華袿飛髾而雜纖羅",
                "29": "顧形影",
                "30": "自整裝",
                "31": "順微風",
                "32": "揮若芳",
                "33": "動朱脣",
                "34": "紆清揚",
                "35": "亢音高歌",
                "36": "爲樂之方",
                "37": "歌曰",
                "38": "攄予意以弘觀兮",
                "39": "繹精靈之所束",
                "40": "弛緊急之弦張兮",
                "41": "慢末事之委曲",
                "42": "舒恢炱之廣度兮",
                "43": "闊細體之苛縟",
                "44": "嘉關雎之不淫兮",
                "45": "哀蟋蟀之侷促",
                "46": "啟泰貞之否隔兮",
                "47": "超遺物而度俗",
                "48": "揚激徵",
                "49": "騁清角",
                "50": "贊舞操",
                "51": "奏均曲",
                "52": "形態和",
                "53": "神意協",
                "54": "從容得",
                "55": "志不劫"
            }
        },
        "3": {
            "7": {
                "1": "於是躡節鼓陳",
                "2": "舒意自廣",
                "3": "遊心無垠",
                "4": "遠思長想",
                "5": "其始興也",
                "6": "若俯若仰",
                "7": "若來若往",
                "8": "雍容惆悵",
                "9": "不可爲象",
                "10": "其少進也",
                "11": "若𦒡若行",
                "12": "若竦若傾",
                "13": "兀動赴度",
                "14": "指顧應聲",
                "15": "羅衣從風",
                "16": "長袖交橫",
                "17": "駱驛飛散",
                "18": "颯擖合倂",
                "19": "鶣𪅃燕居",
                "20": "拉㧺鵠驚",
                "21": "綽約間靡",
                "22": "機迅體輕",
                "23": "姿絕倫之妙態",
                "24": "懷慤素之潔清",
                "25": "修儀操以顯志兮",
                "26": "獨馳思乎杳冥",
                "27": "在山峨峨",
                "28": "在水湯湯",
                "29": "與志遷化",
                "30": "容不虛生",
                "31": "明詩表指",
                "32": "喟息激昂",
                "33": "氣若浮雲",
                "34": "志若秋霜",
                "35": "觀者增歎",
                "36": "諸工莫當"
            }
        },
        "4": {
            "9": {
                "1": "於是合場遞進",
                "2": "案次而俟",
                "3": "埒材角妙",
                "4": "夸容乃理",
                "5": "軼態橫出",
                "6": "瑰姿譎起",
                "7": "眄般鼓則騰清眸",
                "8": "吐哇咬則發皓齒",
                "9": "摘齊行列",
                "10": "經營切儗",
                "11": "彷彿神動",
                "12": "迴翔竦峙",
                "13": "擊不致策",
                "14": "蹈不頓趾",
                "15": "翼爾悠往",
                "16": "闇復輟已",
                "17": "及至回身還入",
                "18": "迫於急節",
                "19": "浮騰累跪",
                "20": "跗蹋摩跌",
                "21": "紆形赴遠",
                "22": "漼似摧折",
                "23": "纖縠蛾飛",
                "24": "紛猋若絕",
                "25": "超𧼯鳥集",
                "26": "縱弛殟歿",
                "27": "蜲蛇姌嫋",
                "28": "雲轉飄曶",
                "29": "體如遊龍",
                "30": "袖如素霓",
                "31": "𥌛𥅪而拜",
                "32": "曲度究畢",
                "33": "遷延微笑",
                "34": "退復次列",
                "35": "觀者稱麗",
                "36": "莫不怡悅"
            }
        },
        "5": {
            "11": {
                "1": "於是歡洽宴夜",
                "2": "命遣諸客",
                "3": "擾躟就駕",
                "4": "僕夫正策",
                "5": "車騎並狎",
                "6": "巃嵸逼迫",
                "7": "良駿逸足",
                "8": "蹌捍凌越",
                "9": "龍驤橫舉",
                "10": "揚鑣飛沫",
                "11": "馬材不同",
                "12": "各相傾奪",
                "13": "或有逾埃赴轍",
                "14": "霆駭電滅",
                "15": "蹠地遠羣",
                "16": "闇跳獨絕",
                "17": "或有宛足鬱怒",
                "18": "般桓不發",
                "19": "後往先至",
                "20": "遂爲逐末",
                "21": "或有矜容愛儀",
                "22": "洋洋習習",
                "23": "遲速承意",
                "24": "控御緩急",
                "25": "車音若雷",
                "26": "騖驟相及",
                "27": "駱漠而歸",
                "28": "雲散城邑",
                "29": "天王燕胥",
                "30": "樂而不溢",
                "31": "娛神遺老",
                "32": "永年之術",
                "33": "優哉遊哉",
                "34": "聊以永日"
            }
        }
    }
}