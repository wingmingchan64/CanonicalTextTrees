{
    "29.03-01": {
        "篇名": "蘇子卿 詩四首·其一",
        "1": {
            "3": {
                "1": "骨肉緣枝葉",
                "2": "結交亦相因",
                "3": "四海皆兄弟",
                "4": "誰爲行路人",
                "5": "況我連枝樹",
                "6": "與子同一身",
                "7": "昔爲鴛與鴦",
                "8": "今爲參與辰",
                "9": "昔者常相近",
                "10": "邈若胡與秦",
                "11": "惟念當離別",
                "12": "恩情日以新",
                "13": "鹿鳴思野草",
                "14": "可以喩嘉賓",
                "15": "我有一憷酒",
                "16": "欲以贈遠人",
                "17": "願子留斟酌",
                "18": "敍此平生親"
            }
        }
    }
}