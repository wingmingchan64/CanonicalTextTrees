{
    "56.09": {
        "篇名": "潘安仁 楊仲武誄[幷序]",
        "1": {
            "3": {
                "1": "楊綏",
                "2": "字仲武",
                "3": "滎陽宛陵人也",
                "4": "中領軍肅侯之曾孫",
                "5": "荊州刺史戴侯之孫",
                "6": "東武康侯之子也",
                "7": "八歲喪父",
                "8": "其母鄭氏",
                "9": "光祿勳密陵成侯之元女",
                "10": "操行甚高",
                "11": "卹養幼孤",
                "12": "以保乂夫家",
                "13": "而免諸艱難",
                "14": "戴侯康侯多所論著",
                "15": "又善草隸之藝",
                "16": "子以妙年之秀",
                "17": "固能綜覽義旨",
                "18": "而軌式模範矣",
                "19": "雖舅氏隆盛",
                "20": "而孤貧守約",
                "21": "心安陋巷",
                "22": "體服菲薄",
                "23": "余甚奇之",
                "24": "若乃清才俊茂",
                "25": "盛德日新",
                "26": "吾見其進",
                "27": "未見其已也",
                "28": "旣藉三葉世親之恩",
                "29": "而子之姑",
                "30": "余之伉儷焉",
                "31": "往歲卒於德宮里",
                "32": "喪服同次",
                "33": "綢繆累月",
                "34": "苟人必有心",
                "35": "此亦款誠之至也",
                "36": "不幸短命",
                "37": "春秋二十九",
                "38": "元康九年夏五月己亥卒",
                "39": "嗚呼哀哉",
                "40": "乃作誄曰"
            }
        },
        "2": {
            "5": {
                "1": "伊子之先",
                "2": "奕葉熙隆",
                "3": "惟祖惟曾",
                "4": "載揚休風",
                "5": "顯考康侯",
                "6": "無祿早終",
                "7": "名器雖光",
                "8": "勳業未融",
                "9": "篤生吾子",
                "10": "誕茂淑姿",
                "11": "克岐克嶷",
                "12": "知章知微",
                "13": "鉤深探賾",
                "14": "味道硏機",
                "15": "匪直也人",
                "16": "邦家之輝",
                "17": "子之遘閔",
                "18": "曾未齓髫",
                "19": "如彼危根",
                "20": "當此衝焱",
                "21": "德之休明",
                "22": "靡幽不喬",
                "23": "弱冠流芳",
                "24": "俊聲清劭",
                "25": "爾舅惟榮",
                "26": "爾宗惟瘁",
                "27": "幼秉殊操",
                "28": "違豐安匱",
                "29": "撰錄先訓",
                "30": "俾無隕墜",
                "31": "舊文新藝",
                "32": "罔不必肄",
                "33": "潘楊之穆",
                "34": "有自來矣",
                "35": "矧乃今日",
                "36": "愼終如始",
                "37": "爾休爾戚",
                "38": "如實在己",
                "39": "視予猶父",
                "40": "不得猶子",
                "41": "敬亦旣篤",
                "42": "愛亦旣深",
                "43": "雖殊其年",
                "44": "實同厥心",
                "45": "日昃景西",
                "46": "望子朝陰",
                "47": "如何短折",
                "48": "背世湮沈",
                "49": "嗚呼哀哉"
            }
        },
        "3": {
            "7": {
                "1": "寢疾彌留",
                "2": "守茲孝友",
                "3": "臨命忘身",
                "4": "顧戀慈母",
                "5": "哀哀慈母",
                "6": "痛心疾首",
                "7": "噭噭同生",
                "8": "悽悽諸舅",
                "9": "春蘭擢莖",
                "10": "方茂其華",
                "11": "荊寶挺璞",
                "12": "將剖於和",
                "13": "含芳委耀",
                "14": "毀璧摧柯",
                "15": "嗚呼仲武",
                "16": "痛哉柰何",
                "17": "德宮之艱",
                "18": "同次外寢",
                "19": "惟我與爾",
                "20": "對筵接枕",
                "21": "自時迄今",
                "22": "曾未盈稔",
                "23": "姑姪繼隕",
                "24": "何痛斯甚",
                "25": "嗚呼哀哉"
            }
        },
        "4": {
            "9": {
                "1": "披帙散書",
                "2": "屢睹遺文",
                "3": "有造有寫",
                "4": "或草或眞",
                "5": "執玩周復",
                "6": "想見其人",
                "7": "紙勞於手",
                "8": "涕霑於巾",
                "9": "龜筮旣襲",
                "10": "埏隧旣開",
                "11": "痛矣楊子",
                "12": "與世長乖",
                "13": "朝濟洛川",
                "14": "夕次山隈",
                "15": "歸鳥頡頏",
                "16": "行雲徘徊",
                "17": "臨穴永訣",
                "18": "撫櫬盡哀",
                "19": "遺形莫紹",
                "20": "增慟余懷",
                "21": "魂兮往矣",
                "22": "梁木實摧",
                "23": "嗚呼哀哉"
            }
        }
    }
