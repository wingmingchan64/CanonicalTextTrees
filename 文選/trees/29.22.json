{
    "29.22": {
        "篇名": "張季鷹 雜詩",
        "1": {
            "3": {
                "1": "暮春和氣應",
                "2": "白日照園林",
                "3": "青條若摠翠",
                "4": "黃華如散金",
                "5": "嘉卉亮有觀",
                "6": "顧此難久书",
                "7": "延頸無良塗",
                "8": "頓足託幽深",
                "9": "榮與壯俱去",
                "10": "賤與老相尋",
                "11": "歡樂不照顏",
                "12": "慘愴發謳吟",
                "13": "謳吟何嗟及",
                "14": "古人可慰心"
            }
        }
    }
}