{
    "43.04": {
        "篇名": "丘希範 與陳伯之書",
        "1": {
            "3": {
                "1": "遲頓首",
                "2": "陳將軍足下",
                "3": "無恙",
                "4": "幸甚幸甚",
                "5": "將軍勇冠三軍",
                "6": "才爲世出",
                "7": "棄燕雀之小志",
                "8": "慕鴻鵠以高翔",
                "9": "昔因機變化",
                "10": "遭遇明主",
                "11": "立功立事",
                "12": "開國稱孤",
                "13": "朱輪華轂",
                "14": "擁旄萬里",
                "15": "何其壯也",
                "16": "如何一旦爲奔亡之虜",
                "17": "聞鳴鏑而股戰",
                "18": "對穹廬以屈膝",
                "19": "又何劣邪"
            }
        },
        "2": {
            "5": {
                "1": "尋君去就之際",
                "2": "非有他故",
                "3": "直以不能內審諸己",
                "4": "外受流言",
                "5": "沈迷猖獗",
                "6": "以至於此",
                "7": "聖朝赦罪責功",
                "8": "棄瑕錄用",
                "9": "推赤心於天下",
                "10": "安反側於萬物",
                "11": "將軍之所知",
                "12": "不假僕一二談也",
                "13": "朱鮪涉血於友於",
                "14": "張繡剚刃於愛子",
                "15": "漢主不以爲疑",
                "16": "魏君待之若舊",
                "17": "況將軍無昔人之罪",
                "18": "而勳重於當世",
                "19": "夫迷塗知反",
                "20": "往哲是與",
                "21": "不遠而復",
                "22": "先典攸高",
                "23": "主上屈法申恩",
                "24": "吞舟是漏",
                "25": "將軍松柏不剪",
                "26": "親戚安居",
                "27": "高臺未傾",
                "28": "愛妾尙在",
                "29": "悠悠爾心",
                "30": "亦何可言"
            }
        },
        "3": {
            "7": {
                "1": "今功臣名將",
                "2": "雁行有序",
                "3": "佩紫懷黃",
                "4": "讚帷幄之謀",
                "5": "乘軺建節",
                "6": "奉疆埸之任",
                "7": "並刑馬作誓",
                "8": "傳之子孫",
                "9": "將軍獨靦顏借命",
                "10": "驅馳氈裘之長",
                "11": "寧不哀哉",
                "12": "夫以慕容超之強",
                "13": "身送東市",
                "14": "姚泓之盛",
                "15": "面縛西都",
                "16": "故知霜露所均",
                "17": "不育異類",
                "18": "姬漢舊邦",
                "19": "無取雜種",
                "20": "北虜僭盜中原",
                "21": "多歷年所",
                "22": "惡積禍盈",
                "23": "理至燋爛",
                "24": "況僞㜸昏狡",
                "25": "自相夷戮",
                "26": "部落攜離",
                "27": "酋豪猜貳",
                "28": "方當繫頸蠻邸",
                "29": "懸首藁街",
                "30": "而將軍魚遊於沸鼎之中",
                "31": "燕巢於飛幕之上",
                "32": "不亦惑乎"
            }
        },
        "4": {
            "9": {
                "1": "暮春三月",
                "2": "江南草長",
                "3": "雜花生樹",
                "4": "羣鶯亂飛",
                "5": "見故國之旗鼓",
                "6": "感平生於疇日",
                "7": "撫絃登陴",
                "8": "豈不愴悢",
                "9": "所以廉公之思趙將",
                "10": "吳子之泣西河",
                "11": "人之情也",
                "12": "將軍獨無情哉"
            }
        },
        "5": {
            "11": {
                "1": "想早勵良規",
                "2": "自求多福",
                "3": "當今皇帝盛明",
                "4": "天下安樂",
                "5": "白環西獻",
                "6": "楛矢東來",
                "7": "夜郎滇池",
                "8": "解辮請職",
                "9": "朝鮮昌海",
                "10": "蹶角受化",
                "11": "唯北狄野心",
                "12": "掘強沙塞之間",
                "13": "欲延歲月之命耳",
                "14": "中軍臨川殿下",
                "15": "明德茂親",
                "16": "總茲戎重",
                "17": "弔民洛汭",
                "18": "伐罪秦中",
                "19": "若遂不改",
                "20": "方思僕言",
                "21": "聊布往懷",
                "22": "君其詳之",
                "23": "丘遲頓首"
            }
        }
    }
}