{
    "20.17": {
        "篇名": "沈休文 應詔樂遊苑餞呂僧珍詩",
        "1": {
            "3": {
                "1": "丹浦非樂戰",
                "2": "負重切君臨",
                "3": "我皇秉至德",
                "4": "忘己用堯心",
                "5": "愍茲區宇內",
                "6": "魚鳥失飛沈",
                "7": "推轂二崤岨",
                "8": "揚旆九河陰",
                "9": "超乘盡三屬",
                "10": "選士皆百金",
                "11": "戎車出細柳",
                "12": "餞席尊上林",
                "13": "命師誅後服",
                "14": "授律緩前禽",
                "15": "函轘方解帶",
                "16": "嶢武稍披襟",
                "17": "伐罪芒山曲",
                "18": "弔民伊水潯",
                "19": "將陪告成禮",
                "20": "待此未抽簪"
            }
        }
    }
