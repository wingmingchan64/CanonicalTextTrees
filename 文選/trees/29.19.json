{
    "29.19": {
        "篇名": "王正長 雜詩",
        "1": {
            "3": {
                "1": "朔風動秋草",
                "2": "邊馬有歸心",
                "3": "胡寧久分析",
                "4": "靡靡忽至今",
                "5": "王事離我志",
                "6": "殊隔過商參",
                "7": "昔往鶬鶊鳴",
                "8": "今來蟀蟋吟",
                "9": "人情懷舊鄕",
                "10": "客鳥思故林",
                "11": "師涓久不奏",
                "12": "誰能宣我心"
            }
        }
    }
}