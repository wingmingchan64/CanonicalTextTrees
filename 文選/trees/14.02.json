{
    "14.02": {
        "篇名": "鮑明遠 舞鶴賦",
        "1": {
            "3": {
                "1": "散幽經以驗物",
                "2": "偉胎化之仙禽",
                "3": "鍾浮曠之藻質",
                "4": "抱清迥之明心",
                "5": "指蓬壺而翻翰",
                "6": "望崑閬而揚音",
                "7": "帀日域以迴騖",
                "8": "窮天步而高尋",
                "9": "踐神區其旣遠",
                "10": "積靈祀而方多",
                "11": "精含丹而星曜",
                "12": "頂凝紫而煙華",
                "13": "引員吭之纖婉",
                "14": "頓修趾之洪姱",
                "15": "疊霜毛而弄影",
                "16": "振玉羽而臨霞",
                "17": "朝戲於芝田",
                "18": "夕飲乎瑤池",
                "19": "厭江海而遊澤",
                "20": "掩雲羅而見羈",
                "21": "去帝鄕之岑寂",
                "22": "歸人寰之喧卑",
                "23": "歲崢嶸而愁暮",
                "24": "心惆悵而哀離"
            }
        },
        "2": {
            "5": {
                "1": "於是窮陰殺節",
                "2": "急景凋年",
                "3": "涼沙振野",
                "4": "箕風動天",
                "5": "嚴嚴苦霧",
                "6": "皎皎悲泉",
                "7": "冰塞長河",
                "8": "雪滿羣山",
                "9": "旣而氛昏夜歇",
                "10": "景物澄廓",
                "11": "星翻漢迴",
                "12": "曉月將落",
                "13": "感寒雞之早晨",
                "14": "憐霜雁之違漠",
                "15": "臨驚風之蕭條",
                "16": "對流光之照灼",
                "17": "唳清響於丹墀",
                "18": "舞飛容於金閣",
                "19": "始連軒以鳳蹌",
                "20": "終宛轉而龍躍",
                "21": "躑躅徘徊",
                "22": "振迅騰摧",
                "23": "驚身蓬集",
                "24": "矯翅雪飛",
                "25": "離綱別赴",
                "26": "合緒相依",
                "27": "將興中止",
                "28": "若往而歸",
                "29": "颯沓矜顧",
                "30": "遷延遲暮",
                "31": "逸翮後塵",
                "32": "翱翥先路",
                "33": "指會規翔",
                "34": "臨岐矩步",
                "35": "態有遺姸",
                "36": "貌無停趣",
                "37": "奔機逗節",
                "38": "角睞分形",
                "39": "長揚緩騖",
                "40": "並翼連聲",
                "41": "輕迹凌亂",
                "42": "浮影交橫",
                "43": "眾變繁姿",
                "44": "參差洊密",
                "45": "煙交霧凝",
                "46": "若無毛質",
                "47": "風去雨還",
                "48": "不可談悉",
                "49": "旣散魂而盪目",
                "50": "迷不知其所之",
                "51": "忽星離而雲罷",
                "52": "整神容而自持",
                "53": "仰天居之崇絕",
                "54": "更惆悵以驚思"
            }
        },
        "3": {
            "7": {
                "1": "當是時也",
                "2": "燕姬色沮",
                "3": "巴童心恥",
                "4": "巾拂兩停",
                "5": "丸劍雙止",
                "6": "雖邯鄲其敢倫",
                "7": "豈陽阿之能擬",
                "8": "入衞國而乘軒",
                "9": "出吳都而傾市",
                "10": "守馴養於千齡",
                "11": "結長悲於萬里"
            }
        }
    }
}