{
    "40.08": {
        "篇名": "吳季重 在元城與魏太子牋",
        "1": {
            "3": {
                "1": "臣質言",
                "2": "前蒙延納",
                "3": "侍宴終日",
                "4": "燿靈匿景",
                "5": "繼以華燈",
                "6": "雖虞卿適趙",
                "7": "平原入秦",
                "8": "受贈千金",
                "9": "浮觴旬日",
                "10": "無以過也",
                "11": "小器易盈",
                "12": "先取沈頓",
                "13": "醒寤之後",
                "14": "不識所言",
                "15": "卽以五日到官"
            }
        },
        "2": {
            "5": {
                "1": "初至承前",
                "2": "未知深淺",
                "3": "然觀地形",
                "4": "察土宜",
                "5": "西帶常山",
                "6": "連岡平代",
                "7": "北鄰柏人",
                "8": "乃高帝之所忌也",
                "9": "重以泜水",
                "10": "漸漬疆宇",
                "11": "喟然歎息",
                "12": "思淮陰之奇譎",
                "13": "亮成安之失策",
                "14": "南望邯鄲",
                "15": "想廉藺之風",
                "16": "東接鉅鹿",
                "17": "存李齊之流",
                "18": "都人士女",
                "19": "服習禮教",
                "20": "皆懷慷慨之節",
                "21": "包左車之計",
                "22": "而質闇弱",
                "23": "無以蒞之",
                "24": "若乃邁德種恩",
                "25": "樹之風聲",
                "26": "使農夫逸豫於疆畔",
                "27": "女工吟詠於機杼",
                "28": "固非質之所能也",
                "29": "至於奉遵科教",
                "30": "班揚明令",
                "31": "下無威福之吏",
                "32": "邑無豪俠之傑",
                "33": "賦事行刑",
                "34": "資於故實",
                "35": "抑亦懍懍有庶幾之心"
            }
        },
        "3": {
            "7": {
                "1": "往者嚴助釋承明之歡",
                "2": "受會稽之位",
                "3": "壽王去侍從之娛",
                "4": "統東郡之任",
                "5": "其後皆克復舊職",
                "6": "追尋前軌",
                "7": "今獨不然",
                "8": "不亦異乎",
                "9": "張敞在外",
                "10": "自謂無奇",
                "11": "陳咸憤積",
                "12": "思入京城",
                "13": "彼豈虛談夸論",
                "14": "誑燿世俗哉",
                "15": "斯實薄郡守之榮",
                "16": "顯左右之勤也",
                "17": "古今一揆",
                "18": "先後不伛",
                "19": "焉知來者之不如今",
                "20": "聊以當覲",
                "21": "不敢多云",
                "22": "質死罪死罪"
            }
        }
    }
}