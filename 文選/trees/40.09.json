{
    "40.09": {
        "篇名": "阮嗣宗 爲鄭沖勸晉王牋",
        "1": {
            "3": {
                "1": "沖等死罪",
                "2": "伏見嘉命顯至",
                "3": "竊聞明公固讓",
                "4": "沖等眷眷",
                "5": "實有愚心",
                "6": "以爲聖王作制",
                "7": "百代同風",
                "8": "襃德賞功",
                "9": "有自來矣",
                "10": "昔伊尹",
                "11": "有莘氏之媵臣耳",
                "12": "一佐成湯",
                "13": "遂荷阿衡之號",
                "14": "周公藉已成之勢",
                "15": "據旣安之業",
                "16": "光宅曲阜",
                "17": "奄有龜蒙",
                "18": "呂尙磻溪之漁者",
                "19": "一朝指麾",
                "20": "乃封營丘",
                "21": "自是以來",
                "22": "功薄而賞厚者",
                "23": "不可勝數",
                "24": "然賢哲之士",
                "25": "猶以爲美談",
                "26": "況自先相國以來",
                "27": "世有明德",
                "28": "翼輔魏室",
                "29": "以綏天下",
                "30": "朝無闕政",
                "31": "民無謗言"
            }
        },
        "2": {
            "5": {
                "1": "前者",
                "2": "明公西征靈州",
                "3": "北臨沙漠",
                "4": "楡中以西",
                "5": "望風震服",
                "6": "羌戎東馳",
                "7": "迴首內向",
                "8": "東誅叛逆",
                "9": "全軍獨克",
                "10": "禽闔閭之將",
                "11": "斬輕銳之卒",
                "12": "以萬萬計",
                "13": "威加南海",
                "14": "名懾三越",
                "15": "宇內康寧",
                "16": "苛慝不作",
                "17": "是以殊俗畏威",
                "18": "東夷獻舞"
            }
        },
        "3": {
            "7": {
                "1": "故聖上覽乃昔以來禮典舊章",
                "2": "開國光宅",
                "3": "顯茲太原",
                "4": "明公宜承聖旨",
                "5": "受茲介福",
                "6": "允當天人",
                "7": "元功盛勳",
                "8": "光光如彼",
                "9": "國土嘉祚",
                "10": "巍巍如此",
                "11": "內外協同",
                "12": "靡伥靡違",
                "13": "由斯征伐",
                "14": "則可朝服濟江",
                "15": "掃除吳會",
                "16": "西塞江源",
                "17": "望祀岷山",
                "18": "迴戈弭節",
                "19": "以麾天下",
                "20": "遠無不服",
                "21": "邇無不肅",
                "22": "今大魏之德",
                "23": "光於唐虞",
                "24": "明公盛勳",
                "25": "超於桓文",
                "26": "然後臨滄州而謝支伯",
                "27": "登箕山而揖許由",
                "28": "豈不盛乎",
                "29": "至公至平",
                "30": "誰與爲鄰",
                "31": "何必勤勤小讓也哉",
                "32": "沖等不通大體",
                "33": "敢以陳聞"
            }
        }
    }
}