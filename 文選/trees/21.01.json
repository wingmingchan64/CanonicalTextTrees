{
    "21.01": {
        "篇名": "王仲宣 詠史詩",
        "1": {
            "3": {
                "1": "自古無殉死",
                "2": "達人共所知"
            },
            "4": {
                "1": "秦穆殺三良",
                "2": "惜哉空爾爲"
            },
            "5": {
                "1": "結髮事明君",
                "2": "受恩良不訾"
            },
            "6": {
                "1": "臨歿要之死",
                "2": "焉得不相隨"
            },
            "7": {
                "1": "妻子當門泣",
                "2": "兄弟哭路垂"
            },
            "8": {
                "1": "臨穴呼蒼天",
                "2": "涕下如綆縻"
            },
            "9": {
                "1": "人生各有志",
                "2": "終不爲此移"
            },
            "10": {
                "1": "同知埋身劇",
                "2": "心亦有所施"
            },
            "11": {
                "1": "生爲百夫雄",
                "2": "死爲壯士規"
            },
            "12": {
                "1": "黃鳥作悲詩",
                "2": "至今聲不虧"
            }
        }
    }
}