{
    "19.04": {
        "篇名": "曹子建 洛神賦[幷序]",
        "1": {
            "3": {
                "1": "黃初三年",
                "2": "余朝京師",
                "3": "還濟洛川",
                "4": "古人有言",
                "5": "斯水之神",
                "6": "名曰宓妃",
                "7": "感宋玉對楚王神女之事",
                "8": "遂作斯賦",
                "9": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "余從京域言歸東藩",
                "2": "背伊闕",
                "3": "越轘轅",
                "4": "經通谷",
                "5": "陵景山",
                "6": "日旣西傾",
                "7": "車殆馬煩",
                "8": "爾迺稅駕乎蘅皋",
                "9": "秣駟乎芝田",
                "10": "容與乎陽林",
                "11": "流眄乎洛川",
                "12": "於是精移神駭",
                "13": "忽焉思散",
                "14": "俯則未察",
                "15": "仰以殊觀",
                "16": "覩一麗人",
                "17": "於巖之畔",
                "18": "迺援御者而告之曰",
                "19": "爾有覿於彼者乎",
                "20": "彼何人斯",
                "21": "若此之豔也",
                "22": "御者對曰",
                "23": "臣聞河洛之神",
                "24": "名曰宓妃",
                "25": "然則君王所見",
                "26": "無迺是乎",
                "27": "其狀若何",
                "28": "臣願聞之"
            }
        },
        "3": {
            "7": {
                "1": "余告之曰",
                "2": "其形也",
                "3": "翩若驚鴻",
                "4": "婉若遊龍",
                "5": "榮曜秋菊",
                "6": "華茂春松",
                "7": "髣髴兮若輕雲之蔽月",
                "8": "飄颻兮若流風之迴雪",
                "9": "遠而望之",
                "10": "皎若太陽升朝霞",
                "11": "迫而察之",
                "12": "灼若芙蕖出淥波",
                "13": "襛纖得衷",
                "14": "修短合度",
                "15": "肩若削成",
                "16": "腰如約素",
                "17": "延頸秀項",
                "18": "皓質呈露",
                "19": "芳澤無加",
                "20": "鉛華弗御",
                "21": "雲髻峨峨",
                "22": "修眉聯娟",
                "23": "丹脣外朗",
                "24": "皓齒內鮮",
                "25": "明眸善睞",
                "26": "靨輔承權",
                "27": "瑰姿豔逸",
                "28": "儀靜體閑",
                "29": "柔情綽態",
                "30": "媚於語言",
                "31": "奇服曠世",
                "32": "骨像應圖",
                "33": "披羅衣之璀粲兮",
                "34": "珥瑤碧之華琚",
                "35": "戴金翠之首飾",
                "36": "綴明珠以耀軀",
                "37": "踐遠遊之文履",
                "38": "曳霧綃之輕裾",
                "39": "微幽蘭之芳藹兮",
                "40": "步踟躕於山隅"
            }
        },
        "4": {
            "9": {
                "1": "於是忽焉縱體",
                "2": "以遨以嬉",
                "3": "左倚采旄",
                "4": "右蔭桂旗",
                "5": "攘皓腕於神滸兮",
                "6": "采湍瀨之玄芝",
                "7": "余情悅其淑美兮",
                "8": "心振蕩而不怡",
                "9": "無良媒以接歡兮",
                "10": "託微波而通辭",
                "11": "願誠素之先達兮",
                "12": "解玉佩以要之",
                "13": "嗟佳人之信修",
                "14": "羌習禮而明詩",
                "15": "抗瓊珶以和予兮",
                "16": "指潛淵而爲期",
                "17": "執眷眷之款實兮",
                "18": "懼斯靈之我欺",
                "19": "感交甫之棄言兮",
                "20": "悵猶豫而狐疑",
                "21": "收和顏而靜志兮",
                "22": "申禮防以自持"
            }
        },
        "5": {
            "11": {
                "1": "於是洛靈感焉",
                "2": "徙倚彷徨",
                "3": "神光離合",
                "4": "乍陰乍陽",
                "5": "竦輕軀以鶴立",
                "6": "若將飛而未翔",
                "7": "踐椒涂之郁烈",
                "8": "步蘅薄而流芳",
                "9": "超長吟以永慕兮",
                "10": "聲哀厲而彌長"
            }
        },
        "6": {
            "13": {
                "1": "爾迺眾靈雜遝",
                "2": "命儔嘯侶",
                "3": "或戲清流",
                "4": "或翔神渚",
                "5": "或采明珠",
                "6": "或拾翠羽",
                "7": "從南湘之二妃",
                "8": "攜漢濱之遊女",
                "9": "歎匏瓜之無匹兮",
                "10": "詠牽牛之獨處",
                "11": "揚輕袿之猗靡兮",
                "12": "翳修袖以延佇",
                "13": "體迅飛鳧",
                "14": "飄忽若神",
                "15": "凌波微步",
                "16": "羅襪生塵",
                "17": "動無常則",
                "18": "若危若安",
                "19": "進止難期",
                "20": "若往若還",
                "21": "轉眄流精",
                "22": "光潤玉顏",
                "23": "含辭未吐",
                "24": "氣若幽蘭",
                "25": "華容婀娜",
                "26": "令我忘餐"
            }
        },
        "7": {
            "15": {
                "1": "於是屛翳收風",
                "2": "川后靜波",
                "3": "馮夷鳴鼓",
                "4": "女媧清歌",
                "5": "騰文魚以警乘",
                "6": "鳴玉鸞以偕逝",
                "7": "六龍儼其齊首",
                "8": "載雲車之容裔",
                "9": "鯨鯢踴而夾轂",
                "10": "水禽翔而爲衞"
            }
        },
        "8": {
            "17": {
                "1": "於是越北沚",
                "2": "過南岡",
                "3": "紆素領",
                "4": "迴清陽",
                "5": "動朱脣以徐言",
                "6": "陳交接之大綱",
                "7": "恨人神之道殊兮",
                "8": "怨盛年之莫當",
                "9": "抗羅袂以掩涕兮",
                "10": "淚流襟之浪浪",
                "11": "悼良會之永絕兮",
                "12": "哀一逝而異鄕",
                "13": "無微情以效愛兮",
                "14": "獻江南之明璫",
                "15": "雖潛處於太陰",
                "16": "長寄心於君王",
                "17": "忽不悟其所舍",
                "18": "悵神宵而蔽光"
            }
        },
        "9": {
            "19": {
                "1": "於是背下陵高",
                "2": "足往神留",
                "3": "遺情想像",
                "4": "顧望懷愁",
                "5": "冀靈體之復形",
                "6": "御輕舟而上溯",
                "7": "浮長川而忘反",
                "8": "思綿綿而增慕",
                "9": "夜耿耿而不寐",
                "10": "霑繁霜而至曙",
                "11": "命僕夫而就駕",
                "12": "吾將歸乎東路",
                "13": "攬騑轡以抗策",
                "14": "悵盤桓而不能去"
            }
        }
    }
}