{
    "37.08": {
        "篇名": "劉越石 勸進表",
        "1": {
            "3": {
                "1": "建興五年三月癸未朔十八日辛丑",
                "2": "使持節散騎常侍都督河北幷冀幽三州諸軍事",
                "3": "領護軍匈奴中郎將",
                "4": "司空",
                "5": "幷州刺史",
                "6": "廣武侯臣琨",
                "7": "使持節侍中都督冀州諸軍事",
                "8": "撫軍大將軍",
                "9": "冀州刺史",
                "10": "左賢王",
                "11": "渤海公臣磾",
                "12": "頓首死罪",
                "13": "上書"
            }
        },
        "2": {
            "5": {
                "1": "臣琨臣磾",
                "2": "頓首頓首",
                "3": "死罪死罪",
                "4": "臣聞天生蒸人",
                "5": "樹之以君",
                "6": "所以對越天地",
                "7": "司牧黎元",
                "8": "聖帝明王鑒其若此",
                "9": "知天地不可以乏饗",
                "10": "故屈其身以奉之",
                "11": "知黎元不可以無主",
                "12": "故不得已而臨之",
                "13": "社稷時難",
                "14": "則戚藩定其傾",
                "15": "郊廟或替",
                "16": "則宗哲纂其祀",
                "17": "所以弘振遐風",
                "18": "式固萬世",
                "19": "牽秀衞公誄曰",
                "20": "仰𦖁遐風",
                "21": "重輝冠世",
                "22": "毛詩曰",
                "23": "式固爾猶",
                "24": "三五以降",
                "25": "靡不由之"
            }
        },
        "3": {
            "7": {
                "1": "臣琨臣殫",
                "2": "頓首頓首",
                "3": "死罪死罪",
                "4": "伏惟高祖宣皇帝肇基景命",
                "5": "世祖武皇帝遂造區夏",
                "6": "三葉重光",
                "7": "四聖繼軌",
                "8": "惠澤侔於有虞",
                "9": "卜年過於周氏",
                "10": "自元康以來",
                "11": "艱禍繁興",
                "12": "永嘉之際",
                "13": "氛厲彌昏",
                "14": "宸極失御",
                "15": "登遐醜裔",
                "16": "國家之危",
                "17": "有若綴旒",
                "18": "賴先后之德",
                "19": "宗廟之靈",
                "20": "皇帝嗣建",
                "21": "舊物克甄",
                "22": "誕授欽明",
                "23": "服膺聰哲",
                "24": "玉質幼彰",
                "25": "金聲夙振",
                "26": "冢宰攝其綱",
                "27": "百辟輔其治",
                "28": "四海想中興之美",
                "29": "羣生懷來蘇之望",
                "30": "不圖天不悔禍",
                "31": "大災荐臻",
                "32": "國未忘難",
                "33": "寇害尋興",
                "34": "逆胡劉曜",
                "35": "縱逸西都",
                "36": "敢肆犬羊",
                "37": "凌虐天邑",
                "38": "臣等奉表使還",
                "39": "仍承西朝",
                "40": "以去年十一月不守",
                "41": "主上幽劫",
                "42": "復沈虜庭",
                "43": "神器流離",
                "44": "再辱荒逆",
                "45": "臣每覽史籍",
                "46": "觀之前載",
                "47": "厄運之極",
                "48": "古今未有",
                "49": "苟在食土之毛",
                "50": "含氣之類",
                "51": "莫不叩心絕氣",
                "52": "行號巷哭",
                "53": "況臣等荷寵三世",
                "54": "位廁鼎司",
                "55": "承問震惶",
                "56": "精爽飛越",
                "57": "且悲且惋",
                "58": "五情無主",
                "59": "舉哀朔垂",
                "60": "上下泣血"
            }
        },
        "4": {
            "9": {
                "1": "臣琨臣磾",
                "2": "頓首頓首",
                "3": "死罪死罪",
                "4": "臣聞昏明迭用",
                "5": "否泰相濟",
                "6": "天命未改",
                "7": "歷數有歸",
                "8": "或多難以固邦國",
                "9": "或殷憂以啟聖明",
                "10": "齊有無知之禍",
                "11": "而小白爲五伯之長",
                "12": "晉有驪姬之難",
                "13": "而重耳主諸侯之盟",
                "14": "社稷靡安",
                "15": "必將有以扶其危",
                "16": "黔首幾絕",
                "17": "必將有以繼其緒",
                "18": "伏惟陛下",
                "19": "玄德通於神明",
                "20": "聖姿合於兩儀",
                "21": "應命代之期",
                "22": "紹千載之運",
                "23": "夫符瑞之表",
                "24": "天人有徵",
                "25": "中興之兆",
                "26": "圖讖垂典",
                "27": "自京畿隕喪",
                "28": "九服崩離",
                "29": "天下囂然無所歸懷",
                "30": "雖有夏之遘夷羿",
                "31": "宗姬之離犬戎",
                "32": "蔑以過之",
                "33": "陛下撫寧江左",
                "34": "奄有舊吳",
                "35": "柔服以德",
                "36": "伐叛以刑",
                "37": "抗明威以攝不類",
                "38": "杖大順以肅宇內",
                "39": "純化旣敷",
                "40": "則率土宅心",
                "41": "義風旣暢",
                "42": "則遐方企踵",
                "43": "百揆時敍於上",
                "44": "四門穆穆於下",
                "45": "昔少康之隆",
                "46": "夏訓以爲美談",
                "47": "宣王之興",
                "48": "周詩以爲休詠",
                "49": "況茂勳格於皇天",
                "50": "清輝光於四海",
                "51": "蒼生顒然",
                "52": "莫不欣戴",
                "53": "聲教所加",
                "54": "願爲臣妾者哉",
                "55": "且宣皇之胤",
                "56": "惟有陛下",
                "57": "億兆攸歸",
                "58": "曾無與二",
                "59": "天祚大晉",
                "60": "必將有主",
                "61": "主晉祀者",
                "62": "非陛下而誰",
                "63": "是以邇無異言",
                "64": "遠無異望",
                "65": "謳歌者無不吟詠徽猷",
                "66": "獄訟者無不思於聖德",
                "67": "天地之際旣交",
                "68": "華裔之情允洽",
                "69": "一角之獸",
                "70": "連理之木",
                "71": "以爲休徵者",
                "72": "蓋有百數",
                "73": "冠帶之倫",
                "74": "要荒之眾",
                "75": "不謀而同辭者",
                "76": "動以萬計",
                "77": "是以臣等敢考天地之心",
                "78": "因函夏之趣",
                "79": "昧死以上尊號",
                "80": "願陛下存舜禹至公之情",
                "81": "狹巢由抗矯之節",
                "82": "以社稷爲務",
                "83": "不以小行爲先",
                "84": "以黔首爲憂",
                "85": "不以克讓爲事",
                "86": "上以慰宗廟乃顧之懷",
                "87": "下以釋普天傾首之望",
                "88": "則所謂生繁華於枯荑",
                "89": "育豐肌於朽骨",
                "90": "神人獲安",
                "91": "無不幸甚"
            }
        },
        "5": {
            "11": {
                "1": "臣琨臣磾",
                "2": "頓首頓首",
                "3": "死罪死罪",
                "4": "臣聞尊位不可久虛",
                "5": "萬機不可久曠",
                "6": "虛之一日",
                "7": "則尊位以殆",
                "8": "曠之浹辰",
                "9": "則萬機以亂",
                "10": "方今鍾百王之季",
                "11": "當陽九之會",
                "12": "狡寇窺窬",
                "13": "伺國瑕隙",
                "14": "齊人波蕩",
                "15": "無所繫心",
                "16": "安可以廢而不卹哉",
                "17": "陛下雖欲逡巡",
                "18": "其若宗廟何",
                "19": "其若百姓何",
                "20": "昔惠公虜秦",
                "21": "晉國震駭",
                "22": "呂郤之謀",
                "23": "欲立子圉",
                "24": "外以絕敵人之志",
                "25": "內以固闔境之情",
                "26": "故曰喪君有君",
                "27": "羣臣輯穆",
                "28": "好我者勸",
                "29": "惡我者懼",
                "30": "前事之不忘",
                "31": "後代之元龜也",
                "32": "陛下明並日月",
                "33": "無幽不燭",
                "34": "深謀遠慮",
                "35": "出自胸懷",
                "36": "不勝犬馬憂國之情",
                "37": "遲睹人神開泰之路",
                "38": "是以陳其乃誠",
                "39": "布之執事",
                "40": "臣等各忝守方任",
                "41": "職在遐外",
                "42": "不得陪列闕庭",
                "43": "共觀盛禮",
                "44": "踊躍之懷",
                "45": "南望罔極",
                "46": "謹上",
                "47": "臣琨謹遣兼左長史右司馬臣溫嶠",
                "48": "主簿臣辟閭訓",
                "49": "臣磾遣散騎常侍",
                "50": "征虜將軍",
                "51": "清河太守",
                "52": "領右長史",
                "53": "高平亭侯臣榮劭",
                "54": "輕車將軍關內侯臣郭穆奉表",
                "55": "臣琨臣磾等",
                "56": "頓首頓苜",
                "57": "死罪死罪"
            }
        }
    }
}