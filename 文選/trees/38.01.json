{
    "38.01": {
        "篇名": "張士然 爲吳令謝詢求爲諸孫置守冢人表",
        "1": {
            "3": {
                "1": "臣聞成湯革夏而封杞",
                "2": "武王入殷而建宋",
                "3": "春秋征伐",
                "4": "則晉修虞祀",
                "5": "燕祭齊廟",
                "6": "夫一國爲一人興",
                "7": "先賢爲後愚廢",
                "8": "誠仁聖所哀悼而不忍也",
                "9": "故三王敦繼絕之德",
                "10": "春秋貴柔服之義",
                "11": "昔漢高受命",
                "12": "追存六國",
                "13": "凡諸絕祚",
                "14": "一時並祀",
                "15": "親與項羽對爭存亡",
                "16": "逮羽之死",
                "17": "臨哭其喪",
                "18": "將以位嘗侔尊",
                "19": "力嘗均勢",
                "20": "雖功奪其成",
                "21": "而恩與其敗",
                "22": "且暴興疾顚",
                "23": "禮之若舊",
                "24": "殘戮之尸",
                "25": "乃以公葬",
                "26": "若使羽位承前緒",
                "27": "世有哲王",
                "28": "一朝力屈",
                "29": "全身從命",
                "30": "則楚廟不隳",
                "31": "有後可冀"
            }
        },
        "2": {
            "5": {
                "1": "伏惟大晉",
                "2": "應天順民",
                "3": "武成止戈",
                "4": "西戎有卽序之人",
                "5": "京邑開吳蜀之館",
                "6": "興滅加乎萬國",
                "7": "繼絕接於百世",
                "8": "雖三五弘道",
                "9": "商周稱仁",
                "10": "洋洋之義",
                "11": "未足以喩",
                "12": "是以孫氏雖家失吳祚",
                "13": "而族蒙晉榮",
                "14": "子弟量才",
                "15": "比肩進取",
                "16": "懷金侯服",
                "17": "佩青千里",
                "18": "當時受恩",
                "19": "多有過望",
                "20": "臣聞春雨潤木",
                "21": "自葉流根",
                "22": "鴟鴞卹功",
                "23": "愛子及室",
                "24": "故天稱罔極之恩",
                "25": "聖有綢繆之惠"
            }
        },
        "3": {
            "7": {
                "1": "追惟吳僞武烈皇帝",
                "2": "遭漢室之弱",
                "3": "値亂臣之強",
                "4": "首唱義兵",
                "5": "先眾犯難",
                "6": "破董卓於陽人",
                "7": "濟神器於甄井",
                "8": "威震羣狡",
                "9": "名顯往朝",
                "10": "桓王才武",
                "11": "弱冠承業",
                "12": "招百越之士",
                "13": "奮鷹揚之勢",
                "14": "西赴許都",
                "15": "將迎幼主",
                "16": "雖元勳未終",
                "17": "然至忠已著",
                "18": "夫家積義勇之基",
                "19": "世傳扶危之業",
                "20": "進爲徇漢之臣",
                "21": "退爲開吳之主",
                "22": "而蒸嘗絕於三葉",
                "23": "園陵殘於薪采",
                "24": "臣竊悼之"
            }
        },
        "4": {
            "9": {
                "1": "伏見吳平之初",
                "2": "明詔追錄先賢",
                "3": "欲封其墓",
                "4": "愚謂二君並宜應書",
                "5": "故舉勞則力輸先代",
                "6": "論德則惠存江南",
                "7": "正刑則罪非晉寇",
                "8": "從坐則異世已輕",
                "9": "若列先賢之數",
                "10": "蒙詔書之恩",
                "11": "裁加表異",
                "12": "以寵亡靈",
                "13": "則人望克厭",
                "14": "誰不曰宜",
                "15": "二君私奴",
                "16": "多在墓側",
                "17": "今爲平民",
                "18": "乞差五人",
                "19": "蠲其徭役",
                "20": "使四時修護頹毀",
                "21": "掃除塋壟",
                "22": "永以爲常"
            }
        }
    }
}