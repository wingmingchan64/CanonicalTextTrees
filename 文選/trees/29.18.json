{
    "29.18": {
        "篇名": "何敬祖 雜詩",
        "1": {
            "3": {
                "1": "秋風乘夕起",
                "2": "明月照高樹",
                "3": "閑房來清氣",
                "4": "廣庭發暉素",
                "5": "靜寂愴然歎",
                "6": "惆悵出遊顧",
                "7": "仰視垣上草",
                "8": "俯察階下露",
                "9": "心虛體自輕",
                "10": "飄颻若仙步",
                "11": "瞻彼陵上柏",
                "12": "想與神人遇",
                "13": "道深難可期",
                "14": "精微非所慕",
                "15": "勤思終遙夕",
                "16": "永言寫情慮"
            }
        }
    }
}