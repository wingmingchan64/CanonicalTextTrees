{
    "30.02-01": {
        "篇名": "陶淵明 雜詩二首·其一",
        "1": {
            "3": {
                "1": "結廬在人境",
                "2": "而無車馬喧",
                "3": "問君何能爾",
                "4": "心遠地自偏",
                "5": "采菊東籬下",
                "6": "悠然望南山",
                "7": "山氣日夕佳",
                "8": "飛鳥相與還",
                "9": "此還有眞意",
                "10": "欲辯已忘言"
            }
        }
    }
}