{
    "27.16-01": {
        "篇名": "古樂府三首飲馬長城窟行·其一",
        "1": {
            "3": {
                "1": "青青河邊草",
                "2": "綿綿思遠道",
                "3": "遠道不可思",
                "4": "夙昔夢見之",
                "5": "夢見在我傍",
                "6": "忽覺在佗鄕",
                "7": "佗鄕各異縣",
                "8": "輾轉不可見",
                "9": "枯桑知天風",
                "10": "海水知天寒",
                "11": "入門各自媚",
                "12": "誰肯相爲言",
                "13": "客從遠方來",
                "14": "遺我雙鯉魚",
                "15": "呼兒烹鯉魚",
                "16": "中有尺素書",
                "17": "長跪讀素書",
                "18": "書上竟何如",
                "19": "上有加餐食",
                "20": "下有長相憶"
            }
        }
    }
}