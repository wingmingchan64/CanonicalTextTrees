{
    "31.09-01": {
        "篇名": "江文通 雜體詩三十首·古離別",
        "1": {
            "3": {
                "1": "遠與君別者",
                "2": "乃至雁門關",
                "3": "黃雲蔽千里",
                "4": "遊子何時還",
                "5": "送君如昨日",
                "6": "檐前露已團",
                "7": "不惜蕙草晚",
                "8": "所悲道里寒",
                "9": "君在天一涯",
                "10": "妾身長別離",
                "11": "願一見顏色",
                "12": "不異瓊樹枝",
                "13": "兔絲及水萍",
                "14": "所寄終不移"
            }
        }
    }
}