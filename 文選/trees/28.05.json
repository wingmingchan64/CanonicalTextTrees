{
    "28.05": {
        "篇名": "繆熙伯 輓歌詩",
        "1": {
            "3": {
                "1": "生時遊國都",
                "2": "死沒棄中野",
                "3": "朝發高堂上",
                "4": "暮宿黃泉下",
                "5": "白日入虞淵",
                "6": "懸车息駟馬",
                "7": "造化雖神明",
                "8": "安能復存我",
                "9": "形容稍歇滅",
                "10": "齒髮行当堕",
                "11": "自古皆有然",
                "12": "誰能离此者"
            }
        }
    }
