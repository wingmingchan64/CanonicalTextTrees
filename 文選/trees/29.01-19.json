                "2": "照我羅牀幃",
                "3": "憂愁不能寐",
                "4": "攬衣起徘徊",
                "5": "客行雖云樂",
                "6": "不如早旋歸",
                "7": "出戶獨彷徨",
                "8": "愁思當告誰",
                "9": "引領還入房",
                "10": "淚下霑裳衣"
            }
        }
