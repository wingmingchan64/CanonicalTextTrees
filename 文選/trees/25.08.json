{
    "25.08": {
        "篇名": "盧子諒 贈劉琨[幷書]",
        "1": {
            "3": {
                "1": "故吏從事中郎盧諶死罪",
                "2": "死罪",
                "3": "諶稟性短弱",
                "4": "當世罕任",
                "5": "因其自然",
                "6": "用安靜退",
                "7": "在木闕不材之資",
                "8": "處雁乏善鳴之分",
                "9": "卷異蘧子",
                "10": "愚殊甯生",
                "11": "匠者時眄",
                "12": "不免𩜹賓",
                "13": "言在木闕不材",
                "14": "故匠者時眄",
                "15": "在雁乏善鳴",
                "16": "故不免𩜹賓也",
                "17": "莊子",
                "18": "惠子謂弟子曰",
                "19": "吾有大樹",
                "20": "人謂之樗",
                "21": "匠者不顧",
                "22": "廣雅曰",
                "23": "饌",
                "24": "進食也",
                "25": "饌與𩜹同",
                "26": "仕眷切",
                "27": "嘗自思惟",
                "28": "因緣運會",
                "29": "得蒙接事",
                "30": "自奉清塵",
                "31": "於今五稔",
                "32": "謨明之效不著",
                "33": "候人之譏以彰",
                "34": "大雅含弘",
                "35": "量苞山藪",
                "36": "加以待接彌優",
                "37": "款眷逾昵",
                "38": "與運籌之謀",
                "39": "廁讌私之歡",
                "40": "綢繆之旨",
                "41": "有同骨肉",
                "42": "其爲知己",
                "43": "古人罔喩",
                "44": "昔聶政殉嚴遂之顧",
                "45": "荊軻慕燕丹之義",
                "46": "意氣之間",
                "47": "靡軀不悔",
                "48": "雖微達節",
                "49": "謂之可庶",
                "50": "然苟曰有情",
                "51": "孰能不懷",
                "52": "故委身之日",
                "53": "夷險已之",
                "54": "事與願違",
                "55": "當忝外役",
                "56": "遂去左右",
                "57": "收迹府朝",
                "58": "蓋本同末異",
                "59": "楊朱興哀",
                "60": "始素終玄",
                "61": "墨翟垂涕",
                "62": "分乖之際",
                "63": "咸可歎慨",
                "64": "致感之途",
                "65": "或迫乎茲",
                "66": "亦奚必臨路而後長號",
                "67": "睹絲而後歔欷哉",
                "68": "是以仰惟先情",
                "69": "俯覽今遇",
                "70": "感存念亡",
                "71": "觸物眷戀",
                "72": "易曰",
                "73": "書不盡言",
                "74": "言不盡意",
                "75": "然則書非盡言之器",
                "76": "言非盡意之具矣",
                "77": "況言有不得至於盡意",
                "78": "書有不得至於盡言邪",
                "79": "不勝猥懣",
                "80": "謹貢詩一篇",
                "81": "抑不足以揄揚弘美",
                "82": "亦以攄其所抱而已",
                "83": "若公肆大惠",
                "84": "遂其厚恩",
                "85": "錫以咳唾之音",
                "86": "慰其違離之意",
                "87": "則所謂咸池酬於北里",
                "88": "夜光報於魚目",
                "89": "諶之願也",
                "90": "非所敢望也",
                "91": "諶死罪",
                "92": "死罪"
            }
        },
