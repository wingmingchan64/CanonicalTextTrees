{
    "19.01": {
        "篇名": "宋玉 高唐賦[幷序]",
        "1": {
            "3": {
                "1": "昔者楚襄王與宋玉遊於雲夢之臺",
                "2": "望高唐之觀",
                "3": "其上獨有雲氣",
                "4": "崒兮直上",
                "5": "忽兮改容",
                "6": "須臾之間",
                "7": "變化無窮",
                "8": "王問玉曰",
                "9": "此何氣也",
                "10": "玉對曰",
                "11": "所謂朝雲者也",
                "12": "王曰",
                "13": "何謂朝雲",
                "14": "玉曰",
                "15": "昔者先王嘗遊高唐",
                "16": "怠而晝寢",
                "17": "夢見一婦人",
                "18": "曰",
                "19": "妾巫山之女也",
                "20": "爲高唐之客",
                "21": "聞君遊高唐",
                "22": "願薦枕席",
                "23": "王因幸之",
                "24": "去而辭曰",
                "25": "妾在巫山之陽",
                "26": "高丘之阻",
                "27": "旦爲朝雲",
                "28": "暮爲行雨",
                "29": "朝朝暮暮",
                "30": "陽臺之下",
                "31": "旦朝視之如言",
                "32": "故爲立廟",
                "33": "號曰朝雲",
                "34": "王曰",
                "35": "朝雲始出",
                "36": "狀若何也",
                "37": "玉對曰",
                "38": "其始出也",
                "39": "㬣兮若松榯",
                "40": "其少進也",
                "41": "晰兮若姣姬",
                "42": "揚袂鄣日",
                "43": "而望所思",
                "44": "忽兮改容",
                "45": "偈兮若駕駟馬",
                "46": "建羽旗",
                "47": "湫兮如風",
                "48": "淒兮如雨",
                "49": "風止雨霽",
                "50": "雲無處所",
                "51": "王曰",
                "52": "寡人方今可以遊乎",
                "53": "玉曰",
                "54": "可",
                "55": "王曰",
                "56": "其何如矣",
                "57": "玉曰",
                "58": "高矣顯矣",
                "59": "臨望遠矣",
                "60": "廣矣普矣",
                "61": "萬物祖矣",
                "62": "上屬於天",
                "63": "下見於淵",
                "64": "珍怪奇偉",
                "65": "不可稱論",
                "66": "王曰",
                "67": "試爲寡人賦之",
                "68": "玉曰",
                "69": "唯唯"
            }
        },
        "2": {
            "5": {
                "1": "惟高唐之大體兮",
                "2": "殊無物類之可儀比",
                "3": "巫山赫其無疇兮",
                "4": "道互折而曾累",
                "5": "登巉巖而下望兮",
                "6": "臨大阺之稸水",
                "7": "遇天雨之新霽兮",
                "8": "觀百谷之俱集",
                "9": "濞洶洶其無聲兮",
                "10": "潰淡淡而並入",
                "11": "滂洋洋而四施兮",
                "12": "蓊湛湛而弗止",
                "13": "長風至而波起兮",
                "14": "若麗山之孤畝",
                "15": "勢薄岸而相擊兮",
                "16": "隘交引而卻會",
                "17": "崒中怒而特高兮",
                "18": "若浮海而望碣石",
                "19": "礫磥磥而相摩兮",
                "20": "巆震天之磕磕",
                "21": "巨石溺溺之瀺灂兮",
                "22": "沫潼潼而高厲",
                "23": "水澹澹而盤紆兮",
                "24": "洪波淫淫之溶㵝",
                "25": "奔揚踊而相擊兮",
                "26": "雲興聲之霈霈",
                "27": "猛獸驚而跳駭兮",
                "28": "妄奔走而馳邁",
                "29": "虎豹豺兕",
                "30": "失氣恐喙",
                "31": "雕鶚鷹鷂",
                "32": "飛揚伏竄",
                "33": "股戰脅息",
                "34": "安敢妄摯"
            }
        },
        "3": {
            "7": {
                "1": "於是水蟲盡暴",
                "2": "乘渚之陽",
                "3": "黿鼉鱣鮪",
                "4": "交積縱橫",
                "5": "振鱗奮翼",
                "6": "蜲蜲蜿蜿",
                "7": "中阪遙望",
                "8": "玄木冬榮",
                "9": "煌煌熒熒",
                "10": "奪人目精",
                "11": "爛兮若列星",
                "12": "曾不可殫形",
                "13": "榛林鬱盛",
                "14": "葩華覆蓋",
                "15": "雙椅垂房",
                "16": "糾枝還會",
                "17": "徙靡澹淡",
                "18": "隨波闇藹",
                "19": "東西施翼",
                "20": "猗狔豐沛",
                "21": "綠葉紫裹",
                "22": "丹莖白蔕",
                "23": "纖條悲鳴",
                "24": "聲似竽籟",
                "25": "清濁相和",
                "26": "五變四會",
                "27": "感心動耳",
                "28": "迴腸傷氣",
                "29": "孤子寡婦",
                "30": "寒心酸鼻",
                "31": "長吏隳官",
                "32": "賢士失志",
                "33": "愁思無已",
                "34": "歎息垂淚"
            }
        },
        "4": {
            "9": {
                "1": "登高遠望",
                "2": "使人心瘁",
                "3": "盤岸巑岏",
                "4": "裖陳磑磑",
                "5": "磐石險峻",
                "6": "傾崎崖隤",
                "7": "巖嶇參差",
                "8": "從橫相追",
                "9": "陬互橫啎",
                "10": "背穴偃蹠",
                "11": "交加累積",
                "12": "重疊增益",
                "13": "狀若砥柱",
                "14": "在巫山下",
                "15": "仰視山顚",
                "16": "肅何千千",
                "17": "炫燿虹蜺",
                "18": "俯視崝嶸",
                "19": "窐寥窈冥",
                "20": "不見其底",
                "21": "虛聞松聲",
                "22": "傾岸洋洋",
                "23": "立而熊經",
                "24": "久而不去",
                "25": "足盡汗出",
                "26": "悠悠忽忽",
                "27": "怊悵自失",
                "28": "使人心動",
                "29": "無故自恐",
                "30": "賁育之斷",
                "31": "不能爲勇",
                "32": "卒愕異物",
                "33": "不知所出",
                "34": "縰縰莘莘",
                "35": "若生於鬼",
                "36": "若出於神",
                "37": "狀似走獸",
                "38": "或象飛禽",
                "39": "譎詭奇偉",
                "40": "不可究陳",
                "41": "上至觀側",
                "42": "地蓋底平",
                "43": "箕踵漫衍",
                "44": "芳草羅生",
                "45": "秋蘭茞蕙",
                "46": "江離載菁",
                "47": "青荃射干",
                "48": "揭車苞幷",
                "49": "薄草靡靡",
                "50": "聯延夭夭",
                "51": "越香掩掩",
                "52": "眾雀嗷嗷",
                "53": "雌雄相失",
                "54": "哀鳴相號",
                "55": "王雎鸝黃",
                "56": "正冥楚鳩",
                "57": "姊歸思婦",
                "58": "垂雞高巢",
                "59": "其鳴喈喈",
                "60": "當年遨遊",
                "61": "更唱迭和",
                "62": "赴曲隨流"
            }
        },
        "5": {
            "11": {
                "1": "有方之士",
                "2": "羨門高谿",
                "3": "上成鬱林",
                "4": "公樂聚穀",
                "5": "進純犧",
                "6": "禱琁室",
                "7": "醮諸神",
                "8": "禮太一",
                "9": "傳祝已具",
                "10": "言辭已畢",
                "11": "王乃乘玉輿",
                "12": "駟倉螭",
                "13": "垂旒旌",
                "14": "旆合諧",
                "15": "紬大絃而雅聲流",
                "16": "冽風過而增悲哀",
                "17": "於是調謳",
                "18": "令人惏悷憯悽",
                "19": "脅息增欷",
                "20": "於是乃縱獵者",
                "21": "基趾如星",
                "22": "傳言羽獵",
                "23": "銜枚無聲",
                "24": "弓弩不發",
                "25": "罘颍不傾",
                "26": "涉漭漭",
                "27": "馳苹苹",
                "28": "飛鳥未及起",
                "29": "走獸未及發",
                "30": "何節奄忽",
                "31": "啼足灑血",
                "32": "舉功先得",
                "33": "獲車已實"
            }
        },
        "6": {
            "13": {
                "1": "王將欲往見",
                "2": "必先齋戒",
                "3": "差時擇日",
                "4": "簡輿玄服",
                "5": "建雲旆",
                "6": "蜺爲旌",
                "7": "翠爲蓋",
                "8": "風起雨止",
                "9": "千里而逝",
                "10": "蓋發蒙",
                "11": "往自會",
                "12": "思萬方",
                "13": "憂國害",
                "14": "開賢聖",
                "15": "輔不逮",
                "16": "九竅通鬱",
                "17": "精神察滯",
                "18": "延年益壽千萬歲"
            }
        }
    }
}