{
    "30.28-11": {
        "篇名": "陸士衡 擬古詩十二首·擬庭中有奇樹",
        "1": {
            "3": {
                "1": "歡友蘭時往",
                "2": "苕苕匿音徽",
                "3": "虞淵引絕景",
                "4": "四節逝若飛",
                "5": "芳草久已茂",
                "6": "佳人竟不歸",
                "7": "躑躅遵林渚",
                "8": "惠風入我懷",
                "9": "感物戀所歡",
                "10": "采此欲貽誰"
            }
        }
    }
}