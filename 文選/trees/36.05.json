{
    "36.05": {
        "篇名": "王元長 永明十一年策秀才文五首",
        "1": {
            "3": {
                "1": "問秀才",
                "2": "朕秉籙御天",
                "3": "握樞臨極",
                "4": "五辰空撫",
                "5": "九序未歌",
                "6": "至於思政明臺",
                "7": "訪道宣室",
                "8": "若墜之惻每勤",
                "9": "如傷之念恆軫",
                "10": "故卹貧緩賦",
                "11": "省繇愼獄",
                "12": "幸四境無虞",
                "13": "三秋式稔",
                "14": "而多黍多稌",
                "15": "不興兩穗之謠",
                "16": "無褐無衣",
                "17": "必盈七月之歎",
                "18": "豈布政未優",
                "19": "將罷民難業",
                "20": "登爾於朝",
                "21": "是屬宏議",
                "22": "罔弗同心",
                "23": "以匡厥辟"
            }
        },
        "2": {
            "5": {
                "1": "又問",
                "2": "惟王建國",
                "3": "惟典命官",
                "4": "上協星象",
                "5": "下符川嶽",
                "6": "必待天爵具修",
                "7": "人紀咸事",
                "8": "然後沿才受職",
                "9": "揆務分司",
                "10": "是以五正置於朱宣",
                "11": "下民不忒",
                "12": "九工開於黃序",
                "13": "庶績其凝",
                "14": "周官三百",
                "15": "漢位兼倍",
                "16": "歷茲以降",
                "17": "遊惰寔繁",
                "18": "若閑冗畢棄",
                "19": "則橫議無已",
                "20": "冕笏不澄",
                "21": "則坐談彌積",
                "22": "何則可修",
                "23": "善詳其對"
            }
        },
        "3": {
            "7": {
                "1": "又問",
                "2": "昔者賢牧分陝",
                "3": "良守共治",
                "4": "下邑必樹其風",
                "5": "一鄕可以爲績",
                "6": "至有旦撫鳴琴",
                "7": "日置醇酒",
                "8": "文而無害",
                "9": "嚴而不殘",
                "10": "故能出人於阽危之域",
                "11": "躋俗於仁壽之地",
                "12": "是以賈誼有言",
                "13": "天下之有惡",
                "14": "吏之罪也",
                "15": "頃深汰珪符",
                "16": "妙簡銅墨",
                "17": "而春雉未馴",
                "18": "秋螟不散",
                "19": "入在朕前",
                "20": "湊其智略",
                "21": "出連城守",
                "22": "闕爾無聞",
                "23": "豈薪槱之道未弘",
                "24": "爲網羅之目尙簡",
                "25": "悉意正辭",
                "26": "無侵執事"
            }
        },
        "4": {
            "9": {
                "1": "又問",
                "2": "朕聞上智利民",
                "3": "不述於禮",
                "4": "大賢彊國",
                "5": "罔圖惟舊",
                "6": "豈非療飢不期於鼎食",
                "7": "拯溺無待於規行",
                "8": "是以三王異道而共昌",
                "9": "五霸殊風而並列",
                "10": "今農戰不修",
                "11": "文儒是競",
                "12": "棄本殉末",
                "13": "厥敝茲多",
                "14": "昔宋臣以禮樂爲殘賊",
                "15": "漢主比文章於鄭衞",
                "16": "豈欲非聖無法",
                "17": "將以旣道而權",
                "18": "今欲專士女於耕桑",
                "19": "習鄕閭以弓騎",
                "20": "五都復而事庠序",
                "21": "四民富而歸文學",
                "22": "其道奚若",
                "23": "爾無面從"
            }
        },
        "5": {
            "11": {
                "1": "又問",
                "2": "自晉氏不綱",
                "3": "關河蕩析",
                "4": "宋人失馭",
                "5": "淮汴崩離",
                "6": "朕思念舊民",
                "7": "永言攸濟",
                "8": "故選將開邊",
                "9": "勞來安集",
                "10": "加以納款通知",
                "11": "布德修禮",
                "12": "歌皇華而遣使",
                "13": "賦膏雨而懷賓",
                "14": "所以關洛動南望之懷",
                "15": "獯夷遽北歸之念",
                "16": "夫危葉畏風",
                "17": "驚禽易落",
                "18": "無待干戈",
                "19": "聊用辭辯",
                "20": "片言而求三輔",
                "21": "一說而定五州",
                "22": "斯路何階",
                "23": "人誰或可",
                "24": "進謀誦志",
                "25": "以沃朕心"
            }
        }
    }
}