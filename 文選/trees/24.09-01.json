{
    "24.09-01": {
        "篇名": "張茂先 答何劭二首·其一",
        "1": {
            "3": {
                "1": "吏道何其迫",
                "2": "窘然坐自拘",
                "3": "纓婑爲徽纆",
                "4": "文憲焉可踰",
                "5": "恬曠苦不足",
                "6": "煩促每有餘",
                "7": "良朋貽新詩",
                "8": "示我以遊娛",
                "9": "穆如灑清風",
                "10": "奐若春華敷",
                "11": "自昔同僚寀",
                "12": "於今比園廬",
                "13": "衰夕近辱殆",
                "14": "庶幾並懸輿",
                "15": "散髮重陰下",
                "16": "抱杖臨清渠",
                "17": "屬耳聽鶯鳴",
                "18": "流目翫儵魚",
                "19": "從容養餘日",
                "20": "取樂於桑楡"
            }
        }
    }
}