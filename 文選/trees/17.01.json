{
    "17.01": {
        "篇名": "陸士衡 文賦[幷序]",
        "1": {
            "3": {
                "1": "余每觀才士之所作",
                "2": "竊有以得其用心",
                "3": "夫放言遣辭",
                "4": "良多變矣",
                "5": "姸蚩好惡",
                "6": "可得而言",
                "7": "每自屬文",
                "8": "尤見其情",
                "9": "恆患意不稱物",
                "10": "文不逮意",
                "11": "蓋非知之難",
                "12": "能之難也",
                "13": "故作文賦",
                "14": "以述先士之盛藻",
                "15": "因論作文之利害所由",
                "16": "他日殆可謂曲盡其妙",
                "17": "至於操斧伐柯",
                "18": "雖取則不遠",
                "19": "若夫隨手之變",
                "20": "良難以辭逮",
                "21": "蓋所能言者",
                "22": "具於此云"
            }
        },
        "2": {
            "5": {
                "1": "佇中區以玄覽",
                "2": "頤情志於典墳",
                "3": "遵四時以歎逝",
                "4": "瞻萬物而思紛",
                "5": "悲落葉於勁秋",
                "6": "喜柔條於芳春",
                "7": "心懍懍以懷霜",
                "8": "志眇眇而臨雲",
                "9": "詠世德之駿烈",
                "10": "誦先人之清芬",
                "11": "遊文章之林府",
                "12": "嘉麗藻之彬彬",
                "13": "慨投篇而援筆",
                "14": "聊宣之乎斯文"
            }
        },
        "3": {
            "7": {
                "1": "其始也",
                "2": "皆收視反聽",
                "3": "耽思傍訊",
                "4": "精騖八極",
                "5": "心遊萬仞",
                "6": "其致也",
                "7": "情曈曨而彌鮮",
                "8": "物昭晰而互進",
                "9": "傾羣言之瀝液",
                "10": "漱六藝之芳潤",
                "11": "浮天淵以安流",
                "12": "濯下泉而潛浸",
                "13": "於是沈辭怫悅",
                "14": "若遊魚銜鉤",
                "15": "而出重淵之深",
                "16": "浮藻聯翩",
                "17": "若翰鳥纓繳",
                "18": "而墜曾雲之峻",
                "19": "收百世之闕文",
                "20": "采千載之遺韻",
                "21": "謝朝華於已披",
                "22": "啟夕秀於未振",
                "23": "觀古今於須臾",
                "24": "撫四海於一瞬"
            }
        },
        "4": {
            "9": {
                "1": "然後選義按部",
                "2": "考辭就班",
                "3": "抱景者咸叩",
                "4": "懷響者畢彈",
                "5": "或因枝以振葉",
                "6": "或沿波而討源",
                "7": "或本隱以之顯",
                "8": "或求易而得難",
                "9": "或虎變而獸擾",
                "10": "或龍見而鳥瀾",
                "11": "或妥帖而易施",
                "12": "或岨峿而不安",
                "13": "罊澄心以凝思",
                "14": "眇眾慮而爲言",
                "15": "籠天地於形內",
                "16": "挫萬物於筆端",
                "17": "始躑躅於燥吻",
                "18": "終流離於濡翰",
                "19": "理扶質以立幹",
                "20": "文垂條而結繁",
                "21": "信情貌之不差",
                "22": "故每變而在顏",
                "23": "思涉樂其必笑",
                "24": "方言哀而已歎",
                "25": "或操觚以率爾",
                "26": "或含毫而邈然"
            }
        },
        "5": {
            "11": {
                "1": "伊茲事之可樂",
                "2": "固聖賢之所欽",
                "3": "課虛無以責有",
                "4": "叩寂寞而求音",
                "5": "函綿邈於尺素",
                "6": "吐滂沛乎寸心",
                "7": "言恢之而彌廣",
                "8": "思按之而逾深",
                "9": "播芳蕤之馥馥",
                "10": "發青條之森森",
                "11": "粲風飛而猋豎",
                "12": "鬱雲起乎翰林"
            }
        },
        "6": {
            "13": {
                "1": "體有萬殊",
                "2": "物無一量",
                "3": "紛紜揮霍",
                "4": "形難爲狀",
                "5": "辭程才以效伎",
                "6": "意司契而爲匠",
                "7": "在有無而僶俛",
                "8": "當淺深而不讓",
                "9": "雖離方而遯圓",
                "10": "期窮形而盡相",
                "11": "故夫夸目者尙奢",
                "12": "愜心者貴當",
                "13": "言窮者無隘",
                "14": "論達者唯曠"
            }
        },
        "7": {
            "15": {
                "1": "詩緣情而綺靡",
                "2": "賦體物而瀏亮",
                "3": "碑披文以相質",
                "4": "誄纏綿而悽愴",
                "5": "銘博約而溫潤",
                "6": "箴頓挫而清壯",
                "7": "頌優遊以彬蔚",
                "8": "論精微而朗暢",
                "9": "奏平徹以閑雅",
                "10": "說煒曄而譎誑",
                "11": "雖區分之在茲",
                "12": "亦禁邪而制放",
                "13": "要辭達而理舉",
                "14": "故無取乎冗長"
            }
        },
        "8": {
            "17": {
                "1": "其爲物也多姿",
                "2": "其爲體也屢遷",
                "3": "其會意也尙巧",
                "4": "其遣言也貴姸",
                "5": "曁音聲之迭代",
                "6": "若五色之相宣",
                "7": "雖逝止之無常",
                "8": "固崎錡而難便",
                "9": "苟達變而識次",
                "10": "猶開流以納泉",
                "11": "如失機而後會",
                "12": "恆操末以續顚",
                "13": "謬玄黃之袟敍",
                "14": "故淟涊而不鮮"
            }
        },
        "9": {
            "19": {
                "1": "或仰逼於先條",
                "2": "或俯侵於後章",
                "3": "或辭害而理比",
                "4": "或言順而義妨",
                "5": "離之則雙美",
                "6": "合之則兩傷",
                "7": "考殿最於錙銖",
                "8": "定去留於毫芒",
                "9": "苟銓衡之所裁",
                "10": "固應繩其必當",
                "11": "或文繁理富",
                "12": "而意不指適",
                "13": "極無兩致",
                "14": "盡不可益",
                "15": "立片言而居要",
                "16": "乃一篇之警策",
                "17": "雖眾辭之有條",
                "18": "必待茲而效績",
                "19": "亮功多而累寡",
                "20": "故取足而不易"
            }
        },
        "10": {
            "21": {
                "1": "或藻思綺合",
                "2": "清麗千眠",
                "3": "炳若縟繡",
                "4": "悽若繁絃",
                "5": "必所擬之不殊",
                "6": "乃闇合乎曩篇",
                "7": "雖杼軸於予懷",
                "8": "怵他人之我先",
                "9": "苟傷廉而愆義",
                "10": "亦雖愛而必捐"
            }
        },
        "11": {
            "23": {
                "1": "或苕發穎豎",
                "2": "離眾絕致",
                "3": "形不可逐",
                "4": "響難爲係",
                "5": "塊孤立而特峙",
                "6": "非常音之所緯",
                "7": "心牢落而無偶",
                "8": "意徘徊而不能揥",
                "9": "石韞玉而山輝",
                "10": "水懷珠而川媚",
                "11": "彼榛楛之勿剪",
                "12": "亦蒙榮於集翠",
                "13": "綴下里於白雪",
                "14": "吾亦濟夫所偉"
            }
        },
        "12": {
            "25": {
                "1": "或託言於短韻",
                "2": "對窮迹而孤興",
                "3": "俯寂寞而無友",
                "4": "仰寥廓而莫承",
                "5": "譬偏絃之獨張",
                "6": "含清唱而靡應",
                "7": "或寄辭於瘁音",
                "8": "徒靡言而弗華",
                "9": "混姸蚩而成體",
                "10": "累良質而爲瑕",
                "11": "象下管之偏疾",
                "12": "故雖應而不和",
                "13": "或遺理以存異",
                "14": "徒尋虛以逐微",
                "15": "言寡情而鮮愛",
                "16": "辭浮漂而不歸",
                "17": "猶絃么而徽急",
                "18": "故雖和而不悲",
                "19": "或奔放以諧合",
                "20": "務嘈囋而妖冶",
                "21": "徒悅目而偶俗",
                "22": "固高聲而曲下",
                "23": "寤防露與桑間",
                "24": "又雖悲而不雅",
                "25": "或清虛以婉約",
                "26": "每除煩而去濫",
                "27": "闕大羹之遺味",
                "28": "同朱絃之清汜",
                "29": "雖一唱而三歎",
                "30": "固旣雅而不豔"
            }
        },
        "13": {
            "27": {
                "1": "若夫豐約之裁",
                "2": "俯仰之形",
                "3": "因宜適變",
                "4": "曲有微情",
                "5": "或言拙而喩巧",
                "6": "或理朴而辭輕",
                "7": "或襲故而彌新",
                "8": "或沿濁而更清",
                "9": "或覽之而必察",
                "10": "或硏之而後精",
                "11": "譬猶舞者赴節以投袂",
                "12": "歌者應絃而遣聲",
                "13": "是蓋輪扁所不得言",
                "14": "故亦非華說之所能精"
            }
        },
        "14": {
            "29": {
                "1": "普辭條與文律",
                "2": "良余膺之所服",
                "3": "練世情之常尤",
                "4": "識前修之所淑",
                "5": "雖濬發於巧心",
                "6": "或受蚩於拙目",
                "7": "彼瓊敷與玉藻",
                "8": "若中原之有菽",
                "9": "同橐籥之罔窮",
                "10": "與天地乎並育",
                "11": "雖紛藹於此世",
                "12": "嗟不盈於予掬",
                "13": "患挈缾之屢空",
                "14": "病昌言之難屬",
                "15": "故踸踔於短垣",
                "16": "放庸音以足曲",
                "17": "恆遺恨以終篇",
                "18": "豈懷盈而自足",
                "19": "懼蒙塵於叩缶",
                "20": "顧取笑乎鳴玉"
            }
        },
        "15": {
            "31": {
                "1": "若夫應感之會",
                "2": "通塞之紀",
                "3": "來不可遏",
                "4": "去不可止",
                "5": "藏若景滅",
                "6": "行猶響起",
                "7": "方天機之駿利",
                "8": "夫何紛而不理",
                "9": "思風發於胸臆",
                "10": "言泉流於脣齒",
                "11": "紛威蕤以馺遝",
                "12": "唯毫素之所擬",
                "13": "文徽徽以溢目",
                "14": "音泠泠而盈耳",
                "15": "及情底滯",
                "16": "志往神留",
                "17": "兀若枯木",
                "18": "豁若涸流",
                "19": "攬營魂以探賾",
                "20": "頓精爽於自求",
                "21": "理翳翳而愈伏",
                "22": "思軋軋其若抽",
                "23": "是以或竭情而多悔",
                "24": "或率意而寡尤",
                "25": "雖茲物之在我",
                "26": "非余力之所戮",
                "27": "故時撫空懷而自惋",
                "28": "吾未識夫開塞之所由"
            }
        },
        "16": {
            "33": {
                "1": "伊茲文之爲用",
                "2": "固眾理之所因",
                "3": "恢萬里而無閡",
                "4": "通億載而爲津",
                "5": "俯貽則於來葉",
                "6": "仰觀象乎古人",
                "7": "濟文武於將墜",
                "8": "宣風聲於不泯",
                "9": "塗無遠而不彌",
                "10": "理無微而弗綸",
                "11": "配霑潤於雲雨",
                "12": "象變化乎鬼神",
                "13": "被金石而德廣",
                "14": "流管絃而日新"
            }
        }
    }
}