{
    "33.05-02": {
        "篇名": "宋玉 九辯五首·其二",
        "1": {
            "3": {
                "1": "悲憂窮蹙兮獨處廓",
                "2": "有美一人兮心不繹",
                "3": "去鄕離家兮",
                "4": "來遠客",
                "5": "超逍遙兮今焉薄",
                "6": "專思君兮不可化",
                "7": "君不知兮可柰何",
                "8": "蓄怨兮積思",
                "9": "心煩憺兮忘食事",
                "10": "願一見兮道余意",
                "11": "君之心兮與余異",
                "12": "車駕兮朅而歸",
                "13": "不得見兮心悲",
                "14": "倚結軨兮太息",
                "15": "涕潺湲兮霑軾",
                "16": "慷慨絕兮不得",
                "17": "中瞀亂兮迷惑",
                "18": "私自憐兮何極",
                "19": "心怦怦兮諒直"
            }
        }
    }
}