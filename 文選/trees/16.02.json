{
    "16.02": {
        "篇名": "司馬長卿 長門賦[幷序]",
        "1": {
            "3": {
                "1": "孝武皇帝陳皇后時得幸",
                "2": "頗妬",
                "3": "別在長門宮",
                "4": "愁悶悲思",
                "5": "聞蜀郡成都司馬相如天下工爲文",
                "6": "奉黃金百斤爲相如",
                "7": "文君取酒",
                "8": "因於解悲愁之辭",
                "9": "而相如爲文以悟主上",
                "10": "陳皇后復得親幸",
                "11": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "夫何一佳人兮",
                "2": "步逍遙以自虞",
                "3": "魂踰佚而不反兮",
                "4": "形枯槁而獨居",
                "5": "言我朝往而暮來兮",
                "6": "飲食樂而忘人",
                "7": "心慊移而不省故兮",
                "8": "交得意而相親"
            }
        },
        "3": {
            "7": {
                "1": "伊予志之慢愚兮",
                "2": "懷貞慤之歡心",
                "3": "願賜問而自進兮",
                "4": "得尙君之玉音",
                "5": "奉虛言而望誠兮",
                "6": "期城南之離宮",
                "7": "修薄具而自設兮",
                "8": "君曾不肯乎幸臨",
                "9": "廓獨潛而專精兮",
                "10": "天飄飄而疾風",
                "11": "登蘭臺而遙望兮",
                "12": "神怳怳而外淫",
                "13": "浮雲鬱而四塞兮",
                "14": "天窈窈而晝陰",
                "15": "雷殷殷而響起兮",
                "16": "聲象君之車音",
                "17": "飄風迴而起閨兮",
                "18": "舉帷幄之襜襜",
                "19": "桂樹交而相紛兮",
                "20": "芳酷烈之誾誾",
                "21": "孔雀集而相存兮",
                "22": "玄猿嘯而長吟",
                "23": "翡翠脅翼而來萃兮",
                "24": "鸞鳳翔而北南"
            }
        },
        "4": {
            "9": {
                "1": "心憑噫而不舒兮",
                "2": "邪氣壯而攻中",
                "3": "下蘭臺而周覽兮",
                "4": "步從容於深宮",
                "5": "正殿塊以造天兮",
                "6": "鬱並起而穹崇",
                "7": "間徙倚於東廂兮",
                "8": "觀夫靡靡而無窮",
                "9": "擠玉戶以撼金鋪兮",
                "10": "聲噌吰而似鐘音"
            }
        },
        "5": {
            "11": {
                "1": "刻木蘭以爲榱兮",
                "2": "飾文杏以爲梁",
                "3": "羅丰茸之遊樹兮",
                "4": "離樓梧而相撐",
                "5": "施瑰木之欂櫨兮",
                "6": "委參差以槺梁",
                "7": "時仿佛以物類兮",
                "8": "象積石之將將",
                "9": "五色炫以相曜兮",
                "10": "爛耀耀而成光",
                "11": "緻錯石之瓴甓兮",
                "12": "象瑇瑁之文章",
                "13": "張羅綺之幔帷兮",
                "14": "垂楚組之連綱"
            }
        },
        "6": {
            "13": {
                "1": "撫柱楣以從容兮",
                "2": "覽曲臺之央央",
                "3": "白鶴噭以哀號兮",
                "4": "孤雌跱於枯楊",
                "5": "日黃昏而望絕兮",
                "6": "悵獨託於空堂",
                "7": "懸明月以自照兮",
                "8": "徂清夜於洞房",
                "9": "援雅琴以變調兮",
                "10": "奏愁思之不可長",
                "11": "案流徵以卻轉兮",
                "12": "聲幼玅而復揚",
                "13": "貫歷覽其中操兮",
                "14": "意慷慨而自卬",
                "15": "左右悲而垂淚兮",
                "16": "涕流離而從橫",
                "17": "舒息悒而增欷兮",
                "18": "蹝履起而彷徨",
                "19": "揄長袂以自翳兮",
                "20": "數昔日之諐殃",
                "21": "無面目之可顯兮",
                "22": "遂頹思而就牀",
                "23": "摶芬若以爲枕兮",
                "24": "席荃蘭而茝香"
            }
        },
        "7": {
            "15": {
                "1": "忽寢寐而夢想兮",
                "2": "魄若君之在旁",
                "3": "惕寤覺而無見兮",
                "4": "魂迋迋若有亡",
                "5": "眾雞鳴而愁予兮",
                "6": "起視月之精光",
                "7": "觀眾星之行列兮",
                "8": "畢昴出於東方",
                "9": "望中庭之藹藹兮",
                "10": "若季秋之降霜",
                "11": "夜曼曼其若歲兮",
                "12": "懷鬱鬱其不可再更",
                "13": "澹偃蹇而待曙兮",
                "14": "荒亭亭而復明",
                "15": "妾人竊自悲兮",
                "16": "究年歲而不敢忘"
            }
        }
    }
}