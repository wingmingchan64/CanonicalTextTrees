{
    "50.02": {
        "篇名": "范蔚宗 宦者傳論",
        "1": {
            "3": {
                "1": "易曰",
                "2": "天垂象",
                "3": "聖人則之",
                "4": "宦者四星",
                "5": "在皇位之側",
                "6": "故周禮置官",
                "7": "亦備其數",
                "8": "閽者守中門之禁",
                "9": "寺人掌女宮之戒",
                "10": "又云",
                "11": "王之正內者五人",
                "12": "月令",
                "13": "仲冬",
                "14": "閹尹審門閭",
                "15": "謹房室",
                "16": "詩之小雅",
                "17": "亦有巷伯剌讒之篇",
                "18": "然宦人之在王朝者",
                "19": "其來舊矣",
                "20": "將以其體非全氣",
                "21": "情志專良",
                "22": "通關中人",
                "23": "易以役養乎",
                "24": "然而後世因之",
                "25": "才任稍廣",
                "26": "其能者",
                "27": "則勃貂管蘇有功於楚晉",
                "28": "景監繆賢著庸於秦趙",
                "29": "及其敝也",
                "30": "豎刁亂齊",
                "31": "伊戾禍宋"
            }
        },
        "2": {
            "5": {
                "1": "漢興",
                "2": "仍襲秦制",
                "3": "置中常侍官",
                "4": "然亦引用士人",
                "5": "以參其選",
                "6": "皆銀璫左貂",
                "7": "給事殿省",
                "8": "及高后稱制",
                "9": "乃以張卿爲大謁者",
                "10": "出入臥內",
                "11": "受宣詔令",
                "12": "文帝時",
                "13": "有趙談北宮伯子",
                "14": "頗見親幸",
                "15": "至於孝武",
                "16": "亦愛李延年",
                "17": "帝數宴後庭",
                "18": "或潛遊離館",
                "19": "故請奏機事",
                "20": "多以宦人主之",
                "21": "元帝之世",
                "22": "史遊爲黃門令",
                "23": "勤心納忠",
                "24": "有所補益",
                "25": "其後弘恭石顯以佞險自進",
                "26": "卒有蕭周之禍",
                "27": "損穢帝德焉"
            }
        },
        "3": {
            "7": {
                "1": "中興之初",
                "2": "宦官悉用閹人",
                "3": "不復雜調他士",
                "4": "至永平中",
                "5": "始置員數",
                "6": "中常侍四人",
                "7": "小黃門十人",
                "8": "和帝卽祚幼弱",
                "9": "而竇憲兄弟專總權威",
                "10": "內外臣僚",
                "11": "莫由親接",
                "12": "所與居者",
                "13": "惟閹官而已",
                "14": "故鄭眾得專謀禁中",
                "15": "終除大憝遂享分土之封",
                "16": "超登宮卿之位",
                "17": "於是中官始盛焉"
            }
        },
        "4": {
            "9": {
                "1": "自明帝以後",
                "2": "迄乎延平",
                "3": "委用漸大",
                "4": "而其資稍增",
                "5": "中常侍至有十人",
                "6": "小黃門亦二十人",
                "7": "改以金璫右貂",
                "8": "兼領卿署之職",
                "9": "鄧后以女主臨政",
                "10": "而萬機殷遠",
                "11": "朝臣圖議",
                "12": "無由參斷帷幄",
                "13": "稱制下令",
                "14": "不出房闈之間",
                "15": "不得不委用刑人",
                "16": "寄之國命",
                "17": "手握王爵",
                "18": "口含天憲",
                "19": "非復掖庭永巷之職",
                "20": "閨牖房闈之任也",
                "21": "其後孫程定立順之功",
                "22": "曹騰參建桓之策",
                "23": "續以五侯合謀",
                "24": "梁冀受鉞",
                "25": "迹因公正",
                "26": "恩固主心",
                "27": "故中外服從",
                "28": "上下屛氣",
                "29": "或稱伊霍之勳",
                "30": "無謝於往載",
                "31": "或謂良平之畫",
                "32": "復興於當今",
                "33": "雖時有忠公",
                "34": "而競見排斥",
                "35": "舉動迴山海",
                "36": "呼吸變霜露",
                "37": "阿旨曲求",
                "38": "則寵光三族",
                "39": "直情忤意",
                "40": "則參夷五宗",
                "41": "漢之綱紀大亂矣"
            }
        },
        "5": {
            "11": {
                "1": "若夫高冠長劍",
                "2": "紆朱懷金者",
                "3": "布滿宮闥",
                "4": "苴茅分虎",
                "5": "南面臣民者",
                "6": "蓋以十數",
                "7": "府署第館",
                "8": "基列於都鄙",
                "9": "子弟支附",
                "10": "過半於州國",
                "11": "南金",
                "12": "和寶",
                "13": "冰紈",
                "14": "霧縠之積",
                "15": "盈牣珍藏",
                "16": "嬙媛",
                "17": "侍兒",
                "18": "歌童",
                "19": "舞女之玩",
                "20": "充備綺室",
                "21": "狗馬飾彫文",
                "22": "土木被緹繡",
                "23": "漢書",
                "24": "東方朔曰",
                "25": "土木衣綺繡",
                "26": "狗馬被繢罽",
                "27": "佞倖傳曰",
                "28": "董賢起大第闕下",
                "29": "土木之功",
                "30": "窮極伎巧",
                "31": "柱檻衣以綈錦",
                "32": "皆剝割萌黎",
                "33": "競恣奢欲",
                "34": "搆害明賢",
                "35": "專樹黨類",
                "36": "其有更相援引",
                "37": "希附權彊者",
                "38": "皆腐身薰子",
                "39": "以自衒達",
                "40": "同敝相濟",
                "41": "故其徒有繁",
                "42": "敗國蠹政之事",
                "43": "不可殫書",
                "44": "所以海內嗟毒",
                "45": "志士窮栖",
                "46": "寇劇緣間",
                "47": "搖亂區夏",
                "48": "雖忠良懷憤",
                "49": "時或奮發",
                "50": "而言出禍從",
                "51": "旋見孥戮",
                "52": "因復大考鉤黨",
                "53": "轉相誣染",
                "54": "凡稱善士",
                "55": "莫不罹被災毒",
                "56": "竇武何進",
                "57": "位崇戚近",
                "58": "乘九服之囂怨",
                "59": "協羣英之勢力",
                "60": "而以疑留不斷",
                "61": "至於殄敗",
                "62": "斯亦運之極乎",
                "63": "雖袁紹龔行",
                "64": "芟夷無餘",
                "65": "然以暴易亂",
                "66": "亦何云及",
                "67": "自曹騰說梁冀",
                "68": "竟立昏弱",
                "69": "魏武因之",
                "70": "遂遷龜鼎",
                "71": "所謂君以此始",
                "72": "必以此終",
                "73": "信乎其然矣"
            }
        }
    }
}