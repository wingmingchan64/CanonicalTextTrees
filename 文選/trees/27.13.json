{
    "27.13": {
        "篇名": "沈休文 新安江水至清淺深見底貽京邑遊好",
        "1": {
            "3": {
                "1": "眷言訪舟客",
                "2": "茲川信可珍",
                "3": "洞澈隨深淺",
                "4": "皎鏡無冬春",
                "5": "千仞寫喬樹",
                "6": "百丈見遊鱗",
                "7": "滄浪有時濁",
                "8": "清濟涸無津",
                "9": "豈若乘斯去",
                "10": "俯映石磷磷",
                "11": "紛吾隔囂滓",
                "12": "寧假濯衣巾",
                "13": "願以潺湲水",
                "14": "霑君纓上塵"
            }
        }
    }
}