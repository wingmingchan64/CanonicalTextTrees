{
    "28.07": {
        "篇名": "陶淵明 輓歌詩",
        "1": {
            "3": {
                "1": "荒草何茫茫",
                "2": "白楊亦蕭蕭",
                "3": "嚴霜九月中",
                "4": "送我出遠郊",
                "5": "四面無人居",
                "6": "高墳正嶕嶢",
                "7": "馬爲仰天鳴",
                "8": "風爲自蕭條",
                "9": "幽室一已閉",
                "10": "千年不復朝",
                "11": "千年不復朝",
                "12": "賢達無柰何",
                "13": "向來相送人",
                "14": "各已歸其家",
                "15": "親戚或餘悲",
                "16": "佗人亦已歌",
                "17": "死去何所道",
                "18": "託體同山阿"
            }
        }
    }
}