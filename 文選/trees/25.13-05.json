{
    "25.13-05": {
        "篇名": "謝惠連 西陵遇風獻康樂·其五",
        "1": {
            "3": {
                "1": "臨津不得濟",
                "2": "佇楫阻風波",
                "3": "蕭條洲渚際",
                "4": "氣色少諧和",
                "5": "西瞻興遊歎",
                "6": "東睇起悽歌",
                "7": "積憤成疢痗",
                "8": "無萱將如何"
            }
        }
    }
}