{
    "33.02": {
        "篇名": "屈平 九章·涉江",
        "1": {
            "3": {
                "1": "余幼好此奇服兮",
                "2": "年旣老而不衰",
                "3": "帶長鋏之陸離兮",
                "4": "冠切雲之崔巍",
                "5": "被明月兮佩寶璐",
                "6": "世溷濁而莫余知兮",
                "7": "吾方高馳而不顧",
                "8": "駕青虯兮驂白螭",
                "9": "吾與重華遊兮瑤之圃",
                "10": "登崑崙兮食玉英",
                "11": "與天地兮比壽",
                "12": "與日月兮齊光",
                "13": "哀南夷之莫吾知兮",
                "14": "旦余濟兮江湘",
                "15": "乘鄂渚而反顧兮",
                "16": "欸秋冬之緒風",
                "17": "步余馬兮山皋",
                "18": "邸余車兮方林",
                "19": "乘舲船余上沅兮",
                "20": "齊吳榜以擊汰",
                "21": "船容與而不進兮",
                "22": "淹回水而疑滯",
                "23": "朝發枉渚兮",
                "24": "夕宿辰陽",
                "25": "苟余心其端直兮",
                "26": "雖僻遠之何傷",
                "27": "入漵浦余儃佪兮",
                "28": "迷不知吾之所如",
                "29": "深林杳以冥冥兮",
                "30": "乃猿狖之所居",
                "31": "山峻高以蔽日兮",
                "32": "下幽晦以多雨",
                "33": "霰雪紛其無垠兮",
                "34": "雲霏霏而承宇",
                "35": "哀吾生之無樂兮",
                "36": "幽獨處乎山中",
                "37": "吾不能變心而從俗兮",
                "38": "固將愁苦而終窮",
                "39": "接輿髡首兮",
                "40": "桑扈臝行",
                "41": "忠不必用兮",
                "42": "賢不必以",
                "43": "伍子逢殃兮",
                "44": "比干葅醢",
                "45": "與前世而皆然兮",
                "46": "吾又何怨乎今之人",
                "47": "余將董道而不豫兮",
                "48": "固將重昏而終身"
            }
        }
    }
}