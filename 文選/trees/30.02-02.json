{
    "30.02-02": {
        "篇名": "陶淵明 雜詩二首·其二",
        "1": {
            "3": {
                "1": "秋菊有佳色",
                "2": "裛露掇其英",
                "3": "泛此忘憂物",
                "4": "遠我達世情",
                "5": "一觴雖獨進",
                "6": "杯盡壺自傾",
                "7": "日入羣動息",
                "8": "歸鳥趨林鳴",
                "9": "嘯傲東軒下",
                "10": "聊復得此生"
            }
        }
    }
}