{
    "31.09-02": {
        "篇名": "江文通 雜體詩三十首·李都尉[從軍]陵",
        "1": {
            "3": {
                "1": "尊酒送征人",
                "2": "踟躕在親宴",
                "3": "日暮浮雲滋",
                "4": "渥手淚如霰",
                "5": "悠悠清川水",
                "6": "嘉魴得所薦",
                "7": "而我在萬里",
                "8": "結髮不相見",
                "9": "袖中有短書",
                "10": "願寄雙飛燕"
            }
        }
    }
