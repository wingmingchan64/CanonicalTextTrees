{
    "14.03": {
        "篇名": "班孟堅 幽通賦",
        "1": {
            "3": {
                "1": "系高頊之玄冑兮",
                "2": "氏中葉之炳靈",
                "3": "颻颽風而蟬蛻兮",
                "4": "雄朔野以颺聲",
                "5": "皇十紀而鴻漸兮",
                "6": "有羽儀於上京",
                "7": "巨滔天而泯夏兮",
                "8": "考遘愍以行謠",
                "9": "終保己而貽則兮",
                "10": "里上仁之所廬",
                "11": "懿前烈之純淑兮",
                "12": "窮與達其必濟",
                "13": "咨孤蒙之眇眇兮",
                "14": "將圮絕而罔階",
                "15": "豈余身之足殉兮",
                "16": "違世業之可懷",
                "17": "靖潛處以永思兮",
                "18": "經日月而彌遠",
                "19": "匪黨人之敢拾兮",
                "20": "庶斯言之不玷"
            }
        },
        "2": {
            "5": {
                "1": "魂煢煢與神交兮",
                "2": "精誠發於宵寐",
                "3": "夢登山而迥眺兮",
                "4": "覿幽人之髣彿",
                "5": "攬葛藟而授余兮",
                "6": "眷峻谷曰勿墜",
                "7": "吻昕寤而仰思兮",
                "8": "心矇矇猶未察",
                "9": "黃神邈而靡質兮",
                "10": "儀遺讖以臆對",
                "11": "曰乘高而遌神兮",
                "12": "道遐通而不迷",
                "13": "葛綿綿於樛木兮",
                "14": "詠南風以爲綏",
                "15": "蓋惴惴之臨深兮",
                "16": "乃二雅之所祇",
                "17": "旣訊爾以吉象兮",
                "18": "又申之以炯戒",
                "19": "盍孟晉以迨羣兮",
                "20": "辰倏忽其不再"
            }
        },
        "3": {
            "7": {
                "1": "承靈訓其虛徐兮",
                "2": "竚盤桓而且俟",
                "3": "惟天地之無窮兮",
                "4": "鮮生民之晦在",
                "5": "紛屯邅與蹇連兮",
                "6": "何艱多而智寡",
                "7": "上聖迕而後拔兮",
                "8": "雖羣黎之所禦",
                "9": "昔衞叔之御昆兮",
                "10": "昆爲寇而喪予",
                "11": "管彎弧欲斃讎兮",
                "12": "讎作后而成己",
                "13": "變化故而相詭兮",
                "14": "孰云預其終始",
                "15": "雍造怨而先賞兮",
                "16": "丁繇惠而被戮",
                "17": "栗取弔於逌吉兮",
                "18": "王膺慶於所慼",
                "19": "叛迴穴其若茲兮",
                "20": "北叟頗識其倚伏",
                "21": "單治裏而外凋兮",
                "22": "張修襮而內逼",
                "23": "聿中龢爲庶幾兮",
                "24": "顏與冉又不得",
                "25": "溺招路以從己兮",
                "26": "謂孔氏猶未可",
                "27": "安慆慆而不萉兮",
                "28": "卒隕身乎世禍",
                "29": "遊聖門而靡救兮",
                "30": "雖覆醢其何補",
                "31": "固行行其必凶兮",
                "32": "免盜亂爲賴道",
                "33": "形氣發於根柢兮",
                "34": "柯葉彙而零茂",
                "35": "恐魍魎之責景兮",
                "36": "羌未得其云已"
            }
        },
        "4": {
            "9": {
                "1": "黎淳耀於高辛兮",
                "2": "羋彊大於南汜",
                "3": "嬴取威於伯儀兮",
                "4": "姜本支乎三趾",
                "5": "旣仁得其信然兮",
                "6": "仰天路而同軌",
                "7": "東鄰虐而殲仁兮",
                "8": "王合位乎三五",
                "9": "戎女烈而喪孝兮",
                "10": "伯徂歸於龍虎",
                "11": "發還師以成命兮",
                "12": "重醉行而自耦",
                "13": "震鱗漦於夏庭兮",
                "14": "匝三正而滅姬",
                "15": "巽羽化於宣宮兮",
                "16": "彌五辟而成災",
                "17": "道修長而世短兮",
                "18": "敻冥默而不周",
                "19": "胥仍物而鬼諏兮",
                "20": "乃窮宙而達幽",
                "21": "媯巢姜於孺筮兮",
                "22": "旦筭祀於契龜",
                "23": "宣曹興敗於下夢兮",
                "24": "魯衞名謚於銘謠",
                "25": "妣聆呱而劾石兮",
                "26": "許相理而鞫條",
                "27": "道混成而自然兮",
                "28": "術同原而分流",
                "29": "神先心以定命兮",
                "30": "命隨行以消息",
                "31": "斡流遷其不濟兮",
                "32": "故遭罹而嬴縮",
                "33": "三欒同於一體兮",
                "34": "雖移易而不忒",
                "35": "洞參差其紛錯兮",
                "36": "斯眾兆之所惑",
                "37": "周賈盪而貢憤兮",
                "38": "齊死生與禍福",
                "39": "抗爽言以矯情兮",
                "40": "信畏犧而忌鵩"
            }
        },
        "5": {
            "11": {
                "1": "所貴聖人至論兮",
                "2": "順天性而斷誼",
                "3": "物有欲而不居兮",
                "4": "亦有惡而不避",
                "5": "守孔約而不貳兮",
                "6": "乃輶德而無累",
                "7": "三仁殊於一致兮",
                "8": "夷惠舛而齊聲",
                "9": "木偃息以蕃魏兮",
                "10": "申重繭以存荊",
                "11": "紀焚躬以衞上兮",
                "12": "皓頤志而弗傾",
                "13": "侯草木之區別兮",
                "14": "苟能實其必榮",
                "15": "要沒世而不朽兮",
                "16": "乃先民之所程",
                "17": "觀天網之紘覆兮",
                "18": "實棐諶而相訓",
                "19": "謨先聖之大猷兮",
                "20": "亦鄰德而助信",
                "21": "虞韶美而儀鳳兮",
                "22": "孔忘味於千載",
                "23": "素文信而底麟兮",
                "24": "漢賓祚於異代",
                "25": "精通靈而感物兮",
                "26": "神動氣而入微",
                "27": "養流睇而猿號兮",
                "28": "李虎發而石開",
                "29": "非精誠其焉通兮",
                "30": "苟無實其孰信",
                "31": "操末技猶必然兮",
                "32": "矧耽躬於道眞",
                "33": "登孔昊而上下兮",
                "34": "緯羣龍之所經",
                "35": "朝貞觀而夕化兮",
                "36": "猶諠己而遺形",
                "37": "若胤彭而偕老兮",
                "38": "訴來哲而通情"
            }
        },
        "6": {
            "13": {
                "1": "亂曰",
                "2": "天造草昧",
                "3": "立性命兮",
                "4": "復心弘道",
                "5": "惟聖賢兮",
                "6": "渾元運物",
                "7": "流不處兮",
                "8": "保身遺名",
                "9": "民之表兮",
                "10": "舍生取誼",
                "11": "以道用兮",
                "12": "憂傷夭物",
                "13": "忝莫痛兮",
                "14": "皓爾太素",
                "15": "曷渝色兮",
                "16": "尙越其幾",
                "17": "淪神域兮"
            }
        }
    }
}