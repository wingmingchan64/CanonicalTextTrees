{
    "26.28": {
        "篇名": "謝靈運 初發石首城",
        "1": {
            "3": {
                "1": "白珪尙可磨",
                "2": "斯言易爲緇",
                "3": "雖抱中孚爻",
                "4": "猶勞貝錦詩",
                "5": "寸心若不亮",
                "6": "微命察如絲",
                "7": "日月垂光景",
                "8": "成貸遂兼茲",
                "9": "出宿薄京畿",
                "10": "晨裝摶魯颸",
                "11": "重經平生別",
                "12": "再與朋知辭",
                "13": "故山日已遠",
                "14": "風波豈還時",
                "15": "苕苕萬里帆",
                "16": "茫茫終何之",
                "17": "遊當羅浮行",
                "18": "息必廬霍期",
                "19": "越海凌三山",
                "20": "遊湘歷九嶷",
                "21": "欽聖若旦暮",
                "22": "懷賢亦悽其",
                "23": "皎皎明發心",
                "24": "不爲歲寒欺"
            }
        }
    }
}