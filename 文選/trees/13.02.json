{
    "13.02": {
        "篇名": "潘安仁 秋興賦[幷序]",
        "1": {
            "3": {
                "1": "晉十有四年",
                "2": "余春秋三十有二",
                "3": "始見二毛",
                "4": "以太尉掾兼虎賁中郎將",
                "5": "寓直於散騎之省",
                "6": "高閣連雲",
                "7": "陽景罕曜",
                "8": "珥蟬冕而襲紈綺之士",
                "9": "此焉遊處",
                "10": "僕野人也",
                "11": "偃息不過茅屋茂林之下",
                "12": "談話不過農夫田父之客",
                "13": "攝官承乏",
                "14": "猥廁朝列",
                "15": "夙興晏寢",
                "16": "匪遑底寧",
                "17": "譬猶池魚籠鳥",
                "18": "有江湖山藪之思",
                "19": "於是染翰操紙",
                "20": "慨然而賦",
                "21": "於時秋也",
                "22": "故以秋興命篇",
                "23": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "四時忽其代序兮",
                "2": "萬物紛以迴薄",
                "3": "覽花蒔之時育兮",
                "4": "察盛衰之所託",
                "5": "感冬索而春敷兮",
                "6": "嗟夏茂而秋落",
                "7": "雖末士之榮悴兮",
                "8": "伊人情之美惡",
                "9": "善乎宋玉之言曰",
                "10": "悲哉秋之爲氣也",
                "11": "蕭瑟兮草木搖落而變衰",
                "12": "憀慄兮若在遠行",
                "13": "登山臨水送將歸",
                "14": "夫送歸懷慕徒之戀兮",
                "15": "遠行有羈旅之憤",
                "16": "臨川感流以歎逝兮",
                "17": "登山懷遠而悼近",
                "18": "彼四慼之疚心兮",
                "19": "遭一塗而難忍",
                "20": "嗟秋日之可哀兮",
                "21": "諒無愁而不盡",
                "22": "野有歸燕",
                "23": "隰有翔隼",
                "24": "遊氛朝興",
                "25": "槁葉夕殞"
            }
        },
        "3": {
            "7": {
                "1": "於是迺屛輕箑",
                "2": "釋纖絺",
                "3": "藉莞蒻",
                "4": "御袷衣",
                "5": "庭樹槭以灑落兮",
                "6": "勁風戾而吹帷",
                "7": "蟬嘒嘒而寒吟兮",
                "8": "雁飄飄而南飛",
                "9": "天晃朗以彌高兮",
                "10": "日悠陽而浸微",
                "11": "何微陽之短晷",
                "12": "覺涼夜之方永",
                "13": "月朣朧以含光兮",
                "14": "露淒清以凝冷",
                "15": "熠燿粲於階闥兮",
                "16": "蟋蟀鳴乎軒屛",
                "17": "聽離鴻之晨吟兮",
                "18": "望流火之餘景",
                "19": "宵耿介而不寐兮",
                "20": "獨展轉於華省",
                "21": "悟時歲之遒盡兮",
                "22": "慨俛首而自省",
                "23": "斑鬢髟以承弁兮",
                "24": "素髮颯以垂領",
                "25": "仰羣儁之逸軌兮",
                "26": "攀雲漢以遊騁",
                "27": "登春臺之熙熙兮",
                "28": "珥金貂之炯炯",
                "29": "苟趣舍之殊塗兮",
                "30": "庸詎識其躁靜",
                "31": "聞至人之休風兮",
                "32": "齊天地於一指",
                "33": "彼知安而忘危兮",
                "34": "故出生而入死",
                "35": "行投趾於容迹兮",
                "36": "殆不踐而獲底",
                "37": "闕側足以及泉兮",
                "38": "雖猴猿而不履",
                "39": "龜祀骨於宗祧兮",
                "40": "思反身於綠水"
            }
        },
        "4": {
            "9": {
                "1": "且斂衽以歸來兮",
                "2": "忽投紱以高厲",
                "3": "耕東皋之沃壤兮",
                "4": "輸黍稷之餘稅",
                "5": "泉涌湍於石間兮",
                "6": "菊揚芳於崖澨",
                "7": "澡秋水之涓涓兮",
                "8": "玩遊鯈之潎潎",
                "9": "逍遙乎山川之阿",
                "10": "放曠乎人間之世",
                "11": "優哉遊哉",
                "12": "聊以卒歲"
            }
        }
    }
}