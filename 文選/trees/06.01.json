                "38": "嬰堞帶涘",
                "39": "四門䡾䡾",
                "40": "隆廈重起",
                "41": "憑太清以混成",
                "42": "越埃壒而資始",
                "43": "藐藐標危",
                "44": "亭亭峻趾",
                "45": "臨焦原而不怳",
                "46": "誰勁捷而無𤟧",
                "47": "與岡岑而永固",
                "48": "非有期乎世祀",
                "49": "陽靈停曜於其表",
                "50": "陰祇濛霧於其裏",
                "51": "菀以玄武",
                "52": "陪以幽林",
                "53": "繚垣開囿",
