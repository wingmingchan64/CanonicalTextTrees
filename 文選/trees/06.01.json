                "34": "永巷壼術",
                "35": "楸梓木蘭",
                "36": "次舍甲乙",
                "37": "西南其戶",
                "38": "成之匪日",
                "39": "丹青煥炳",
                "40": "特有溫室",
                "41": "儀形宇宙",
                "42": "歷像賢聖",
                "43": "圖以百瑞",
                "44": "綷以藻詠",
                "45": "芒芒終古",
                "46": "此焉則鏡",
                "47": "有虞作繪",
                "48": "茲亦等競"
            }
        },
        "7": {
            "15": {
                "1": "右則疏圃曲池",
                "2": "下畹高堂",
                "3": "蘭渚莓莓",
                "4": "石瀨湯湯",
                "5": "弱葼係實",
                "6": "輕葉振芳",
                "7": "奔龜躍魚",
                "8": "有𥉻呂梁",
                "9": "馳道周屈於果下",
                "10": "延閣胤宇以經營",
                "11": "飛陛方輦而徑西",
                "12": "三臺列峙以崢嶸",
                "13": "亢陽臺於陰基",
                "14": "擬華山之削成",
