                "48": "華蓮重葩而倒披",
                "49": "齊龍首而涌霤",
                "50": "時梗槪於滮池",
                "51": "旅楹閑列",
                "52": "暉鑒抰振",
                "53": "榱題黮𪒡",
                "54": "階𨺠嶙峋",
                "55": "長庭砥平",
                "56": "鐘簴夾陳",
                "57": "風無纖埃",
                "58": "雨無微津",
                "59": "巖巖北闕",
                "60": "南端逌遵",
                "61": "竦峭雙碣",
                "62": "方駕比輪",
