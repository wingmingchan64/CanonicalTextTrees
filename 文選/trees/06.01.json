{
    "06.01": {
        "篇名": "左太沖 魏都賦",
        "1": {
            "3": {
                "1": "魏國先生有睟其容",
                "2": "乃盱衡而誥曰",
                "3": "异乎交益之士",
                "4": "蓋音有楚夏者",
                "5": "土風之乖也",
                "6": "情有險易者",
                "7": "習俗之殊也",
                "8": "雖則生常",
                "9": "固非自得之謂也",
                "10": "昔市南宜僚弄丸",
                "11": "而兩家之難解",
                "12": "聊爲吾子復翫德音",
                "13": "以釋二客競於辯囿者也"
            }
        },
        "2": {
            "5": {
                "1": "夫泰極剖判",
                "2": "造化權輿",
                "3": "體兼晝夜",
                "4": "理包清濁",
                "5": "流而爲江海",
                "6": "結而爲山嶽",
                "7": "列宿分其野",
                "8": "荒裔帶其隅",
                "9": "巖岡潭淵",
                "10": "限蠻隔夷",
                "11": "峻危之竅也",
                "12": "蠻陬夷落",
                "13": "譯導而通",
                "14": "鳥獸之氓也",
                "15": "正位居體者",
                "16": "以中夏爲喉",
                "17": "不以邊垂爲襟也",
                "18": "長世字甿者",
                "19": "以道德爲藩",
                "20": "不以襲險爲屛也",
                "21": "而子大夫之賢者",
                "22": "尙弗曾庶翼等威",
                "23": "附麗皇極",
                "24": "思稟正朔",
                "25": "樂率貢職",
                "26": "而徒務於詭隨匪人",
                "27": "宴安於絕域",
                "28": "榮其文身",
                "29": "驕其險棘",
                "30": "繆默語之常倫",
                "31": "牽膠言而踰侈",
                "32": "飾華離以矜然",
                "33": "假倔彊而攘臂",
                "34": "非醇粹之方壯",
                "35": "謀踳駮於王義",
                "36": "孰愈尋靡䓑於中逵",
                "37": "造沐猴於棘刺",
                "38": "劍閣雖嶚",
                "39": "憑之者蹶",
                "40": "非所以深根固蔕也",
                "41": "洞庭雖濬",
                "42": "負之者北",
                "43": "非所以愛人治國也",
                "44": "彼桑楡之末光",
                "45": "踰長庚之初輝",
                "46": "況河冀之爽塏",
                "47": "與江介之湫湄",
                "48": "故將語子以神州之略",
                "49": "赤縣之畿",
                "50": "魏都之卓犖",
                "51": "六合之樞機"
            }
        },
        "3": {
            "7": {
                "1": "於時運距陽九",
                "2": "漢網絕維",
                "3": "姦回內贔",
                "4": "兵纏紫微",
                "5": "翼翼京室",
                "6": "眈眈帝宇",
                "7": "巢焚原燎",
                "8": "變爲煨燼",
                "9": "故荊棘旅庭也",
                "10": "殷殷寰內",
                "11": "繩繩八區",
                "12": "鋒鏑縱橫",
                "13": "化爲戰場",
                "14": "故麋鹿寓城也",
                "15": "伊洛榛曠",
                "16": "崤函荒蕪",
                "17": "臨菑牢落",
                "18": "鄢郢丘墟",
                "19": "而是有魏開國之日",
                "20": "締構之初",
                "21": "萬邑譬焉",
                "22": "亦獨犨麋之與子都",
                "23": "培塿之與方壺也"
            }
        },
        "4": {
            "9": {
                "1": "且魏地者",
                "2": "畢昴之所應",
                "3": "虞夏之餘人",
                "4": "先王之桑梓",
                "5": "列聖之遺塵",
                "6": "考之四隈",
                "7": "則八埏之中",
                "8": "測之寒暑",
                "9": "則霜露所均",
                "10": "卜偃前識而賞其隆",
                "11": "吳札聽歌而美其風",
                "12": "雖則衰世",
                "13": "而盛德形於管絃",
                "14": "雖踰千祀",
                "15": "而懷舊蘊於遐年",
                "16": "爾其疆域",
                "17": "則旁極齊秦",
                "18": "結湊冀道",
                "19": "開胸殷衞",
                "20": "跨躡燕趙",
                "21": "山林幽岟",
                "22": "川澤迴繚",
                "23": "恆碣碪𥔲於青霄",
                "24": "河汾浩涆而皓溔",
                "25": "南瞻淇澳",
                "26": "則綠竹純茂",
                "27": "北臨漳滏",
                "28": "則冬夏異沼",
                "29": "神鉦迢遞於高巒",
                "30": "靈響時驚於四表",
                "31": "溫泉毖涌而自浪",
                "32": "華清蕩邪而難老",
                "33": "墨井鹽池",
                "34": "玄滋素液",
                "35": "厥田惟中",
                "36": "厥壤惟白",
                "37": "原隰畇畇",
                "38": "墳衍斥斥",
                "39": "或嵬罍而複陸",
                "40": "或黋朗而拓落",
                "41": "乾坤交泰而絪縕",
                "42": "嘉祥徽顯而豫作",
                "43": "是以兆朕振古",
                "44": "萌柢疇昔",
                "45": "藏氣讖緯",
                "46": "閟象竹帛",
                "47": "迥時世而淵默",
                "48": "應期運而光赫",
                "49": "曁聖武之龍飛",
                "50": "肇受命而光宅"
            }
        },
        "5": {
            "11": {
                "1": "爰初自臻",
                "2": "言占其良",
                "3": "謀龜謀筮",
                "4": "亦旣允臧",
                "5": "修其郛郭",
                "6": "繕其城隍",
                "7": "經始之制",
                "8": "牢籠百王",
                "9": "畫雍豫之居",
                "10": "寫八都之宇",
                "11": "鑒茅茨於陶唐",
                "12": "察卑宮於夏禹",
                "13": "古公草創",
                "14": "而高門有閌",
                "15": "宣王中興",
                "16": "而築室百堵",
                "17": "兼聖哲之軌",
                "18": "幷文質之狀",
                "19": "商豐約而折中",
                "20": "准當年而爲量",
                "21": "思重爻",
                "22": "摹大壯",
                "23": "覽荀卿",
                "24": "采蕭相",
                "25": "僝拱木於林衡",
                "26": "授全模於梓匠",
                "27": "遐邇悅豫而子來",
                "28": "工徒擬議而騁巧",
                "29": "闡鉤繩之筌緒",
                "30": "承二分之正要",
                "31": "揆日晷",
                "32": "考星耀",
                "33": "建社稷",
                "34": "作清廟",
                "35": "築曾宮以迴匝",
                "36": "比岡隒而無陂",
                "37": "造文昌之廣殿",
                "38": "極棟宇之弘規",
                "39": "𡽵若崇山崫起以崔嵬",
                "40": "髧若玄雲舒蜺以高垂",
                "41": "瑰材巨世",
                "42": "𡍪㙷參差",
                "43": "枌橑複結",
                "44": "欒櫨疊施",
                "45": "丹梁虹申以並亙",
                "46": "朱桷森布而支離",
