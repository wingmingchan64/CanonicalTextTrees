        "6": {
            "13": {
                "1": "左則中朝有赩",
                "2": "聽政作寢",
                "3": "匪樸匪斲",
                "4": "去泰去甚",
                "5": "木無彫鎪",
                "6": "土無綈錦",
                "7": "玄化所甄",
                "8": "國風所稟",
