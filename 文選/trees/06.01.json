                "32": "反旆悠悠",
                "33": "凱歸同飲",
                "34": "疏爵普疇",
                "35": "朝無刓印",
                "36": "國無費留"
            }
        },
        "10": {
            "21": {
                "1": "喪亂旣弭而能宴",
                "2": "武人歸獸而去戰",
                "3": "蕭斧戢柯以柙刃",
                "4": "虹旍攝麾以就卷",
                "5": "斟洪範",
                "6": "酌典憲",
                "7": "觀所恆",
                "8": "通其變",
                "9": "上垂拱而司契",
                "10": "下緣督而自勸",
                "11": "道來斯貴",
                "12": "利往則賤",
                "13": "囹圄寂寥",
                "14": "京庾流衍",
                "15": "於時東鯷卽序",
                "16": "西傾順軌",
                "17": "荊南懷憓",
                "18": "朔北思韙",
                "19": "綿綿迥塗",
                "20": "驟山驟水",
                "21": "襁負賮贄",
                "22": "重譯貢篚",
                "23": "髽首之豪",
                "24": "鐻耳之傑",
                "25": "服其荒服",
                "26": "斂衽魏闕",
                "27": "置酒文昌",
                "28": "高張宿設",
                "29": "其夜未遽",
                "30": "庭燎晰晰",
                "31": "有客祁祁",
                "32": "載華載裔",
                "33": "岌岌冠縰",
                "34": "纍纍辮髮",
                "35": "清酤如濟",
                "36": "濁醪如河",
                "37": "凍醴流澌",
                "38": "溫酎躍波",
                "39": "豐肴衍衍",
                "40": "行庖皤皤",
                "41": "愔愔醧讌",
                "42": "酣湑無譁延廣樂",
                "43": "奏九成",
                "44": "冠韶夏",
                "45": "冒六莖",
                "46": "傮響起",
                "47": "疑震霆",
                "48": "天宇駭",
                "49": "地廬驚",
                "50": "億若大帝之所興作",
                "51": "二嬴之所曾聆",
                "52": "金石絲竹之恆韻",
                "53": "匏土革木之常調",
                "54": "干戚羽旄之飾好",
                "55": "清謳微吟之要妙",
                "56": "世業之所日用",
                "57": "耳目之所聞覺",
                "58": "雜糅紛錯",
                "59": "兼該泛博",
                "60": "鞮鞻所掌之音",
                "61": "韎昧任禁之曲",
                "62": "以娛四夷之君",
                "63": "以睦八荒之俗"
            }
        },
        "11": {
            "23": {
                "1": "旣苗旣狩",
                "2": "爰遊爰豫",
                "3": "藉田以禮動",
                "4": "大閱以義舉",
                "5": "備法駕",
                "6": "理秋御",
                "7": "顯文武之壯觀",
                "8": "邁梁騶之所著",
                "9": "林不槎枿",
                "10": "澤不伐夭",
                "11": "斧斨以時",
                "12": "罾𦉾以道",
                "13": "德連木理",
                "14": "仁挺芝草",
                "15": "皓獸爲之育藪",
                "16": "丹魚爲之生沼",
                "17": "矞雲翔龍",
                "18": "澤馬亍阜",
                "19": "山圖其石",
                "20": "川形其寶",
                "21": "莫黑匪烏",
                "22": "三趾而來儀",
                "23": "莫赤匪狐",
                "24": "九尾而自擾",
                "25": "嘉穎離合以䔿䔿",
                "26": "醴泉涌流而浩浩",
                "27": "顯禎祥以曲成",
                "28": "固觸物而兼造",
                "29": "蓋亦明靈之所酬酢",
                "30": "休徵之所偉兆"
            }
        },
        "12": {
            "25": {
                "1": "旼旼率土",
                "2": "遷善罔匱",
                "3": "沐浴福應",
                "4": "宅心醰粹",
                "5": "餘糧栖畝而弗收",
                "6": "頌聲載路而洋溢",
                "7": "河洛開奧",
                "8": "符命用出",
                "9": "翩翩黃鳥",
                "10": "銜書來訊",
                "11": "人謀所尊",
                "12": "鬼謀所秩",
                "13": "劉宗委馭",
                "14": "巽其神器",
                "15": "闚玉策於金縢",
                "16": "案圖籙於石室",
                "17": "考曆數之所在",
                "18": "察五德之所蒞",
                "19": "量寸旬",
                "20": "涓吉日",
                "21": "陟中壇",
                "22": "卽帝位",
                "23": "改正朔",
                "24": "易服色",
                "25": "繼絕世",
                "26": "修廢職",
                "27": "徽幟以變",
                "28": "器械以革",
                "29": "顯仁翌明",
                "30": "藏用玄默",
                "31": "菲言厚行",
                "32": "陶化染學",
                "33": "讎校篆籀",
                "34": "篇章畢覿",
                "35": "優賢著於揚歷",
                "36": "匪孼形於親戚",
                "37": "本枝別幹",
                "38": "蕃屛皇家",
                "39": "勇若任城",
                "40": "才若東阿",
                "41": "抗旍則威噞秋霜",
                "42": "摛翰則華縱春葩",
                "43": "英喆雄豪",
                "44": "佐命帝室",
                "45": "相兼二八",
                "46": "將猛四七",
                "47": "赫赫震震",
                "48": "開務有謐",
                "49": "故令斯民睹泰階之平",
                "50": "可比屋而爲一"
            }
        },
        "13": {
            "27": {
                "1": "筭祀有紀",
                "2": "天祿有終",
                "3": "傳業禪祚",
                "4": "高謝萬邦",
                "5": "皇恩綽矣",
                "6": "帝德沖矣",
                "7": "讓其天下",
                "8": "臣至公矣",
                "9": "榮操行之獨得",
                "10": "超百王之庸庸",
                "11": "追亙卷領與結繩",
                "12": "睠留重華而比蹤",
                "13": "尊盧赫胥",
                "14": "羲農有熊",
                "15": "雖自以爲道",
                "16": "洪化以爲隆",
                "17": "世篤玄同",
                "18": "奚遽不能與之踵武而齊其風",
                "19": "是故料其建國",
                "20": "析其法度",
                "21": "諮其考室",
                "22": "議其舉厝",
                "23": "復之而無斁",
                "24": "申之而有裕",
                "25": "非疏糲之士所能精",
                "26": "非鄙俚之言所能具"
            }
        },
        "14": {
            "29": {
                "1": "至於山川之倬詭",
                "2": "物產之魁殊",
                "3": "或名奇而見稱",
                "4": "或實異而可書",
                "5": "生生之所常厚",
                "6": "洵美之所不渝",
                "7": "其中則有鴛鴦交谷",
                "8": "虎澗龍山",
                "9": "掘鯉之淀",
                "10": "蓋節之淵",
                "11": "𦐠𦐠精衞",
                "12": "銜木償怨",
                "13": "常山平干",
                "14": "鉅鹿河間",
                "15": "列眞非一",
                "16": "往往出焉",
                "17": "昌容練色",
                "18": "犢配眉連",
                "19": "玄俗無影",
                "20": "木羽偶仙",
                "21": "琴高沈水而不濡",
                "22": "時乘赤鯉而周旋",
                "23": "師門使火以驗術",
                "24": "故將去而林燔",
                "25": "易陽壯容",
                "26": "衞之稚質",
                "27": "邯鄲躧步",
                "28": "趙之鳴瑟",
                "29": "眞定之梨",
                "30": "故安之栗",
                "31": "醇酎中山",
                "32": "流湎千日",
                "33": "淇洹之筍",
                "34": "信都之棗",
                "35": "雍丘之粱",
                "36": "清流之稻",
                "37": "錦繡襄邑",
                "38": "羅綺朝歌",
                "39": "綿纊房子",
                "40": "縑總清河",
                "41": "若此之屬",
                "42": "繁富夥夠",
                "43": "非可單究",
                "44": "是以抑而未罄也",
                "45": "蓋比物以錯辭",
                "46": "述清都之閑麗",
                "47": "雖選言以簡章",
                "48": "徒九復而遺旨",
                "49": "覽大易與春秋",
                "50": "判殊隱而一致",
                "51": "末上林之隤牆",
                "52": "本前修以作系"
            }
        },
        "15": {
            "31": {
                "1": "其軍容弗犯",
                "2": "信其果毅",
                "3": "糾華綏戎",
                "4": "以戴公室",
                "5": "元勳配管敬之績",
                "6": "歌鐘析邦君之肆",
                "7": "則魏絳之賢有令聞也",
                "8": "閑居隘巷",
                "9": "室邇心遐",
                "10": "富仁寵義",
                "11": "職競弗羅",
                "12": "千乘爲之軾廬",
                "13": "諸侯爲之止戈",
                "14": "則干木之德自解紛也",
                "15": "貴非吾尊",
                "16": "重士踰山",
                "17": "親御監門",
                "18": "嗛嗛同軒",
                "19": "搦秦起趙",
                "20": "威振八蕃",
                "21": "則信陵之名若蘭芬也",
                "22": "英辯榮枯",
                "23": "能濟其厄",
                "24": "位加將相",
                "25": "窒隙之策",
                "26": "四海齊鋒",
                "27": "一口所敵",
                "28": "張儀",
                "29": "張祿亦足云也"
            }
        },
        "16": {
            "33": {
                "1": "搉惟庸蜀與鴝鵲同窠",
                "2": "句吳與䵷黽同穴",
                "3": "一自以爲禽鳥",
                "4": "一自以爲魚鱉",
                "5": "山阜猥積而踦𨄅",
                "6": "泉流逬集而咉咽",
                "7": "隰壤瀸漏而沮洳",
                "8": "林藪石留而蕪穢",
                "9": "窮岫泄雲",
                "10": "日月恆翳",
                "11": "宅土熇暑",
                "12": "封疆障癘",
                "13": "蔡莽螫剌",
                "14": "昆蟲毒噬",
                "15": "漢罪流禦",
                "16": "秦餘徙㡂",
                "17": "宵貌蕞陋",
                "18": "稟質遳脆",
                "19": "巷無杼首",
                "20": "里罕耆耋",
                "21": "或魋髻而左言",
                "22": "或鏤膚而鑽髮",
                "23": "或明發而嬥歌",
                "24": "或浮泳而卒歲",
                "25": "風俗以韰果爲嫿",
                "26": "人物以戕害爲藝",
                "27": "威儀所不攝",
                "28": "憲章所不綴",
                "29": "由重山之束阨",
                "30": "因長川之裾勢",
                "31": "距遠關以闚𨵦",
                "32": "時高樔而陛制",
                "33": "薄戍綿冪",
                "34": "無異蛛蝥之網",
                "35": "弱卒瑣甲",
                "36": "無異螳蜋之衞"
            }
        },
        "17": {
            "35": {
                "1": "與先世而常然",
                "2": "雖信險而勦絕",
                "3": "揆旣往之前迹",
                "4": "卽將來之後轍",
                "5": "成都迄已傾覆",
                "6": "建鄴則亦顚沛",
                "7": "顧非累卵於疊棊",
                "8": "焉至觀形而懷怛",
                "9": "權假日以餘榮",
                "10": "比朝華而菴藹",
                "11": "覽麥秀與黍離",
                "12": "可作謠於吳會"
            }
        },
        "18": {
            "37": {
                "1": "先生之言未卒",
                "2": "吳蜀二客",
                "3": "矍焉相顧",
                "4": "𥉉焉失所",
                "5": "有靦瞢容",
                "6": "神惢形茹",
                "7": "㢮氣離坐",
                "8": "㥏墨而謝",
                "9": "曰",
                "10": "僕黨清狂",
                "11": "怵迫閩濮",
                "12": "習蓼蟲之忘辛",
                "13": "翫進退之惟谷",
                "14": "非常寐而無覺",
                "15": "不睹皇輿之軌躅",
                "16": "過以𠆩剽之單慧",
                "17": "歷執古之醇聽",
                "18": "兼重悂以䝯繆",
                "19": "偭辰光而罔定",
                "20": "先生玄識",
                "21": "深頌靡測",
                "22": "得聞上德之至盛",
                "23": "匪同憂於有聖",
                "24": "抑若春霆發響",
                "25": "而驚蟄飛競",
                "26": "潛龍浮景",
                "27": "而幽泉高鏡",
                "28": "雖星有風雨之好",
                "29": "人有異同之性",
                "30": "庶覿蔀家與剝廬",
                "31": "非蘇世而居正",
                "32": "且夫寒谷豐黍",
                "33": "吹律暖之也",
                "34": "昏情爽曙",
                "35": "箴規顯之也",
                "36": "雖明珠兼寸",
                "37": "尺璧有盈",
                "38": "曜車二六",
                "39": "三傾五城",
                "40": "未若申錫典章之爲遠也"
            }
        },
        "19": {
            "39": {
                "1": "亮曰",
                "2": "日不雙麗",
                "3": "世不兩帝",
                "4": "天經地緯",
                "5": "理有大歸",
                "6": "安得齊給守其小辯也哉"
            }
        }
    }
}