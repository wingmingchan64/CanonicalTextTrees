                "9": "爰及冠帶",
                "10": "馮寵自放",
                "11": "抗心希古",
                "12": "任其所尙",
                "13": "託好老莊",
                "14": "賤物貴身",
                "15": "志在守樸",
                "16": "養素全眞",
                "17": "曰余不敏",
                "18": "好善闇人",
                "19": "子玉之敗",
