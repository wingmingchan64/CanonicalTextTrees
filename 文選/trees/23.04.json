{
    "23.04": {
        "篇名": "嵇叔夜 幽憤詩",
        "1": {
            "3": {
                "1": "嗟余薄祜",
                "2": "少遭不造",
                "3": "哀煢靡識",
                "4": "越在繈褓",
                "5": "母兄鞠育",
                "6": "有慈無威",
                "7": "恃愛肆姐",
