{
    "23.03": {
        "篇名": "歐陽堅石 臨終詩",
        "1": {
            "3": {
                "1": "伯陽適西戎",
                "2": "子欲居九蠻",
                "3": "苟懷四方志",
                "4": "所在可遊盤",
                "5": "況乃遭屯蹇",
                "6": "顚沛遇災患古人達機兆",
                "7": "策馬遊近關",
                "8": "咨余沖且暗",
                "9": "抱責守微官",
                "10": "潛圖密已構",
                "11": "成此禍福端",
                "12": "恢恢六合間",
                "13": "四海一何寬",
                "14": "天網布紘綱",
                "15": "投足不獲安",
                "16": "松柏隆冬悴",
                "17": "然後知歲寒",
                "18": "不涉太行險",
                "19": "誰知斯路難",
                "20": "眞僞因事顯",
                "21": "人情難豫觀",
                "22": "窮達有定分",
                "23": "慷慨復何歎上負慈母恩",
                "24": "痛酷摧心肝",
                "25": "下顧所憐女",
                "26": "惻惻中心酸",
                "27": "二子棄若遺",
                "28": "念皆遘凶殘",
                "29": "不惜一身死",
                "30": "惟此如循環",
                "31": "執紙五情塞",
                "32": "揮筆涕汍瀾"
            }
        }
    }
}