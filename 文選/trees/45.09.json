{
    "45.09": {
        "篇名": "杜預 春秋左氏傳序",
        "1": {
            "3": {
                "1": "春秋者",
                "2": "魯史記之名也",
                "3": "記事者",
                "4": "以事繫日",
                "5": "以日繫月",
                "6": "以月繫時",
                "7": "以時繫年",
                "8": "所以紀遠近",
                "9": "別同異也",
                "10": "故史之所記",
                "11": "必表年以首事",
                "12": "年有四時",
                "13": "故錯舉以爲所記之名也",
                "14": "周禮有史官",
                "15": "掌邦國四方之事",
                "16": "達四方之志",
                "17": "諸侯亦各有國史",
                "18": "大事書之於策",
                "19": "小事簡牘而已",
                "20": "孟子曰",
                "21": "楚謂之檮杌",
                "22": "晉謂之乘",
                "23": "而魯謂之春秋",
                "24": "其實一也",
                "25": "韓宣子適魯",
                "26": "見易象與魯春秋",
                "27": "曰",
                "28": "周禮盡在魯矣",
                "29": "吾乃今知周公之德",
                "30": "與周之所以王也",
                "31": "韓子所見",
                "32": "蓋周之舊典禮經也"
            }
        },
        "2": {
            "5": {
                "1": "周德旣衰",
                "2": "官失其守",
                "3": "上之人不能使春秋昭明",
                "4": "赴告策書",
                "5": "諸所記注",
                "6": "多違舊章",
                "7": "仲尼因魯史策書成文",
                "8": "考其眞僞",
                "9": "而志其典禮",
                "10": "上以遵周公之遺制",
                "11": "下以明將來之法",
                "12": "其教之所存",
                "13": "文之所害",
                "14": "則刊而正之",
                "15": "以示勸誡",
                "16": "其餘皆卽用舊史",
                "17": "史有文質",
                "18": "辭有詳略",
                "19": "不必改也",
                "20": "故傳曰",
                "21": "其善志",
                "22": "又曰",
                "23": "非聖人孰能修之",
                "24": "蓋周公之志",
                "25": "仲尼從而明之",
                "26": "左丘明受經於仲尼",
                "27": "以爲經者不刊之書也",
                "28": "故傳或先經以始事",
                "29": "或後經以終義",
                "30": "或依經以辨理",
                "31": "或錯經以合異",
                "32": "隨義而發其例之所重",
                "33": "舊史遺文",
                "34": "略不盡舉",
                "35": "非聖人所修之要故也",
                "36": "身爲國史",
                "37": "躬覽載籍",
                "38": "必廣記而備言之",
                "39": "其文緩",
                "40": "其旨遠",
                "41": "將令學者原始要終",
                "42": "尋其枝葉",
                "43": "究其所窮",
                "44": "優而柔之",
                "45": "使自求之",
                "46": "饜而飫之",
                "47": "使自趨之",
                "48": "若江海之浸",
                "49": "膏澤之潤",
                "50": "渙然冰釋",
                "51": "怡然理順",
                "52": "然後爲得也",
                "53": "其發凡以言例",
                "54": "皆經國之常制",
                "55": "周公之垂法",
                "56": "史書之舊章",
                "57": "仲尼從而修之",
                "58": "以成一經之通體",
                "59": "其微顯闡幽",
                "60": "裁成義類者",
                "61": "皆據舊例而發義",
                "62": "指行事以正襃貶",
                "63": "諸稱書",
                "64": "不書",
                "65": "先書",
                "66": "故書",
                "67": "不言",
                "68": "不稱",
                "69": "書曰之類",
                "70": "皆所以起新舊",
                "71": "發大義",
                "72": "謂之變例",
                "73": "然亦有史所不書",
                "74": "卽以爲義者",
                "75": "此蓋春秋新意",
                "76": "故傳不言凡",
                "77": "曲而暢之也",
                "78": "其經無義例",
                "79": "因行事而言",
                "80": "則傳直言其歸趣而已",
                "81": "非例也",
                "82": "故發傳之體有三",
                "83": "而爲例之情有五",
                "84": "一曰微而顯",
                "85": "文見於此而義起在彼",
                "86": "稱族尊君命",
                "87": "舍族尊夫人",
                "88": "梁亡",
                "89": "城緣陵之類是也",
                "90": "二曰志而晦",
                "91": "約言示制",
                "92": "推以知例",
                "93": "參會不地",
                "94": "與謀曰及之類是也",
                "95": "三曰婉而成章",
                "96": "曲從義訓",
                "97": "以示大順",
                "98": "諸所諱避",
                "99": "璧假許田之類是也",
                "100": "四曰盡而不汙",
                "101": "直書其事",
                "102": "具文見意",
                "103": "丹楹",
                "104": "刻桷",
                "105": "天王求車",
                "106": "齊侯獻捷之類是也",
                "107": "五曰懲惡而勸善",
                "108": "求名而亡",
                "109": "欲蓋而章",
                "110": "書齊豹盜",
                "111": "三叛人名之類是也",
                "112": "推此五體以尋經",
                "113": "傳",
                "114": "觸類而長之",
                "115": "附於二百四十二年行事",
                "116": "王道之正",
                "117": "人倫之紀備矣"
            }
        },
        "3": {
            "7": {
                "1": "或曰",
                "2": "春秋以錯文見義",
                "3": "若如所論",
                "4": "則經當有事同文異而無其義也",
                "5": "先儒所傳",
                "6": "皆不其然",
                "7": "答曰",
                "8": "春秋雖以一字爲襃貶",
                "9": "然皆須數句以成言",
                "10": "非如八卦之爻",
                "11": "可錯綜爲六十四也",
                "12": "固當依傳以爲斷",
                "13": "古今言左氏春秋者多矣",
                "14": "今其遺文可見者十數家",
                "15": "大體轉相祖述",
                "16": "進不成爲錯綜經文以盡其變",
                "17": "退不守丘明之傳",
                "18": "於丘明之傳",
                "19": "有所不通",
                "20": "皆沒而不說",
                "21": "而更膚引公羊穀梁",
                "22": "適足自亂",
                "23": "預今所以爲異",
                "24": "專修丘明之傳以釋經",
                "25": "經之條貫",
                "26": "必出於傳",
                "27": "傳之義例",
                "28": "總歸諸凡",
                "29": "推變例以正襃貶",
                "30": "簡二傳而去異端",
                "31": "蓋丘明之志也",
                "32": "其有疑錯",
                "33": "則備論而闕之",
                "34": "以俟後賢",
                "35": "然劉子駿創通大義",
                "36": "賈景伯父子",
                "37": "許惠卿",
                "38": "皆先儒之美者也",
                "39": "末有穎子嚴者",
                "40": "雖淺近亦復名家",
                "41": "故特舉劉賈許穎之違",
                "42": "以見同異",
                "43": "分經之年與傳之年相附",
                "44": "比其義類",
                "45": "各隨而解之",
                "46": "名曰經傳集解",
                "47": "又別集諸例",
                "48": "及地名",
                "49": "譜第",
                "50": "歷數",
                "51": "相與爲部",
                "52": "凡四十部",
                "53": "十五卷",
                "54": "皆顯其異同",
                "55": "從而釋之",
                "56": "名曰釋例",
                "57": "將令學者觀其所聚異同之說",
                "58": "釋例詳之也"
            }
        },
        "4": {
            "9": {
                "1": "或曰",
                "2": "春秋之作",
                "3": "左傳及穀梁無明文",
                "4": "說者以爲仲尼自衞反魯",
                "5": "修春秋",
                "6": "立素王",
                "7": "丘明爲素臣",
                "8": "言公羊者亦云黜周而王魯",
                "9": "危行言遜",
                "10": "以避當時之害",
                "11": "故微其文",
                "12": "隱其義",
                "13": "公羊經止獲麟",
                "14": "而左氏經終孔丘卒",
                "15": "敢問所安",
                "16": "答曰",
                "17": "異乎余所聞",
                "18": "仲尼曰",
                "19": "文王旣沒",
                "20": "文不在茲乎",
                "21": "此制作之本意也",
                "22": "歎曰",
                "23": "鳳鳥不至",
                "24": "河不出圖",
                "25": "吾已矣夫",
                "26": "蓋傷時王之政也",
                "27": "麟鳳五靈",
                "28": "王者之嘉瑞也",
                "29": "今麟出非其時",
                "30": "虛其應而失其歸",
                "31": "此聖人所以爲感也",
                "32": "絕筆於獲麟之一句者",
                "33": "所感而起",
                "34": "固所以爲終也"
            }
        },
        "5": {
            "11": {
                "1": "曰",
                "2": "然春秋何始於魯隱公",
                "3": "答曰",
                "4": "周平王",
                "5": "東周之始王也",
                "6": "隱公",
                "7": "讓國之賢君也",
                "8": "考乎其時則相接",
                "9": "言乎其位則列國",
                "10": "本乎其始則周公之祚胤也",
                "11": "若平王能祈天永命",
                "12": "紹開中興",
                "13": "隱公能弘宣祖業",
                "14": "光啟王室",
                "15": "則西周之美可尋",
                "16": "文武之迹不墜",
                "17": "是故因其歷數",
                "18": "附其行事",
                "19": "采周之舊",
                "20": "以會成王義",
                "21": "垂法將來",
                "22": "所書之王",
                "23": "卽平王也",
                "24": "所用之歷",
                "25": "卽周正也",
                "26": "所稱之公",
                "27": "卽魯隱也",
                "28": "安在其黜周而王魯乎",
                "29": "子曰",
                "30": "如有用我者",
                "31": "吾其爲東周乎",
                "32": "此其義也",
                "33": "若夫制作之文",
                "34": "所以彰往考來",
                "35": "情見乎辭",
                "36": "言高則旨遠",
                "37": "辭約則義微",
                "38": "此理之常",
                "39": "非隱之也",
                "40": "聖人包周身之防",
                "41": "旣作之後",
                "42": "方復隱諱以避患",
                "43": "非所聞也",
                "44": "子路使門人爲臣",
                "45": "孔子以爲欺天",
                "46": "而云仲尼素王",
                "47": "丘明素臣",
                "48": "又非通論也",
                "49": "先儒以爲制作三年",
                "50": "文成致麟",
                "51": "旣已妖妄",
                "52": "又引經以至仲尼卒",
                "53": "亦又近誣",
                "54": "據公羊經止獲麟",
                "55": "而左氏小邾射不在三叛之數",
                "56": "故余以爲感麟而作",
                "57": "作起獲麟",
                "58": "則文止於所起",
                "59": "爲得其實",
                "60": "至於反袂拭面",
                "61": "稱吾道窮",
                "62": "亦無取焉"
            }
        }
    }
}