{
    "13.03": {
        "篇名": "謝惠連 雪賦",
        "1": {
            "3": {
                "1": "歲將暮",
                "2": "時旣昏",
                "3": "寒風積",
                "4": "愁雲繁",
                "5": "梁王不悅",
                "6": "遊於兔園",
                "7": "迺置旨酒",
                "8": "命賓友",
                "9": "召鄒生",
                "10": "延枚叟",
                "11": "相如末至",
                "12": "居客之右",
                "13": "俄而微霰零",
                "14": "密雪下",
                "15": "王迺歌北風於衞詩",
                "16": "詠南山於周雅",
                "17": "授簡於司馬大夫",
                "18": "曰",
                "19": "抽子祕思",
                "20": "騁子姸辭",
                "21": "侔色揣稱",
                "22": "爲寡人賦之"
            }
        },
        "2": {
            "5": {
                "1": "相如於是避席而起",
                "2": "逡巡而揖",
                "3": "曰",
                "4": "臣聞雪宮建於東國",
                "5": "雪山峙於西域",
                "6": "岐昌發詠於來思",
                "7": "姬滿申歌於黃竹",
                "8": "曹風以麻衣比色",
                "9": "楚謠以幽蘭儷曲",
                "10": "盈尺則呈瑞於豐年",
                "11": "袤丈則表沴於陰德",
                "12": "雪之時義遠矣哉",
                "13": "請言其始"
            }
        },
        "3": {
            "7": {
                "1": "若迺玄律窮",
                "2": "嚴氣升",
                "3": "焦溪涸",
                "4": "湯谷凝",
                "5": "火井滅",
                "6": "溫泉冰",
                "7": "沸潭無湧",
                "8": "炎風不興",
                "9": "北戶墐扉",
                "10": "裸壤垂繒",
                "11": "於是河海生雲",
                "12": "朔漠飛沙",
                "13": "連氛累䨠",
                "14": "揜日韜霞",
                "15": "霰淅瀝而先集",
                "16": "雪粉糅而遂多"
            }
        },
        "4": {
            "9": {
                "1": "其爲狀也",
                "2": "散漫交錯",
                "3": "氛氳蕭索",
                "4": "藹藹浮浮",
                "5": "瀌瀌弈弈",
                "6": "聯翩飛灑",
                "7": "徘徊委積",
                "8": "始緣甍而冒棟",
                "9": "終開簾而入隙",
                "10": "初便娟於墀廡",
                "11": "末縈盈於帷席",
                "12": "旣因方而爲珪",
                "13": "亦遇圓而成璧",
                "14": "眄隰則萬頃同縞",
                "15": "瞻山則千巖俱白",
                "16": "於是臺如重璧",
                "17": "逵似連璐",
                "18": "庭列瑤階",
                "19": "林挺瓊樹",
                "20": "皓鶴奪鮮",
                "21": "白鷳失素",
                "22": "紈袖慚冶",
                "23": "玉顏掩姱"
            }
        },
        "5": {
            "11": {
                "1": "若迺積素未虧",
                "2": "白日朝鮮",
                "3": "爛兮若燭龍",
                "4": "銜燿照崑山",
                "5": "爾其流滴垂冰",
                "6": "緣霤承隅",
                "7": "粲兮若馮夷",
                "8": "剖蚌列明珠",
                "9": "至夫繽紛繁騖之貌",
                "10": "皓𤽂曒絜之儀",
                "11": "迴散縈積之勢",
                "12": "飛聚凝曜之奇",
                "13": "固展轉而無窮",
                "14": "嗟難得而備知"
            }
        },
        "6": {
            "13": {
                "1": "若迺申娛翫之無已",
                "2": "夜幽靜而多懷",
                "3": "風觸楹而轉響",
                "4": "月承幌而通暉",
                "5": "酌湘吳之醇酎",
                "6": "御狐貉之兼衣",
                "7": "對庭鵾之雙舞",
                "8": "瞻雲雁之孤飛",
                "9": "踐霜雪之交積",
                "10": "憐枝葉之相違",
                "11": "馳遙思於千里",
                "12": "願接手而同歸",
                "13": "鄒陽聞之",
                "14": "懣然心服",
                "15": "有懷姸唱",
                "16": "敬接末曲",
                "17": "於是迺作而賦積雪之歌",
                "18": "歌曰",
                "19": "攜佳人兮披重幄",
                "20": "援綺衾兮坐芳縟",
                "21": "燎薰爐兮炳明燭",
                "22": "酌桂酒兮揚清曲",
                "23": "又續而爲白雪之歌"
            }
        },
        "7": {
            "15": {
                "1": "歌曰",
                "2": "曲旣揚兮酒旣陳",
                "3": "朱顏𨠑兮思自親",
                "4": "願低帷以昵枕",
                "5": "念解珮而褫紳",
                "6": "怨年歲之易暮",
                "7": "傷後會之無因",
                "8": "君寧見階上之白雪",
                "9": "豈鮮耀於陽春",
                "10": "歌卒",
                "11": "王迺尋繹吟翫",
                "12": "撫覽扼腕",
                "13": "顧謂枚叔",
                "14": "起而爲亂"
            }
        },
        "8": {
            "17": {
                "1": "亂曰",
                "2": "白羽雖白",
                "3": "質以輕兮",
                "4": "白玉雖白",
                "5": "空守貞兮",
                "6": "未若茲雪",
                "7": "因時興滅",
                "8": "玄陰凝不昧其潔",
                "9": "太陽曜不固其節",
                "10": "節豈我名",
                "11": "潔豈我貞",
                "12": "憑雲陞降",
                "13": "從風飄零",
                "14": "値物賦象",
                "15": "任地班形",
                "16": "素因遇立",
                "17": "汙隨染成",
                "18": "縱心皓然",
                "19": "何慮何營"
            }
        }
    }
}