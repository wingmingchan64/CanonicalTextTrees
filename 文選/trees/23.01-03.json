{
    "23.01-03": {
        "篇名": "阮嗣宗 詠懷詩十七首·其三",
        "1": {
            "3": {
                "1": "嘉樹下成蹊",
                "2": "東園桃與李"
            },
            "4": {
                "1": "秋風吹飛藿",
                "2": "零落從此始"
            },
            "5": {
                "1": "繁華有憔悴",
                "2": "堂上生荊杞"
            },
            "6": {
                "1": "驅馬舍之去",
                "2": "去上西山趾"
            },
            "7": {
                "1": "一身不自保",
                "2": "何況戀妻子"
            },
            "8": {
                "1": "凝霜被野草",
                "2": "歲暮亦云已"
            }
        }
    }
}