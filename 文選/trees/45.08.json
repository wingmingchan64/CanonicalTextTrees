{
    "45.08": {
        "篇名": "孔安國 尙書序",
        "1": {
            "3": {
                "1": "古者伏犧氏之王天下也",
                "2": "始畫八卦",
                "3": "造書契",
                "4": "以代結繩之政",
                "5": "由是文籍生焉",
                "6": "伏羲神農黃帝之書",
                "7": "謂之三墳",
                "8": "言大道也",
                "9": "少昊顓頊高辛唐虞之書",
                "10": "謂之五典",
                "11": "言常道也",
                "12": "至於夏商周之書",
                "13": "雖設教不倫",
                "14": "雅誥奧義",
                "15": "其歸一揆",
                "16": "是故歷代寶之",
                "17": "以爲大訓",
                "18": "八卦之說",
                "19": "謂之八索",
                "20": "求其義也",
                "21": "九州之志",
                "22": "謂之九丘",
                "23": "丘",
                "24": "聚也",
                "25": "言九州所有",
                "26": "土地所生",
                "27": "風氣所宜",
                "28": "皆聚此書也",
                "29": "春秋左氏傳曰",
                "30": "楚左史倚相能讀三墳五典八索九丘",
                "31": "卽謂上世帝王遺書也"
            }
        },
        "2": {
            "5": {
                "1": "先君孔子",
                "2": "生於周末",
                "3": "睹史籍之煩文",
                "4": "懼覽之者不一",
                "5": "遂乃定禮樂",
                "6": "明舊章",
                "7": "刪詩爲三百篇",
                "8": "約史記而修春秋",
                "9": "讚易道以黜八索",
                "10": "述職方以除九丘",
                "11": "討論墳典",
                "12": "斷自唐虞以下訖於周",
                "13": "芟夷煩亂",
                "14": "剪截浮辭",
                "15": "舉其宏綱",
                "16": "撮其機要",
                "17": "足以垂世立教",
                "18": "典謨訓誥誓命之文",
                "19": "凡百篇",
                "20": "所以恢弘至道",
                "21": "示人主以軌範也",
                "22": "帝王之制",
                "23": "坦然明白",
                "24": "可舉而行",
                "25": "三千之徒",
                "26": "並受其義",
                "27": "及秦始皇滅先代典籍",
                "28": "焚書坑儒",
                "29": "天下學士",
                "30": "逃難解散",
                "31": "我先人用藏其家書於屋壁"
            }
        },
        "3": {
            "7": {
                "1": "漢室龍興",
                "2": "開設學校",
                "3": "旁求儒雅",
                "4": "以闡大猷",
                "5": "濟南伏生",
                "6": "年過九十",
                "7": "失其本經",
                "8": "口以傳授",
                "9": "裁二十餘篇",
                "10": "以其上古之書",
                "11": "謂之尙書",
                "12": "百篇之義",
                "13": "世莫得聞",
                "14": "至魯共王好治宮室",
                "15": "壞孔子舊宅",
                "16": "以廣其居",
                "17": "於壁中得先人所藏古文虞夏商周之書",
                "18": "及傳論語孝經",
                "19": "皆科斗文字",
                "20": "王又升孔子堂",
                "21": "聞金石絲竹之音",
                "22": "乃不壞宅",
                "23": "悉以書還孔氏",
                "24": "科斗書廢已久",
                "25": "時人無能知者",
                "26": "以所聞伏生之書",
                "27": "考論文義",
                "28": "定其可知者",
                "29": "爲隸古定",
                "30": "更以竹簡寫以",
                "31": "增多伏生二十五篇",
                "32": "伏生又以舜典合於堯典",
                "33": "益稷合於皋陶謨",
                "34": "盤庚三篇合爲一",
                "35": "康王之誥合於顧命",
                "36": "復出此篇幷序",
                "37": "凡五十九篇",
                "38": "爲四十六卷",
                "39": "其餘錯亂摩滅",
                "40": "不可復知",
                "41": "悉上送官",
                "42": "藏之書府",
                "43": "以待能者"
            }
        },
        "4": {
            "9": {
                "1": "承詔爲五十九篇作傳",
                "2": "於是遂硏精覃思",
                "3": "博考經籍",
                "4": "采摭羣言",
                "5": "以立訓傳",
                "6": "約文申義",
                "7": "敷暢厥旨",
                "8": "庶幾有補於將來",
                "9": "書序",
                "10": "序所以爲作者之意",
                "11": "昭然義見",
                "12": "宜相附近",
                "13": "故引之各冠其篇首",
                "14": "定五十八篇旣畢",
                "15": "會國有巫蠱事",
                "16": "經籍道息",
                "17": "用不復以聞",
                "18": "傳之子孫",
                "19": "以貽後世",
                "20": "若好古博雅君子",
                "21": "與我同志",
                "22": "亦所不隱也"
            }
        }
    }
}