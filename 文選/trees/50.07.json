{
    "50.07": {
        "篇名": "班孟堅 述成紀第十",
        "1": {
            "3": {
                "1": "孝成皇皇",
                "2": "臨朝有光",
                "3": "威儀之盛",
                "4": "如珪如璋",
                "5": "閫闈恣趙",
                "6": "朝政在王",
                "7": "炎炎燎火",
                "8": "光允不陽",
                "9": "項岱曰",
                "10": "允",
                "11": "信也",
                "12": "內損於飛燕",
                "13": "外見壅於王鳳等",
                "14": "信不得陽也",
                "15": "張晏曰",
                "16": "天子之威",
                "17": "盛若燎火之陽",
                "18": "今委政王氏",
                "19": "不亦熾乎"
            }
        }
    }
}