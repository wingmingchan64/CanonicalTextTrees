{
    "60.02": {
        "篇名": "賈誼 弔屈原文[幷序]",
        "1": {
            "3": {
                "1": "誼爲長沙王太傅",
                "2": "旣以謫去",
                "3": "意不自得",
                "4": "及渡湘水",
                "5": "爲賦以弔屈原",
                "6": "屈原",
                "7": "楚賢臣也",
                "8": "被讒放逐",
                "9": "作離騷賦",
                "10": "其終篇曰",
                "11": "已矣哉",
                "12": "國無人兮",
                "13": "莫我知也",
                "14": "遂自投汨羅而死",
                "15": "誼追傷之",
                "16": "因自喩",
                "17": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "恭承嘉惠兮",
                "2": "俟罪長沙",
                "3": "側聞屈原兮",
                "4": "自沈汨羅",
                "5": "造託湘流兮",
                "6": "敬弔先生",
                "7": "遭世罔極兮",
                "8": "乃殞厥身",
                "9": "嗚呼哀哉",
                "10": "逢時不祥",
                "11": "鸞鳳伏竄兮",
                "12": "鴟梟翱翔",
                "13": "闒茸尊顯兮",
                "14": "讒諛得志",
                "15": "賢聖逆曳兮",
                "16": "方正倒植",
                "17": "世謂隨夷爲溷兮",
                "18": "謂跖蹻爲廉",
                "19": "莫邪爲鈍兮",
                "20": "鉛刀爲銛",
                "21": "吁嗟默默",
                "22": "生之無故兮",
                "23": "斡棄周鼎",
                "24": "寶康瓠兮",
                "25": "騰駕罷牛",
                "26": "驂蹇驢兮",
                "27": "驥垂兩耳",
                "28": "服鹽車兮",
                "29": "章甫薦履",
                "30": "漸不可久兮",
                "31": "嗟苦先生",
                "32": "獨離此咎兮"
            }
        },
        "3": {
            "7": {
                "1": "訊曰",
                "2": "已矣",
                "3": "國其莫我知兮",
                "4": "獨壹鬱其誰語",
                "5": "鳳漂漂其高逝兮",
                "6": "固自引而遠去",
                "7": "襲九淵之神龍兮",
                "8": "沕深潛以自珍",
                "9": "偭蟂獺以隱處兮",
                "10": "夫豈從蝦與蛭螾",
                "11": "所貴聖人之神德兮",
                "12": "遠濁世而自藏",
                "13": "使騏驥可得係而羈兮",
                "14": "豈云異夫犬羊",
                "15": "般紛紛其離此尤兮",
                "16": "亦夫子之故也",
                "17": "歷九州而相其君兮",
                "18": "何必懷此都也",
                "19": "鳳凰翔於千仞兮",
                "20": "覽德輝而下之",
                "21": "見細德之險徵兮",
                "22": "遙曾擊而去之",
                "23": "彼尋常之汙瀆兮",
                "24": "豈能容夫吞舟之巨魚",
                "25": "橫江湖之鱣鯨兮",
                "26": "固將制於螻蟻"
            }
        }
    }
}