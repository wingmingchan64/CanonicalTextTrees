{
    "56.02": {
        "篇名": "班孟堅 封燕然山銘[幷序]",
        "1": {
            "3": {
                "1": "惟永元元年秋七月",
                "2": "有漢元舅曰車騎將軍竇憲",
                "3": "寅亮聖皇",
                "4": "登翼王室",
                "5": "納於大麓",
                "6": "惟清緝熙",
                "7": "乃與執金吾耿秉",
                "8": "述職巡禦",
                "9": "治兵於朔方",
                "10": "鷹揚之校",
                "11": "螭虎之士",
                "12": "爰該六師",
                "13": "曁南單於",
                "14": "東胡烏桓",
                "15": "西戎氐羌",
                "16": "侯王君長之羣",
                "17": "驍騎十萬",
                "18": "元戎輕武",
                "19": "長轂四分",
                "20": "雷輜蔽路",
                "21": "萬有三千餘乘",
                "22": "勒以八陣",
                "23": "蒞以威神",
                "24": "玄甲耀日",
                "25": "朱旗絳天",
                "26": "遂凌高闕",
                "27": "下雞鹿",
                "28": "經磧鹵",
                "29": "絕大漠",
                "30": "斬溫禺以釁鼓",
                "31": "血尸逐以染鍔",
                "32": "然後四校橫徂",
                "33": "星流彗掃",
                "34": "蕭條萬里",
                "35": "野無遺寇"
            }
        },
        "2": {
            "5": {
                "1": "於是域滅區殫",
                "2": "反旆而旋",
                "3": "考傳驗圖",
                "4": "窮覽其山川",
                "5": "遂踰涿邪",
                "6": "跨安侯",
                "7": "乘燕然",
                "8": "躡冒頓之區落",
                "9": "焚老上之龍庭",
                "10": "將上以攄高文之宿憤",
                "11": "光祖宗之玄靈",
                "12": "下以安固後嗣",
                "13": "恢拓境宇",
                "14": "振大漢之天聲",
                "15": "茲可謂一勞而久逸",
                "16": "暫費而永寧也",
                "17": "乃遂封山刊石",
                "18": "昭銘盛德",
                "19": "其辭曰"
            }
        },
        "3": {
            "7": {
                "1": "鑠王師兮征荒裔",
                "2": "勦凶虐兮截海外",
                "3": "敻其邈兮亙地界",
                "4": "封神丘兮建隆嵑",
                "5": "熙帝載兮振萬世"
            }
        }
    }
}