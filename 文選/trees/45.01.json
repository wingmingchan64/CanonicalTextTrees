{
    "45.01": {
        "篇名": "宋玉 對楚王問",
        "1": {
            "3": {
                "1": "楚襄王問於宋玉曰",
                "2": "先生其有遺行與",
                "3": "何士民眾庶不譽之甚也"
            }
        },
        "2": {
            "5": {
                "1": "宋玉對曰",
                "2": "唯",
                "3": "然",
                "4": "有之",
                "5": "願大王寬其罪",
                "6": "使得畢其辭",
                "7": "客有歌於郢中者",
                "8": "其始曰下里巴人",
                "9": "國中屬而和者數千人",
                "10": "其爲陽阿薤露",
                "11": "國中屬而和者數百人",
                "12": "其爲陽春白雪",
                "13": "國中屬而和者不過數十人",
                "14": "引商刻羽",
                "15": "雜以流徵",
                "16": "國中屬而和者不過數人而已",
                "17": "是其曲彌高其和彌寡",
                "18": "故鳥有鳳而魚有鯤",
                "19": "鳳皇上擊九千里",
                "20": "絕雲霓",
                "21": "負蒼天",
                "22": "翱翔乎杳冥之上",
                "23": "夫蕃籬之鷃",
                "24": "豈能與之料天地之高哉",
                "25": "鯤魚朝發崑崙之墟",
                "26": "暴鬐於碣石",
                "27": "暮宿於孟諸",
                "28": "夫尺澤之鯢",
                "29": "豈能與之量江海之大哉",
                "30": "故非獨鳥有鳳而魚有鯤也",
                "31": "士亦有之",
                "32": "夫聖人瑰意琦行",
                "33": "超然獨處",
                "34": "夫世俗之民又安知臣之所爲哉"
            }
        }
    }
}