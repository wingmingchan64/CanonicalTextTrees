{
    "33.05-04": {
        "篇名": "宋玉 九辯五首·其四",
        "1": {
            "3": {
                "1": "竊悲夫蕙華之曾敷兮",
                "2": "紛旖旎乎都房",
                "3": "何曾華之無實兮",
                "4": "從風雨而飛颺",
                "5": "以爲君獨服此蕙兮",
                "6": "羌無以異於眾芳",
                "7": "閔奇思之不通兮",
                "8": "將去君而高翔",
                "9": "心閔憐之慘悽兮",
                "10": "願一見而有明",
                "11": "重無怨而生離兮",
                "12": "中結軫而增傷",
                "13": "豈不鬱陶而思君兮",
                "14": "君之門以九重",
                "15": "猛犬狺狺而迎吠兮",
                "16": "關梁閉而不通",
                "17": "皇天淫溢而秋霖兮",
                "18": "后土何時而得乾",
                "19": "塊獨守此無澤兮",
                "20": "仰浮雲而永歎"
            }
        }
    }
}