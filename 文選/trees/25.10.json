{
    "25.10": {
        "篇名": "盧子諒 答魏子悌",
        "1": {
            "3": {
                "1": "崇臺非一幹",
                "2": "珍裘非一腋",
                "3": "多士成大業",
                "4": "羣賢濟弘績",
                "5": "遇蒙時來會",
                "6": "聊齊朝彥迹",
                "7": "顧此腹背羽",
                "8": "愧彼排虛翮",
                "9": "寄身蔭四嶽",
                "10": "託好憑三益",
                "11": "傾蓋雖終朝",
                "12": "大分邁疇昔",
                "13": "在危每同險",
                "14": "處安不異易",
                "15": "俱涉晉昌艱",
                "16": "共更飛狐厄",
                "17": "恩由契闊生",
                "18": "義隨周旋積",
                "19": "豈謂鄕曲譽",
                "20": "謬充本州役",
                "21": "乖離令我感",
                "22": "悲欣使情惕",
                "23": "理以精神通",
                "24": "匪曰形骸隔",
                "25": "妙詩申篤好",
                "26": "清義貫幽賾",
                "27": "恨無隨侯珠",
                "28": "以酬荊文璧"
            }
        }
    }
}