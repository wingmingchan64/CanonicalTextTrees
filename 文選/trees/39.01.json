{
    "39.01": {
        "篇名": "李斯 上書秦始皇",
        "1": {
            "3": {
                "1": "臣聞吏議逐客",
                "2": "竊以爲過矣",
                "3": "昔穆公求士",
                "4": "西取由余於戎",
                "5": "東得百里奚於宛",
                "6": "迎蹇叔於宋",
                "7": "來邳豹公孫支於晉",
                "8": "此五子者",
                "9": "不產於秦",
                "10": "穆公用之",
                "11": "幷國三十",
                "12": "遂霸西戎",
                "13": "孝公用商鞅之法",
                "14": "移風易俗",
                "15": "民以殷盛",
                "16": "國以富彊",
                "17": "百姓樂用",
                "18": "諸侯親服",
                "19": "獲楚魏之師",
                "20": "舉地千里",
                "21": "至今治彊",
                "22": "惠王用張儀之計",
                "23": "拔三川之地",
                "24": "西幷巴蜀",
                "25": "北收上郡",
                "26": "南取漢中",
                "27": "包九夷",
                "28": "制鄢郢",
                "29": "東據成皋之險",
                "30": "割膏腴之壤",
                "31": "遂散六國之從",
                "32": "使之西面事秦",
                "33": "功施到今",
                "34": "昭王得范雎",
                "35": "廢穰侯",
                "36": "逐華陽",
                "37": "彊公室",
                "38": "杜私門",
                "39": "蠶食諸侯",
                "40": "使秦成帝業",
                "41": "此四君者",
                "42": "皆以客之功",
                "43": "由此觀之",
                "44": "客何負於秦哉",
                "45": "向使四君卻客而弗納",
                "46": "疏士而弗用",
                "47": "是使國無富利之實",
                "48": "而秦無彊大之名也"
            }
        },
        "2": {
            "5": {
                "1": "今陛下致昆山之玉",
                "2": "有和隨之寶",
                "3": "垂明月之珠",
                "4": "服太阿之劍",
                "5": "乘纖離之馬",
                "6": "建翠鳳之旗",
                "7": "樹靈鱓之鼓",
                "8": "此數寶者",
                "9": "秦不生一焉",
                "10": "而陛下悅之何也",
                "11": "必秦國之所生然後可",
                "12": "則夜光之璧不飾朝廷",
                "13": "犀象之器不爲玩好",
                "14": "而趙衞之女不充後庭",
                "15": "駿良駃騠不實外廏",
                "16": "江南金錫不爲用",
                "17": "西蜀丹青不爲采",
                "18": "所以飾後宮充下陳娛心意悅耳目者",
                "19": "必出於秦然後可",
                "20": "則是宛珠之簪",
                "21": "傅璣之珥",
                "22": "阿縞之衣",
                "23": "錦繡之飾",
                "24": "不進於前",
                "25": "而隨俗雅化",
                "26": "佳冶窈窕",
                "27": "趙女不立於側也"
            }
        },
        "3": {
            "7": {
                "1": "夫擊甕叩缶",
                "2": "彈箏搏髀",
                "3": "而歌呼嗚嗚快耳者",
                "4": "眞秦之聲也",
                "5": "鄭衞桑間韶虞武象者",
                "6": "異國之樂也",
                "7": "今棄叩缶擊甕而就鄭衞",
                "8": "退彈箏而取韶虞",
                "9": "若是者何也",
                "10": "快意當前",
                "11": "適觀而已矣",
                "12": "今取人則不然",
                "13": "不問可否",
                "14": "不論曲直",
                "15": "非秦者去",
                "16": "爲客者逐",
                "17": "然則是所重者在乎色樂珠玉",
                "18": "而所輕者在乎民人也",
                "19": "此非所以跨海內制諸侯之術也"
            }
        },
        "4": {
            "9": {
                "1": "臣聞地廣者粟多",
                "2": "國大者人眾",
                "3": "兵彊者則士勇",
                "4": "是以太山不讓土壤",
                "5": "故能成其大",
                "6": "河海不擇細流",
                "7": "故能就其深",
                "8": "王者不卻眾庶",
                "9": "故能明其德",
                "10": "是以地無四方",
                "11": "民無異國",
                "12": "四時充美",
                "13": "鬼神降福",
                "14": "此五帝三王之所以無敵也",
                "15": "今乃棄黔首以資敵國",
                "16": "卻賓客以業諸侯",
                "17": "使天下之士退而不敢西向",
                "18": "裹足不入秦",
                "19": "此所謂藉寇兵而齎盜糧者也",
                "20": "夫物不產於秦",
                "21": "可寶者多",
                "22": "士不產於秦",
                "23": "願忠者眾",
                "24": "今逐客以資敵國",
                "25": "損民以益讎",
                "26": "內自虛而外樹怨諸侯",
                "27": "求國無危",
                "28": "不可得也"
            }
        }
    }
}