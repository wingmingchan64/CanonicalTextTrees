{
    "46.04": {
        "篇名": "任彥升 王文憲集序",
        "1": {
            "3": {
                "1": "公諱儉",
                "2": "字仲寶",
                "3": "琅邪臨沂人也",
                "4": "其先自秦至宋",
                "5": "國史家諜詳焉",
                "6": "晉中興以來",
                "7": "六世名德",
                "8": "海內冠冕",
                "9": "古語云",
                "10": "仁人之利",
                "11": "天道運行",
                "12": "故呂虔歸其佩刀",
                "13": "郭璞誓以淮水",
                "14": "若離剪之止殺",
                "15": "吉駿之誠感",
                "16": "蓋有助焉"
            }
        },
        "2": {
            "5": {
                "1": "公之生也",
                "2": "誕授命世",
                "3": "體三才之茂",
                "4": "踐得二之機",
                "5": "信乃昴宿垂芒",
                "6": "德精降祉",
                "7": "有一於此",
                "8": "蔚爲帝師",
                "9": "況乃淵角殊祥",
                "10": "山庭異表",
                "11": "望衢罕窺其術",
                "12": "觀海莫際其瀾",
                "13": "宏覽載籍",
                "14": "博遊才義",
                "15": "若乃金版玉匱之書",
                "16": "海上名山之旨",
                "17": "沈鬱澹雅之思",
                "18": "離堅合異之談",
                "19": "莫不總制清衷",
                "20": "遞爲心極",
                "21": "斯固通人之所包",
                "22": "非虛明之絕境",
                "23": "不可窮者",
                "24": "其唯神用者乎",
                "25": "然檢鏡所歸",
                "26": "人倫以表",
                "27": "雲屋天構",
                "28": "匠者何",
                "29": "自咸洛不守",
                "30": "憲章中輟",
                "31": "賀生達禮之宗",
                "32": "蔡公儒林之亞",
                "33": "闕典未補",
                "34": "大備茲日",
                "35": "至若齒危髮秀之老",
                "36": "含經味道之生",
                "37": "莫不北面人宗",
                "38": "自同資敬",
                "39": "性託夷遠",
                "40": "少屛塵雜",
                "41": "自非可以弘獎風流",
                "42": "增益標勝",
                "43": "未嘗留心"
            }
        },
        "3": {
            "7": {
                "1": "期歲而孤",
                "2": "叔父司空簡穆公",
                "3": "早所器異",
                "4": "年始志學",
                "5": "家門禮訓",
                "6": "皆折衷於公",
                "7": "孝友之性",
                "8": "豈伊橋梓",
                "9": "夷雅之體",
                "10": "無待韋弦",
                "11": "汝郁之幼挺淳至",
                "12": "黃琬之早標聰察",
                "13": "曾何足尙",
                "14": "年六歲",
                "15": "襲封豫寧侯",
                "16": "拜日",
                "17": "家人以公尙幼",
                "18": "弗之先告",
                "19": "旣襲珪組",
                "20": "對揚王命",
                "21": "因便感咽",
                "22": "若不自勝",
                "23": "初",
                "24": "宋明帝居蕃",
                "25": "與公母武康公主素不協",
                "26": "及卽位",
                "27": "有詔廢毀舊塋",
                "28": "投棄棺柩",
                "29": "公以死固請",
                "30": "誓不遵奉",
                "31": "表啟酸切",
                "32": "義感人神",
                "33": "太宗聞而悲之",
                "34": "遂無以奪也",
                "35": "初拜祕書郎",
                "36": "遷太子舍人",
                "37": "以選尙公主",
                "38": "拜駙馬都尉",
                "39": "元徽初",
                "40": "遷祕書丞",
                "41": "於是采公曾之中經",
                "42": "刊弘度之四部",
                "43": "依劉歆七略",
                "44": "更撰七志",
                "45": "蓋嘗賦詩云",
                "46": "稷契匡虞夏",
                "47": "伊呂翼商周",
                "48": "自是始有應務之迹",
                "49": "生民屬心矣",
                "50": "時司徒袁粲",
                "51": "有高世之度",
                "52": "脫落塵俗",
                "53": "見公弱齡",
                "54": "便望風推服",
                "55": "歎曰",
                "56": "衣冠禮樂在是矣",
                "57": "時粲位亞台司",
                "58": "公年始弱冠",
                "59": "年勢不侔",
                "60": "公與之抗禮",
                "61": "因贈粲詩",
                "62": "要以歲暮之期",
                "63": "申以止足之戒",
                "64": "粲答詩曰",
                "65": "老夫亦何寄",
                "66": "之子照清襟"
            }
        },
        "4": {
            "9": {
                "1": "服闋",
                "2": "拜司徒右長史",
                "3": "出爲義興太守",
                "4": "風化之美",
                "5": "奏課爲最",
                "6": "還除給事黃門侍郎",
                "7": "旬日",
                "8": "遷尙書吏部郎參選",
                "9": "昔毛玠之公清",
                "10": "李重之識會",
                "11": "兼之者公也",
                "12": "俄遷侍中",
                "13": "以愍侯始終之職",
                "14": "固辭不拜",
                "15": "補太尉右長史",
                "16": "時聖武定業",
                "17": "肇基王命",
                "18": "寤寐風雲",
                "19": "實資人傑",
                "20": "是以宸居膺列宿之表",
                "21": "圖緯著王佐之符",
                "22": "俄遷左長史",
                "23": "齊臺初建",
                "24": "以公爲尙書右僕射",
                "25": "領吏部",
                "26": "時年二十八",
                "27": "宋末艱虞",
                "28": "百王澆季",
                "29": "禮紊舊宗",
                "30": "樂傾恆軌",
                "31": "自朝章國紀",
                "32": "典彝備物",
                "33": "奏議符策",
                "34": "文辭表記",
                "35": "素意所不蓄",
                "36": "前古所未行",
                "37": "皆取定俄頃",
                "38": "神無滯用"
            }
        },
        "5": {
            "11": {
                "1": "太祖受命",
                "2": "以佐命之功",
                "3": "封南昌縣開國公",
                "4": "食邑二千戶",
                "5": "建元二年",
                "6": "遷尙書左僕射",
                "7": "領選如故",
                "8": "自營郃分司",
                "9": "盧欽兼掌",
                "10": "譽望所歸",
                "11": "允集茲日",
                "12": "尋表解選",
                "13": "詔加侍中",
                "14": "又授太子詹事",
                "15": "侍中僕射如故",
                "16": "固辭侍中",
                "17": "改授散騎常侍",
                "18": "餘如故",
                "19": "太祖崩",
                "20": "遺詔以公爲侍中尙書令鎭國將軍",
                "21": "永明元年",
                "22": "進號衞將軍",
                "23": "二年",
                "24": "以本官領丹陽尹",
                "25": "六輔殊風",
                "26": "五方異俗",
                "27": "公不謀聲訓",
                "28": "而楚夏移情",
                "29": "故能使解劍拜仇",
                "30": "歸田息訟",
                "31": "前郡尹溫太眞劉眞長",
                "32": "或功銘鼎彝",
                "33": "或德標素尙",
                "34": "臭味風雲",
                "35": "千載無爽",
                "36": "親加弔祭",
                "37": "表薦孤遺",
                "38": "遠協神期",
                "39": "用彰世祀",
                "40": "時簡穆公薨",
                "41": "以撫養之恩",
                "42": "特深恆慕",
                "43": "表求解職",
                "44": "有詔不許"
            }
        },
        "6": {
            "13": {
                "1": "國學初興",
                "2": "華夷慕義",
                "3": "經師人表",
                "4": "允資望實",
                "5": "復以本官領國子祭酒",
                "6": "三年",
                "7": "解丹陽尹",
                "8": "領太子少傅",
                "9": "餘悉如故",
                "10": "挂服捐駒",
                "11": "前良取則",
                "12": "臥轍棄子",
                "13": "後予胥怨",
                "14": "皇太子不矜天姿",
                "15": "俯同人範",
                "16": "師友之義",
                "17": "穆若金蘭",
                "18": "又領本州大中正",
                "19": "頃之解職",
                "20": "四年",
                "21": "以本號開府儀同三司",
                "22": "餘悉如故",
                "23": "謙光愈遠",
                "24": "大典未申",
                "25": "六年",
                "26": "又申前命",
                "27": "七年",
                "28": "固辭選任",
                "29": "帝所重違",
                "30": "詔加中書監",
                "31": "猶參掌選事",
                "32": "長輿追專車之恨",
                "33": "公曾甘鳳池之失"
            }
        },
        "7": {
            "15": {
                "1": "夫奔競之塗",
                "2": "有自來矣",
                "3": "以難知之性",
                "4": "協易失之情",
                "5": "必使無訟",
                "6": "事深弘誘",
                "7": "公提衡惟允",
                "8": "一紀於茲",
                "9": "拔奇取異",
                "10": "興微繼絕",
                "11": "望側階而容賢",
                "12": "候景風而式典",
                "13": "春秋三十有八",
                "14": "七年五月三日",
                "15": "薨於建康官舍",
                "16": "皇朝軫慟",
                "17": "儲鉉傷情",
                "18": "有識銜悲",
                "19": "行路掩泣",
                "20": "豈直舂者不相",
                "21": "工女寢機而已哉",
                "22": "故以痛深衣冠",
                "23": "悲纏教義",
                "24": "豈非功深砥礪",
                "25": "道邁舟航",
                "26": "沒世遺愛",
                "27": "古之益友",
                "28": "追贈太尉",
                "29": "侍中中書監如故",
                "30": "給節",
                "31": "加羽葆鼓吹",
                "32": "增班劍六十人",
                "33": "謚曰文憲",
                "34": "禮也"
            }
        },
        "8": {
            "17": {
                "1": "公在物斯厚",
                "2": "居身以約",
                "3": "玩好絕於耳目",
                "4": "布素表於造次",
                "5": "室無姬姜",
                "6": "門多長者",
                "7": "立言必雅",
                "8": "未嘗顯其所長",
                "9": "持論從容",
                "10": "未嘗言人所短",
                "11": "弘長風流",
                "12": "許與氣類",
                "13": "檀道鸞晉陽秋曰",
                "14": "謝安爲桓溫司馬",
                "15": "不存小察",
                "16": "盡弘長之風",
                "17": "風流",
                "18": "已見上文",
                "19": "謝承後漢書曰",
                "20": "桓�邴營氣類經緯士人",
                "21": "雖單門後進",
                "22": "必加善誘",
                "23": "勖以丹霄之價",
                "24": "弘以青冥之期",
                "25": "公銓品人倫",
                "26": "各盡其用",
                "27": "居厚者不矜其多",
                "28": "處薄者不怨其少",
                "29": "窮涯而反",
                "30": "盈量知歸",
                "31": "皇朝以治定制禮",
                "32": "功成作樂",
                "33": "思我民譽",
                "34": "緝熙帝圖",
                "35": "雖張曹爭論於漢朝",
                "36": "荀摯競爽於晉世",
                "37": "無以仰摸淵旨",
                "38": "取則後昆",
                "39": "每荒服請罪",
                "40": "遠夷慕義",
                "41": "宣威授指",
                "42": "寔寄宏略",
                "43": "理積則神無忤往",
                "44": "事感則悅情斯來",
                "45": "無是己之心",
                "46": "事隔於容謟",
                "47": "罕愛憎之情",
                "48": "理絕於毀譽",
                "49": "造理常若可干",
                "50": "臨事每不可奪",
                "51": "約己不以廉物",
                "52": "弘量不以容非",
                "53": "攻乎異端",
                "54": "歸之正義"
            }
        },
        "9": {
            "19": {
                "1": "公生自華宗",
                "2": "世務簡隔",
                "3": "至於軍國遠圖",
                "4": "刑政大典",
                "5": "旣道在廊廟",
                "6": "則理擅民宗",
                "7": "若乃明練庶務",
                "8": "鑒達治體",
                "9": "懸然天得",
                "10": "不謀成心",
                "11": "求之載籍",
                "12": "翰牘所未紀",
                "13": "訊之遺老",
                "14": "耳目所不接",
                "15": "至若文案自環",
                "16": "主者百數",
                "17": "皆深文爲吏",
                "18": "積習成奸",
                "19": "蓄筆削之刑",
                "20": "懷輕重之意",
                "21": "公乘理照物",
                "22": "動必硏機",
                "23": "當時嗟服",
                "24": "若有神道",
                "25": "豈非希世之雋民",
                "26": "瑚璉之宏器"
            }
        },
        "10": {
            "21": {
                "1": "昉行無異操",
                "2": "才無異能",
                "3": "得奉名節",
                "4": "迄將一紀",
                "5": "一言之譽",
                "6": "東陵侔於西山",
                "7": "一眄之榮",
                "8": "鄭璞踰於周寶",
                "9": "士感知己",
                "10": "懷此何極",
                "11": "出入禮闈",
                "12": "朝夕舊館",
                "13": "瞻棟宇而興慕",
                "14": "撫身名而悼恩",
                "15": "公自幼及長",
                "16": "述作不倦",
                "17": "固以理窮言行",
                "18": "事該軍國",
                "19": "豈直彫章縟采而已哉",
                "20": "若乃統體必善",
                "21": "綴賞無地",
                "22": "雖楚趙羣才",
                "23": "漢魏眾作",
                "24": "曾何足云",
                "25": "曾何足云",
                "26": "昉嘗以筆札見知",
                "27": "思以薄技效德",
                "28": "是用綴緝遺文",
                "29": "永貽世範",
                "30": "爲如干秩",
                "31": "如干卷",
                "32": "所撰古今集記今書七志",
                "33": "爲一家言",
                "34": "不列於集",
                "35": "集錄如左"
            }
        }
    }
}