{
    "21.11": {
        "篇名": "應休璉 百一詩",
        "1": {
            "3": {
                "1": "下流不可處",
                "2": "君子愼厥初"
            },
            "4": {
                "1": "名高不宿著",
                "2": "易用受侵誣"
            },
            "5": {
                "1": "前者隳官去",
                "2": "有人適我閭"
            },
            "6": {
                "1": "田家無所有",
                "2": "酌醴焚枯魚"
            },
            "7": {
                "1": "問我何功德",
                "2": "三入承明廬"
            },
            "8": {
                "1": "所占於此土",
                "2": "是謂仁智居"
            },
            "9": {
                "1": "文章不經國",
                "2": "筐篋無尺書"
            },
            "10": {
                "1": "用等稱才學",
                "2": "往往見歎譽"
            },
            "11": {
                "1": "避席跪自陳",
                "2": "賤子實空虛"
            },
            "12": {
                "1": "宋人遇周客",
                "2": "慚愧靡所如"
            }
        }
    }
}