    "25.02": {
        "篇名": "郭泰機 答傅咸",
        "1": {
            "3": {
                "1": "皦皦白素絲",
                "2": "織爲寒女衣",
                "3": "寒女雖妙巧",
                "4": "不得秉抒機",
                "5": "天寒知運速",
                "6": "況復雁南飛",
                "7": "衣工秉刀尺",
                "8": "棄我忽若遺",
                "9": "人不取諸身",
                "10": "世事焉所希",
                "11": "況復已朝餐",
                "12": "曷由知我飢"
            }
        }
    }
