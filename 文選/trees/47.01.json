{
    "47.01": {
        "篇名": "王子淵 聖主得賢臣頌",
        "1": {
            "3": {
                "1": "夫荷旃被毳者",
                "2": "難與道純綿之麗密",
                "3": "羹藜唅糗者",
                "4": "不足與論太牢之滋味",
                "5": "今臣僻在西蜀",
                "6": "生於窮巷之中",
                "7": "長於蓬茨之下",
                "8": "無有遊觀廣覽之知",
                "9": "顧有至愚極陋之累",
                "10": "不足以塞厚望",
                "11": "應明旨",
                "12": "雖然",
                "13": "敢不略陳愚心",
                "14": "而杼情素"
            }
        },
        "2": {
            "5": {
                "1": "記曰",
                "2": "恭惟春秋法五始之要",
                "3": "在乎審己正統而已",
                "4": "夫賢者",
                "5": "國家之器用也",
                "6": "所任賢",
                "7": "則趨舍省而功施普",
                "8": "器用利",
                "9": "則用力少而就效眾",
                "10": "故工人之用鈍器也",
                "11": "勞筋苦骨",
                "12": "終日矻矻",
                "13": "及至巧冶鑄干將之璞",
                "14": "清水淬其鋒",
                "15": "越砥斂其鍔",
                "16": "水斷蛟龍",
                "17": "陸剸犀革",
                "18": "忽若篲泛畫塗",
                "19": "如此則使離婁督繩",
                "20": "公輸削墨",
                "21": "雖崇臺五層",
                "22": "延袤百丈而不溷者",
                "23": "工用相得也",
                "24": "庸人之御駑馬",
                "25": "亦傷吻敝筴而不進於行",
                "26": "胸喘膚汗",
                "27": "人極馬倦",
                "28": "及至駕齧膝",
                "29": "驂乘旦",
                "30": "王良執靶",
                "31": "韓哀附輿",
                "32": "縱騁馳騖",
                "33": "忽如影靡",
                "34": "過都越國",
                "35": "蹶如歷塊",
                "36": "追奔電",
                "37": "逐遺風",
                "38": "周流八極",
                "39": "萬里一息",
                "40": "何其遼哉",
                "41": "人馬相得也",
                "42": "故服絺綌之涼者",
                "43": "不苦盛暑之鬱燠",
                "44": "論語曰",
                "45": "當暑紾絺𥿭",
                "46": "孔安國曰",
                "47": "絺𥿭",
                "48": "葛也",
                "49": "襲狐貉之暖者",
                "50": "不憂至寒之淒愴",
                "51": "何則",
                "52": "有其具者易其備",
                "53": "賢人君子",
                "54": "亦聖王之所以易海內也",
                "55": "是以嘔喩受之",
                "56": "開寬裕之路",
                "57": "以延天下之英俊也",
                "58": "夫竭智附賢者",
                "59": "必建仁策",
                "60": "索人求士者",
                "61": "必樹伯迹",
                "62": "昔周公躬吐握之勞",
                "63": "故有圄空之隆",
                "64": "齊桓設庭燎之禮",
                "65": "故有匡合之功",
                "66": "由此觀之",
                "67": "君人者勤於求賢而逸於得人"
            }
        },
        "3": {
            "7": {
                "1": "人臣亦然",
                "2": "昔賢者之未遭遇也",
                "3": "圖事揆策",
                "4": "則君不用其謀",
                "5": "陳見悃誠",
                "6": "則上不然其信",
                "7": "進仕不得施效",
                "8": "斥逐又非其愆",
                "9": "是故伊尹勤於鼎俎",
                "10": "太公困於鼓刀",
                "11": "百里自鬻",
                "12": "寗戚飯牛",
                "13": "離此患也",
                "14": "及其遇明君",
                "15": "遭聖主也",
                "16": "運籌合上意",
                "17": "諫諍則見聽",
                "18": "進退得關其忠",
                "19": "任職得行其術",
                "20": "去卑辱奧渫而升本朝",
                "21": "離蔬釋蹻而享膏粱",
                "22": "剖符錫壤",
                "23": "而光祖考",
                "24": "傳之子孫",
                "25": "以資說士",
                "26": "故世必有聖智之君",
                "27": "而後有賢明之臣",
                "28": "虎嘯而谷風冽",
                "29": "龍興而致雲氣",
                "30": "蟋蟀俟秋吟",
                "31": "蜉蝣出以陰",
                "32": "易曰",
                "33": "飛龍在天",
                "34": "利見大人",
                "35": "詩曰",
                "36": "思皇多士",
                "37": "生此王國",
                "38": "故世平主聖",
                "39": "俊乂將自至",
                "40": "若堯舜禹湯文武之君",
                "41": "獲稷契皋陶伊尹呂望之臣",
                "42": "明明在朝",
                "43": "穆穆列布",
                "44": "聚精會神",
                "45": "相得益章",
                "46": "雖伯牙操𥳠鐘",
                "47": "蓬門子彎烏號",
                "48": "猶未足以喩其意也",
                "49": "晉灼曰",
                "50": "𥳠音迭遞之遞",
                "51": "二十四鍾",
                "52": "各有節奏",
                "53": "聲之不常",
                "54": "故曰遞鍾",
                "55": "瓚以爲楚辭曰",
                "56": "奏伯牙之號鍾",
                "57": "馬融長笛賦曰",
                "58": "號鍾高調",
                "59": "號鍾",
                "60": "琴名也",
                "61": "謂伯牙以善鼓琴",
                "62": "不說能擊鍾也",
                "63": "且漢書多借假",
                "64": "或以𥳠爲號",
                "65": "不得便以迭遞判其音也",
                "66": "善曰",
                "67": "孫卿子曰",
                "68": "羿",
                "69": "蜂門",
                "70": "善服射者也",
                "71": "吳越春秋",
                "72": "陳音曰",
                "73": "黃帝作弓",
                "74": "後有楚狐父以其道傳羿",
                "75": "羿傳蓬蒙",
                "76": "漢書曰",
                "77": "黃帝鼎成",
                "78": "龍迎黃帝",
                "79": "黃帝上騎",
                "80": "小臣持龍髯",
                "81": "拔墮",
                "82": "墮黃帝之弓",
                "83": "百姓仰望黃帝龍髯號",
                "84": "故名其弓曰烏號"
            }
        },
        "4": {
            "9": {
                "1": "故聖主必待賢臣而弘功業",
                "2": "俊士亦俟明主以顯其德",
                "3": "上下俱欲",
                "4": "歡然交欣",
                "5": "千載一會",
                "6": "論說無疑",
                "7": "翼乎如鴻毛遇順風",
                "8": "沛乎若巨魚縱大壑",
                "9": "其得意如此",
                "10": "則胡禁不止",
                "11": "曷令不行",
                "12": "化溢四表",
                "13": "橫被無窮",
                "14": "遐夷貢獻",
                "15": "萬祥必臻",
                "16": "是以聖主不遍窺望而視已明",
                "17": "不殫傾耳而聽已聰",
                "18": "恩從祥風翱",
                "19": "德與和氣遊",
                "20": "太平之責塞",
                "21": "優遊之望得",
                "22": "遵遊自然之勢",
                "23": "恬淡無爲之場",
                "24": "休徵自至",
                "25": "壽考無疆",
                "26": "雍容垂拱",
                "27": "永永萬年",
                "28": "何必偃仰詘信若彭祖",
                "29": "呴噓呼吸如喬松",
                "30": "眇然絕俗離世哉",
                "31": "詩曰",
                "32": "濟濟多士",
                "33": "文王以寧",
                "34": "蓋信乎其以寧也"
            }
        }
    }
}