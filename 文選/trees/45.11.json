{
    "45.11": {
        "篇名": "石季倫 思歸引序",
        "1": {
            "3": {
                "1": "余少有大志",
                "2": "夸邁流俗",
                "3": "弱冠登朝",
                "4": "歷位二十五年",
                "5": "五十以事去官",
                "6": "晚節更樂放逸",
                "7": "篤好林藪",
                "8": "遂肥遁於河陽別業",
                "9": "其制宅也",
                "10": "卻阻長堤",
                "11": "前臨清渠",
                "12": "百木幾於萬株",
                "13": "流水周於舍下",
                "14": "有觀閣池沼",
                "15": "多養魚鳥",
                "16": "家素習技",
                "17": "頗有秦趙之聲",
                "18": "出則以遊目弋釣爲事",
                "19": "入則有琴書之娛",
                "20": "又好服食咽氣",
                "21": "志在不朽",
                "22": "傲然有凌雲之操",
                "23": "欻復見牽",
                "24": "羈婆娑於九列",
                "25": "困於人間煩黷",
                "26": "常思歸而永歎",
                "27": "尋覽樂篇",
                "28": "有思歸引",
                "29": "儻古人之情",
                "30": "有同於今",
                "31": "故制此曲",
                "32": "此曲有絃無歌",
                "33": "今爲作歌辭",
                "34": "以述余懷",
                "35": "恨時無知音者",
                "36": "令造新聲而播於絲竹也"
            }
        }
    }
}