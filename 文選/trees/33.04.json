{
    "33.04": {
        "篇名": "屈平 漁父",
        "1": {
            "3": {
                "1": "屈原旣放",
                "2": "遊於江潭",
                "3": "行吟澤畔",
                "4": "顏色憔悴",
                "5": "形容枯槁",
                "6": "漁父見而問之",
                "7": "曰",
                "8": "子非三閭大夫歟",
                "9": "何故至於斯",
                "10": "屈原曰",
                "11": "世人皆濁我獨清",
                "12": "眾人皆醉我獨醒",
                "13": "是以見放",
                "14": "漁父曰",
                "15": "聖人不凝滯於物",
                "16": "而能與世推移",
                "17": "世皆濁",
                "18": "何不淈其泥而揚其波",
                "19": "眾人皆醉",
                "20": "何不餔其糟而歠其醨",
                "21": "何故深思高舉",
                "22": "自令放爲",
                "23": "屈原曰",
                "24": "吾聞之",
                "25": "新沐者必彈冠",
                "26": "新浴者必振衣",
                "27": "安能以身之察察",
                "28": "受物之汶汶者乎",
                "29": "寧赴湘流",
                "30": "葬於江魚腹中",
                "31": "安能以皓皓之白",
                "32": "蒙世俗之塵埃乎",
                "33": "漁父莞爾而笑",
                "34": "鼓枻而去",
                "35": "乃歌曰",
                "36": "滄浪之水清兮",
                "37": "可以濯我纓",
                "38": "滄浪之水濁兮",
                "39": "可以濯我足",
                "40": "遂去",
                "41": "不復與言"
            }
        }
    }
}