{
    "23.05": {
        "篇名": "曹子建 七哀詩",
        "1": {
            "3": {
                "1": "明月照高樓",
                "2": "流光正徘徊",
                "3": "上有愁思婦",
                "4": "悲歎有餘哀",
                "5": "借問歎者誰",
                "6": "言是客子妻",
                "7": "君行踰十年",
                "8": "孤妾常獨栖",
                "9": "君若清路塵",
                "10": "妾若濁水泥",
                "11": "浮沈各異勢",
                "12": "會合何時諧",
                "13": "願爲西南風",
                "14": "長逝入君懷",
                "15": "君懷良不開",
                "16": "賤妾當何依"
            }
        }
    }
}