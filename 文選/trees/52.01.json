{
    "52.01": {
        "篇名": "班叔皮 王命論",
        "1": {
            "3": {
                "1": "昔在帝堯之禪曰",
                "2": "咨爾舜",
                "3": "天之歷數在爾躬",
                "4": "舜亦以命禹",
                "5": "曁於稷契",
                "6": "咸佐唐虞",
                "7": "光濟四海",
                "8": "奕世載德",
                "9": "至於湯武",
                "10": "而有天下",
                "11": "雖其遭遇異時",
                "12": "禪代不同",
                "13": "至於應天順人",
                "14": "其揆一焉",
                "15": "是故劉氏承堯之祚",
                "16": "氏族之世",
                "17": "著於春秋",
                "18": "唐據火德",
                "19": "而漢紹之",
                "20": "始起沛澤",
                "21": "則神母夜號",
                "22": "以彰赤帝之符",
                "23": "由是言之",
                "24": "帝王之祚",
                "25": "必有明聖顯懿之德",
                "26": "豐功厚利積累之業",
                "27": "然後精誠通於神明",
                "28": "流澤加於生民",
                "29": "故能爲鬼神所福饗",
                "30": "天下所歸往",
                "31": "未見運世無本",
                "32": "功德不紀",
                "33": "而得倔起在此位者也",
                "34": "世俗見高祖興於布衣",
                "35": "不達其故",
                "36": "以爲適遭暴亂",
                "37": "得奮其劍",
                "38": "遊說之士",
                "39": "至比天下於逐鹿",
                "40": "幸捷而得之",
                "41": "不知神器有命",
                "42": "不可以智力求",
                "43": "悲夫",
                "44": "此世之所以多亂臣賊子者也",
                "45": "若然者",
                "46": "豈徒闇於天道哉",
                "47": "又不睹之於人事矣"
            }
        },
        "2": {
            "5": {
                "1": "夫餓饉流隸",
                "2": "飢寒道路",
                "3": "思有短褐之襲",
                "4": "檐石之蓄",
                "5": "所願不過一金",
                "6": "終於轉死溝壑",
                "7": "何則",
                "8": "貧窮亦有命也",
                "9": "況乎天子之貴",
                "10": "四海之富",
                "11": "神明之祚",
                "12": "可得而妄處哉",
                "13": "故雖遭罹厄會",
                "14": "竊其權柄",
                "15": "勇如信布",
                "16": "強如梁籍",
                "17": "成如王莽",
                "18": "然卒潤鑊伏鑕",
                "19": "烹醢分裂",
                "20": "又況么麼不及數子",
                "21": "而欲闇干天位者也",
                "22": "是故駑蹇之乘",
                "23": "不騁千里之塗",
                "24": "燕雀之疇",
                "25": "不奮六翮之用",
                "26": "楶梲之材不荷棟梁之任",
                "27": "斗筲之子",
                "28": "不秉帝王之重",
                "29": "易曰",
                "30": "鼎折足",
                "31": "覆公餗",
                "32": "不勝其任也"
            }
        },
        "3": {
            "7": {
                "1": "當秦之末",
                "2": "豪桀共推陳嬰而王之",
                "3": "嬰母止之曰",
                "4": "自吾爲子家婦",
                "5": "而世貧賤",
                "6": "卒富貴",
                "7": "不祥",
                "8": "不如以兵屬人",
                "9": "事成",
                "10": "少受其利",
                "11": "不成",
                "12": "禍有所歸",
                "13": "嬰從其言",
                "14": "而陳氏以寧",
                "15": "王陵之母",
                "16": "亦見項氏之必亡",
                "17": "而劉氏之將興也",
                "18": "是時",
                "19": "陵爲漢將",
                "20": "而母獲於楚",
                "21": "有漢使來",
                "22": "陵母見之",
                "23": "謂曰",
                "24": "願告吾子",
                "25": "漢王長者",
                "26": "必得天下",
                "27": "子謹事之",
                "28": "無有二心",
                "29": "遂對漢使伏劍而死",
                "30": "以固勉陵",
                "31": "其後",
                "32": "果定於漢",
                "33": "陵爲宰相",
                "34": "封侯",
                "35": "夫以匹婦之明",
                "36": "猶能推事理之致",
                "37": "探禍福之機",
                "38": "全宗祀於無窮",
                "39": "垂冊書於春秋",
                "40": "而況大丈夫之事乎",
                "41": "是故窮達有命",
                "42": "吉凶由人",
                "43": "嬰母知廢",
                "44": "陵母知興",
                "45": "審此二者",
                "46": "帝王之分決矣"
            }
        },
        "4": {
            "9": {
                "1": "蓋在高祖",
                "2": "其興也有五",
                "3": "一曰帝堯之苗裔",
                "4": "二曰體貌多奇異",
                "5": "三曰神武有徵應",
                "6": "四曰寬明而仁恕",
                "7": "五曰知人善任使",
                "8": "加之以信誠好謀",
                "9": "達於聽受",
                "10": "見善如不及",
                "11": "用人如由己",
                "12": "從諫如順流",
                "13": "趣時如響起",
                "14": "當食吐哺",
                "15": "納子房之策",
                "16": "拔足揮洗",
                "17": "揖酈生之說",
                "18": "悟戍卒之言",
                "19": "斷懷土之情",
                "20": "高四皓之名",
                "21": "割肌膚之愛",
                "22": "舉韓信於行陣",
                "23": "收陳平於亡命",
                "24": "英雄陳力",
                "25": "羣策畢舉",
                "26": "此高祖之大略",
                "27": "所以成帝業也",
                "28": "若乃靈瑞符應",
                "29": "又可略聞矣",
                "30": "初劉媼妊高祖",
                "31": "而夢與神遇",
                "32": "震電晦冥",
                "33": "有龍蛇之怪",
                "34": "及長而多靈",
                "35": "有異於眾",
                "36": "是以王武感物而折契",
                "37": "呂公睹形而進女",
                "38": "秦皇東遊以厭其氣",
                "39": "呂后望雲而知所處",
                "40": "始受命則白蛇分",
                "41": "西入關則五星聚",
                "42": "故淮陰留侯謂之天授",
                "43": "非人力也"
            }
        },
        "5": {
            "11": {
                "1": "歷古今之得失",
                "2": "驗行事之成敗",
                "3": "稽帝王之世運",
                "4": "考五者之所謂",
                "5": "取舍不厭斯位",
                "6": "符瑞不同斯度",
                "7": "而苟昧權利",
                "8": "越次妄據",
                "9": "外不量力",
                "10": "內不知命",
                "11": "則必喪保家之主",
                "12": "失天年之壽",
                "13": "遇折足之凶",
                "14": "伏斧鉞之誅",
                "15": "英雄誠知覺寤",
                "16": "畏若禍戒",
                "17": "超然遠覽",
                "18": "淵然深識",
                "19": "收陵嬰之明分",
                "20": "絕信布之覬覦",
                "21": "距逐鹿之瞽說",
                "22": "審神器之有授",
                "23": "貪不可冀",
                "24": "無爲二母之所笑",
                "25": "則福祚流於子孫",
                "26": "天祿其永終矣"
            }
        }
    }
}