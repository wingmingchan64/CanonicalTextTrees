{
    "24.10": {
        "篇名": "何敬祖 贈張華",
        "1": {
            "3": {
                "1": "四時更代謝",
                "2": "懸象迭卷舒",
                "3": "暮春忽復來",
                "4": "和風與節俱",
                "5": "俯臨清泉涌",
                "6": "仰觀嘉木敷",
                "7": "周旋我陋圃",
                "8": "西瞻廣武廬",
                "9": "旣貴不忘儉",
                "10": "處有能存無",
                "11": "鎭俗在簡約",
                "12": "樹塞焉足摹",
                "13": "在昔同班司",
                "14": "今者並園墟",
                "15": "私願偕黃髮",
                "16": "逍遙綜琴書",
                "17": "舉爵茂陰下",
                "18": "攜手共躊躇",
                "19": "奚用遺形骸",
                "20": "忘筌在得魚"
            }
        }
    }
}