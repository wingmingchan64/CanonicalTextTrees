{
    "24.09-02": {
        "篇名": "張茂先 答何劭二首·其二",
        "1": {
            "3": {
                "1": "洪鈞陶萬類",
                "2": "大塊稟羣生",
                "3": "明闇信異姿",
                "4": "靜躁亦殊形",
                "5": "自予及有識",
                "6": "志不在功名",
                "7": "虛恬竊所好",
                "8": "文學少所經",
                "9": "忝荷旣過任",
                "10": "白日已西傾",
                "11": "道長苦智短",
                "12": "責重困才輕",
                "13": "周任有遺規",
                "14": "其言明且清",
                "15": "負乘爲我戒",
                "16": "夕惕坐自驚",
                "17": "是用感嘉貺",
                "18": "寫心出中誠",
                "19": "發篇雖溫麗",
                "20": "無乃違其情"
            }
        }
    }
}