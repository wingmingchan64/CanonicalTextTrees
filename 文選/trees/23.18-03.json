{
    "23.18-03": {
        "篇名": "劉公幹 贈從弟三首·其三",
        "1": {
            "3": {
                "1": "鳳凰集南嶽",
                "2": "徘徊孤竹根",
                "3": "於心有不厭",
                "4": "奮翅凌紫氛",
                "5": "豈不常勤苦",
                "6": "羞與黃雀羣",
                "7": "何時當來儀",
                "8": "將須聖明君"
            }
        }
    }
}