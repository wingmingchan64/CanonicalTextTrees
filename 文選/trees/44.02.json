{
    "44.02": {
        "篇名": "陳孔璋 爲袁紹檄豫州",
        "1": {
            "3": {
                "1": "左將軍領豫州刺史郡國相守",
                "2": "蓋聞明主圖危以制變",
                "3": "忠臣慮難以立權",
                "4": "是以有非常之人",
                "5": "然後有非常之事",
                "6": "有非常之事",
                "7": "然後立非常之功",
                "8": "夫非常者",
                "9": "故非常人所擬也"
            }
        },
        "2": {
            "5": {
                "1": "曩者彊秦弱主",
                "2": "趙高執柄",
                "3": "專制朝權",
                "4": "威福由己",
                "5": "時人迫脅",
                "6": "莫敢正言",
                "7": "終有望夷之敗",
                "8": "祖宗焚滅",
                "9": "汙辱至今",
                "10": "永爲世鑒",
                "11": "及臻呂后季年",
                "12": "產祿專政",
                "13": "內兼二軍",
                "14": "外統梁趙",
                "15": "擅斷萬機",
                "16": "決事省禁",
                "17": "下凌上替",
                "18": "海內寒心",
                "19": "於是絳侯朱虛興兵奮怒",
                "20": "誅夷逆暴",
                "21": "尊立太宗",
                "22": "故能王道興隆",
                "23": "光明顯融",
                "24": "此則大臣立權之明表也"
            }
        },
        "3": {
            "7": {
                "1": "司空曹操祖父中常侍騰",
                "2": "與左悺徐璜並作妖孼",
                "3": "饕餮放橫",
                "4": "傷化虐民",
                "5": "父嵩",
                "6": "乞匄攜養",
                "7": "因贓假位",
                "8": "輿金輦璧",
                "9": "輸貨權門",
                "10": "竊盜鼎司",
                "11": "傾覆重器",
                "12": "操贅閹遺醜",
                "13": "本無懿德",
                "14": "𤡑狡鋒協",
                "15": "好亂樂禍",
                "16": "幕府董統鷹揚",
                "17": "掃除凶逆",
                "18": "續遇董卓侵官暴國",
                "19": "於是提劍揮鼓",
                "20": "發命東夏",
                "21": "收羅英雄",
                "22": "棄瑕取用",
                "23": "故遂與操同諮合謀",
                "24": "授以裨師",
                "25": "謂其鷹犬之才",
                "26": "爪牙可任",
                "27": "至乃愚佻短略",
                "28": "輕進易退",
                "29": "傷夷折衄",
                "30": "數喪師徒",
                "31": "幕府輒復分兵命銳",
                "32": "修完補輯",
                "33": "表行東郡",
                "34": "領兗州刺史",
                "35": "被以虎文",
                "36": "獎蹙威柄",
                "37": "冀獲秦師一克之報",
                "38": "而操遂承資跋扈",
                "39": "肆行凶忒",
                "40": "割剝元元",
                "41": "殘賢害善",
                "42": "故九江太守邊讓",
                "43": "英才俊偉",
                "44": "天下知名",
                "45": "直言正色",
                "46": "論不阿諂",
                "47": "身首被梟懸之誅",
                "48": "妻孥受灰滅之咎",
                "49": "自是士林憤痛",
                "50": "民怨彌重",
                "51": "一夫奮臂",
                "52": "舉州同聲",
                "53": "故躬破於徐方",
                "54": "地奪於呂布",
                "55": "彷徨東裔",
                "56": "蹈據無所",
                "57": "幕府惟強幹弱枝之義",
                "58": "且不登叛人之黨",
                "59": "故復援旌擐甲",
                "60": "席卷起征",
                "61": "金鼓響振",
                "62": "布眾奔沮",
                "63": "拯其死亡之患",
                "64": "復其方伯之位",
                "65": "則幕府無德於兗土之民",
                "66": "而有大造於操也"
            }
        },
        "4": {
            "9": {
                "1": "後會鸞賀反旆",
                "2": "羣虜寇攻",
                "3": "時冀州方有北鄙之警",
                "4": "匪遑離局",
                "5": "故使從事中郎徐勛就發遣操",
                "6": "使繕修郊廟",
                "7": "翊衞幼主",
                "8": "操便放志專行",
                "9": "脅遷當御省禁",
                "10": "卑侮王室",
                "11": "敗法亂紀",
                "12": "坐領三臺",
                "13": "專制朝政",
                "14": "爵賞由心",
                "15": "刑戮在口",
                "16": "所愛光五宗",
                "17": "所惡滅三族",
                "18": "羣談者受顯誅",
                "19": "腹議者蒙隱戮",
                "20": "百僚鉗口",
                "21": "道路以目",
                "22": "尙書記朝會",
                "23": "公卿充員品而已"
            }
        },
        "5": {
            "11": {
                "1": "故太尉楊彪",
                "2": "典歷二司",
                "3": "享國極位",
                "4": "操因緣眥睚",
                "5": "被以非罪",
                "6": "榜楚參幷",
                "7": "五毒備至",
                "8": "觸情任忒",
                "9": "不顧憲網",
                "10": "又議郎趙彥",
                "11": "忠諫直言",
                "12": "義有可納",
                "13": "是以聖朝含聽",
                "14": "改容加飾",
                "15": "操欲迷奪時明",
                "16": "杜絕言路",
                "17": "擅收立殺",
                "18": "不俟報聞",
                "19": "又梁孝王先帝母昆",
                "20": "墳陵尊顯",
                "21": "桑梓松柏",
                "22": "猶宜肅恭",
                "23": "而操帥將吏士",
                "24": "親臨發掘",
                "25": "破棺裸尸",
                "26": "掠取金寶",
                "27": "至令聖朝流涕",
                "28": "士民傷懷",
                "29": "操又特置發丘中郎將摸金校尉",
                "30": "所過隳突",
                "31": "無骸不露",
                "32": "身處三公之位",
                "33": "而行桀虜之態",
                "34": "汙國虐民",
                "35": "毒施人鬼",
                "36": "加其細政苛慘",
                "37": "科防互設",
                "38": "罾繳充蹊",
                "39": "坑阱塞路",
                "40": "舉手挂網羅",
                "41": "動足觸機陷",
                "42": "是以兗豫有無聊之民",
                "43": "帝都有吁嗟之怨"
            }
        },
        "6": {
            "13": {
                "1": "歷觀載籍",
                "2": "無道之臣",
                "3": "貪殘酷烈",
                "4": "於操爲甚",
                "5": "幕府方詰外姦",
                "6": "未及整訓",
                "7": "加緒含容",
                "8": "冀可彌縫",
                "9": "而操豺狼野心",
                "10": "潛包禍謀",
                "11": "乃欲摧橈棟梁",
                "12": "孤弱漢室",
                "13": "除滅忠正",
                "14": "專爲梟雄",
                "15": "往者伐鼓北征公孫瓚",
                "16": "強寇桀逆",
                "17": "拒圍一年",
                "18": "操因其未破",
                "19": "陰交書命",
                "20": "外助王師",
                "21": "內相掩襲",
                "22": "故引兵造河",
                "23": "方舟北濟",
                "24": "會其行人發露",
                "25": "瓚亦梟夷",
                "26": "故使鋒芒挫縮",
                "27": "厥圖不果",
                "28": "爾乃大軍過蕩西山",
                "29": "屠各左校",
                "30": "皆束手奉質",
                "31": "爭爲前登",
                "32": "犬羊殘醜",
                "33": "消淪山谷",
                "34": "於是操師震慴",
                "35": "晨夜逋遁",
                "36": "屯據敖倉",
                "37": "阻河爲固",
                "38": "欲以螗蜋之斧",
                "39": "禦隆車之隧",
                "40": "幕府奉漢威靈",
                "41": "折衝宇宙",
                "42": "長戟百萬",
                "43": "胡騎千羣",
                "44": "奮中黃育獲之士",
                "45": "騁良弓勁弩之勢",
                "46": "幷州越太行",
                "47": "青州涉濟漯",
                "48": "大軍泛黃河而角其前",
                "49": "荊州下宛葉而掎其後",
                "50": "雷霆虎步",
                "51": "並集虜庭",
                "52": "若舉炎火以槪飛蓬",
                "53": "覆滄海以沃熛炭",
                "54": "有何不滅者哉"
            }
        },
        "7": {
            "15": {
                "1": "又操軍吏士",
                "2": "其可戰者皆自出幽冀",
                "3": "或故營部曲",
                "4": "咸怨曠思歸",
                "5": "流涕北顧",
                "6": "其餘兗豫之民",
                "7": "及呂布張揚之遺眾",
                "8": "覆亡迫脅",
                "9": "權時苟從",
                "10": "各被創夷",
                "11": "人爲讎敵",
                "12": "若迴旆方徂",
                "13": "登高岡而擊鼓吹",
                "14": "揚素揮以啟降路",
                "15": "必土崩瓦解",
                "16": "不俟血刃"
            }
        },
        "8": {
            "17": {
                "1": "方今漢室陵遲",
                "2": "綱維弛絕",
                "3": "聖朝無一介之輔",
                "4": "股肱無折衝之勢",
                "5": "方畿之內",
                "6": "簡練之臣",
                "7": "皆垂頭搨翼",
                "8": "莫所憑恃",
                "9": "雖有忠義之佐",
                "10": "脅於暴虐之臣",
                "11": "焉能展其節",
                "12": "又操持部曲精兵七百",
                "13": "圍守宮闕",
                "14": "外託宿衞",
                "15": "內實拘執",
                "16": "懼其篡逆之萌",
                "17": "因斯而作",
                "18": "此乃忠臣肝腦塗地之秋",
                "19": "烈士立功之會",
                "20": "可不勖哉"
            }
        },
        "9": {
            "19": {
                "1": "操又矯命稱制",
                "2": "遣使發兵",
                "3": "恐邊遠州郡",
                "4": "過聽而給與",
                "5": "強寇弱主",
                "6": "違眾旅叛",
                "7": "舉以喪名",
                "8": "爲天下笑",
                "9": "則明哲不取也",
                "10": "卽日幽幷青冀四州並進",
                "11": "書到荊州",
                "12": "便勒見兵",
                "13": "與建忠將軍協同聲勢",
                "14": "州郡各整戎馬",
                "15": "羅落境界",
                "16": "舉師揚威",
                "17": "並匡社稷",
                "18": "則非常之功",
                "19": "於是乎著",
                "20": "其得操首者",
                "21": "封五千戶侯",
                "22": "賞錢五千萬",
                "23": "部曲偏裨將校諸吏降者",
                "24": "勿有所問",
                "25": "廣宣恩信",
                "26": "班揚符賞",
                "27": "布告天下",
                "28": "咸使知聖朝有拘逼之難",
                "29": "如律令"
            }
        }
    }
}