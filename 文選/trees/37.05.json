{
    "37.05": {
        "篇名": "羊叔子 讓開府表",
        "1": {
            "3": {
                "1": "臣祜言",
                "2": "臣昨出",
                "3": "伏聞恩詔",
                "4": "拔臣使同台司",
                "5": "臣自出身已來",
                "6": "適十數年",
                "7": "受任外內",
                "8": "每極顯重之地",
                "9": "常以智力不可強進",
                "10": "恩寵不可久謬",
                "11": "夙夜戰慄",
                "12": "以榮爲憂",
                "13": "臣聞古人之言",
                "14": "德未爲眾所服",
                "15": "而受高爵",
                "16": "則使才臣不進",
                "17": "功未爲眾所歸",
                "18": "而荷厚祿",
                "19": "則使勞臣不勸",
                "20": "今臣身託外戚",
                "21": "事遭運會",
                "22": "誡在寵過",
                "23": "不患見遺",
                "24": "而猥超然降發中之詔",
                "25": "加非次之榮",
                "26": "臣有何功可以堪之",
                "27": "何心可以安之",
                "28": "以身誤陛下",
                "29": "辱高位",
                "30": "傾覆亦尋而至",
                "31": "願復守先人敝廬",
                "32": "豈可得哉",
                "33": "違命誠忤天威",
                "34": "曲從卽復若此",
                "35": "蓋聞古人申於見知",
                "36": "大臣之節",
                "37": "不可則止",
                "38": "臣雖小人",
                "39": "敢緣所蒙",
                "40": "念存斯義"
            }
        },
        "2": {
            "5": {
                "1": "今天下自服化已來",
                "2": "方漸八年",
                "3": "雖側席求賢",
                "4": "不遺幽賤",
                "5": "然臣等不能推有德",
                "6": "進有功",
                "7": "使聖聽知勝臣者多",
                "8": "而未達者不少",
                "9": "假令有遺德於板築之下",
                "10": "有隱才於屠釣之間",
                "11": "而令朝議用臣不以爲非",
                "12": "臣處之不以爲愧",
                "13": "所失豈不大哉"
            }
        },
        "3": {
            "7": {
                "1": "且臣忝竊雖久",
                "2": "未若今日兼文武之極寵",
                "3": "等宰輔之高位也",
                "4": "臣所見雖狹",
                "5": "據今光祿大夫李喜",
                "6": "秉節高亮",
                "7": "正身在朝",
                "8": "光祿大夫魯芝",
                "9": "絜身寡欲",
                "10": "和而不同",
                "11": "光祿大夫李胤",
                "12": "蒞政弘簡",
                "13": "在公正色",
                "14": "皆服事華髮",
                "15": "以禮終始",
                "16": "雖歷內外之寵",
                "17": "不異寒賤之家",
                "18": "而猶未蒙此選",
                "19": "臣更越之",
                "20": "何以塞天下之望",
                "21": "少益日月",
                "22": "是以誓心守節",
                "23": "無苟進之志"
            }
        },
        "4": {
            "9": {
                "1": "今道路未通",
                "2": "方隅多事",
                "3": "乞留前恩",
                "4": "使臣得速還屯",
                "5": "不爾留連",
                "6": "必於外虞有闕",
                "7": "臣不勝憂懼",
                "8": "謹觸冒拜表",
                "9": "惟陛下察匹夫之志",
                "10": "不可以奪"
            }
        }
    }
}