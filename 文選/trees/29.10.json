{
    "29.10": {
        "篇名": "曹子建 情詩",
        "1": {
            "3": {
                "1": "微陰翳陽景",
                "2": "清風飄我衣",
                "3": "遊魚潛淥水",
                "4": "翔鳥薄天飛",
                "5": "眇眇客行士",
                "6": "遙役不得歸",
                "7": "始出嚴霜結",
                "8": "今來白露晞",
                "9": "遊子歎黍離",
                "10": "處者歌式微",
                "11": "慷慨對嘉賓",
                "12": "悽愴內傷悲"
            }
        }
    }
}