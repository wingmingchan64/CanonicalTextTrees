{
    "03.01": {
        "篇名": "張平子 東京賦",
        "1": {
            "3": {
                "1": "安處先生於是似不能言",
                "2": "憮然有間",
                "3": "乃莞爾而笑曰",
                "4": "若客所謂",
                "5": "末學膚受",
                "6": "貴耳而賤目者也",
                "7": "苟有胸而無心",
                "8": "不能節之以禮",
                "9": "宜其陋今而榮古矣",
                "10": "由余以西戎孤臣",
                "11": "而悝繆公於宮室",
                "12": "如之何其以溫故知新",
                "13": "硏覈是非",
                "14": "近於此惑"
            }
        },
        "2": {
            "5": {
                "1": "周姬之末",
                "2": "不能厥政",
                "3": "政用多僻",
                "4": "始於宮鄰",
                "5": "卒於金虎",
                "6": "嬴氏搏翼",
                "7": "擇肉西邑",
                "8": "是時也",
                "9": "七雄並爭",
                "10": "競相高以奢麗",
                "11": "楚築章華於前",
                "12": "趙建叢臺於後",
                "13": "秦政利觜長距",
                "14": "終得擅場",
                "15": "思專其侈",
                "16": "以莫己若",
                "17": "迺構阿房",
                "18": "起甘泉",
                "19": "結雲閣",
                "20": "冠南山",
                "21": "征稅盡",
                "22": "人力殫",
                "23": "然後收以太半之賦",
                "24": "威以參夷之刑",
                "25": "其遇民也",
                "26": "若薙氏之芟草",
                "27": "旣蘊崇之",
                "28": "又行火焉",
                "29": "𢛐𢛐黔首",
                "30": "豈徒跼高天",
                "31": "蹐厚地而已哉",
                "32": "乃救死於其頸",
                "33": "敺以就役",
                "34": "唯力是視",
                "35": "百姓弗能忍",
                "36": "是用息肩於大漢而欣戴高祖"
            }
        },
        "3": {
            "7": {
                "1": "高祖膺籙受圖",
                "2": "順天行誅",
                "3": "杖朱旗而建大號",
                "4": "所推必亡",
                "5": "所存必固",
                "6": "掃項軍於垓下",
                "7": "紲子嬰於軹塗",
                "8": "因秦宮室",
                "9": "據其府庫",
                "10": "作洛之制",
                "11": "我則未暇",
                "12": "是以西匠營宮",
                "13": "目翫阿房",
                "14": "規摹踰溢",
                "15": "不度不臧",
                "16": "損之又損之",
                "17": "然尙過於周堂",
                "18": "觀者狹而謂之陋",
                "19": "帝已譏其泰而弗康"
            }
        },
        "4": {
            "9": {
                "1": "且高旣受命建家",
                "2": "造我區夏矣",
                "3": "文又躬自菲薄",
                "4": "治致升平之德",
                "5": "武有大啟土宇",
                "6": "紀禪肅然之功",
                "7": "宣重威以撫和",
                "8": "戎狄呼韓來享",
                "9": "咸用紀宗存主",
                "10": "饗祀不輟",
                "11": "銘勳彝器",
                "12": "歷世彌光",
                "13": "今捨純懿而論爽德",
                "14": "以春秋所諱而爲美談",
                "15": "宜無嫌於往初",
                "16": "故蔽善而揚惡",
                "17": "祇吾子之不知言也",
                "18": "必以肆奢爲賢",
                "19": "則是黃帝合宮",
                "20": "有虞總期",
                "21": "固不如夏癸之瑤臺",
                "22": "殷辛之瓊室也",
                "23": "湯武誰革而用師哉",
                "24": "盍亦覽東京之事以自寤乎"
            }
        },
        "5": {
            "11": {
                "1": "且天子有道",
                "2": "守在海外",
                "3": "守位以仁",
                "4": "不恃隘害",
                "5": "苟民志之不諒",
                "6": "何云巖險與襟帶",
                "7": "秦負阻於二關",
                "8": "卒開項而受沛",
                "9": "彼偏據而規小",
                "10": "豈如宅中而圖大"
            }
        },
        "6": {
            "13": {
                "1": "昔先王之經邑也",
                "2": "掩觀九隩",
                "3": "靡地不營",
                "4": "土圭測景",
                "5": "不縮不盈",
                "6": "總風雨之所交",
                "7": "然後以建王城",
                "8": "審曲面勢",
                "9": "泝洛背河",
                "10": "左伊右瀍",
                "11": "西阻九阿",
                "12": "東門於旋",
                "13": "盟津達其後",
                "14": "太谷通其前",
                "15": "迴行道乎伊闕",
                "16": "邪徑捷乎轘轅",
                "17": "大室作鎭",
                "18": "揭以熊耳",
                "19": "底柱輟流",
                "20": "鐔以大岯",
                "21": "溫液湯泉",
                "22": "黑丹石緇",
                "23": "王鮪岫居",
                "24": "能鼈三趾",
                "25": "宓妃攸館",
                "26": "神用挺紀",
                "27": "龍圖授羲",
                "28": "龜書畀姒",
                "29": "召伯相宅",
                "30": "卜惟洛食",
                "31": "周公初基",
                "32": "其繩則直",
                "33": "萇弘魏舒",
                "34": "是廓是極",
                "35": "經途九軌",
                "36": "城隅九雉",
                "37": "度堂以筵",
                "38": "度室以几",
                "39": "京邑翼翼",
                "40": "四方所視",
                "41": "漢初弗之宅",
                "42": "故宗緒中圮"
            }
        },
        "7": {
            "15": {
                "1": "巨猾間舋",
                "2": "竊弄神器",
                "3": "歷載三六",
                "4": "偸安天位",
                "5": "於時蒸民",
                "6": "罔敢或貳",
                "7": "其取威也重矣",
                "8": "我世祖忿之",
                "9": "乃龍飛白水",
                "10": "鳳翔參墟",
                "11": "授鉞四七",
                "12": "共工是除",
                "13": "欃槍旬始",
                "14": "羣凶靡餘",
                "15": "區宇乂寧",
                "16": "思和求中",
                "17": "睿哲玄覽",
                "18": "都茲洛宮",
                "19": "曰止曰時",
                "20": "昭明有融",
                "21": "旣光厥武",
                "22": "仁洽道豐",
                "23": "登岱勒封",
                "24": "與黃比崇"
            }
        },
        "8": {
            "17": {
                "1": "逮至顯宗",
                "2": "六合殷昌",
                "3": "乃新崇德",
                "4": "遂作德陽",
                "5": "啟南端之特闈",
                "6": "立應門之將將",
                "7": "昭仁惠於崇賢",
                "8": "抗義聲於金商",
                "9": "飛雲龍於春路",
                "10": "屯神虎於秋方",
                "11": "建象魏之兩觀",
                "12": "旌六典之舊章",
                "13": "其內則含德章臺",
                "14": "天祿宣明",
                "15": "溫飭迎春",
                "16": "壽安永寧",
                "17": "飛閣神行",
                "18": "莫我能形",
                "19": "濯龍芳林",
                "20": "九谷八溪",
                "21": "芙蓉覆水",
                "22": "秋蘭被涯渚戲躍魚",
                "23": "淵遊龜𧓈永安離宮",
                "24": "修竹冬青",
                "25": "陰池幽流",
                "26": "玄泉洌清",
                "27": "鵯鶋秋栖",
                "28": "鶻鵃春鳴",
                "29": "鴡鳩麗黃",
                "30": "關關嚶嚶",
                "31": "於南則前殿靈臺",
                "32": "龢歡安福",
                "33": "謻門曲榭",
                "34": "邪阻城洫",
                "35": "奇樹珍果",
                "36": "鉤盾所職",
                "37": "西登少華",
                "38": "亭候修敕",
                "39": "九龍之內",
                "40": "寔曰嘉德",
                "41": "西南其戶",
                "42": "匪雕匪刻",
                "43": "我后好約",
                "44": "乃宴斯息",
                "45": "於東則洪池清蘌",
                "46": "淥水澹澹",
                "47": "內阜川禽",
                "48": "外豐葭菼",
                "49": "獻鼈蜃與龜魚",
                "50": "供蝸蠯與菱芡",
                "51": "其西則有平樂都場",
                "52": "示遠之觀",
                "53": "龍雀蟠蜿",
                "54": "天馬半漢",
                "55": "瑰異譎詭",
                "56": "燦爛炳煥",
                "57": "奢未及侈",
                "58": "儉而不陋",
                "59": "規遵王度",
                "60": "動中得趣"
            }
        },
        "9": {
            "19": {
                "1": "於是觀禮",
                "2": "禮舉儀具",
                "3": "經始勿亟",
                "4": "成之不日",
                "5": "猶謂爲之者勞",
                "6": "居之者逸",
                "7": "慕唐虞之茅茨",
                "8": "思夏后之卑室",
                "9": "乃營三宮",
                "10": "布教頒常",
                "11": "複廟重屋",
                "12": "八達九房",
                "13": "規天矩地",
                "14": "授時順鄕",
                "15": "造舟清池",
                "16": "惟水泱泱",
                "17": "左制辟雍",
                "18": "右立靈臺",
                "19": "因進距衰",
                "20": "表賢簡能",
                "21": "馮相觀祲",
                "22": "祈禠禳災"
            }
        },
        "10": {
            "21": {
                "1": "於是孟春元日",
                "2": "羣后旁戾",
                "3": "百僚師師",
                "4": "於斯胥洎",
                "5": "藩國奉聘",
                "6": "要荒來質",
                "7": "具惟帝臣",
                "8": "獻琛執贄",
                "9": "當覲乎殿下者",
                "10": "蓋數萬以二",
                "11": "爾乃九賓重",
                "12": "臚人列",
                "13": "崇牙張",
                "14": "鏞鼓設",
                "15": "郎將司階",
                "16": "虎戟交鎩龍輅充庭",
                "17": "雲旗拂霓",
                "18": "夏正三朝",
                "19": "庭燎晢晢",
                "20": "撞洪鍾",
                "21": "伐靈鼓",
                "22": "旁震八鄙",
                "23": "軯礚隱訇若疾霆轉雷而激迅風也"
            }
        },
        "11": {
            "23": {
                "1": "是時稱警蹕已下雕輦於東廂",
                "2": "冠通天",
                "3": "佩玉璽",
                "4": "紆皇組",
                "5": "要干將",
                "6": "負斧扆",
                "7": "次席紛純",
                "8": "左右玉几而南面以聽矣",
                "9": "然後百辟乃入",
                "10": "司儀辨等",
                "11": "尊卑以班",
                "12": "璧羔皮帛之贄旣奠",
                "13": "天子乃以三揖之禮禮之",
                "14": "穆穆焉",
                "15": "皇皇焉",
                "16": "濟濟焉",
                "17": "將將焉",
                "18": "信天下之壯觀也",
                "19": "乃羨公侯卿士",
                "20": "登自東除",
                "21": "訪萬機",
                "22": "詢朝政",
                "23": "勤卹民隱",
                "24": "而除其眚",
                "25": "人或不得其所",
                "26": "若己納之於隍",
                "27": "荷天下之重任",
                "28": "匪怠皇以寧靜",
                "29": "發京倉",
                "30": "散禁財",
                "31": "賚皇僚",
                "32": "逮輿臺",
                "33": "命膳夫以大饗",
                "34": "饔餼浹乎家陪",
                "35": "春醴惟醇",
                "36": "燔炙芬芬",
                "37": "君臣歡康",
                "38": "具醉熏熏",
                "39": "千品萬官",
                "40": "已事而踆勤屢省",
                "41": "懋乾乾",
                "42": "清風協於玄德",
                "43": "淳化通於自然",
                "44": "憲先靈而齊軌",
                "45": "必三思以顧愆",
                "46": "招有道於側陋",
                "47": "開敢諫之直言",
                "48": "聘丘園之耿絜",
                "49": "旅束帛之戔戔",
                "50": "上下通情",
                "51": "式宴且盤"
            }
        },
        "12": {
            "25": {
                "1": "及將祀天郊",
                "2": "報地功",
                "3": "祈福乎上玄",
                "4": "思所以爲虔",
                "5": "肅肅之儀盡",
                "6": "穆穆之禮殫",
                "7": "然後以獻精誠",
                "8": "奉禋祀",
                "9": "曰",
                "10": "允矣",
                "11": "天子者也",
                "12": "乃整法服",
                "13": "正冕帶",
                "14": "珩紞紘綖",
                "15": "玉笄綦會",
                "16": "火龍黼黻",
                "17": "藻繂鞶厲",
                "18": "結飛雲之袷輅",
                "19": "樹翠羽之高蓋",
                "20": "建辰旒之太常",
                "21": "紛焱悠以容裔",
                "22": "六玄虯之弈弈",
                "23": "齊騰驤而沛艾",
                "24": "龍輈華轙",
                "25": "金鋄鏤鍚",
                "26": "方釳左纛",
                "27": "鉤膺玉瓖",
                "28": "鑾聲噦噦",
                "29": "和鈴鉠鉠",
                "30": "重輪貳轄",
                "31": "䟽轂飛軨",
                "32": "羽蓋威蕤",
                "33": "葩瑵曲莖",
                "34": "順時服而設副",
                "35": "咸龍旂而繁纓",
                "36": "立戈迆戛",
                "37": "農輿輅木",
                "38": "屬車九九",
                "39": "乘軒並轂",
                "40": "𨌥弩重旃",
                "41": "朱旄青屋",
                "42": "奉引旣畢",
                "43": "先輅乃發",
                "44": "鸞旗皮軒",
                "45": "通帛綪旆",
                "46": "雲罕九斿",
                "47": "闟戟轇輵",
                "48": "髶髦被繡",
                "49": "虎夫戴鶡",
                "50": "駙承華之蒲梢",
                "51": "飛流蘇之騷殺",
                "52": "總輕武於後陳",
                "53": "奏嚴鼓之嘈囐",
                "54": "戎士介而揚揮",
                "55": "戴金鉦而建黃鉞",
                "56": "清道案列",
                "57": "天行星陳",
                "58": "肅肅習習",
                "59": "隱隱轔轔",
                "60": "殿未出乎城闕",
                "61": "旆已反乎郊畛",
                "62": "盛夏后之致美",
                "63": "爰敬恭於明神"
            }
        },
        "13": {
            "27": {
                "1": "爾乃孤竹之管",
                "2": "雲和之瑟",
                "3": "雷鼓鼝鼝",
                "4": "六變旣畢",
                "5": "冠華秉翟",
                "6": "列舞八佾",
                "7": "元祀惟稱",
                "8": "羣望咸秩",
                "9": "颺槱燎之炎煬",
                "10": "致高煙乎太一",
                "11": "神歆馨而顧德",
                "12": "祚靈主以元吉",
                "13": "然後宗上帝於明堂",
                "14": "推光武以作配",
                "15": "辯方位而正則",
                "16": "五精帥而來摧",
                "17": "尊赤氏之朱光",
                "18": "四靈懋而允懷",
                "19": "於是春秋改節",
                "20": "四時迭代",
                "21": "蒸蒸之心",
                "22": "感物曾思",
                "23": "躬追養於廟祧",
                "24": "奉蒸嘗與禴祠",
                "25": "物牲辯省",
                "26": "設其楅衡",
                "27": "毛炰豚胉",
                "28": "亦有和羹",
                "29": "滌濯靜嘉",
                "30": "禮儀孔明",
                "31": "萬舞奕奕",
                "32": "鍾鼓喤喤",
                "33": "靈祖皇考",
                "34": "來顧來饗神具醉止",
                "35": "降福穰穰"
            }
        },
        "14": {
            "29": {
                "1": "及至農祥晨正",
                "2": "土膏脈起",
                "3": "乘鑾輅而駕蒼龍",
                "4": "介馭間以剡耜",
                "5": "躬三推於天田",
                "6": "修帝籍之千畝",
                "7": "供禘郊之粢盛",
                "8": "必致思乎勤己",
                "9": "兆民勸於疆埸",
                "10": "感懋力以耘耔春日載陽",
                "11": "合射辟雍",
                "12": "設業設虡",
                "13": "宮懸金鏞",
                "14": "鼖鼓路鼗",
                "15": "樹羽幢幢",
                "16": "於是備物",
                "17": "物有其容",
                "18": "伯夷起而相儀",
                "19": "后夔坐而爲工",
                "20": "張大侯",
                "21": "制五正",
                "22": "設三乏",
                "23": "厞司旌",
                "24": "幷夾旣設",
                "25": "儲乎廣庭",
                "26": "於是皇輿夙駕",
                "27": "䡨於東階",
                "28": "以須消啟明",
                "29": "掃朝霞",
                "30": "登天光於扶桑",
                "31": "天子乃撫玉輅",
                "32": "時乘六龍",
                "33": "發鯨魚",
                "34": "鏗華鍾",
                "35": "大丙弭節",
                "36": "風后陪乘",
                "37": "攝提運衡",
                "38": "徐至於射宮",
                "39": "禮事展",
                "40": "樂物具",
                "41": "王夏闋",
                "42": "騶虞奏",
                "43": "決拾旣次",
                "44": "彫弓斯彀達餘萌於暮春",
                "45": "昭誠心以遠喩",
                "46": "進明德而崇業",
                "47": "滌饕餮之貪慾",
                "48": "仁風衍而外流",
                "49": "誼方激而遐騖",
                "50": "日月會於龍狵",
                "51": "卹民事之勞疚",
                "52": "因休力以息勤",
                "53": "致歡忻於春酒",
                "54": "執鑾刀以袒割",
                "55": "奉觴豆於國叟",
                "56": "降至尊以訓恭",
                "57": "送迎拜乎三壽",
                "58": "敬愼威儀",
                "59": "示民不偸我有嘉賓",
                "60": "其樂愉愉",
                "61": "聲教布濩",
                "62": "盈溢天區"
            }
        },
        "15": {
            "31": {
                "1": "文德旣昭",
                "2": "武節是宣",
                "3": "三農之隙",
                "4": "曜威中原",
                "5": "歲惟仲冬",
                "6": "大閱西園",
                "7": "虞人掌焉",
                "8": "先期戒事",
                "9": "悉率百禽",
                "10": "鳩諸靈囿",
                "11": "獸之所同",
                "12": "是謂告備",
                "13": "乃御小戎",
                "14": "撫輕軒",
                "15": "中畋四牡",
                "16": "旣佶且閑",
                "17": "戈矛若林",
                "18": "牙旗繽紛",
                "19": "迄上林",
                "20": "結徒營",
                "21": "次和樹表",
                "22": "司鐸授鉦",
                "23": "坐作進退",
                "24": "節以軍聲",
                "25": "三令五申",
                "26": "示戮斬牲",
                "27": "陳師鞠旅",
                "28": "教達禁成",
                "29": "火列具舉",
                "30": "武士星敷",
                "31": "鵝鸛魚麗",
                "32": "箕張翼舒",
                "33": "軌塵掩迒",
                "34": "匪疾匪徐",
                "35": "馭不詭遇",
                "36": "射不剪毛",
                "37": "升獻六禽",
                "38": "時膳四膏",
                "39": "馬足未極",
                "40": "輿徒不勞",
                "41": "成禮三毆",
                "42": "解罘放麟",
                "43": "不窮樂以訓儉",
                "44": "不殫物以昭仁",
                "45": "慕天乙之弛罟",
                "46": "因教祝以懷民",
                "47": "儀姬伯之渭陽",
                "48": "失熊羆而獲人",
                "49": "澤浸昆蟲",
                "50": "威振八㝢",
                "51": "好樂無荒",
                "52": "允文允武",
                "53": "薄狩於敖",
                "54": "旣璅璅焉",
                "55": "岐陽之蒐",
                "56": "又何足數"
            }
        },
        "16": {
            "33": {
                "1": "爾乃卒歲大儺",
                "2": "毆除羣厲",
                "3": "方相秉鉞",
                "4": "巫覡操茢侲子萬童",
                "5": "丹首玄製",
                "6": "桃弧棘矢",
                "7": "所發無臬",
                "8": "飛礫雨散",
                "9": "剛癉必斃",
                "10": "煌火馳而星流",
                "11": "逐赤疫於四裔",
                "12": "然後凌天池",
                "13": "絕飛梁",
                "14": "捎魑魅",
                "15": "斮獝狂",
                "16": "斬蜲蛇",
                "17": "腦方良",
                "18": "囚耕父於清泠",
                "19": "溺女魃於神潢殘夔魖與罔像",
                "20": "殪野仲而殲遊光",
                "21": "八靈爲之震慴",
                "22": "況鬾𧌒與畢方",
                "23": "度朔作梗",
                "24": "守以鬱壘",
                "25": "神荼副焉",
                "26": "對操索葦",
                "27": "目察區陬",
                "28": "司執遺鬼",
                "29": "京室密清",
                "30": "罔有不韙"
            }
        },
        "17": {
            "35": {
                "1": "於是陰陽交和",
                "2": "庶物時育",
                "3": "卜征考祥",
                "4": "終然允淑",
                "5": "乘輿巡乎岱嶽",
                "6": "勸稼穡於原陸",
                "7": "同衡律而壹軌量",
                "8": "齊急舒於寒燠",
                "9": "省幽明以黜陟",
                "10": "乃反旆而迴復",
                "11": "望先帝之舊墟",
                "12": "慨長思而懷古",
                "13": "俟閶風而西遐",
                "14": "致恭祀乎高祖",
                "15": "旣春遊以發生",
                "16": "啟諸蟄於潛戶",
                "17": "度秋豫以收成",
                "18": "觀豐年之多稌嘉田畯之匪懈",
                "19": "行致賚於九扈",
                "20": "左瞰暘谷",
                "21": "右睨玄圃",
                "22": "眇天末以遠期",
                "23": "規萬世而大摹",
                "24": "且歸來以釋勞",
                "25": "膺多福以安悆",
                "26": "總集瑞命",
                "27": "備致嘉祥",
                "28": "圉林氏之騶虞",
                "29": "擾澤馬與騰黃",
                "30": "鳴女牀之鸞鳥",
                "31": "舞丹穴之鳳皇",
                "32": "植華平於春圃",
                "33": "豐朱草於中唐",
                "34": "惠風廣被",
                "35": "澤洎幽荒",
                "36": "北爕丁令",
                "37": "南諧越裳",
                "38": "西包大秦",
                "39": "東過樂浪",
                "40": "重舌之人九譯",
                "41": "僉稽首而來王"
            }
        },
        "18": {
            "37": {
                "1": "是以論其遷邑易京",
                "2": "則同規乎殷盤",
                "3": "改奢卽儉",
                "4": "則合美乎斯干",
                "5": "登封降禪",
                "6": "則齊德乎黃軒",
                "7": "爲無爲",
                "8": "事無事",
                "9": "永有民以孔安",
                "10": "遵節儉",
                "11": "尙素樸",
                "12": "思仲尼之克己",
                "13": "履老氏之常足",
                "14": "將使心不亂其所在",
                "15": "目不見其可欲",
                "16": "賤犀象",
                "17": "簡珠玉",
                "18": "藏金於山",
                "19": "扺璧於谷",
                "20": "翡翠不裂",
                "21": "瑇瑁不蔟所貴惟賢",
                "22": "所寶惟穀",
                "23": "民去末而反本",
                "24": "咸懷忠而抱慤於斯之時",
                "25": "海內同悅",
                "26": "曰",
                "27": "吁",
                "28": "漢帝之德",
                "29": "侯其褘而",
                "30": "蓋蓂莢爲難蒔也",
                "31": "故曠世而不覿",
                "32": "惟我后能殖之",
                "33": "以至和平",
                "34": "方將數諸朝階",
                "35": "然則道胡不懷",
                "36": "化胡不柔",
                "37": "聲與風翔",
                "38": "澤從雲遊",
                "39": "萬物我賴",
                "40": "亦又何求",
                "41": "德㝢天覆",
                "42": "輝烈光燭",
                "43": "狹三王之趢趗",
                "44": "軼五帝之長驅",
                "45": "踵二皇之遐武",
                "46": "誰謂駕遲而不能屬",
                "47": "東京之懿未罄",
                "48": "値余有犬馬之疾",
                "49": "不能究其精詳",
                "50": "故粗爲賓言其梗槪如此"
            }
        },
        "19": {
            "39": {
                "1": "若乃流遁忘反",
                "2": "放心不覺",
                "3": "樂而無節",
                "4": "後離其戚",
                "5": "一言幾於喪國",
                "6": "我未之學也",
                "7": "且夫挈缾之智",
                "8": "守不假器",
                "9": "況纂帝業",
                "10": "而輕天位",
                "11": "瞻仰二祖",
                "12": "厥庸孔肆",
                "13": "常翹翹以危懼",
                "14": "若乘奔而無轡",
                "15": "白龍魚服",
                "16": "見困豫且",
                "17": "雖萬乘之無懼",
                "18": "猶怵惕於一夫",
                "19": "終日不離其輜重",
                "20": "獨微行其焉如",
                "21": "夫君人者",
                "22": "黈纊塞耳",
                "23": "車中不內顧",
                "24": "珮以制容",
                "25": "鑾以節塗",
                "26": "行不變玉",
                "27": "駕不亂步",
                "28": "卻走馬以糞車",
                "29": "何惜騕褭與飛兔",
                "30": "方其用財取物",
                "31": "常畏生類之殄也",
                "32": "賦政任役",
                "33": "常畏人力之盡也",
                "34": "取之以道",
                "35": "用之以時",
                "36": "山無槎枿",
                "37": "畋不䴠胎",
                "38": "草木蕃廡",
                "39": "鳥獸阜滋",
                "40": "民忘其勞",
                "41": "樂輸其財",
                "42": "百姓同於饒衍",
                "43": "上下共其雍熙",
                "44": "洪恩素蓄",
                "45": "民心固結",
                "46": "執誼顧主",
                "47": "夫懷貞節",
                "48": "忿姦慝之干命",
                "49": "怨皇統之見替玄謀設而陰行",
                "50": "合二九而成譎",
                "51": "登聖皇於天階",
                "52": "章漢祚之有秩",
                "53": "若此",
                "54": "故王業可樂焉"
            }
        },
        "20": {
            "41": {
                "1": "今公子苟好勦民以媮樂",
                "2": "忘民怨之爲仇也",
                "3": "好殫物以窮寵",
                "4": "忽下叛而生憂也",
                "5": "夫水所以載舟",
                "6": "亦所以覆舟",
                "7": "堅冰作於履霜",
                "8": "尋木起於蘖栽",
                "9": "昧旦丕顯",
                "10": "後世猶怠",
                "11": "況初制於甚泰",
                "12": "服者焉能改裁",
                "13": "故相如壯上林之觀",
                "14": "楊雄騁羽獵之辭",
                "15": "雖系以隤牆塡壍",
                "16": "亂以收罝解罘",
                "17": "卒無補於風規",
                "18": "祇以昭其愆尤",
                "19": "臣濟奓以陵君",
                "20": "忘經國之長基",
                "21": "故函谷擊柝於東",
                "22": "西朝顚覆而莫持",
                "23": "凡人心是所學",
                "24": "體安所習",
                "25": "鮑肆不知其臰",
                "26": "翫其所以先入",
                "27": "咸池不齊度於䵷咬",
                "28": "而眾聽或疑",
                "29": "能不惑者",
                "30": "其唯子野乎"
            }
        },
        "21": {
            "43": {
                "1": "客旣醉於大道",
                "2": "飽於文義",
                "3": "勸德畏戒",
                "4": "喜懼交爭",
                "5": "罔然若酲",
                "6": "朝罷夕倦",
                "7": "奪氣褫魄之爲者",
                "8": "忘其所以爲談",
                "9": "失其所以爲夸",
                "10": "良久乃言曰",
                "11": "鄙哉予乎",
                "12": "習非而遂迷也",
                "13": "幸見指南於吾子",
                "14": "若僕所聞",
                "15": "華而不實",
                "16": "先生之言",
                "17": "信而有徵",
                "18": "鄙夫寡識",
                "19": "而今而後",
                "20": "乃知大漢之德馨",
                "21": "咸在於此",
                "22": "昔常恨三墳五典旣泯",
                "23": "仰不睹炎帝帝魁之美",
                "24": "得聞先生之餘論",
                "25": "則大庭氏何以尙茲",
                "26": "走雖不敏",
                "27": "庶斯達矣"
            }
        }
    }
}