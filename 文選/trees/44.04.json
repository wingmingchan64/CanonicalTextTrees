{
    "44.04": {
        "篇名": "鍾士季 檄蜀文",
        "1": {
            "3": {
                "1": "往者漢祚衰微",
                "2": "率土分崩",
                "3": "生民之命",
                "4": "幾於泯滅",
                "5": "我太祖武皇帝神武聖哲",
                "6": "撥亂反正",
                "7": "拯其將墜",
                "8": "造我區夏",
                "9": "高祖文皇帝應天順民",
                "10": "受命踐祚",
                "11": "烈祖明皇帝奕世重光",
                "12": "恢拓洪業",
                "13": "然江山之外",
                "14": "異政殊俗",
                "15": "率土齊民",
                "16": "未蒙王化",
                "17": "此三祖所以顧懷遺志也",
                "18": "今主上聖德欽明",
                "19": "紹隆前緒",
                "20": "宰輔忠肅明允",
                "21": "劬勞王室",
                "22": "布政垂惠而萬邦協和",
                "23": "施德百蠻而肅愼致貢",
                "24": "悼彼巴蜀",
                "25": "獨爲匪民",
                "26": "愍此百姓",
                "27": "勞役未已",
                "28": "是以命授六師",
                "29": "龔行天罰",
                "30": "征西雍州鎭西諸軍",
                "31": "五道並進",
                "32": "古之行軍",
                "33": "以仁爲本",
                "34": "以義治之",
                "35": "王者之師",
                "36": "有征無戰",
                "37": "故虞舜舞干戚而服有苗",
                "38": "周武有散財發廩表閭之義",
                "39": "今鎭西奉辭銜命",
                "40": "攝統戎車",
                "41": "庶弘文告之訓",
                "42": "以濟元元之命",
                "43": "非欲窮武極戰",
                "44": "以快一朝之志",
                "45": "故略陳安危之要",
                "46": "其敬聽話言"
            }
        },
        "2": {
            "5": {
                "1": "益州先主以命世英才",
                "2": "興兵新野",
                "3": "困躓冀徐之郊",
                "4": "制命紹布之手",
                "5": "太祖拯而濟之",
                "6": "興隆大好",
                "7": "中更背違",
                "8": "棄同卽異",
                "9": "諸葛孔明仍規秦川",
                "10": "姜伯約屢出隴右",
                "11": "勞動我邊境",
                "12": "侵擾我氐羌",
                "13": "方國家多故",
                "14": "未遑修九伐之征也",
                "15": "今邊境乂清",
                "16": "方內無事",
                "17": "蓄力待時",
                "18": "倂兵一向",
                "19": "而巴蜀一州之眾",
                "20": "分張守備",
                "21": "難以禦天下之師",
                "22": "段谷侯和沮傷之氣",
                "23": "難以敵堂堂之陣",
                "24": "比年已來",
                "25": "曾無寧歲",
                "26": "征夫勤瘁",
                "27": "難以當子來之民",
                "28": "此皆諸賢所共親見",
                "29": "蜀侯見禽於秦",
                "30": "公孫述授首於漢",
                "31": "九州之險",
                "32": "是非一姓",
                "33": "此皆諸君所備聞也",
                "34": "明者見危於無形",
                "35": "智者規福於未萌",
                "36": "是以微子去商",
                "37": "長爲周賓",
                "38": "陳平背項",
                "39": "立功於漢",
                "40": "豈宴安鴆毒",
                "41": "懷祿而不變哉"
            }
        },
        "3": {
            "7": {
                "1": "今國朝隆天覆之恩",
                "2": "宰輔弘寬恕之德",
                "3": "先惠後誅",
                "4": "好生惡殺",
                "5": "往者吳將孫壹舉眾內附",
                "6": "位爲上司",
                "7": "寵秩殊異",
                "8": "文欽唐咨爲國大害",
                "9": "叛主讎賊",
                "10": "還爲戎首",
                "11": "咨困偪禽獲",
                "12": "欽二子還降",
                "13": "皆將軍封候",
                "14": "咨豫聞國事",
                "15": "壹等窮踧歸命",
                "16": "猶加上寵",
                "17": "況巴蜀賢智見機而作者哉",
                "18": "誠能深鑒成敗",
                "19": "邈然高蹈",
                "20": "投迹微子之蹤",
                "21": "措身陳平之軌",
                "22": "則福同古人",
                "23": "慶流來裔",
                "24": "百姓士民",
                "25": "安堵樂業",
                "26": "農不易畝",
                "27": "市不迴肆",
                "28": "去累卵之危",
                "29": "就永安之計",
                "30": "豈不美與",
                "31": "若偸安旦夕",
                "32": "迷而不反",
                "33": "大兵一放",
                "34": "玉石俱碎",
                "35": "雖欲悔之",
                "36": "亦無及也",
                "37": "各具宣布",
                "38": "咸使知聞"
            }
        }
    }
}