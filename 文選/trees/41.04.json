{
    "41.04": {
        "篇名": "孔文舉 論盛孝章書",
        "1": {
            "3": {
                "1": "歲月不居",
                "2": "時節如流",
                "3": "五十之年",
                "4": "忽焉已至",
                "5": "公爲始滿",
                "6": "融又過二",
                "7": "海內知識",
                "8": "零落殆盡",
                "9": "惟有會稽盛孝章尙存",
                "10": "其人困於孫氏",
                "11": "妻孥湮沒",
                "12": "單孑獨立",
                "13": "孤危愁苦",
                "14": "若使憂能傷人",
                "15": "此子不得永年矣",
                "16": "春秋傳曰",
                "17": "諸侯有相滅亡者",
                "18": "桓公不能救",
                "19": "則桓公恥之",
                "20": "今孝章實丈夫之雄也",
                "21": "天下談士",
                "22": "依以揚聲",
                "23": "而身不免於幽縶",
                "24": "命不期於旦夕",
                "25": "吾祖不當復論損益之友",
                "26": "而朱穆所以絕交也",
                "27": "公誠能馳一介之使",
                "28": "加咫尺之書",
                "29": "則孝章可致",
                "30": "友道可弘矣"
            }
        },
        "2": {
            "5": {
                "1": "今之少年",
                "2": "喜謗前輩",
                "3": "或能譏評孝章",
                "4": "孝章要爲有天下大名",
                "5": "九牧之人",
                "6": "所共稱歎",
                "7": "燕君市駿馬之骨",
                "8": "非欲以騁道里",
                "9": "乃當以招絕足也",
                "10": "惟公匡復漢室",
                "11": "宗社將絕",
                "12": "又能正之",
                "13": "正之術",
                "14": "實須得賢",
                "15": "珠玉無脛而自至者",
                "16": "以人好之也",
                "17": "況賢者之有足乎",
                "18": "昭王築臺以尊郭隗",
                "19": "隗雖小才而逢大遇",
                "20": "竟能發明主之至心",
                "21": "故樂毅自魏往",
                "22": "劇辛自趙往",
                "23": "鄒衍自齊往",
                "24": "向使郭隗倒懸而王不解",
                "25": "臨難而王不拯",
                "26": "則士亦將高翔遠引",
                "27": "莫有北首燕路者矣",
                "28": "凡所稱引",
                "29": "自公所知",
                "30": "而復有云者",
                "31": "欲公崇篤斯義",
                "32": "因表不悉"
            }
        }
    }
}