{
    "27.14-04": {
        "篇名": "王仲宣 從軍詩五首·其四",
        "1": {
            "3": {
                "1": "朝發鄴都橋",
                "2": "暮濟白馬津",
                "3": "逍遙河堤上",
                "4": "左右望我軍",
                "5": "連舫踰萬艘",
                "6": "帶甲千萬人",
                "7": "率彼東南路",
                "8": "將定一舉勳",
                "9": "籌策運帷幄",
                "10": "一由我聖君",
                "11": "恨我無時謀",
                "12": "譬諸具官臣",
                "13": "鞠躬中堅內",
                "14": "微畫無所陳",
                "15": "許歷爲完士",
                "16": "一言獨敗秦",
                "17": "我有素餐責",
                "18": "誠愧伐檀人",
                "19": "雖無鉛刀用",
                "20": "庶幾奮薄身"
            }
        }
    }
}