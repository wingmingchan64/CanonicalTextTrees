{
    "45.10": {
        "篇名": "皇甫士安 三都賦序",
        "1": {
            "3": {
                "1": "玄晏先生曰",
                "2": "古人稱不歌而頌謂之賦",
                "3": "然則賦也者",
                "4": "所以因物造端",
                "5": "敷弘體理",
                "6": "欲人不能加也",
                "7": "引而申之",
                "8": "故文必極美",
                "9": "觸類而長之",
                "10": "故辭必盡麗",
                "11": "然則美麗之文",
                "12": "賦之作也",
                "13": "昔之爲文者",
                "14": "非苟尙辭而已",
                "15": "將以紐之王教",
                "16": "本乎勸戒也",
                "17": "自夏殷以前",
                "18": "其文隱沒",
                "19": "靡得而詳焉",
                "20": "周監二代",
                "21": "文質之體",
                "22": "百世可知",
                "23": "故孔子采萬國之風",
                "24": "正雅頌之名",
                "25": "集而謂之詩",
                "26": "詩人之作",
                "27": "雜有賦體",
                "28": "子夏序詩曰",
                "29": "一曰風",
                "30": "二曰賦",
                "31": "故知賦者",
                "32": "古詩之流也"
            }
        },
        "2": {
            "5": {
                "1": "至於戰國",
                "2": "王道陵遲",
                "3": "風雅寖頓",
                "4": "於是賢人失志",
                "5": "辭賦作焉",
                "6": "是以孫卿屈原之屬",
                "7": "遺文炳然",
                "8": "辭義可觀",
                "9": "存其所感",
                "10": "咸有古詩之意",
                "11": "皆因文以寄其心",
                "12": "託理以全其制",
                "13": "賦之首也",
                "14": "及宋玉之徒",
                "15": "淫文放發",
                "16": "言過於實",
                "17": "誇競之興",
                "18": "體失之漸",
                "19": "風雅之則",
                "20": "於是乎乖",
                "21": "逮漢賈誼",
                "22": "頗節之以禮",
                "23": "自時厥後",
                "24": "綴文之士",
                "25": "不率典言",
                "26": "並務恢張",
                "27": "其文博誕空類",
                "28": "大者罩天地之表",
                "29": "細者入毫纖之內",
                "30": "雖充車聯駟",
                "31": "不足以載",
                "32": "廣夏接榱",
                "33": "不容以居也",
                "34": "其中高者",
                "35": "至如相如上林",
                "36": "楊雄甘泉",
                "37": "班固兩都",
                "38": "張衡二京",
                "39": "馬融廣成",
                "40": "王生靈光",
                "41": "初極宏侈之辭",
                "42": "終以約簡之制",
                "43": "煥乎有文",
                "44": "蔚爾鱗集",
                "45": "皆近代辭賦之偉也",
                "46": "若夫土有常產",
                "47": "俗有舊風",
                "48": "方以類聚",
                "49": "物以羣分",
                "50": "而長卿之儔",
                "51": "過以非方之物",
                "52": "寄以中域",
                "53": "虛張異類",
                "54": "託有於無",
                "55": "祖構之士",
                "56": "雷同影附",
                "57": "流宕忘反",
                "58": "非一時也"
            }
        },
        "3": {
            "7": {
                "1": "曩者漢室內潰",
                "2": "四海圮裂",
                "3": "孫劉二氏",
                "4": "割有交益",
                "5": "魏武撥亂",
                "6": "擁據函夏",
                "7": "故作者先爲吳蜀二客",
                "8": "盛稱其本土險阻瑰琦",
                "9": "可以偏王",
                "10": "而卻爲魏主述其都畿",
                "11": "弘敞豐麗",
                "12": "奄有諸華之意",
                "13": "言吳蜀以擒滅比亡國",
                "14": "而魏以交禪比唐虞",
                "15": "旣已著逆順",
                "16": "且以爲鑒戒",
                "17": "蓋蜀包梁岷之資",
                "18": "吳割荊南之富",
                "19": "魏跨中區之衍",
                "20": "考分次之多少",
                "21": "計殖物之眾寡",
                "22": "比風俗之清濁",
                "23": "課士人之優劣",
                "24": "亦不可同年而語矣",
                "25": "二國之士",
                "26": "各沐浴所聞",
                "27": "家自以爲我土樂",
                "28": "人自以爲我民良",
                "29": "皆非通方之論也",
                "30": "作者又因客主之辭",
                "31": "正之以魏都",
                "32": "折之以王道",
                "33": "其物土所出",
                "34": "可得披圖而校",
                "35": "體國經制",
                "36": "可得按記而驗",
                "37": "豈誣也哉"
            }
        }
    }
}