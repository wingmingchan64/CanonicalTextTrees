{
    "04.03": {
        "篇名": "左太沖 蜀都賦",
        "1": {
            "3": {
                "1": "有西蜀公子者",
                "2": "言於東吳王孫",
                "3": "曰",
                "4": "蓋聞天以日月爲綱",
                "5": "地以四海爲紀",
                "6": "九土星分",
                "7": "萬國錯跱",
                "8": "崤函有帝皇之宅",
                "9": "河洛爲王者之里",
                "10": "吾子豈亦曾聞蜀都之事歟",
                "11": "請爲左右揚搉而陳之"
            }
        },
        "2": {
            "5": {
                "1": "夫蜀都者",
                "2": "蓋兆基於上世",
                "3": "開國於中古",
                "4": "廓靈關以爲門",
                "5": "包玉壘而爲宇",
                "6": "帶二江之雙流",
                "7": "抗峨眉之重阻",
                "8": "水陸所湊",
                "9": "兼六合而交會焉",
                "10": "豐蔚所盛",
                "11": "茂八區而菴藹焉"
            }
        },
        "3": {
            "7": {
                "1": "於前則跨躡犍牂",
                "2": "枕輢交趾",
                "3": "經途所亙",
                "4": "五千餘里",
                "5": "山阜相屬",
                "6": "含谿懷谷",
                "7": "崗巒糺紛",
                "8": "觸石吐雲",
                "9": "鬱葐蒀以翠微",
                "10": "崛巍巍以峩峩",
                "11": "干青霄而秀出",
                "12": "舒丹氣而爲霞",
                "13": "龍池𤀰瀑濆其隈",
                "14": "漏江伏流潰其阿",
                "15": "汩若湯谷之揚濤",
                "16": "沛若濛汜之涌波",
                "17": "於是乎邛竹緣嶺",
                "18": "菌桂臨崖",
                "19": "旁挺龍目",
                "20": "側生荔枝",
                "21": "布綠葉之萋萋",
                "22": "結朱實之離離",
                "23": "迎隆冬而不凋",
                "24": "常曄曄以猗猗",
                "25": "孔翠羣翔",
                "26": "犀象競馳",
                "27": "白雉朝雊",
                "28": "猩猩夜啼",
                "29": "金馬騁光而絕景",
                "30": "碧雞儵忽而曜儀",
                "31": "火井沈熒於幽泉",
                "32": "高爓飛煽於天垂",
                "33": "其間則有虎珀丹青",
                "34": "江珠瑕英",
                "35": "金沙銀礫",
                "36": "符采彪炳",
                "37": "暉麗灼爍"
            }
        },
        "4": {
            "9": {
                "1": "於後則卻背華容",
                "2": "北指崑崙",
                "3": "緣以劍閣",
                "4": "阻以石門",
                "5": "流漢湯湯",
                "6": "驚浪雷奔",
                "7": "望之天迴",
                "8": "卽之雲昏",
                "9": "水物殊品",
                "10": "鱗介異族",
                "11": "或藏蛟螭",
                "12": "或隱碧玉",
                "13": "嘉魚出於丙穴",
                "14": "良木攢於襃谷",
                "15": "其樹則有木蘭梫桂",
                "16": "杞櫹椅桐",
                "17": "椶枒楔樅",
                "18": "楩柟幽藹於谷底",
                "19": "松柏蓊鬱於山峯",
                "20": "擢修幹",
                "21": "竦長條",
                "22": "扇飛雲",
                "23": "拂輕霄",
                "24": "羲和假道於峻歧",
                "25": "陽烏迴翼乎高標",
                "26": "巢居栖翔",
                "27": "聿兼鄧林",
                "28": "穴宅奇獸",
                "29": "窠宿異禽",
                "30": "熊羆咆其陽",
                "31": "雕鶚鴪其陰",
                "32": "猿狖騰希而競捷",
                "33": "虎豹長嘯而永吟"
            }
        },
        "5": {
            "11": {
                "1": "於東則左緜巴中",
                "2": "百濮所充",
                "3": "外負銅梁於宕渠",
                "4": "內函要害於膏腴",
                "5": "其中則有巴菽巴戟",
                "6": "靈壽桃枝",
                "7": "樊以蒩圃",
                "8": "濱以鹽池",
                "9": "𧌽蛦山栖",
                "10": "黿龜水處",
                "11": "潛龍蟠於沮澤",
                "12": "應鳴鼓而興雨",
                "13": "丹沙赩熾出其坂",
                "14": "蜜房郁毓被其阜",
                "15": "山圖采而得道",
                "16": "赤斧服而不朽",
                "17": "若乃剛悍生其方",
                "18": "風謠尙其武",
                "19": "奮之則賨旅",
                "20": "翫之則渝舞",
                "21": "銳氣剽於中葉",
                "22": "蹻容世於樂府"
            }
        },
        "6": {
            "13": {
                "1": "於西則右挾岷山",
                "2": "涌瀆發川",
                "3": "陪以白狼",
                "4": "夷歌成章",
                "5": "坰野草昧",
                "6": "林麓黝儵",
                "7": "交讓所植",
                "8": "蹲鴟所伏",
                "9": "百藥灌叢",
                "10": "寒卉冬馥",
                "11": "異類眾夥",
                "12": "於何不育",
                "13": "其中則有青珠黃環",
                "14": "碧砮芒消",
                "15": "或豐綠荑",
                "16": "或蕃丹椒",
                "17": "麋蕪布濩於中阿",
                "18": "風連莚蔓於蘭皋",
                "19": "紅葩紫飾",
                "20": "柯葉漸苞",
                "21": "敷蕊葳蕤",
                "22": "落英飄颻",
                "23": "神農是嘗",
                "24": "盧跗是料",
                "25": "芳追氣邪",
                "26": "味蠲癘痟"
            }
        },
        "7": {
            "15": {
                "1": "其封域之內",
                "2": "則有原隰墳衍",
                "3": "通望彌博",
                "4": "演以潛沬",
                "5": "浸以緜雒",
                "6": "溝洫脈散",
                "7": "疆里綺錯",
                "8": "黍稷油油",
                "9": "稉稻莫莫",
                "10": "指渠口以爲雲門",
                "11": "灑滮池而爲陸澤",
                "12": "雖星畢之滂沱",
                "13": "尙未齊其膏液",
                "14": "爾乃邑居隱賑",
                "15": "夾江傍山",
                "16": "棟宇相望",
                "17": "桑梓接連",
                "18": "家有鹽泉之井",
                "19": "戶有橘柚之園",
                "20": "其園則林檎枇杷",
                "21": "橙𣐈梬楟",
                "22": "榹桃函列",
                "23": "梅李羅生",
                "24": "百果甲宅",
                "25": "異色同榮",
                "26": "朱櫻春熟",
                "27": "素柰夏成",
                "28": "若乃大火流",
                "29": "涼風厲",
                "30": "白露凝",
                "31": "微霜結",
                "32": "紫梨津潤",
                "33": "樼栗罅發",
                "34": "蒲陶亂潰",
                "35": "若榴競裂",
                "36": "甘至自零",
                "37": "芬芬酷烈",
                "38": "其園則有蒟蒻茱萸",
                "39": "瓜疇芋區",
                "40": "甘蔗辛薑",
                "41": "陽蓲陰敷",
                "42": "日往菲薇",
                "43": "月來扶疏",
                "44": "任土所麗",
                "45": "眾獻而儲"
            }
        },
        "8": {
            "17": {
                "1": "其沃瀛則有攢蔣叢蒲",
                "2": "綠菱紅蓮",
                "3": "雜以蘊藻",
                "4": "糅以蘋蘩",
                "5": "總莖柅柅",
                "6": "裛葉蓁蓁",
                "7": "蕡實時味",
                "8": "王公羞焉",
                "9": "其中則有鴻儔鵠侶",
                "10": "䳲鷺鵜鶘",
                "11": "晨鳧旦至",
                "12": "候雁銜蘆",
                "13": "木落南翔",
                "14": "冰泮北徂",
                "15": "雲飛水宿",
                "16": "哢吭清渠",
                "17": "其深則有白黿命鼈",
                "18": "玄獺上祭",
                "19": "鱣鮪鱒魴",
                "20": "鮷鱧魦鱨",
                "21": "差鱗次色",
                "22": "錦質報章",
                "23": "躍濤戲瀨",
                "24": "中流相忘"
            }
        },
        "9": {
            "19": {
                "1": "於是乎金城石郭",
                "2": "兼帀中區",
                "3": "旣麗且崇",
                "4": "實號成都",
                "5": "闢二九之通門",
                "6": "畫方軌之廣塗",
                "7": "營新宮於爽塏",
                "8": "擬承明而起廬",
                "9": "結陽城之延閣",
                "10": "飛觀榭乎雲中",
                "11": "開高軒以臨山",
                "12": "列綺牎而瞰江",
                "13": "內則議殿爵堂",
                "14": "武義虎威",
                "15": "宣化之闥",
                "16": "崇禮之闈",
                "17": "華闕雙邈",
                "18": "重門洞開",
                "19": "金鋪交映",
                "20": "玉題相暉",
                "21": "外則軌躅八達",
                "22": "里閈對出",
                "23": "比屋連甍",
                "24": "千廡萬室",
                "25": "亦有甲第",
                "26": "當衢向術",
                "27": "壇宇顯敞",
                "28": "高門納駟",
                "29": "庭扣鍾磬",
                "30": "堂撫琴瑟",
                "31": "匪葛匪姜",
                "32": "疇能是卹"
            }
        },
        "10": {
            "21": {
                "1": "亞以少城",
                "2": "接乎其西",
                "3": "市廛所會",
                "4": "萬商之淵",
                "5": "列隧百重",
                "6": "羅肆巨千",
                "7": "賄貨山積",
                "8": "纖麗星繁",
                "9": "都人士女",
                "10": "袨服靚䊋",
                "11": "賈貿墆鬻",
                "12": "舛錯縱橫",
                "13": "異物崛詭",
                "14": "奇於八方",
                "15": "布有橦華",
                "16": "麪有桄榔",
                "17": "邛杖傳節於大夏之邑",
                "18": "蒟醬流味於番禺之鄕",
                "19": "輿輦雜沓",
                "20": "冠帶混幷",
                "21": "累轂疊迹",
                "22": "叛衍相傾",
                "23": "諠譁鼎沸",
                "24": "則哤聒宇宙",
                "25": "嚻塵張天",
                "26": "則埃壒曜靈",
                "27": "闤闠之裏",
                "28": "伎巧之家",
                "29": "百室離房",
                "30": "機杼相和",
                "31": "貝錦斐成",
                "32": "濯色江波",
                "33": "黃潤比筒",
                "34": "籝金所過"
            }
        },
        "11": {
            "23": {
                "1": "侈侈隆富",
                "2": "卓鄭埒名",
                "3": "公擅山川",
                "4": "貨殖私庭",
                "5": "藏鏹巨萬",
                "6": "䤨摫兼呈",
                "7": "亦以財雄",
                "8": "翕習邊城",
                "9": "三蜀之豪",
                "10": "時來時往",
                "11": "養交都邑",
                "12": "結儔附黨",
                "13": "劇談戲論",
                "14": "扼腕抵掌",
                "15": "出則連騎",
                "16": "歸從百兩",
                "17": "若其舊俗",
                "18": "終冬始春",
                "19": "吉日良辰",
                "20": "置酒高堂",
                "21": "以御嘉賓",
                "22": "金罍中坐",
                "23": "肴槅四陳",
                "24": "觴以清醥",
                "25": "鮮以紫鱗",
                "26": "羽爵執競",
                "27": "絲竹乃發",
                "28": "巴姬彈弦",
                "29": "漢女擊節",
                "30": "起西音於促柱",
                "31": "歌江上之𩙂厲",
                "32": "紆長袖而屢舞",
                "33": "翩躚躚以裔裔",
                "34": "合尊促席",
                "35": "引滿相罰",
                "36": "樂飲今夕",
                "37": "一醉累月"
            }
        },
        "12": {
            "25": {
                "1": "若夫王孫之屬",
                "2": "郤公之倫",
                "3": "從禽於外",
                "4": "巷無居人",
                "5": "並乘驥子",
                "6": "俱服魚文",
                "7": "玄黃異校",
                "8": "結駟繽紛",
                "9": "西踰金隄",
                "10": "東越玉津",
                "11": "朔別期晦",
                "12": "匪日匪旬",
                "13": "蹴蹈蒙籠",
                "14": "涉𨆍寥廓",
                "15": "鷹犬倏眒",
                "16": "罻羅絡幕",
                "17": "毛羣陸離",
                "18": "羽族紛泊",
                "19": "翕響揮霍",
                "20": "中網林薄",
                "21": "屠麖麋",
                "22": "剪旄麈",
                "23": "帶文蛇",
                "24": "跨彫虎",
                "25": "志未騁",
                "26": "時欲晚",
                "27": "追輕翼",
                "28": "赴絕遠",
                "29": "出彭門之闕",
                "30": "馳九折之坂",
                "31": "經三峽之崢嶸",
                "32": "躡五屼之蹇滻",
                "33": "戟食鐵之獸",
                "34": "射噬毒之鹿",
                "35": "皛貙氓於葽草",
                "36": "彈言鳥於森木",
                "37": "拔象齒",
                "38": "戾犀角",
                "39": "鳥鎩翮",
                "40": "獸廢足"
            }
        },
        "13": {
            "27": {
                "1": "殆而朅來相與",
                "2": "第如滇池",
                "3": "集於江洲",
                "4": "試水客",
                "5": "艤輕舟",
                "6": "娉江婓",
                "7": "與神遊",
                "8": "罨翡翠",
                "9": "釣鰋鮋",
                "10": "下高鵠",
                "11": "出潛虯",
                "12": "吹洞簫",
                "13": "發櫂謳",
                "14": "感鱏魚",
                "15": "動陽侯",
                "16": "騰波沸涌",
                "17": "珠貝汜浮",
                "18": "若雲漢含星",
                "19": "而光耀洪流",
                "20": "將饗獠者",
                "21": "張帟幕",
                "22": "會平原",
                "23": "酌清酤",
                "24": "割芳鮮",
                "25": "飲御酣",
                "26": "賓旅旋",
                "27": "車馬雷駭",
                "28": "轟轟闐闐",
                "29": "若風流雨散",
                "30": "漫乎數百里間",
                "31": "斯蓋宅土之所安樂",
                "32": "觀聽之所踴躍也",
                "33": "焉獨三川",
                "34": "爲世朝市"
            }
        },
        "14": {
            "29": {
                "1": "若乃卓犖奇譎",
                "2": "倜儻罔已",
                "3": "一經神怪",
                "4": "一緯人理",
                "5": "遠則岷山之精",
                "6": "上爲井絡",
                "7": "天帝運期而會昌",
                "8": "景福肸饗而興作",
                "9": "碧出萇弘之血",
                "10": "鳥生杜宇之魄",
                "11": "妄變化而非常",
                "12": "羌見偉於疇昔",
                "13": "近則江漢炳靈",
                "14": "世載其英",
                "15": "蔚若相如",
                "16": "皭若君平",
                "17": "王襃韡曄而秀發",
                "18": "楊雄含章而挺生",
                "19": "幽思絢道德",
                "20": "摛藻掞天庭",
                "21": "考四海而爲儁",
                "22": "當中葉而擅名",
                "23": "是故遊談者以爲譽",
                "24": "造作者以爲程也"
            }
        },
        "15": {
            "31": {
                "1": "至乎臨谷爲塞",
                "2": "因山爲障",
                "3": "峻岨塍埒長城",
                "4": "豁險吞若巨防",
                "5": "一人守隘",
                "6": "萬夫莫向",
                "7": "公孫躍馬而稱帝",
                "8": "劉宗下輦而自王",
                "9": "由此言之",
                "10": "天下孰尙",
                "11": "故雖兼諸夏之富有",
                "12": "猶未若茲都之無量也"
            }
        }
    }
}