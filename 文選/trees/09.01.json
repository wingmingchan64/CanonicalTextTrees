{
    "09.01": {
        "篇名": "楊子雲 長楊賦[幷序]",
        "1": {
            "3": {
                "1": "明年",
                "2": "上將大誇胡人以多禽獸",
                "3": "秋",
                "4": "命右扶風發民入南山",
                "5": "西自襃斜",
                "6": "東至弘農",
                "7": "南敺漢中",
                "8": "張羅罔罝罘",
                "9": "捕熊羆豪豬虎豹狖玃狐菟麋鹿",
                "10": "載以檻車",
                "11": "輸長楊射熊館",
                "12": "以網爲周阹",
                "13": "縱禽獸其中",
                "14": "令胡人手搏之",
                "15": "自取其獲",
                "16": "上親臨觀焉",
                "17": "是時",
                "18": "農民不得收斂",
                "19": "雄從至射熊館",
                "20": "還",
                "21": "上長楊賦",
                "22": "聊因筆墨之成文章",
                "23": "故藉翰林以爲主人",
                "24": "子墨爲客卿",
                "25": "以風",
                "26": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "子墨客卿問於翰林主人曰",
                "2": "蓋聞聖主之養民也",
                "3": "仁霑而恩洽",
                "4": "動不爲身",
                "5": "今年獵長楊",
                "6": "先命右扶風",
                "7": "左太華而右襃斜",
                "8": "椓截嶭而爲弋",
                "9": "紆南山以爲罝",
                "10": "羅千乘於林莽",
                "11": "列萬騎於山隅",
                "12": "帥軍踤阹",
                "13": "錫戎獲胡",
                "14": "搤熊羆",
                "15": "拕豪豬",
                "16": "木雍槍纍",
                "17": "以爲儲胥",
                "18": "此天下之窮覽極觀也",
                "19": "雖然",
                "20": "亦頗擾於農民",
                "21": "三旬有餘",
                "22": "其廑至矣",
                "23": "而功不圖",
                "24": "恐不識者",
                "25": "外之則以爲娛樂之遊",
                "26": "內之則不以爲乾豆之事",
                "27": "豈爲民乎哉",
                "28": "且人君以玄默爲神",
                "29": "澹泊爲德",
                "30": "今樂遠出以露威靈",
                "31": "數搖動以罷車甲",
                "32": "本非人主之急務也",
                "33": "蒙竊惑焉"
            }
        },
        "3": {
            "7": {
                "1": "翰林主人曰",
                "2": "吁",
                "3": "客何謂之茲耶",
                "4": "若客",
                "5": "所謂知未睹",
                "6": "見其外不識其內者也",
                "7": "僕嘗倦談",
                "8": "不能一二其詳",
                "9": "請略舉其凡",
                "10": "而客自覽其切焉"
            }
        },
        "4": {
            "9": {
                "1": "客曰",
                "2": "唯唯"
            }
        },
        "5": {
            "11": {
                "1": "主人曰",
                "2": "昔有彊秦",
                "3": "封豕其士",
                "4": "窫窳其民",
                "5": "鑿齒之徒相與摩牙而爭之",
                "6": "豪俊麋沸雲擾",
                "7": "羣黎爲之不康",
                "8": "於是上帝眷顧高祖",
                "9": "高祖奉命",
                "10": "順斗極",
                "11": "運天關",
                "12": "橫鉅海",
                "13": "票昆侖",
                "14": "提劍而叱之",
                "15": "所過麾城摲邑",
                "16": "下將降旗",
                "17": "一日之戰",
                "18": "不可殫記",
                "19": "當此之勤",
                "20": "頭蓬不暇疏",
                "21": "飢不及餐",
                "22": "提鍪生蟣蝨",
                "23": "介冑被霑汗",
                "24": "以爲萬姓請命虖皇天",
                "25": "迺展民之所詘",
                "26": "振民之所乏",
                "27": "規億載",
                "28": "恢帝業",
                "29": "七年之間",
                "30": "而天下密如也"
            }
        },
        "6": {
            "13": {
                "1": "逮至聖文",
                "2": "隨風乘流",
                "3": "方垂意於至寧",
                "4": "躬服節儉",
                "5": "綈衣不敝",
                "6": "革鞜不穿",
                "7": "大夏不居",
                "8": "木器無文",
                "9": "於是後宮賤瑇瑁而疏珠璣",
                "10": "卻翡翠之飾",
                "11": "除彫琢之巧",
                "12": "惡麗靡而不近",
                "13": "斥芬芳而不御",
                "14": "抑止絲竹晏衍之樂",
                "15": "憎聞鄭衞幼眇之聲",
                "16": "是以玉衡正而太階平也"
            }
        },
        "7": {
            "15": {
                "1": "其後熏鬻作虐",
                "2": "東夷橫畔",
                "3": "羌戎睚眦",
                "4": "閩越相亂",
                "5": "遐萌爲之不安",
                "6": "中國蒙被其難",
                "7": "於是聖武勃怒",
                "8": "爰整其旅",
                "9": "迺命票衞",
                "10": "汾沄沸渭",
                "11": "雲合電發",
                "12": "猋騰波流",
                "13": "機駭蠭軼",
                "14": "疾如奔星",
                "15": "擊如震霆",
                "16": "碎轒轀",
                "17": "破穹廬",
                "18": "腦沙幕",
                "19": "髓余吾",
                "20": "遂獵乎王庭",
                "21": "敺橐它",
                "22": "燒𤑺蠡",
                "23": "分梨單於",
                "24": "磔裂屬國",
                "25": "夷阬谷",
                "26": "拔鹵莽",
                "27": "刊山石",
                "28": "蹂屍輿廝",
                "29": "係累老弱",
                "30": "兗鋋瘢耆",
                "31": "金鏃淫夷者數十萬人",
                "32": "皆稽顙樹頷",
                "33": "扶服蛾伏",
                "34": "二十餘年矣",
                "35": "尙不敢惕息",
                "36": "夫天兵四臨",
                "37": "幽都先加",
                "38": "回戈邪指",
                "39": "南越相夷",
                "40": "靡節西征",
                "41": "羌僰東馳",
                "42": "是以遐方疏俗殊鄰絕黨之域",
                "43": "自上仁所不化",
                "44": "茂德所不綏",
                "45": "莫不蹻足抗首",
                "46": "請獻厥珍",
                "47": "使海內澹然",
                "48": "永亡邊城之災",
                "49": "金革之患"
            }
        },
        "8": {
            "17": {
                "1": "今朝廷純仁",
                "2": "遵道顯義",
                "3": "幷包書林",
                "4": "聖風雲靡",
                "5": "英華沈浮",
                "6": "洋溢八區",
                "7": "普天所覆",
                "8": "莫不霑濡",
                "9": "士有不談王道者",
                "10": "則樵夫笑之",
                "11": "故意者以爲事罔隆而殺",
                "12": "物靡盛而不虧",
                "13": "故平不肆險",
                "14": "安不忘危",
                "15": "迺時以有年出兵",
                "16": "整輿竦戎",
                "17": "振師五莋",
                "18": "習馬長楊",
                "19": "簡力狡獸",
                "20": "校武票禽",
                "21": "迺萃然登南山",
                "22": "瞰烏弋",
                "23": "西厭月𩨳",
                "24": "東震日域",
                "25": "又恐後代迷於一時之事",
                "26": "常以此爲國家之大務",
                "27": "淫荒田獵",
                "28": "陵夷而不禦也",
                "29": "是以車不安軔",
                "30": "日未靡旃",
                "31": "從者彷彿",
                "32": "骫屬而還",
                "33": "亦所以奉太尊之烈",
                "34": "遵文武之度",
                "35": "復三王之田",
                "36": "反五帝之虞",
                "37": "使農不輟耰",
                "38": "工不下機",
                "39": "婚姻以時",
                "40": "男女莫違",
                "41": "出愷弟",
                "42": "行簡易",
                "43": "矜劬勞",
                "44": "休力役",
                "45": "見百年",
                "46": "存孤弱",
                "47": "帥與之同苦樂",
                "48": "然後陳鐘鼓之樂",
                "49": "鳴鞀磬之和",
                "50": "建碣磍之虡",
                "51": "拮隔鳴球",
                "52": "掉八列之舞",
                "53": "酌允鑠",
                "54": "肴樂胥",
                "55": "聽廟中之雍雍",
                "56": "受神人之福祜",
                "57": "歌投頌",
                "58": "吹合雅",
                "59": "其勤若此",
                "60": "故眞神之所勞也",
                "61": "方將俟元符",
                "62": "以禪梁甫之基",
                "63": "增泰山之高",
                "64": "延光於將來",
                "65": "比榮乎往號",
                "66": "豈徒欲淫覽浮觀",
                "67": "馳騁稉稻之地",
                "68": "周流梨栗之林",
                "69": "蹂踐芻蕘",
                "70": "誇詡眾庶",
                "71": "盛狖玃之收",
                "72": "多麋鹿之獲哉",
                "73": "且盲者不見咫尺",
                "74": "而離婁燭千里之隅",
                "75": "客徒愛胡人之獲我禽獸",
                "76": "曾不知我亦已獲其王侯"
            }
        },
        "9": {
            "19": {
                "1": "言未卒",
                "2": "墨客降席再拜",
                "3": "稽首曰",
                "4": "大哉體乎",
                "5": "允非小人之所能及也",
                "6": "迺今日發矇",
                "7": "廓然已昭矣"
            }
        }
    }
}