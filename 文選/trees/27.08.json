{
    "27.08": {
        "篇名": "謝玄暉 晚登三山還望京邑",
        "1": {
            "3": {
                "1": "灞涘望長安",
                "2": "河陽視京縣",
                "3": "白日麗飛甍",
                "4": "參差皆可見",
                "5": "餘霞散成綺",
                "6": "澄江靜如練",
                "7": "喧鳥覆春洲",
                "8": "雜英滿芳甸",
                "9": "去矣方滯淫",
                "10": "懷哉罷歡宴",
                "11": "佳期悵何許",
                "12": "淚下如流霰",
                "13": "有情知望鄕",
                "14": "誰能縝不變"
            }
        }
    }
}