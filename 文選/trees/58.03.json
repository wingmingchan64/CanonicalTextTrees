{
    "58.03": {
        "篇名": "蔡伯喈 郭有道碑文[幷序]",
        "1": {
            "3": {
                "1": "先生諱泰",
                "2": "字林宗",
                "3": "太原界休人也",
                "4": "其先出自有周王季之穆",
                "5": "有虢叔者",
                "6": "寔有懿德",
                "7": "文王咨焉",
                "8": "建國命氏",
                "9": "或謂之郭",
                "10": "卽其後也",
                "11": "先生誕應天衷",
                "12": "聰睿明哲",
                "13": "孝友溫恭",
                "14": "仁篤慈惠",
                "15": "夫其器量弘深",
                "16": "姿度廣大",
                "17": "浩浩焉",
                "18": "汪汪焉",
                "19": "奧乎不可測已",
                "20": "若乃砥節厲行",
                "21": "直道正辭",
                "22": "貞固足以幹事",
                "23": "隱括足以矯時",
                "24": "遂考覽六經",
                "25": "探綜圖緯",
                "26": "周流華夏",
                "27": "隨集帝學",
                "28": "收文武之將墜",
                "29": "拯微言之未絕",
                "30": "於時纓緌之徒",
                "31": "紳佩之士",
                "32": "望形表而影附",
                "33": "聆嘉聲而響和者",
                "34": "猶百川之歸巨海",
                "35": "鱗介之宗龜龍也",
                "36": "爾乃潛隱衡門",
                "37": "收朋勤誨",
                "38": "童蒙賴焉",
                "39": "用袪其蔽",
                "40": "州郡聞德",
                "41": "虛己備禮",
                "42": "莫之能致",
                "43": "羣公休之",
                "44": "遂辟司徒掾",
                "45": "又舉有道",
                "46": "皆以疾辭",
                "47": "將蹈鴻涯之遐迹",
                "48": "紹巢許之絕軌",
                "49": "翔區外以舒翼",
                "50": "超天衢以高峙",
                "51": "稟命不融",
                "52": "享年四十有二",
                "53": "以建寧二年正月乙亥卒"
            }
        },
        "2": {
            "5": {
                "1": "凡我四方同好之人",
                "2": "永懷哀悼",
                "3": "靡所寘念",
                "4": "乃相與惟先生之德",
                "5": "以謀不朽之事",
                "6": "僉以爲先民旣沒",
                "7": "而德音猶存者",
                "8": "亦賴之於見述也",
                "9": "今其如何而闕斯禮",
                "10": "於是樹碑表墓",
                "11": "昭銘景行",
                "12": "俾芳烈奮於百世",
                "13": "令問顯於無窮",
                "14": "其辭曰"
            }
        },
        "3": {
            "7": {
                "1": "於休先生",
                "2": "明德通玄",
                "3": "純懿淑靈",
                "4": "受之自天",
                "5": "崇壯幽浚",
                "6": "如山如淵",
                "7": "禮樂是悅",
                "8": "詩書是敦",
                "9": "匪惟摭華",
                "10": "乃尋厥根",
                "11": "宮牆重仞",
                "12": "允得其門",
                "13": "懿乎其純",
                "14": "確乎其操",
                "15": "洋洋搢紳",
                "16": "言觀其高",
                "17": "栖遲泌丘",
                "18": "善誘能教",
                "19": "赫赫三事",
                "20": "幾行其招",
                "21": "委辭召貢",
                "22": "保此清妙",
                "23": "降年不永",
                "24": "民斯悲悼",
                "25": "爰勒茲銘",
                "26": "摛其光耀",
                "27": "嗟爾來世",
                "28": "是則是效"
            }
        }
    }
}