{
    "05.01": {
        "篇名": "左太沖 吳都賦",
        "1": {
            "3": {
                "1": "東吳王孫囅然而咍",
                "2": "曰",
                "3": "夫上圖景宿",
                "4": "辨於天文者也",
                "5": "下料物土",
                "6": "析於地理者也",
                "7": "古先帝代",
                "8": "曾覽八紘之洪緒",
                "9": "一六合而光宅",
                "10": "翔集遐宇",
                "11": "鳥策篆素",
                "12": "玉牒石記",
                "13": "烏聞梁岷有陟方之館",
                "14": "行宮之基歟",
                "15": "而吾子言蜀都之富",
                "16": "禺同之有",
                "17": "瑋其區域",
                "18": "美其林藪",
                "19": "矜巴漢之阻",
                "20": "則以爲襲險之右",
                "21": "徇蹲鴟之沃",
                "22": "則以爲世濟陽九",
                "23": "齷齪而筭",
                "24": "顧亦曲士之所歎也",
                "25": "旁魄而論都",
                "26": "抑非大人之壯觀也",
                "27": "何則",
                "28": "土壤不足以攝生",
                "29": "山川不足以周衞",
                "30": "公孫國之而破",
                "31": "諸葛家之而滅",
                "32": "茲乃喪亂之丘墟",
                "33": "顚覆之軌轍",
                "34": "安可以儷王公而著風烈也",
                "35": "翫其磧礫而不窺玉淵者",
                "36": "未知驪龍之所蟠也",
                "37": "習其𡚁邑而不睹上邦者",
                "38": "未知英雄之所躔也"
            }
        },
        "2": {
            "5": {
                "1": "子獨未聞大吳之巨麗乎",
                "2": "且有吳之開國也",
                "3": "造自太伯",
                "4": "宣於延陵",
                "5": "蓋端委之所彰",
                "6": "高節之所興",
                "7": "建至德以剏洪業",
                "8": "世無得而顯稱",
                "9": "由克讓以立風俗",
                "10": "輕脫躧於千乘",
                "11": "若率土而論都",
                "12": "則非列國之所觖望也",
                "13": "故其經略",
                "14": "上當星紀",
                "15": "拓土畫疆",
                "16": "卓犖兼幷",
                "17": "包括干越",
                "18": "跨躡蠻荊",
                "19": "婺女寄其曜",
                "20": "翼軫寓其精",
                "21": "指衡岳以鎭野",
                "22": "目龍川而帶坰"
            }
        },
        "3": {
            "7": {
                "1": "爾其山澤",
                "2": "則嵬嶷嶢𡵉",
                "3": "巊冥鬱𡶒",
                "4": "潰渱泮汗",
                "5": "滇㴐淼漫",
                "6": "或涌川而開瀆",
                "7": "或吞江而納漢",
                "8": "磈磈𡾖𡾖",
                "9": "滮滮涆涆",
                "10": "䃢碒乎數州之間",
                "11": "灌注乎天下之半",
                "12": "百川派別",
                "13": "歸海而會",
                "14": "控清引濁",
                "15": "混濤幷瀨",
                "16": "濆薄沸騰",
                "17": "寂寥長邁",
                "18": "濞焉洶洶",
                "19": "隱焉礚礚",
                "20": "出乎大荒之中",
                "21": "行乎東極之外",
                "22": "經扶桑之中林",
                "23": "包湯谷之滂沛",
                "24": "潮波汩起",
                "25": "迴復萬里",
                "26": "歊霧漨浡",
                "27": "雲蒸昏昧",
                "28": "泓澄奫潫",
                "29": "澒溶沆瀁",
                "30": "莫測其深",
                "31": "莫究其廣",
                "32": "澶湉漠而無涯",
                "33": "㹅有流而爲長",
                "34": "瓌異之所叢育",
                "35": "鱗甲之所集往"
            }
        },
        "4": {
            "9": {
                "1": "於是乎長鯨吞航",
                "2": "修鯢吐浪",
                "3": "躍龍騰蛇",
                "4": "鮫鯔琵琶",
                "5": "王鮪鯸鮐",
                "6": "鮣龜鱕䱜",
                "7": "烏賊擁劍",
                "8": "𮮢鼊鯖鰐",
                "9": "涵泳乎其中",
                "10": "葺鱗鏤甲",
                "11": "詭類舛錯",
                "12": "泝洄順流",
                "13": "噞喁沈浮",
                "14": "鳥則鵾雞鸀𩿱",
                "15": "鸘鵠鷺鴻",
                "16": "鶢鶋避風",
                "17": "候雁造江",
                "18": "鸂䳵鷛𪆂",
                "19": "鶄鶴鶖鶬",
                "20": "鸛鷗鷁鸕",
                "21": "泛濫乎其上",
                "22": "湛淡羽儀",
                "23": "隨波參差",
                "24": "理翮整翰",
                "25": "容與自翫",
                "26": "彫啄蔓藻",
                "27": "刷盪漪瀾",
                "28": "魚鳥聱耴",
                "29": "萬物蠢生",
                "30": "芒芒黖黖",
                "31": "慌罔奄欻",
                "32": "神化翕忽",
                "33": "函幽育明",
                "34": "窮性極形",
                "35": "盈虛自然",
                "36": "蚌蛤珠胎",
                "37": "與月虧全",
                "38": "巨鼇贔屓",
                "39": "首冠靈山",
                "40": "大鵬繽翻",
                "41": "翼若垂天",
                "42": "振盪汪流",
                "43": "雷抃重淵",
                "44": "殷動宇宙",
                "45": "胡可勝原"
            }
        },
        "5": {
            "11": {
                "1": "島嶼緜邈",
                "2": "洲渚馮隆",
                "3": "曠瞻迢遞",
                "4": "迥眺冥蒙",
                "5": "珍怪麗",
                "6": "奇隙充",
                "7": "徑路絕",
                "8": "風雲通",
                "9": "洪桃屈盤",
                "10": "丹桂灌叢",
                "11": "瓊枝抗莖而敷蕊",
                "12": "珊瑚幽茂而玲瓏",
                "13": "增岡重阻",
                "14": "列眞之宇",
                "15": "玉堂對霤",
                "16": "石室相距",
                "17": "藹藹翠幄",
                "18": "嫋嫋素女",
                "19": "江斐於是往來",
                "20": "海童於是宴語",
                "21": "斯實神妙之響象",
                "22": "嗟難得而覼縷"
            }
        },
        "6": {
            "13": {
                "1": "爾乃地勢坱圠",
                "2": "卉木镺蔓",
                "3": "遭藪爲圃",
                "4": "値林爲苑",
                "5": "異荂蓲蘛",
                "6": "夏曄冬蒨",
                "7": "方志所辨",
                "8": "中州所羨",
                "9": "草則藿蒳豆蔻",
                "10": "薑彙非一",
                "11": "江蘺之屬",
                "12": "海苔之類",
                "13": "綸組紫絳",
                "14": "食葛香茅",
                "15": "石帆水松",
                "16": "東風扶留",
                "17": "布濩皋澤",
                "18": "蟬聯陵丘",
                "19": "夤緣山嶽之岊",
                "20": "羃歷江海之流",
                "21": "扤白蔕",
                "22": "銜朱蕤",
                "23": "鬱兮䓲茂",
                "24": "曄兮菲菲",
                "25": "光色炫晃",
                "26": "芬馥肸蠁",
                "27": "職貢納其包匭",
                "28": "離騷詠其宿莽",
                "29": "木則楓柙櫲樟",
                "30": "栟櫚枸桹",
                "31": "緜杬杶櫨",
                "32": "文欀楨橿",
                "33": "平仲桾櫏",
                "34": "松梓古度",
                "35": "楠榴之木",
                "36": "相思之樹",
                "37": "宗生高岡",
                "38": "族茂幽阜",
                "39": "擢本千尋",
                "40": "垂蔭萬畝",
                "41": "攢柯挐莖",
                "42": "重葩殗葉",
                "43": "輪囷蚪蟠",
                "44": "𡍪㙷鱗接",
                "45": "榮色雜糅",
                "46": "綢繆縟繡",
                "47": "宵露霮䨴",
                "48": "旭日晻㫲",
                "49": "與風䬙颺",
                "50": "䬀瀏颼飀",
                "51": "鳴條律暢",
                "52": "飛音響亮",
                "53": "蓋象琴筑幷奏",
                "54": "笙竽俱唱",
                "55": "其上則猿父哀吟",
                "56": "𤟤子長嘯",
                "57": "狖鼯猓然",
                "58": "騰趠飛超",
                "59": "爭接縣垂",
                "60": "競遊遠枝",
                "61": "驚透沸亂",
                "62": "牢落翬散",
                "63": "其下則有梟羊麡狼",
                "64": "猰㺄𤠾象",
                "65": "烏菟之族",
                "66": "犀兕之黨",
                "67": "鉤爪鋸牙",
                "68": "自成鋒穎",
                "69": "精若燿星",
                "70": "聲若雲霆",
                "71": "名載於山經",
                "72": "形鏤於夏鼎"
            }
        },
        "7": {
            "15": {
                "1": "其竹則篔簹箖箊",
                "2": "桂箭射筒",
                "3": "柚梧有篁",
                "4": "篻簩有叢",
                "5": "苞筍抽節",
                "6": "往往縈結",
                "7": "綠葉翠莖",
                "8": "冒霜停雪",
                "9": "橚矗森萃",
                "10": "蓊茸蕭瑟",
                "11": "檀欒蟬蜎",
                "12": "玉潤碧鮮",
                "13": "梢雲無以踰",
                "14": "嶰谷弗能連",
                "15": "鸑鷟食其實",
                "16": "鵷雛擾其間",
                "17": "其果則丹橘餘甘",
                "18": "荔枝之林",
                "19": "檳榔無柯",
                "20": "椰葉無陰",
                "21": "龍眼橄欖",
                "22": "棎榴禦霜",
                "23": "結根比景之陰",
                "24": "列挺衡山之陽",
                "25": "素華斐",
                "26": "丹秀芳",
                "27": "臨青壁",
                "28": "系紫房",
                "29": "鷓鴣南翥而中留",
                "30": "孔雀綷羽以翶翔",
                "31": "山雞歸飛而來栖",
                "32": "翡翠列巢以重行",
                "33": "其琛賂則琨瑤之阜",
                "34": "銅鍇之垠",
                "35": "火齊之寶",
                "36": "駭雞之珍",
                "37": "頳丹明璣",
                "38": "金華銀樸",
                "39": "紫貝流黃",
                "40": "縹碧素玉",
                "41": "隱賑崴㠢",
                "42": "雜插幽屛",
                "43": "精曜潛穎",
                "44": "硩陊山谷",
                "45": "碕岸爲之不枯",
                "46": "林木爲之潤黷",
                "47": "隋侯於是鄙其夜光",
                "48": "宋王於是陋其結綠"
            }
        },
        "8": {
            "17": {
                "1": "其荒陬譎詭",
                "2": "則有龍穴內蒸",
                "3": "雲雨所儲",
                "4": "陵鯉若獸",
                "5": "浮石若桴",
                "6": "雙則比目",
                "7": "片則王餘",
                "8": "窮陸飲木",
                "9": "極沈水居",
                "10": "泉室潛織而卷綃",
                "11": "淵客慷慨而泣珠",
                "12": "開北戶以向日",
                "13": "齊南冥於幽都",
                "14": "野",
                "15": "則畛畷無數",
                "16": "膏腴兼倍",
                "17": "原隰殊品",
                "18": "窊隆異等",
                "19": "象耕鳥耘",
                "20": "此之自與",
                "21": "穱秀菰穗",
                "22": "於是乎在",
                "23": "煮海爲鹽",
                "24": "采山鑄錢",
                "25": "國稅再熟之稻",
