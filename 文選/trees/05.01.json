        "13": {
            "27": {
                "1": "露往霜來",
                "2": "日月其除",
                "3": "草木節解",
                "4": "鳥獸腯膚",
                "5": "觀鷹隼",
                "6": "誡征夫",
                "7": "坐組甲",
                "8": "建祀姑",
                "9": "命官帥而擁鐸",
                "10": "將校獵乎具區",
                "11": "烏滸狼䐠",
                "12": "夫南西屠",
                "13": "儋耳黑齒之酋",
                "14": "金鄰象郡之渠",
                "15": "驫𩣊飍矞",
                "16": "靸霅警捷",
                "17": "先驅前塗",
                "18": "兪騎騁路",
                "19": "指南司方",
                "20": "出車檻檻",
                "21": "被練鏘鏘",
                "22": "吳王乃巾玉輅",
                "23": "軺驌驦",
                "24": "旂魚須",
                "25": "常重光",
                "26": "攝烏號",
                "27": "佩干將",
                "28": "羽旄揚蕤",
                "29": "雄戟耀芒",
                "30": "貝冑象弭",
                "31": "織文鳥章",
                "32": "六軍袀服",
                "33": "四騏龍驤",
                "34": "峭格周施",
                "35": "罿罻普張",
                "36": "罼䍐瑣結",
                "37": "罠蹏連綱",
                "38": "阹以九疑",
                "39": "禦以沅湘",
                "40": "輶軒蓼擾",
                "41": "彀騎煒煌",
                "42": "袒裼徒搏",
                "43": "拔距投石之部",
                "44": "猿臂骿脅",
                "45": "狂趭獷猤",
                "46": "鷹瞵鶚視",
                "47": "䟃𧽼翋𦑶",
                "48": "若離若合者",
                "49": "相與騰躍乎莽䍚之野",
                "50": "干鹵殳鋋",
                "51": "暘夷勃盧之旅",
                "52": "長𥍟短兵",
                "53": "直髮馳騁",
                "54": "儇佻坌並",
                "55": "銜枚無聲",
                "56": "悠悠旆旌者",
                "57": "相與聊浪乎昧莫之坰",
                "58": "鉦鼓疊山",
                "59": "火烈熛林",
                "60": "飛爓浮煙",
                "61": "載霞載陰",
                "62": "菈擸雷硠",
                "63": "崩巒弛岑",
                "64": "鳥不擇木",
                "65": "獸不擇音",
                "66": "𧇭甝虪",
                "67": "𩓇麋麖",
                "68": "驀六駮",
                "69": "追飛生",
                "70": "彈鸞鶁",
                "71": "射猱㹶",
                "72": "白雉落",
                "73": "黑鴆零",
                "74": "陵絕嶛嶕",
                "75": "聿越巉險",
                "76": "跇踰竹柏",
                "77": "㺦猭杞柟",
                "78": "封狶䓼",
                "79": "神螭掩",
                "80": "剛鏃潤",
                "81": "霜刃染"
            }
        },
        "14": {
            "29": {
                "1": "於是弭節頓轡",
                "2": "齊鑣駐蹕",
                "3": "徘徊倘佯",
                "4": "寓目幽蔚",
                "5": "覽將帥之拳勇",
                "6": "與士卒之抑揚",
                "7": "羽族以觜距爲刀鈹",
                "8": "毛羣以齒角爲矛鋏",
                "9": "皆體著而應卒",
                "10": "所以挂扢而爲創痏",
                "11": "衝踤而斷筋骨",
                "12": "莫不衄銳挫芒",
                "13": "拉捭摧藏",
                "14": "雖有石林之岝崿",
                "15": "請攘臂而靡之",
                "16": "雖有雄虺之九首",
                "17": "將抗足而跐之",
                "18": "顚覆巢居",
                "19": "剖破窟宅",
                "20": "仰攀鵕䴊",
                "21": "俯蹴豺獏",
                "22": "刦剞熊羆之室",
                "23": "剽掠虎豹之落",
                "24": "猩猩啼而就禽",
                "25": "𥜿𥜿笑而被格",
                "26": "屠巴蛇",
                "27": "出象骼",
                "28": "斬鵬翼",
                "29": "掩廣澤",
                "30": "輕禽狡獸",
                "31": "周章夷猶",
                "32": "狼跋乎紭中",
                "33": "忘其所以睒睗",
                "34": "失其所以去就",
                "35": "魂褫氣懾而自踢䟮者",
                "36": "應弦飲羽",
                "37": "形僨景僵者",
                "38": "累積而增益",
                "39": "雜襲錯繆",
                "40": "傾藪薄",
                "41": "倒岬岫",
                "42": "巖穴無豜豵",
                "43": "翳薈無𪋯鷚",
                "44": "思假道於豐隆",
                "45": "披重霄而高狩",
                "46": "籠烏兔於日月",
                "47": "窮飛走之栖宿"
            }
        },
        "15": {
            "31": {
                "1": "嶰澗閴",
                "2": "岡岵童",
                "3": "罾罘滿",
                "4": "效獲眾",
                "5": "迴靶乎行邪",
                "6": "睨觀魚乎三江",
                "7": "泛舟航於彭蠡",
                "8": "渾萬艘而旣同",
                "9": "弘舸連舳",
                "10": "巨檻接艫",
                "11": "飛雲蓋海",
                "12": "制非常模",
                "13": "疊華樓而島跱",
                "14": "時髣髴於方壺",
                "15": "比鷁首而有裕",
                "16": "邁餘皇於往初",
                "17": "張組幃",
                "18": "構流蘇",
                "19": "開軒幌",
                "20": "鏡水區",
                "21": "槁工楫師",
                "22": "選自閩禺",
                "23": "習御長風",
                "24": "狎翫靈胥",
                "25": "責千里於寸陰",
                "26": "聊先期而須臾",
                "27": "櫂謳唱",
                "28": "簫籟鳴",
                "29": "洪流響",
                "30": "渚禽驚",
                "31": "弋磻放",
                "32": "稽鷦䳟",
                "33": "虞機發",
                "34": "留鵁鶄",
                "35": "鉤鉺縱橫",
                "36": "網罟接緒",
                "37": "術兼詹公",
                "38": "巧傾任父",
                "39": "筌䱎䲛",
                "40": "鱺鱨魦",
                "41": "罩兩魪",
                "42": "罺鰝鰕",
                "43": "乘鱟黿鼉",
                "44": "同罛共羅",
                "45": "沈虎潛鹿",
                "46": "馽龓僒束",
                "47": "鰴鯨輩中於羣犗",
                "48": "攙搶暴出而相屬",
                "49": "雖復臨河而釣鯉",
                "50": "無異射鮒於井谷"
            }
        },
        "16": {
            "33": {
                "1": "結輕舟而競逐",
                "2": "迎潮水而振緡",
                "3": "想萍實之復形",
                "4": "訪靈夔於鮫人",
                "5": "精衞銜石而遇繳",
                "6": "文鰩夜飛而觸綸",
                "7": "北山亡其翔翼",
                "8": "西海失其遊鱗",
                "9": "雕題之士",
                "10": "鏤身之卒",
                "11": "比飾虯龍",
                "12": "蛟螭與對",
                "13": "簡其華質",
                "14": "則𠃸錦繢",
                "15": "料其虓勇",
                "16": "則雕悍狼戾",
                "17": "相與昧潛險",
                "18": "搜瓌奇",
                "19": "摸蝳蝐",
                "20": "捫觜𧓈",
                "21": "剖巨蚌於回淵",
                "22": "濯明月於漣漪"
            }
        },
        "17": {
            "35": {
                "1": "畢天下之至異",
                "2": "訖無索而不臻",
                "3": "谿壑爲之一罄",
                "4": "川瀆爲之中貧",
                "5": "哂澹臺之見謀",
                "6": "聊襲海而徇珍",
                "7": "載漢女於後舟",
                "8": "追晉賈而同塵",
                "9": "汩乘流以砰宕",
                "10": "翼颸風之䬟䬟",
                "11": "直衝濤而上瀨",
                "12": "常沛沛以悠悠",
                "13": "汔可休而凱歸",
                "14": "揖天吳與陽侯",
                "15": "指包山而爲期",
                "16": "集洞庭而淹留",
                "17": "數軍實乎桂林之苑",
                "18": "饗戎旅乎落星之樓",
                "19": "置酒若淮泗",
                "20": "積肴若山丘",
                "21": "飛輕軒而酌綠酃",
                "22": "方雙轡而賦珍羞",
                "23": "飲烽起",
                "24": "釂鼓震",
                "25": "士遺倦",
                "26": "眾懷欣",
                "27": "幸乎館娃之宮",
                "28": "張女樂而娛羣臣",
                "29": "羅金石與絲竹",
                "30": "若鈞天之下陳",
                "31": "登東歌",
                "32": "操南音",
                "33": "胤陽阿",
                "34": "詠韎任",
                "35": "荊豔楚舞",
                "36": "吳愉越吟",
                "37": "翕習容裔",
                "38": "靡靡愔愔"
            }
        },
        "18": {
            "37": {
                "1": "若此者",
                "2": "與夫唱和之隆響",
                "3": "動鍾鼓之鏗耾",
                "4": "有殷坻頹於前",
                "5": "曲度難勝",
                "6": "皆與謠俗汁協",
                "7": "律呂相應",
                "8": "其奏樂也",
                "9": "則木石潤色",
                "10": "其吐哀也",
                "11": "則淒風暴興",
                "12": "或超延露而駕辯",
                "13": "或踰綠水而采菱",
                "14": "軍馬弭髦而仰秣",
                "15": "淵魚竦鱗而上升",
                "16": "酣湑半",
                "17": "八音幷",
                "18": "歡情留",
                "19": "良辰征",
                "20": "魯陽揮戈而高麾",
                "21": "迴曜靈於太清",
                "22": "將轉西日而再中",
                "23": "齊旣往之精誠"
            }
        },
        "19": {
            "39": {
                "1": "昔者夏后氏朝羣臣於茲土",
                "2": "而執玉帛者以萬國",
                "3": "蓋亦先生之所高會",
                "4": "而四方之所軌則",
                "5": "春秋之際",
                "6": "要盟之主",
                "7": "闔閭信其威",
                "8": "夫差窮其武",
                "9": "內果伍員之謀",
                "10": "外騁孫子之奇",
                "11": "勝彊楚於柏舉",
                "12": "栖勁越於會稽",
                "13": "闕溝乎商魯",
                "14": "爭長於黃池",
                "15": "徒以江湖嶮陂",
                "16": "物產殷充",
                "17": "繞霤未足言其固",
                "18": "鄭白未足語其豐",
                "19": "士有陷堅之銳",
                "20": "俗有節槪之風",
                "21": "睚眦則挺劍",
                "22": "喑嗚則彎弓",
                "23": "擁之者龍騰",
                "24": "據之者虎視",
                "25": "麾城若振槁",
                "26": "搴旗若顧指",
                "27": "雖帶甲一朝",
                "28": "而元功遠致",
                "29": "雖累葉百疊",
                "30": "而富彊相繼",
                "31": "樂湑衎其方域",
                "32": "列仙集其土地",
                "33": "桂父練形而易色",
                "34": "赤須蟬蛻而附麗",
                "35": "中夏比焉",
                "36": "畢世而罕見",
                "37": "丹青圖其珍瑋",
                "38": "貴其寶利也",
                "39": "舜禹遊焉",
                "40": "沒齒而忘歸",
                "41": "精靈留其山阿",
                "42": "翫其奇麗也",
                "43": "剖判庶士",
                "44": "商搉萬俗",
                "45": "國有鬱鞅而顯敞",
                "46": "邦有湫阨而踡跼",
                "47": "伊茲都之函弘",
                "48": "傾神州而韞櫝",
                "49": "仰南斗以斟酌",
                "50": "兼二儀之優渥"
            }
        },
        "20": {
            "41": {
                "1": "繇此而揆之",
                "2": "西蜀之於東吳",
                "3": "小大之相絕也",
                "4": "亦猶棘林螢燿",
                "5": "而與夫樳木龍燭也",
                "6": "否泰之相背也",
                "7": "亦猶帝之懸解",
                "8": "而與桎梏疏屬也",
                "9": "庸可共世而論巨細",
                "10": "同年而議豐确乎",
                "11": "曁其幽遐獨邃",
                "12": "寥廓閑奧",
                "13": "耳目之所不該",
                "14": "足趾之所不蹈",
                "15": "倜儻之極異",
                "16": "誳詭之殊事",
                "17": "藏理於終古",
                "18": "而未寤於前覺也",
                "19": "若吾子之所傳",
                "20": "孟浪之遺言",
                "21": "略舉其梗槪",
                "22": "而未得其要妙也"
            }
        }
    }
}