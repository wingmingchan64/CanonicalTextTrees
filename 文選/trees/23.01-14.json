{
    "23.01-14": {
        "篇名": "阮嗣宗 詠懷詩十七首·其十四",
        "1": {
            "3": {
                "1": "灼灼西隤日",
                "2": "餘光照我衣"
            },
            "4": {
                "1": "迴風吹四壁",
                "2": "寒鳥相因依"
            },
            "5": {
                "1": "周周尙銜羽",
                "2": "蛩蛩亦念飢"
            },
            "6": {
                "1": "如何當路子",
                "2": "磬折忘所歸"
            },
            "7": {
                "1": "豈爲夸譽名",
                "2": "憔悴使心悲"
            },
            "8": {
                "1": "寧與燕雀翔",
                "2": "不隨黃鵠飛"
            },
            "9": {
                "1": "黃鵠遊四海",
                "2": "中路將安歸"
            }
        }
    }
