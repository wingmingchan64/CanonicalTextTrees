{
    "40.01": {
        "篇名": "任彥升 奏彈曹景宗",
        "1": {
            "3": {
                "1": "御史中丞臣任昉稽首言",
                "2": "臣聞將軍死綏",
                "3": "咫步無卻",
                "4": "顧望避敵",
                "5": "逗橈有刑",
                "6": "至乃趙母深識",
                "7": "乞不爲坐",
                "8": "魏主著令",
                "9": "抵罪已輕",
                "10": "是知敗軍之將",
                "11": "身死家戮",
                "12": "爰自古昔",
                "13": "明罰斯在"
            }
        },
        "2": {
            "5": {
                "1": "臣昉頓首頓首",
                "2": "死罪死罪",
                "3": "竊尋獯獫侵軼",
                "4": "暫擾疆陲",
                "5": "王師薄伐",
                "6": "所向風靡",
                "7": "是以淮徐獻捷",
                "8": "河兗凱歸",
                "9": "東關無一戰之勞",
                "10": "塗中罕千金之費",
                "11": "而司部懸隔",
                "12": "斜臨寇境",
                "13": "故使狡虜憑陵",
                "14": "淹移歲月",
                "15": "故司州刺史蔡道恭",
                "16": "率厲義勇",
                "17": "奮不顧命",
                "18": "全城守死",
                "19": "自冬徂秋",
                "20": "猶有轉戰無窮",
                "21": "亟摧醜虜",
                "22": "方之居延",
                "23": "則陵降而恭守",
                "24": "比之疏勒",
                "25": "則耿存而蔡亡",
                "26": "若使郢部救兵",
                "27": "微接聲援",
                "28": "則單於之首",
                "29": "久懸北闕",
                "30": "豈直受降可築",
                "31": "涉安啟土而已哉"
            }
        },
        "3": {
            "7": {
                "1": "寔由郢州刺史臣景宗",
                "2": "受命致討",
                "3": "不時言邁",
                "4": "故使蝟結蟻聚",
                "5": "水草有依",
                "6": "方復按甲盤桓",
                "7": "緩救資敵",
                "8": "遂令孤城窮守",
                "9": "力屈凶威",
                "10": "雖然",
                "11": "猶應固守三關",
                "12": "更謀進取",
                "13": "而退師延頸",
                "14": "自貽虧衄",
                "15": "疆埸侵駭",
                "16": "職是之由",
                "17": "不有嚴刑",
                "18": "誅賞安寘",
                "19": "景宗卽主"
            }
        },
        "4": {
            "9": {
                "1": "臣謹案使持節都督郢司二州諸軍事",
                "2": "左將軍",
                "3": "郢州刺史",
                "4": "湘西縣開國侯臣景宗",
                "5": "擢自行間",
                "6": "遘茲多幸",
                "7": "指蹤非擬",
                "8": "獲獸何勤",
                "9": "賞茂通侯",
                "10": "榮高列將",
                "11": "負檐裁弛",
                "12": "鍾鼎遽列",
                "13": "和戎莫效",
                "14": "二八已陳",
                "15": "自頂至踵",
                "16": "功歸造化",
                "17": "潤草塗原",
                "18": "豈獲自已",
                "19": "且道恭云逝",
                "20": "城守累旬",
                "21": "景宗之存",
                "22": "一朝棄甲",
                "23": "生曹死蔡",
                "24": "優劣若是",
                "25": "惟此人斯",
                "26": "有靦面目"
            }
        },
        "5": {
            "11": {
                "1": "昔漢光命將",
                "2": "坐知千里",
                "3": "魏武置法",
                "4": "案以從事",
                "5": "故能出必以律",
                "6": "錙銖無爽",
                "7": "伏惟聖武英挺",
                "8": "略不世出",
                "9": "料敵制變",
                "10": "萬里無差",
                "11": "奉而行之",
                "12": "實弘廟筭",
                "13": "惟此庸固",
                "14": "理絕言提"
            }
        },
        "6": {
            "13": {
                "1": "自逆胡縱逸",
                "2": "久患諸夏",
                "3": "聖朝乃顧",
                "4": "將一車書",
                "5": "愍彼司氓",
                "6": "致辱非所",
                "7": "早朝永歎",
                "8": "載懷矜惻",
                "9": "致茲虧喪",
                "10": "何所逃罪",
                "11": "宜正刑書",
                "12": "肅明典憲",
                "13": "臣謹以劾",
                "14": "請以見事免景宗所居官",
                "15": "下太常削爵土",
                "16": "收付廷尉法獄治罪",
                "17": "其軍佐職僚",
                "18": "偏裨將帥絓諸應及咎者",
                "19": "別攝治書侍御史隨違續奏",
                "20": "臣謹奉白簡以聞云云"
            }
        }
    }
}