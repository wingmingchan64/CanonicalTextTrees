{
    "20.18-01": {
        "篇名": "曹子建 送應氏詩二首·其一",
        "1": {
            "3": {
                "1": "步登北芒阪",
                "2": "遙望洛陽山",
                "3": "洛陽何寂寞",
                "4": "宮室盡燒焚",
                "5": "垣牆皆頓擗",
                "6": "荊棘上參天",
                "7": "不見舊耆老",
                "8": "但睹新少年",
                "9": "側足無行徑",
                "10": "荒疇不復田",
                "11": "遊子久不歸",
                "12": "不識陌與阡",
                "13": "中野何蕭條",
                "14": "千里無人煙",
                "15": "念我平常居",
                "16": "氣結不能言"
            }
        }
    }
}