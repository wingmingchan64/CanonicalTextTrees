{
    "38.08": {
        "篇名": "任彥升 爲范尙書讓吏部封侯第一表",
        "1": {
            "3": {
                "1": "臣雲言",
                "2": "被尙書召",
                "3": "以臣爲散騎常侍",
                "4": "吏部尙書",
                "5": "封霄城縣開國侯",
                "6": "食邑千戶",
                "7": "奉命震驚",
                "8": "心顏無措",
                "9": "臣雲頓首頓首",
                "10": "死罪死罪",
                "11": "臣素門凡流",
                "12": "輪翮無取",
                "13": "進謝中庸",
                "14": "退慚狂狷",
                "15": "固嘗鑽厲求學",
                "16": "而一經不治",
                "17": "篆刻爲文",
                "18": "而三冬靡就",
                "19": "負書燕魏",
                "20": "空殫菽粟",
                "21": "躡屩齊楚",
                "22": "徒失貧賤",
                "23": "旣而分虎出守",
                "24": "以囊被見嗤",
                "25": "持斧作牧",
                "26": "以薏苡興謗",
                "27": "赭衣爲虜",
                "28": "見獄吏之尊",
                "29": "除名爲民",
                "30": "知井臼之逸",
                "31": "百年上壽",
                "32": "旣曰徒然",
                "33": "如其誠說",
                "34": "亦以過半",
                "35": "亂離斯瘼",
                "36": "欲以安歸",
                "37": "閉門荒郊",
                "38": "再離寒暑",
                "39": "兼以東皋數畝",
                "40": "控帶朝夕",
                "41": "關外一區",
                "42": "悵望鍾阜",
                "43": "雖室無趙女",
                "44": "而門多好事",
                "45": "祿微賜金",
                "46": "而歡同娛老",
                "47": "折芰燔枯",
                "48": "此焉自足"
            }
        },
        "2": {
            "5": {
                "1": "陛下應期萬世",
                "2": "接統千祀",
                "3": "三千景附",
                "4": "八百不謀",
                "5": "臣釁等離心",
                "6": "功慚同德",
                "7": "泥首在顏",
                "8": "輿棺未毀",
                "9": "締構草昧",
                "10": "敢叨天功",
                "11": "獄訟謳歌",
                "12": "示民同志",
                "13": "而隆器大名",
                "14": "一朝總集",
                "15": "顧己反躬",
                "16": "何以臻此",
                "17": "正當以接閈白水",
                "18": "列宅舊豐",
                "19": "忘捨講之尤",
                "20": "存諸公之費",
                "21": "俯拾青紫",
                "22": "豈待明經"
            }
        },
        "3": {
            "7": {
                "1": "臣雲頓首頓首",
                "2": "死罪死罪",
                "3": "夫銓衡之重",
                "4": "關諸隆替",
                "5": "遠惟則哲",
                "6": "在帝猶難",
                "7": "漢魏已降",
                "8": "達識繼軌",
                "9": "雅俗所歸",
                "10": "惟稱許郭",
                "11": "拔十得五",
                "12": "尙曰比肩",
                "13": "其餘得失未聞",
                "14": "偶察童幼",
                "15": "天機暫發",
                "16": "顧無足算",
                "17": "在魏則毛玠公方",
                "18": "居晉則山濤識量",
                "19": "以臣況之",
                "20": "一何遼落",
                "21": "齊季陵遲",
                "22": "官方淆亂",
                "23": "鴻都不綱",
                "24": "西園成市",
                "25": "金章有盈笥之談",
                "26": "華貂深不足之歎",
                "27": "草創惟始",
                "28": "義存改作",
                "29": "恭己南面",
                "30": "責成斯在",
                "31": "豈宜妄加寵私",
                "32": "以乏王事",
                "33": "附蟬之飾",
                "34": "空成寵章",
                "35": "求之公私",
                "36": "授受交失"
            }
        },
        "4": {
            "9": {
                "1": "近世侯者",
                "2": "功緒參差",
                "3": "或足食關中",
                "4": "或成軍河內",
                "5": "或制勝帷幄",
                "6": "或門人加親",
                "7": "或與時抑揚",
                "8": "或隱若敵國",
                "9": "或策定禁中",
                "10": "或功成野戰",
                "11": "或盛德如卓茂",
                "12": "或師道如桓榮",
                "13": "或四姓侍祠",
                "14": "已無足紀",
                "15": "五侯外戚",
                "16": "且非舊章",
                "17": "而臣之所附",
                "18": "惟在恩澤",
                "19": "旣義異疇庸",
                "20": "實榮乖儒者",
                "21": "雖小人貪幸",
                "22": "豈獨無心"
            }
        },
        "5": {
            "11": {
                "1": "臣本自諸生",
                "2": "家承素業",
                "3": "門無富貴",
                "4": "易農而仕",
                "5": "乃祖玄平",
                "6": "道風秀世",
                "7": "爰在中興",
                "8": "儀刑多士位裁元凱",
                "9": "任止牧伯",
                "10": "高祖少連",
                "11": "夙秉高尙",
                "12": "所富者義",
                "13": "所乏者時",
                "14": "薄宦東朝",
                "15": "謝病下邑",
                "16": "先志不忘",
                "17": "愚臣是庶",
                "18": "且去歲冬初",
                "19": "國學之老博士耳",
                "20": "今茲首夏",
                "21": "將亞冢司",
                "22": "雖千秋之一日九遷",
                "23": "荀爽之十旬遠至",
                "24": "方之微臣",
                "25": "未爲速達",
                "26": "臣雖無識",
                "27": "惟利是視",
                "28": "至於虧名損實",
                "29": "爲國爲身",
                "30": "知其不可",
                "31": "不敢妄冒"
            }
        },
        "6": {
            "13": {
                "1": "陛下不棄菅蒯",
                "2": "愛同絲麻",
                "3": "儻平生之言",
                "4": "猶在聽覽",
                "5": "宿心素志",
                "6": "無復貳辭",
                "7": "矜臣所乞",
                "8": "特迴寵命",
                "9": "則彛章載穆",
                "10": "微物知免",
                "11": "臣今在假",
                "12": "不容詣省",
                "13": "不任荷懼之至",
                "14": "謹奉表以聞",
                "15": "臣雲誠惶以下"
            }
        }
    }
}