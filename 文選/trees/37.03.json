{
    "37.03": {
        "篇名": "曹子建 求自試表",
        "1": {
            "3": {
                "1": "臣植言",
                "2": "臣聞士之生世",
                "3": "入則事父",
                "4": "出則事君",
                "5": "事父尙於榮親",
                "6": "事君貴於興國",
                "7": "故慈父不能愛無益之子",
                "8": "仁君不能畜無用之臣",
                "9": "夫論德而授官者",
                "10": "成功之君也",
                "11": "量能而受爵者",
                "12": "畢命之臣也",
                "13": "故君無虛授",
                "14": "臣無虛受",
                "15": "虛授謂之謬舉",
                "16": "虛受謂之尸祿",
                "17": "詩之素餐",
                "18": "所由作也",
                "19": "昔二虢不辭兩國之任",
                "20": "其德厚也",
                "21": "旦奭不讓燕魯之封",
                "22": "其功大也"
            }
        },
        "2": {
            "5": {
                "1": "今臣蒙國重恩",
                "2": "三世於今矣",
                "3": "正値陛下升平之際",
                "4": "沐浴聖澤",
                "5": "潛潤德教",
                "6": "可謂厚幸矣",
                "7": "而位竊東藩",
                "8": "爵在上列",
                "9": "身被輕暖",
                "10": "口厭百味",
                "11": "目極華靡",
                "12": "耳倦絲竹者",
                "13": "爵重祿厚之所致也",
                "14": "退念古之受爵祿者",
                "15": "有異於此",
                "16": "皆以功勤濟國",
                "17": "輔主惠民",
                "18": "今臣無德可述",
                "19": "無功可紀",
                "20": "若此終年",
                "21": "無益國朝",
                "22": "將挂風人彼己之譏",
                "23": "是以上慚玄冕",
                "24": "俯愧朱紱"
            }
        },
        "3": {
            "7": {
                "1": "方今天下一統",
                "2": "九州晏如",
                "3": "顧西尙有違命之蜀",
                "4": "東有不臣之吳",
                "5": "使邊境未得稅甲",
                "6": "謀士未得高枕者",
                "7": "誠欲混同宇內",
                "8": "以致太和也",
                "9": "故啟滅有扈而夏功昭",
                "10": "成克商奄而周德著",
                "11": "今陛下以聖明統世",
                "12": "將欲卒文武之功",
                "13": "繼成康之隆",
                "14": "簡良授能",
                "15": "以方叔邵虎之臣",
                "16": "鎭衞四境",
                "17": "爲國爪牙者",
                "18": "可謂當矣",
                "19": "然而高鳥未挂於輕繳",
                "20": "淵魚未懸於鉤餌者",
                "21": "恐釣射之術",
                "22": "或未盡也",
                "23": "昔耿弇不俟光武",
                "24": "亟擊張步",
                "25": "言不以賊遺於君父也",
                "26": "故車右伏劍於鳴轂",
                "27": "雍門刎首於齊境",
                "28": "若此二子",
                "29": "豈惡生而尙死哉",
                "30": "誠忿其慢主而陵君也",
                "31": "夫君之寵臣",
                "32": "欲以除害興利",
                "33": "臣之事君",
                "34": "必以殺身靜亂",
                "35": "以功報主也",
                "36": "昔賈誼弱冠",
                "37": "求試屬國",
                "38": "請係單於之頸而制其命",
                "39": "終軍以妙年使越",
                "40": "欲得長纓占其王",
                "41": "羈致北闕",
                "42": "此二臣豈好爲夸主而耀世俗哉",
                "43": "志或鬱結",
                "44": "欲逞才力輸能於明君也",
                "45": "昔漢武爲霍去病治第",
                "46": "辭曰",
                "47": "匈奴未滅",
                "48": "臣無以家爲",
                "49": "固夫憂國忘家",
                "50": "捐軀濟難",
                "51": "忠臣之志也"
            }
        },
        "4": {
            "9": {
                "1": "今臣居外",
                "2": "非不厚也",
                "3": "而寢不安席",
                "4": "食不遑味者",
                "5": "伏以二方未克爲念",
                "6": "伏見先武皇帝武臣宿兵",
                "7": "年耆卽世者有聞矣",
                "8": "雖賢不乏世",
                "9": "宿將舊卒",
                "10": "猶習戰也",
                "11": "竊不自量",
                "12": "志在效命",
                "13": "庶立毛髮之功",
                "14": "以報所受之恩",
                "15": "若使陛下出不世之詔",
                "16": "效臣錐刀之用",
                "17": "使得西屬大將軍",
                "18": "當一校之隊",
                "19": "若東屬大司馬",
                "20": "統偏師之任",
                "21": "必乘危躡險",
                "22": "騁舟奮驪",
                "23": "突刃觸鋒",
                "24": "爲士卒先",
                "25": "雖未能禽權馘亮",
                "26": "庶將虜其雄率",
                "27": "殲其醜類",
                "28": "必效須臾之捷",
                "29": "以滅終身之愧",
                "30": "使名挂史筆",
                "31": "事列朝榮",
                "32": "雖身分蜀境",
                "33": "首懸吳闕",
                "34": "猶生之年也",
                "35": "如微才不試",
                "36": "沒世無聞",
                "37": "徒榮其軀而豐其體",
                "38": "生無益於事",
                "39": "死無損於數",
                "40": "虛荷上位而忝重祿",
                "41": "禽息鳥視",
                "42": "終於白首",
                "43": "此徒圈牢之養物",
                "44": "非臣之所志也",
                "45": "流聞東軍失備",
                "46": "師徒小衄",
                "47": "輟食棄餐",
                "48": "奮袂攘衽",
                "49": "撫劍東顧",
                "50": "而心已馳於吳會矣"
            }
        },
        "5": {
            "11": {
                "1": "臣昔從先武皇帝",
                "2": "南極赤岸",
                "3": "東臨滄海",
                "4": "西望玉門",
                "5": "北出玄塞",
                "6": "伏見所以行軍用兵之勢",
                "7": "可謂神妙矣",
                "8": "故兵者不可預言",
                "9": "臨難而制變者也",
                "10": "志欲自效於明時",
                "11": "立功於聖世",
                "12": "每覽史籍",
                "13": "觀古忠臣義士",
                "14": "出一朝之命",
                "15": "以殉國家之難",
                "16": "身雖屠裂",
                "17": "而功銘著於景鍾",
                "18": "名稱垂於竹帛",
                "19": "未嘗不拊心而歎息也",
                "20": "臣聞明主使臣",
                "21": "不廢有罪",
                "22": "故奔北敗軍之將用",
                "23": "秦魯以成其功",
                "24": "絕纓盜馬之臣赦",
                "25": "楚趙以濟其難",
                "26": "臣竊感先帝早崩",
                "27": "威王棄代",
                "28": "臣獨何人",
                "29": "以堪長久",
                "30": "常恐先朝露",
                "31": "塡溝壑",
                "32": "墳土未乾",
                "33": "而身名並滅",
                "34": "臣聞騏驥長鳴",
                "35": "伯樂昭其能",
                "36": "盧狗悲號",
                "37": "韓國知其才",
                "38": "是以效之齊楚之路",
                "39": "以逞千里之任",
                "40": "試之狡兔之捷",
                "41": "以驗搏噬之用",
                "42": "今臣志狗馬之微功",
                "43": "竊自惟度",
                "44": "終無伯樂韓國之舉",
                "45": "是以於邑而竊自痛者也",
                "46": "夫臨博而企竦",
                "47": "聞樂而竊抃者",
                "48": "或有賞音而識道也",
                "49": "昔毛遂",
                "50": "趙之陪隸",
                "51": "猶假錐囊之喩",
                "52": "以寤主立功",
                "53": "何況巍巍大魏多士之朝",
                "54": "而無慷慨死難之臣乎"
            }
        },
        "6": {
            "13": {
                "1": "夫自衒自媒者",
                "2": "士女之醜行也",
                "3": "干時求進者",
                "4": "道家之明忌也",
                "5": "而臣敢陳聞於陛下者",
                "6": "誠與國分形同氣",
                "7": "憂患共之者也",
                "8": "冀以塵露之微",
                "9": "補益山海",
                "10": "螢燭末光",
                "11": "增輝日月",
                "12": "是以敢冒其醜而獻其忠",
                "13": "必知爲朝士所笑",
                "14": "聖主不以人廢言",
                "15": "伏惟陛下少垂神聽",
                "16": "臣則幸矣"
            }
        }
    }
}