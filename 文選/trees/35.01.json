                "85": "傾罍一朝",
                "86": "可以流湎千日",
                "87": "單醪投川",
                "88": "可使三軍告捷",
                "89": "斯人神之所歆羨",
                "90": "觀聽之所煒曄也",
                "91": "子豈能強起而御之乎",
                "92": "公子曰",
                "93": "耽口爽之饌",
                "94": "甘腊毒之味",
                "95": "服腐腸之藥",
                "96": "御亡國之器",
                "97": "雖子大夫之所榮",
                "98": "故亦吾人之所畏",
                "99": "余病",
                "100": "未能也"
            }
        },
        "8": {
            "17": {
                "1": "大夫曰",
                "2": "蓋有晉之融皇風也",
                "3": "金華啟徵",
                "4": "大人有作",
                "5": "繼明代照",
                "6": "配天光宅",
                "7": "其基德也",
                "8": "隆於姬公之處岐",
                "9": "其垂仁也",
                "10": "富乎有殷之在亳",
                "11": "南箕之風",
                "12": "不能暢其化",
                "13": "離畢之雲",
                "14": "無以豐其澤",
                "15": "皇道煥炳",
                "16": "帝載緝熙",
                "17": "導氣以樂",
                "18": "宣德以詩",
                "19": "教清於雲官之世",
                "20": "治穆乎鳥紀之時",
                "21": "王猷四塞",
                "22": "函夏謐寧",
                "23": "丹冥投烽",
                "24": "青徼釋警",
                "25": "卻馬於糞車之轅",
                "26": "銘德於昆吳之鼎",
                "27": "羣萌反素",
                "28": "時文載郁",
                "29": "耕父推畔",
                "30": "魚豎讓陸",
                "31": "樵夫恥危冠之飾",
                "32": "輿臺笑短後之服",
                "33": "六合時邕",
                "34": "巍巍蕩蕩",
                "35": "玄齠巷歌",
                "36": "黃髮擊壤",
                "37": "解羲皇之繩",
                "38": "錯陶唐之象",
                "39": "若乃華裔之夷",
                "40": "流荒之貊",
                "41": "語不傳於輶軒",
                "42": "地不被乎正朔",
                "43": "莫不駿奔稽顙",
                "44": "委質重譯",
                "45": "於時昆蚑感惠",
                "46": "無思不擾",
                "47": "苑戲九尾之禽",
                "48": "囿栖三足之烏",
                "49": "鳴鳳在林",
                "50": "夥於黃帝之園",
                "51": "有龍遊淵",
                "52": "盈於孔甲之沼",
                "53": "萬物煙熅",
                "54": "天地交泰",
                "55": "義懷靡內",
                "56": "化感無外",
                "57": "林無被褐",
                "58": "山無韋帶",
                "59": "皆象刻於百工",
                "60": "兆發乎靈蔡",
                "61": "搢紳濟濟",
                "62": "軒冕藹藹",
                "63": "功與造化爭流",
                "64": "德與二儀比大",
                "65": "言未終",
                "66": "公子蹶然而興",
                "67": "曰",
                "68": "鄙夫固陋",
                "69": "守此狂狷",
                "70": "蓋理有毀之",
                "71": "而爭寶之訟解",
                "72": "言有怒之",
                "73": "而齊王之疾痊",
                "74": "向子誘我以聾耳之樂",
                "75": "栖我以蔀家之屋",
                "76": "田遊馳蕩",
                "77": "利刃駿足",
                "78": "旣老氏之攸戒",
                "79": "非吾人之所欲",
                "80": "故靡得應子",
                "81": "至聞皇風載韙",
                "82": "時聖道醇",
                "83": "舉實爲秋",
                "84": "摛藻爲春",
                "85": "下有可封之民",
                "86": "上有大哉之君",
                "87": "余雖不敏",
                "88": "請尋後塵"
            }
        }
    }
}