                "62": "生必耀華名於玉牒",
                "63": "沒則勒洪伐於金冊",
                "64": "今公子違世陸沈",
                "65": "避地獨竄",
                "66": "有生之歡滅",
                "67": "資父之義廢",
                "68": "愁洽百年",
                "69": "苦溢千歲",
                "70": "何異促鱗之遊汀濘",
                "71": "短羽之栖翳薈",
                "72": "今將榮子以天人之大寶",
                "73": "悅子以縱性之至娛",
                "74": "窮地而遊",
                "75": "中天而居",
                "76": "傾四海之歡",
                "77": "殫九州之腴",
                "78": "鑽屈轂之瓠",
                "79": "解疏屬之拘",
                "80": "子欲之乎",
                "81": "公子曰",
                "82": "大夫不遺",
                "83": "來萃荒外",
                "84": "雖在不敏",
                "85": "敬聽嘉話"
