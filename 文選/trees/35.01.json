                "33": "發蓐收之變商",
                "34": "若乃龍火西頹",
                "35": "暄氣初收",
                "36": "飛霜迎節",
                "37": "高風送秋",
                "38": "羈旅懷土之徒",
                "39": "流宕百罹之疇",
                "40": "撫促柱則酸鼻",
                "41": "揮危絃則涕流",
                "42": "若乃追清哇",
                "43": "赴嚴節",
                "44": "奏綠水",
                "45": "吐白雪",
                "46": "激楚迴",
                "47": "流風結",
                "48": "悲蓂莢之朝落",
                "49": "悼望舒之夕缺",
                "50": "煢釐爲之擗摽",
                "51": "孀老爲之嗚咽",
                "52": "王子拂纓而傾耳",
