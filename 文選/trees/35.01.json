{
    "35.01": {
        "篇名": "張景陽 七命八首",
        "1": {
            "3": {
                "1": "沖漠公子",
                "2": "含華隱曜",
                "3": "嘉遯龍盤",
                "4": "翫世高蹈",
                "5": "遊心於浩然",
                "6": "玩志乎眾妙",
                "7": "絕景乎大荒之遐阻",
                "8": "吞響乎幽山之窮奧",
