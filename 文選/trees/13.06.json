{
    "13.06": {
        "篇名": "禰正平 鸚鸝賦[幷序]",
        "1": {
            "3": {
                "1": "時黃祖太子射賓客大會",
                "2": "有獻鸚鵡者",
                "3": "舉酒於衡前曰",
                "4": "禰處士",
                "5": "今日無用娛賓",
                "6": "竊以此鳥自遠而至",
                "7": "明慧聰善",
                "8": "羽族之可貴",
                "9": "願先生爲之賦",
                "10": "使四坐咸共榮觀",
                "11": "不亦可乎",
                "12": "衡因爲賦",
                "13": "筆不停綴",
                "14": "文不加點",
                "15": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "惟西域之靈鳥兮",
                "2": "挺自然之奇姿",
                "3": "體金精之妙質兮",
                "4": "合火德之明煇",
                "5": "性辯慧而能言兮",
                "6": "才聰明以識機",
                "7": "故其嬉遊高峻",
                "8": "栖跱幽深",
                "9": "飛不妄集",
                "10": "翔必擇林",
                "11": "紺趾丹觜",
                "12": "綠衣翠矜",
                "13": "采采麗容",
                "14": "咬咬好音",
                "15": "雖同族於羽毛",
                "16": "固殊智而異心",
                "17": "配鸞皇而等美",
                "18": "焉比德於眾禽"
            }
        },
        "3": {
            "7": {
                "1": "於是羨芳聲之遠暢",
                "2": "偉靈表之可嘉",
                "3": "命虞人於隴坻",
                "4": "詔伯益於流沙",
                "5": "跨崑崙而播弋",
                "6": "冠雲霓而張羅",
                "7": "雖綱維之備設",
                "8": "終一目之所加",
                "9": "且其容止閑暇",
                "10": "守植安停",
                "11": "逼之不懼",
                "12": "撫之不驚",
                "13": "寧順從以遠害",
                "14": "不違迕以喪生",
                "15": "故獻全者受賞",
                "16": "而傷肌者被刑"
            }
        },
        "4": {
            "9": {
                "1": "爾乃歸窮委命",
                "2": "離羣喪侶",
                "3": "閉以雕籠",
                "4": "剪其翅羽",
                "5": "流飄萬里",
                "6": "崎嶇重阻",
                "7": "踰岷越障",
                "8": "載罹寒暑",
                "9": "女辭家而適人",
                "10": "臣出身而事主",
                "11": "彼賢哲之逢患",
                "12": "猶栖遲以羈旅",
                "13": "矧禽鳥之微物",
                "14": "能馴擾以安處",
                "15": "眷西路而長懷",
                "16": "望故鄕而延佇",
                "17": "忖陋體之腥臊",
                "18": "亦何勞於鼎俎"
            }
        },
        "5": {
            "11": {
                "1": "嗟祿命之衰薄",
                "2": "奚遭時之險巇",
                "3": "豈言語以階亂",
                "4": "將不密以致危",
                "5": "痛母子之永隔",
                "6": "哀伉儷之生離",
                "7": "匪餘年之足惜",
                "8": "慜眾雛之無知",
                "9": "背蠻夷之下國",
                "10": "侍君子之光儀",
                "11": "懼名實之不副",
                "12": "恥才能之無奇",
                "13": "羨西都之沃壤",
                "14": "識苦樂之異宜",
                "15": "懷代越之悠思",
                "16": "故每言而稱斯"
            }
        },
        "6": {
            "13": {
                "1": "若乃少昊司辰",
                "2": "蓐收整轡",
                "3": "嚴霜初降",
                "4": "涼風蕭瑟",
                "5": "長吟遠慕",
                "6": "哀鳴感類",
                "7": "音聲悽以激揚",
                "8": "容貌慘以憔悴",
                "9": "聞之者悲傷",
                "10": "見之者隕淚",
                "11": "放臣爲之屢歎",
                "12": "棄妻爲之歔欷"
            }
        },
        "7": {
            "15": {
                "1": "感平身之遊處",
                "2": "若壎篪之相須",
                "3": "何今日之兩絕",
                "4": "若胡越之異區",
                "5": "順櫳檻以俯仰",
                "6": "闚戶牖以踟躇",
                "7": "想崑山之高嶽",
                "8": "思鄧林之扶疏",
                "9": "顧六翮之殘毀",
                "10": "雖奮迅其焉如",
                "11": "心懷歸而弗果",
                "12": "徒怨毒於一隅",
                "13": "苟竭心於所事",
                "14": "敢背惠而忘初",
                "15": "託輕鄙之微命",
                "16": "委陋賤於薄軀",
                "17": "期守死以報德",
                "18": "甘盡辭以效愚",
                "19": "恃隆恩於旣往",
                "20": "庶彌久而不渝"
            }
        }
    }
}