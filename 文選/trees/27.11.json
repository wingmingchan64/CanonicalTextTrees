{
    "27.11": {
        "篇名": "丘希範 旦發魚浦潭",
        "1": {
            "3": {
                "1": "漁潭霧未開",
                "2": "赤亭風已颺",
                "3": "櫂歌發中流",
                "4": "鳴鼙響沓障",
                "5": "村童忽相聚",
                "6": "野老時一望",
                "7": "詭怪石異像",
                "8": "嶄絕峯殊狀",
                "9": "森森荒樹齊",
                "10": "析析寒沙漲",
                "11": "藤垂島易陟",
                "12": "崖傾嶼難傍",
                "13": "信是永幽栖",
                "14": "豈徒暫清曠",
                "15": "坐嘯昔有委",
                "16": "臥治今可尙"
            }
        }
    }
}