{
    "30.04": {
        "篇名": "陶淵明 讀山海經詩",
        "1": {
            "3": {
                "1": "孟夏草木長",
                "2": "繞屋樹扶疏",
                "3": "眾鳥欣有託",
                "4": "吾亦愛吾廬",
                "5": "旣耕亦已種",
                "6": "且還讀我書",
                "7": "窮巷隔深轍",
                "8": "頗迴故人車",
                "9": "歡言酌春酒",
                "10": "擿我園中蔬",
                "11": "微雨從東來",
                "12": "好風與之俱",
                "13": "泛覽周王傳",
                "14": "流觀山海圖",
                "15": "俛仰終宇宙",
                "16": "不樂復何如"
            }
        }
    }
}