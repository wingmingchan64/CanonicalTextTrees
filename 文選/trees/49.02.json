{
    "49.02": {
        "篇名": "干令升 晉紀·論晉武帝革命",
        "1": {
            "3": {
                "1": "史臣曰",
                "2": "帝王之興",
                "3": "必俟天命",
                "4": "苟有代謝",
                "5": "非人事也",
                "6": "文質異時",
                "7": "興建不同",
                "8": "故古之有天下者",
                "9": "柏皇栗陸以前",
                "10": "爲而不有",
                "11": "應而不求",
                "12": "執大象也",
                "13": "鴻黃世及",
                "14": "以一民也",
                "15": "堯舜內禪",
                "16": "體文德也",
                "17": "漢魏外禪",
                "18": "順大名也",
                "19": "湯武革命",
                "20": "應天人也",
                "21": "高光爭伐",
                "22": "定功業也",
                "23": "各因其運而天下隨時",
                "24": "隨時之義大矣哉",
                "25": "古者敬其事則命以始",
                "26": "今帝王受命而用其終",
                "27": "豈人事乎",
                "28": "其天意乎"
            }
        }
    }
}