{
    "29.23-07": {
        "篇名": "張景陽 雜詩十首·其七",
        "1": {
            "3": {
                "1": "此鄕非吾地",
                "2": "此郭非吾城",
                "3": "羈旅無定心",
                "4": "翩翩如懸旌",
                "5": "出睹軍馬陣",
                "6": "入聞鼙鼓聲",
                "7": "常懼羽檄飛",
                "8": "神武一朝征",
                "9": "長鋏鳴鞘中",
                "10": "烽火列邊亭",
                "11": "舍我衡門依",
                "12": "更被縵胡纓",
                "13": "疇昔懷微志",
                "14": "帷幕竊所經",
                "15": "何必操干戈",
                "16": "堂上有奇兵",
                "17": "折衝尊俎間",
                "18": "制勝在兩楹",
                "19": "巧遲不足稱",
                "20": "拙速乃垂名"
            }
        }
    }
}