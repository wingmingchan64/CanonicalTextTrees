{
    "36.04": {
        "篇名": "王元長 永明九年策秀才文五首",
        "1": {
            "3": {
                "1": "問秀才高第明經",
                "2": "朕聞神靈文思之君",
                "3": "聰明聖德之后",
                "4": "體道而不居",
                "5": "見善如不及",
                "6": "是以崆峒有順風之請",
                "7": "華封致乘雲之拜",
                "8": "或揚旌求士",
                "9": "或設簴待賢",
                "10": "用能敷化一時",
                "11": "餘烈千古",
                "12": "朕夤奉天命",
                "13": "恭惟永圖",
                "14": "審聽高居",
                "15": "載懷祇懼",
                "16": "雖言事必史",
                "17": "而象闕未箴",
                "18": "寤寐嘉猷",
                "19": "延佇忠實",
                "20": "子大夫選名升學",
                "21": "利用賓王",
                "22": "懋陳三道之要",
                "23": "以光四科之首",
                "24": "鹽梅之和",
                "25": "屬有望焉"
            }
        },
        "2": {
            "5": {
                "1": "又問",
                "2": "昔周宣惰千畝之禮",
                "3": "虢公納諫",
                "4": "漢文缺三推之義",
                "5": "賈生置言",
                "6": "良以食爲民天",
                "7": "農爲政本",
                "8": "金湯非粟而不守",
                "9": "水旱有待而無遷",
                "10": "朕式照前經",
                "11": "寶茲稼穡",
                "12": "祥正而青旗肅事",
                "13": "土膏而朱紘戒典",
                "14": "將使杏花菖葉",
                "15": "耕穫不愆",
                "16": "清甽泠風",
                "17": "述遵無廢",
                "18": "而釋耒佩牛",
                "19": "相沿莫反",
                "20": "兼貧擅富",
                "21": "浸以爲俗",
                "22": "若爰井開制",
                "23": "懼驚擾愚民",
                "24": "舄鹵可腴",
                "25": "恐時無史白",
                "26": "興廢之術",
                "27": "矢陳厥謀"
            }
        },
        "3": {
            "7": {
                "1": "又問",
                "2": "議獄緩死",
                "3": "大易深規",
                "4": "敬法卹刑",
                "5": "虞書茂典",
                "6": "自萌俗澆弛",
                "7": "法令滋彰",
                "8": "胏石少不冤之人",
                "9": "棘林多夜哭之鬼",
                "10": "朕所以明發動容",
                "11": "昃食興慮",
                "12": "傷秋荼之密網",
                "13": "惻夏日之嚴威",
                "14": "永念畫冠",
                "15": "緬追刑厝",
                "16": "徒以百鍰輕科",
                "17": "反行季葉",
                "18": "四支重罰",
                "19": "爰創前古",
                "20": "訪遊禽於絕澗",
                "21": "作霸秦基",
                "22": "歌雞鳴於闕下",
                "23": "稱仁漢牘",
                "24": "二途如爽",
                "25": "卽用兼通",
                "26": "昌言所安",
                "27": "朕將親覽"
            }
        },
        "4": {
            "9": {
                "1": "又問",
                "2": "聚人曰財",
                "3": "次政曰貨",
                "4": "泉流表其不匱",
                "5": "貿遷通其有亡",
                "6": "旣龜貝積寢",
                "7": "緡繈專用",
                "8": "世代滋多",
                "9": "銷漏參倍",
                "10": "下貧無兼辰之業",
                "11": "中產闕洊歲之貲",
                "12": "惟瘼卹隱",
                "13": "無捨矜歎",
                "14": "上帝溥臨",
                "15": "賜朕休寶",
                "16": "命邛斜之谷",
                "17": "開而出銅",
                "18": "且有後命",
                "19": "事茲鎔範",
                "20": "充都內之金",
                "21": "紹圓府之職",
                "22": "但赤側深巧學之患",
                "23": "楡莢難輕重之權",
                "24": "開塞所宜",
                "25": "悉心以對"
            }
        },
        "5": {
            "11": {
                "1": "又問",
                "2": "治歷明時",
                "3": "紹遷革之運",
                "4": "改憲敕法",
                "5": "審刑德之原",
                "6": "分命顯於唐官",
                "7": "文條炳於鄒說",
                "8": "及嵎夷廢職",
                "9": "昧谷虧方",
                "10": "漢秉素祇之徵",
                "11": "魏稱黃星之驗",
                "12": "紛爭空軫",
                "13": "疑論無歸",
                "14": "朕獲纂洪基",
                "15": "思弘至道",
                "16": "庶令日月休徵",
                "17": "風雨玉燭",
                "18": "克明之旨弗遠",
                "19": "欽若之義復還",
                "20": "於子大夫何如哉",
                "21": "其驪翰改色",
                "22": "寅丑殊建",
                "23": "別白書之"
            }
        }
    }
}