{
    "18.02": {
        "篇名": "嵇叔夜 琴賦[幷序]",
        "1": {
            "3": {
                "1": "余少好音聲",
                "2": "長而翫之",
                "3": "以爲物有盛衰",
                "4": "而此無變",
                "5": "滋味有厭",
                "6": "而此不勌",
                "7": "可以導養神氣",
                "8": "宣和情志",
                "9": "處窮獨而不悶者",
                "10": "莫近於音聲也",
                "11": "是故復之而不足",
                "12": "則吟詠以肆志",
                "13": "吟詠之不足",
                "14": "則寄言以廣意",
                "15": "然八音之器",
                "16": "歌舞之象",
                "17": "歷世才士",
                "18": "並爲之賦頌",
                "19": "其體制風流",
                "20": "莫不相襲",
                "21": "稱其材幹",
                "22": "則以危苦爲上",
                "23": "賦其聲音",
                "24": "則以悲哀爲主",
                "25": "美其感化",
                "26": "則以垂涕爲貴",
                "27": "麗則麗矣",
                "28": "然未盡其理也",
                "29": "推其所由",
                "30": "似元不解音聲",
                "31": "覽其旨趣",
                "32": "亦未達禮樂之情也",
                "33": "眾器之中",
                "34": "琴德最優",
                "35": "故綴敍所懷",
                "36": "以爲之賦",
                "37": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "惟椅梧之所生兮",
                "2": "託峻嶽之崇岡",
                "3": "披重壤以誕載兮",
                "4": "參辰極而高驤",
                "5": "含天地之醇和兮",
                "6": "吸日月之休光",
                "7": "鬱紛紜以獨茂兮",
                "8": "飛英蕤於昊蒼",
                "9": "夕納景於虞淵兮",
                "10": "旦晞幹於九陽",
                "11": "經千載以待價兮",
                "12": "寂神跱而永康"
            }
        },
        "3": {
            "7": {
                "1": "且其山川形勢",
                "2": "則盤紆隱深",
                "3": "磪嵬岑嵓",
                "4": "互嶺巉巖",
                "5": "岞崿嶇崟",
                "6": "丹崖嶮巇",
                "7": "青壁萬尋",
                "8": "若乃重巘增起",
                "9": "偃蹇雲覆",
                "10": "邈隆崇以極壯",
                "11": "崛巍巍而特秀",
                "12": "蒸靈液以播雲",
                "13": "據神淵而吐溜",
                "14": "爾乃顚波奔突",
                "15": "狂赴爭流",
                "16": "觸巖觝隈",
                "17": "鬱怒彪休",
                "18": "洶涌騰薄",
                "19": "奪沫揚濤",
                "20": "瀄汨澎湃",
                "21": "䖤蟺相糾",
                "22": "放肆大川",
                "23": "濟乎中州",
                "24": "安回徐邁",
                "25": "寂爾長浮",
                "26": "澹乎洋洋",
                "27": "縈抱山丘",
                "28": "詳觀其區土之所產毓",
                "29": "奧宇之所寶殖",
                "30": "珍怪琅玕",
                "31": "瑤瑾翕赩",
                "32": "叢集累積",
                "33": "奐衍於其側",
                "34": "若乃春蘭被其東",
                "35": "沙棠殖其西",
                "36": "涓子宅其陽",
                "37": "玉醴涌其前",
                "38": "玄雲蔭其上",
                "39": "翔鸞集其巓",
                "40": "清露潤其膚",
                "41": "惠風流其間",
                "42": "竦肅肅以靜謐",
                "43": "密微微其清閑",
                "44": "夫所以經營其左右者",
                "45": "固以自然神麗",
                "46": "而足思願愛樂矣"
            }
        },
        "4": {
            "9": {
                "1": "於是遯世之士",
                "2": "榮期綺季之疇",
                "3": "乃相與登飛梁",
                "4": "越幽壑",
                "5": "援瓊枝",
                "6": "陟峻崿",
                "7": "以遊乎其下",
                "8": "周旋永望",
                "9": "邈若凌飛",
                "10": "邪睨崑崙",
                "11": "俯闞海湄",
                "12": "指蒼梧之迢遞",
                "13": "臨迴江之威夷",
                "14": "悟時俗之多累",
                "15": "仰箕山之餘輝",
                "16": "羨斯嶽之弘敞",
                "17": "心慷慨以忘歸",
                "18": "情舒放而遠覽",
                "19": "接軒轅之遺音",
                "20": "慕老童於騩隅",
                "21": "欽泰容之高吟",
                "22": "顧茲梧而興慮",
                "23": "思假物以託心",
                "24": "乃斲孫枝",
                "25": "准量所任",
                "26": "至人攄思",
                "27": "制爲雅琴"
            }
        },
        "5": {
            "11": {
                "1": "乃使離子督墨",
                "2": "匠石奮斤",
                "3": "夔襄薦法",
                "4": "般倕騁神",
                "5": "鎪會裛廁",
                "6": "朗密調均",
                "7": "華繪彫琢",
                "8": "布藻垂文",
                "9": "錯以犀象",
                "10": "籍以翠綠",
                "11": "絃以園客之絲",
                "12": "徽以鍾山之玉",
                "13": "爰有龍鳳之象",
                "14": "古人之形",
                "15": "伯牙揮手",
                "16": "鍾期聽聲",
                "17": "華容灼爚",
                "18": "發采揚明",
                "19": "何其麗也",
                "20": "伶倫比律",
                "21": "田連操張",
                "22": "進御君子",
                "23": "新聲憀亮",
                "24": "何其偉也"
            }
        },
        "6": {
            "13": {
                "1": "及其初調",
                "2": "則角羽俱起",
                "3": "宮徵相證",
                "4": "參發並趣",
                "5": "上下累應",
                "6": "踸踔磥硌",
                "7": "美聲將興",
                "8": "固以和昶而足躭矣",
                "9": "爾乃理正聲",
                "10": "奏妙曲",
                "11": "揚白雪",
                "12": "發清角",
                "13": "紛淋浪以流離",
                "14": "奐淫衍而優渥",
                "15": "粲奕奕而高逝",
                "16": "馳岌岌以相屬",
                "17": "沛騰遌而競趣",
                "18": "翕韡曄而繁縟",
                "19": "狀若崇山",
                "20": "又象流波",
                "21": "浩兮湯湯",
                "22": "鬱兮峨峨",
                "23": "怫㥜煩冤",
                "24": "紆餘婆娑",
                "25": "陵縱播逸",
                "26": "霍濩紛葩",
                "27": "檢容授節",
                "28": "應變合度",
                "29": "兢名擅業",
                "30": "安軌徐步",
                "31": "洋洋習習",
                "32": "聲烈遐布",
                "33": "含顯媚以送終",
                "34": "飄餘響乎泰素",
                "35": "若乃高軒飛觀",
                "36": "廣夏閑房",
                "37": "冬夜肅清",
                "38": "朗月垂光",
                "39": "新衣翠粲",
                "40": "纓徽流芳",
                "41": "於是器冷絃調",
                "42": "心閑手敏",
                "43": "觸批(鎞金改扌)如志",
                "44": "唯意所擬",
                "45": "初涉淥水",
                "46": "中奏清徵",
                "47": "雅昶唐堯",
                "48": "終詠微子",
                "49": "寬明弘潤",
                "50": "優遊躇跱",
                "51": "拊絃安歌",
                "52": "新聲代起",
                "53": "歌曰",
                "54": "凌扶搖兮憩瀛洲",
                "55": "要列子兮爲好仇",
                "56": "餐沆瀣兮帶朝霞",
                "57": "眇翩翩兮薄天遊",
                "58": "齊萬物兮超自得",
                "59": "委性命兮任去留",
                "60": "激清響以赴會",
                "61": "何絃歌之綢繆"
            }
        },
        "7": {
            "15": {
                "1": "於是曲引向闌",
                "2": "眾音將歇",
                "3": "改韻易調",
                "4": "奇弄乃發",
                "5": "揚和顏",
                "6": "攘皓腕",
                "7": "飛纖指以馳騖",
                "8": "紛𢕬譶以流漫",
                "9": "或徘徊顧慕",
                "10": "擁鬱抑按",
                "11": "盤桓毓養",
                "12": "從容祕翫",
                "13": "闥爾奮逸",
                "14": "風駭雲亂",
                "15": "牢落凌厲",
                "16": "布濩半散",
                "17": "豐融披離",
                "18": "斐韡奐爛",
                "19": "英聲發越",
                "20": "采采粲粲",
                "21": "或間聲錯糅",
                "22": "狀若詭赴",
                "23": "雙美並進",
                "24": "騈馳翼驅",
                "25": "初若將乖",
                "26": "後卒同趣",
                "27": "或曲而不屈",
                "28": "直而不倨",
                "29": "或相凌而不亂",
                "30": "或相離而不殊",
                "31": "時劫掎以慷慨",
                "32": "或怨㜘而躊躇",
                "33": "忽飄颻以輕邁",
                "34": "乍留聯而扶疏",
                "35": "或參譚繁促",
                "36": "複疊攢仄",
                "37": "從橫駱驛",
                "38": "奔遯相逼",
                "39": "拊嗟累讚",
                "40": "間不容息",
                "41": "瑰豔奇偉",
                "42": "殫不可識"
            }
        },
        "8": {
            "17": {
                "1": "若乃閑舒都雅",
                "2": "洪纖有宜",
                "3": "清和條昶",
                "4": "案衍陸離",
                "5": "穆溫柔以怡懌",
                "6": "婉順敍而委蛇",
                "7": "或乘險投會",
                "8": "邀隙趨危",
                "9": "譻若離鵾鳴清池",
                "10": "翼若遊鴻翔曾崖",
                "11": "紛文斐尾",
                "12": "慊縿離纖纚微風餘音",
                "13": "靡靡猗猗",
                "14": "或摟𢱧擽捋",
                "15": "縹繚潎冽",
                "16": "輕行浮彈",
                "17": "明嫿𥉻慧",
                "18": "疾而不速",
                "19": "留而不滯",
                "20": "翩綿飄邈",
                "21": "微音迅逝",
                "22": "遠而聽之",
                "23": "若鸞鳳和鳴戲雲中",
                "24": "迫而察之",
                "25": "若眾葩敷榮曜春風",
                "26": "旣豐贍以多姿",
                "27": "又善始而令終",
                "28": "嗟姣妙以弘麗",
                "29": "何變態之無窮"
            }
        },
        "9": {
            "19": {
                "1": "若夫三春之初",
                "2": "麗服以時",
                "3": "乃攜友生",
                "4": "以遨以嬉",
                "5": "涉蘭圃",
                "6": "登重基",
                "7": "背長林",
                "8": "翳華芝",
                "9": "臨清流",
                "10": "賦新詩",
                "11": "嘉魚龍之逸豫",
                "12": "樂百卉之榮滋",
                "13": "理重華之遺操",
                "14": "慨遠慕而長思"
            }
        },
        "10": {
            "21": {
                "1": "若乃華堂曲宴",
                "2": "密友近賓",
                "3": "蘭肴兼御",
                "4": "旨酒清醇",
                "5": "進南荊",
                "6": "發西秦",
                "7": "紹陵陽",
                "8": "度巴人",
                "9": "變用雜而並起",
                "10": "竦眾聽而駭神",
                "11": "料殊功而比操",
                "12": "豈笙籥之能倫"
            }
        },
        "11": {
            "23": {
                "1": "若次其曲引所宜",
                "2": "則廣陵止息",
                "3": "東武太山",
                "4": "飛龍鹿鳴",
                "5": "鵾雞遊絃",
                "6": "更唱迭奏",
                "7": "聲若自然",
                "8": "流楚窈窕",
                "9": "懲躁雪煩",
                "10": "下逮謠俗",
                "11": "蔡氏五曲",
                "12": "王昭楚妃",
                "13": "千里別鶴",
                "14": "猶有一切承間簉乏",
                "15": "亦有可觀者焉",
                "16": "然非夫曠遠者",
                "17": "不能與之嬉遊",
                "18": "非夫淵靜者",
                "19": "不能與之閑止",
                "20": "非夫放達者",
                "21": "不能與之無吝",
                "22": "非夫至精者",
                "23": "不能與之析理也"
            }
        },
        "12": {
            "25": {
                "1": "若論其體勢",
                "2": "詳其風聲",
                "3": "器和故響逸",
                "4": "張急故聲清",
                "5": "間遼故音庳",
                "6": "絃長故徽鳴",
                "7": "性絜靜以端理",
                "8": "含至德之和平",
                "9": "誠可以感盪心志",
                "10": "而發泄幽情矣",
                "11": "是故懷戚者聞之",
                "12": "莫不憯懍慘悽",
                "13": "愀愴傷心",
                "14": "含哀懊咿",
                "15": "不能自禁",
                "16": "其康樂者聞之",
                "17": "則欨愉歡釋",
                "18": "抃舞踊溢",
                "19": "留連瀾漫",
                "20": "嗢噱終日",
                "21": "若和平者聽之",
                "22": "則怡養悅悆",
                "23": "淑穆玄眞",
                "24": "恬虛樂古",
                "25": "棄事遺身",
                "26": "是以伯夷以之廉",
                "27": "顏回以之仁",
                "28": "比干以之忠",
                "29": "尾生以之信",
                "30": "惠施以之辯給",
                "31": "萬石以之訥愼",
                "32": "其餘觸類而長",
                "33": "所致非一",
                "34": "同歸殊途",
                "35": "或文或質",
                "36": "總中和以統物",
                "37": "咸日用而不失",
                "38": "其感人動物",
                "39": "蓋亦弘矣"
            }
        },
        "13": {
            "27": {
                "1": "於時也",
                "2": "金石寢聲",
                "3": "匏竹屛氣",
                "4": "王豹輟謳",
                "5": "狄牙喪味",
                "6": "天吳踊躍於重淵",
                "7": "王喬披雲而下墜",
                "8": "舞鸑鷟於庭階",
                "9": "遊女飄焉而來萃",
                "10": "感天地以致和",
                "11": "況蚑行之眾類",
                "12": "嘉斯器之懿茂",
                "13": "詠茲文以自慰",
                "14": "永服御而不厭",
                "15": "信古今之所貴"
            }
        },
        "14": {
            "29": {
                "1": "亂曰",
                "2": "愔愔琴德",
                "3": "不可測兮",
                "4": "體清心遠",
                "5": "邈難極兮",
                "6": "良質美手",
                "7": "遇今世兮",
                "8": "紛綸翕響",
                "9": "冠眾藝兮",
                "10": "識音者希",
                "11": "孰能珍兮",
                "12": "能盡雅琴",
                "13": "唯至人兮"
            }
        }
    }
}