        },
        "3": {
            "7": {
                "1": "問",
                "2": "朕立諫鼓",
                "3": "設謗木",
                "4": "於茲三年矣",
                "5": "比雖輻湊闕下",
                "6": "多非政要",
                "7": "日伏青蒲",
                "8": "罕能切直",
                "9": "將齊季多諱",
                "10": "風流遂往",
                "11": "將謂朕空然慕古",
                "12": "虛受弗弘",
                "13": "然自君臨萬寓",
                "14": "介在民上",
                "15": "何嘗以一言失旨",
                "16": "轉徙朔方",
                "17": "睚眥有違",
                "18": "論輸左校",
                "19": "而使直臣杜口",
                "20": "忠讜路絕",
                "21": "將恐弘長之道",
                "22": "別有未周",
                "23": "悉意以陳",
                "24": "極言無隱"
