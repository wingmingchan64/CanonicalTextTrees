{
    "36.06": {
        "篇名": "任彥升 天監三年策秀才文三首",
        "1": {
            "3": {
                "1": "問秀才",
                "2": "朕長驅樊鄧",
                "3": "直指商郊",
                "4": "因藉時來",
                "5": "乘此歷運",
                "6": "當扆永念",
                "7": "猶懷慚德",
                "8": "何者",
                "9": "百王之敝",
                "10": "齊季斯甚",
                "11": "衣冠禮樂",
                "12": "掃地無餘",
                "13": "斲雕刓方",
                "14": "經綸草昧",
                "15": "采三王之禮",
                "16": "冠履粗分",
                "17": "因六代之樂",
                "18": "宮判始辨",
                "19": "而百度草創",
                "20": "倉廩未實",
                "21": "若終畝不稅",
                "22": "則國用靡資",
                "23": "百姓不足",
                "24": "則惻隱深慮",
                "25": "每時入芻藁",
                "26": "歲課田租",
                "27": "愀然疚懷",
                "28": "如憐赤子",
                "29": "今欲使朕無滿堂之念",
                "30": "民有家給之饒",
                "31": "漸登九年之畜",
                "32": "稍去關市之賦",
                "33": "子大夫當此三道",
                "34": "利用賓王",
                "35": "斯理何從",
                "36": "佇聞良說"
            }
        },
        "2": {
            "5": {
                "1": "問",
                "2": "朕本自諸生",
                "3": "弱齡有志",
                "4": "閉戶自精",
                "5": "開卷獨得",
                "6": "九流七略",
                "7": "頗常觀覽",
                "8": "六藝百家",
                "9": "庶非牆面",
                "10": "雖一日萬機",
                "11": "早朝晏罷",
                "12": "聽覽之暇",
                "13": "三餘靡失",
                "14": "上之化下",
                "15": "草偃風從",
                "16": "惟此虛寡",
                "17": "弗能動俗",
                "18": "昔紫衣賤服",
                "19": "猶化齊風",
                "20": "長纓鄙好",
                "21": "且變鄒俗",
                "22": "雖德慚往賢",
                "23": "業優前事",
                "24": "且夫搢紳道行",
                "25": "祿利然也",
                "26": "朕傾心駿骨",
                "27": "非懼眞龍",
                "28": "輜軿青紫",
                "29": "如拾地芥",
                "30": "而惰遊廢業",
                "31": "十室而九",
                "32": "鳴鳥薎聞",
                "33": "子衿不作",
                "34": "弘獎之路",
                "35": "斯旣然矣",
                "36": "猶其寂寞",
                "37": "應有良規"
