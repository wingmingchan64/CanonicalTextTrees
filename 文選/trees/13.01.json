{
    "13.01": {
        "篇名": "宋玉 風賦",
        "1": {
            "3": {
                "1": "楚襄王遊於蘭臺之宮",
                "2": "宋玉",
                "3": "景差侍",
                "4": "有風颯然而至",
                "5": "王迺披襟而當之",
                "6": "曰",
                "7": "快哉此風",
                "8": "寡人所與庶人共者邪",
                "9": "宋玉對曰",
                "10": "此獨大王之風耳",
                "11": "庶人安得而共之"
            }
        },
        "2": {
            "5": {
                "1": "王曰",
                "2": "夫風者",
                "3": "天地之氣",
                "4": "溥暢而至",
                "5": "不擇貴賤高下而加焉",
                "6": "今子獨以爲寡人之風",
                "7": "豈有說乎",
                "8": "宋玉對曰",
                "9": "臣聞於師",
                "10": "枳句來巢",
                "11": "空穴來風",
                "12": "其所托者然",
                "13": "則風氣殊焉"
            }
        },
        "3": {
            "7": {
                "1": "王曰",
                "2": "夫風",
                "3": "安生始哉",
                "4": "宋玉對曰",
                "5": "夫風生於地",
                "6": "起於青蘋之末",
                "7": "侵淫谿谷",
                "8": "盛怒於土囊之口",
                "9": "緣太山之阿",
                "10": "舞於松柏之下",
                "11": "飄忽淜滂",
                "12": "激颶熛怒",
                "13": "耾耾雷聲",
                "14": "回穴錯迕",
                "15": "蹶石伐木",
                "16": "梢殺林莽",
                "17": "至其將衰也",
                "18": "被麗披離",
                "19": "衝孔動楗",
                "20": "眴煥粲爛",
                "21": "離散轉移",
                "22": "故其清涼雄風",
                "23": "則飄舉升降",
                "24": "乘淩高城",
                "25": "入於深宮",
                "26": "抵花葉而振氣",
                "27": "徘徊於桂椒之間",
                "28": "翱翔於激水之上",
                "29": "將擊芙蓉之精",
                "30": "獵蕙草",
                "31": "離秦蘅",
                "32": "槪新夷",
                "33": "被荑楊",
                "34": "回穴衝陵",
                "35": "蕭條眾芳",
                "36": "然後徜徉中庭",
                "37": "北上玉堂",
                "38": "躋於羅幢",
                "39": "經於洞房",
                "40": "乃得爲大王之風也",
                "41": "故其風中人",
                "42": "狀直憯悽惏慄",
                "43": "清涼增欷",
                "44": "清清冷冷",
                "45": "愈病析酲",
                "46": "發明耳目",
                "47": "寧體便人",
                "48": "此所謂大王之雄風也"
            }
        },
        "4": {
            "9": {
                "1": "王曰",
                "2": "善哉論事",
                "3": "夫庶人之風",
                "4": "豈可聞乎",
                "5": "宋玉對曰",
                "6": "夫庶人之風",
                "7": "塕然起於窮巷之間",
                "8": "堀堁揚塵",
                "9": "勃鬱煩冤",
                "10": "衝孔襲門",
                "11": "動沙堁",
                "12": "吹死灰",
                "13": "駭渾濁",
                "14": "揚腐餘",
                "15": "邪薄入甕牖",
                "16": "至於室廬",
                "17": "故其風中人",
                "18": "狀直憞混鬱邑",
                "19": "驅溫致濕",
                "20": "中心慘怛",
                "21": "生病造熱",
                "22": "中脣爲胗",
                "23": "得目爲篾",
                "24": "啗齰嗽獲",
                "25": "死生不卒",
                "26": "此所謂庶人之雌風也"
            }
        }
    }
}