{
    "34.01": {
        "篇名": "枚叔 七發八首",
        "1": {
            "3": {
                "1": "楚太子有疾",
                "2": "而吳客往問之",
                "3": "曰",
                "4": "伏聞太子玉體不安",
                "5": "亦少間乎",
                "6": "太子曰",
                "7": "憊",
                "8": "謹謝客",
                "9": "客因稱曰",
                "10": "今時天下安寧",
                "11": "四宇和平",
                "12": "太子方富於年",
                "13": "意者久耽安樂",
                "14": "日夜無極",
                "15": "邪氣襲逆",
                "16": "中若結轖",
                "17": "紛屯澹淡",
                "18": "噓唏煩酲",
                "19": "惕惕怵怵",
                "20": "臥不得瞑",
                "21": "虛中重聽",
                "22": "惡聞人聲",
                "23": "精神越渫",
                "24": "百病咸生",
                "25": "聰明眩曜",
                "26": "悅怒不平",
                "27": "久執不廢",
                "28": "大命乃傾",
                "29": "太子豈有是乎",
                "30": "太子曰",
                "31": "謹謝客",
                "32": "賴君之力",
                "33": "時時有之",
                "34": "然未至於是也",
                "35": "客曰",
                "36": "今夫貴人之子",
                "37": "必宮居而閨處",
                "38": "內有保母",
                "39": "外有傅父",
                "40": "欲交無所",
                "41": "飲食則溫淳甘膬",
                "42": "脭醲肥厚",
                "43": "衣裳則雜遝曼暖",
                "44": "燂爍熱暑",
                "45": "雖有金石之堅",
                "46": "猶將銷鑠而挺解也",
                "47": "況其在筋骨之間乎哉",
                "48": "故曰",
                "49": "縱耳目之欲",
                "50": "恣支體之安者",
                "51": "傷血脈之和",
                "52": "且夫出輿入輦",
                "53": "命曰蹶痿之機",
                "54": "洞房清宮",
                "55": "命曰寒熱之媒",
                "56": "皓齒娥眉",
                "57": "命曰伐性之斧",
                "58": "甘脆肥膿",
                "59": "命曰腐腸之藥",
                "60": "今太子膚色靡曼",
                "61": "四支委隨",
                "62": "筋骨挺解",
                "63": "血脈淫濯",
                "64": "手足墮窳",
                "65": "越女侍前",
                "66": "齊姬奉後",
                "67": "往來遊醼",
                "68": "縱恣於曲房隱間之中",
                "69": "此甘餐毒藥",
                "70": "戲猛獸之爪牙也",
                "71": "所從來者至深遠",
                "72": "淹滯永久而不廢",
                "73": "雖令扁鵲治內",
                "74": "巫咸治外",
                "75": "尙何及哉",
                "76": "今如太子之病者",
                "77": "獨宜世之君子",
                "78": "博見強識",
                "79": "承間語事",
                "80": "變度易意",
                "81": "常無離側",
                "82": "以爲羽翼",
                "83": "淹沈之樂",
                "84": "浩唐之心",
                "85": "遁佚之志",
                "86": "其奚由至哉",
                "87": "太子曰",
                "88": "諾",
                "89": "病已",
                "90": "請事此言"
            }
        },
        "2": {
            "5": {
                "1": "客曰",
                "2": "今太子之病",
                "3": "可無藥石針刺灸療而已",
                "4": "可以要言妙道說而去也",
                "5": "不欲聞之乎",
                "6": "太子曰",
                "7": "僕願聞之"
            }
        },
        "3": {
            "7": {
                "1": "客曰",
                "2": "龍門之桐",
                "3": "高百尺而無枝",
                "4": "中鬱結之輪菌",
                "5": "根扶疏以分離",
                "6": "上有千仞之峯",
                "7": "下臨百丈之谿",
                "8": "湍流溯波",
                "9": "又澹淡之",
                "10": "其根半死半生",
                "11": "冬則烈風漂霰飛雪之所激也",
                "12": "夏則雷霆霹靂之所感也",
                "13": "朝則鸝黃鳱鴠鳴焉",
                "14": "暮則羈雌迷鳥宿焉",
                "15": "獨鵠晨號乎其上",
                "16": "鵾雞哀鳴翔乎其下",
                "17": "於是背秋涉冬",
                "18": "使琴摯斫斬以爲琴",
                "19": "野繭之絲以爲絃",
                "20": "孤子之鉤以爲隱",
                "21": "九寡之珥以爲約",
                "22": "使師堂操暢",
                "23": "伯子牙爲之歌",
                "24": "歌曰",
                "25": "麥秀蔪兮雉朝飛",
                "26": "向虛壑兮背槁槐",
                "27": "依絕區兮臨迴溪",
                "28": "飛鳥聞之",
                "29": "翕翼而不能去",
                "30": "野獸聞之",
                "31": "垂耳而不能行",
                "32": "蚑蟜螻蟻聞之",
                "33": "拄喙而不能前",
                "34": "此亦天下之至悲也",
                "35": "太子能強起聽之乎",
                "36": "太子曰",
                "37": "僕病",
                "38": "未能也"
            }
        },
        "4": {
            "9": {
                "1": "客曰",
                "2": "犓牛之腴",
                "3": "菜以筍蒲",
                "4": "說文曰",
                "5": "犓",
                "6": "以芻莝養國牛也",
                "7": "國語曰",
                "8": "犓豢幾何",
                "9": "犓或爲�",
                "10": "未詳",
                "11": "說文曰",
                "12": "腴",
                "13": "腹下肥者",
                "14": "毛詩曰",
                "15": "其蓛維何",
                "16": "維筍及蒲也",
                "17": "肥狗之和",
                "18": "冒以山膚",
                "19": "楚苗之食",
                "20": "安胡之飰",
                "21": "摶之不解",
                "22": "一啜而散",
                "23": "於是使伊尹煎熬",
                "24": "易牙調和",
                "25": "熊蹯之臑",
                "26": "勺藥之醬",
                "27": "薄耆之炙",
                "28": "鮮鯉之鱠",
                "29": "秋黃之蘇",
                "30": "白露之茹",
                "31": "蘭英之酒",
                "32": "酌以滌口",
                "33": "山梁之餐",
                "34": "豢豹之胎",
                "35": "小飰大歠",
                "36": "如湯沃雪",
                "37": "此亦天下之至美也",
                "38": "太子能彊起嘗之乎",
                "39": "太子曰",
                "40": "僕病",
                "41": "未能也"
            }
        },
        "5": {
            "11": {
                "1": "客曰",
                "2": "鍾岱之牡",
                "3": "齒至之車",
                "4": "前似飛鳥",
                "5": "後類距虛",
                "6": "穱麥服處",
                "7": "躁中煩外",
                "8": "羈堅轡",
                "9": "附易路",
                "10": "於是伯樂相其前後",
                "11": "王良造父爲之御",
                "12": "秦缺樓季爲之右",
                "13": "此兩人者",
                "14": "馬佚能止之",
                "15": "車覆能起之",
                "16": "於是使射千鎰之重",
                "17": "爭千里之逐",
                "18": "此亦天下之至駿也",
                "19": "太子能彊起乘之乎",
                "20": "太子曰",
                "21": "僕病",
                "22": "未能也"
            }
        },
        "6": {
            "13": {
                "1": "客曰",
                "2": "旣登景夷之臺",
                "3": "南望荊山",
                "4": "北望汝海",
                "5": "左江右湖",
                "6": "其樂無有",
                "7": "於是使博辯之士",
                "8": "原本山川",
                "9": "極命草木",
                "10": "比物屬事",
                "11": "離辭連類",
                "12": "浮遊覽觀",
                "13": "乃下置酒於虞懷之宮",
                "14": "連廊四注",
                "15": "臺城層構",
                "16": "紛紜玄綠",
                "17": "輦道邪交",
                "18": "黃池紆曲",
                "19": "溷章白鷺",
                "20": "孔鳥鶤鵠",
                "21": "鵷雛鵁鶄",
                "22": "翠鬣紫纓",
                "23": "螭龍德牧",
                "24": "邕邕羣鳴",
                "25": "陽魚騰躍",
                "26": "奮翼振鱗",
                "27": "漃漻薵蓼",
                "28": "蔓草芳苓",
                "29": "女桑河柳",
                "30": "素葉紫莖",
                "31": "苗松豫章",
                "32": "條上造天",
                "33": "梧桐幷閭",
                "34": "極望成林",
                "35": "眾芳芬鬱",
                "36": "亂於五風",
                "37": "從容猗靡",
                "38": "消息陽陰",
                "39": "列坐縱酒",
                "40": "蕩樂娛心",
                "41": "景春佐酒",
                "42": "杜連理音",
                "43": "滋味雜陳",
                "44": "肴糅錯該",
                "45": "練色娛目",
                "46": "流聲悅耳",
                "47": "於是乃發激楚之結風",
                "48": "揚鄭衞之皓樂",
                "49": "使先施徵舒陽文段干吳娃閭娵傅予之徒",
                "50": "雜裾垂髾",
                "51": "目窕心與",
                "52": "揄流波",
                "53": "雜杜若",
                "54": "蒙清塵",
                "55": "被蘭澤",
                "56": "嬿服而御",
                "57": "此亦天下之靡麗皓侈廣博之樂也",
                "58": "太子能彊起遊乎",
                "59": "太子曰",
                "60": "僕病",
                "61": "未能也"
            }
        },
        "7": {
            "15": {
                "1": "客曰",
                "2": "將爲太子馴騏驥之馬",
                "3": "駕飛軨之輿",
                "4": "乘牡駿之乘",
                "5": "右夏服之勁箭",
                "6": "左烏號之彫弓",
                "7": "遊涉乎雲林",
                "8": "周馳乎蘭澤",
                "9": "弭節乎江潯",
                "10": "掩青蘋",
                "11": "遊清風",
                "12": "陶陽氣",
                "13": "蕩春心",
                "14": "逐狡獸",
                "15": "集輕禽",
                "16": "於是極犬馬之才",
                "17": "困野獸之足",
                "18": "窮相御之智巧",
                "19": "恐虎豹",
                "20": "慴鷙鳥",
                "21": "逐馬鳴鑣",
                "22": "魚跨麋角",
                "23": "履遊麕兔",
                "24": "蹈踐麖鹿",
                "25": "汗流沫墜",
                "26": "冤汱陵窘",
                "27": "無創而死者",
                "28": "固足充後乘矣",
                "29": "此校獵之至壯也",
                "30": "太子能彊起遊乎",
                "31": "太子曰",
                "32": "僕病",
                "33": "未能也",
                "34": "然陽氣見於眉宇之間",
                "35": "侵淫而上",
                "36": "幾滿大宅"
            }
        },
        "8": {
            "17": {
                "1": "客見太子有悅色",
                "2": "遂推而進之曰",
                "3": "冥火薄天",
                "4": "兵車雷運",
                "5": "旍旗偃蹇",
                "6": "羽毛肅紛",
                "7": "馳騁角逐",
                "8": "慕味爭先",
                "9": "徼墨廣博",
                "10": "觀望之有圻",
                "11": "純粹全犧",
                "12": "獻之公門",
                "13": "太子曰",
                "14": "善",
                "15": "願復聞之"
            }
        },
        "9": {
            "19": {
                "1": "客曰",
                "2": "未旣",
                "3": "於是榛林深澤",
                "4": "煙雲闇莫",
                "5": "兕虎並作",
                "6": "毅武孔猛",
                "7": "袒裼身薄",
                "8": "白刃磑磑",
                "9": "矛戟交錯",
                "10": "收獲掌功",
                "11": "賞賜金帛",
                "12": "掩蘋肆若",
                "13": "爲牧人席",
                "14": "旨酒嘉肴",
                "15": "羞炰膾炙",
                "16": "以御賓客",
                "17": "涌觸並起",
                "18": "動心驚耳",
                "19": "誠必不悔",
                "20": "決絕以諾",
                "21": "貞信之色",
                "22": "形於金石",
                "23": "高歌陳唱",
                "24": "萬歲無斁",
                "25": "此眞太子之所喜也",
                "26": "能強起而遊乎",
                "27": "太子曰",
                "28": "僕甚願從",
                "29": "直恐爲諸大夫累耳",
                "30": "然而有起色矣"
            }
        },
        "10": {
            "21": {
                "1": "客曰",
                "2": "將以八月之望",
                "3": "與諸侯遠方交遊兄弟",
                "4": "並往觀濤乎廣陵之曲江",
                "5": "至則未見濤之形也",
                "6": "徒觀水力之所到",
                "7": "則卹然足以駭矣",
                "8": "觀其所駕軼者",
                "9": "所擢拔者",
                "10": "所揚汩者",
                "11": "所溫汾者",
                "12": "所滌汔者",
                "13": "小雅曰",
                "14": "駕",
                "15": "陵也",
                "16": "杜預左氏傳注曰",
                "17": "軼",
                "18": "穾也",
                "19": "蒼頡篇曰",
                "20": "擢",
                "21": "抽也",
                "22": "孔安國尙書傳曰",
                "23": "汩",
                "24": "亂也",
                "25": "古沒切",
                "26": "溫汾",
                "27": "轉之貌也",
                "28": "爾雅曰",
                "29": "𧰙",
                "30": "汔也",
                "31": "郭璞曰",
                "32": "謂摩近",
                "33": "汔",
                "34": "許乞切",
                "35": "雖有心略辭給",
                "36": "固未能縷形其所由然也",
                "37": "怳兮忽兮",
                "38": "聊兮慄兮",
                "39": "混汩汩兮",
                "40": "忽兮慌兮",
                "41": "俶兮儻兮",
                "42": "浩瀇瀁兮",
                "43": "慌曠曠兮",
                "44": "秉意乎南山",
                "45": "通望乎東海",
                "46": "虹洞兮蒼天",
                "47": "極慮乎崖涘",
                "48": "流攬無窮",
                "49": "歸神日母",
                "50": "汨乘流而下降兮",
                "51": "或不知其所止",
                "52": "或紛紜其流折兮",
                "53": "忽繆往而不來",
                "54": "臨朱汜而遠逝兮",
                "55": "中虛煩而益怠",
                "56": "莫離散而發曙兮",
                "57": "內存心而自持",
                "58": "於是澡槪胸中",
                "59": "灑練五藏",
                "60": "澹澉手足",
                "61": "頮濯髮齒",
                "62": "揄棄恬怠",
                "63": "輸寫淟濁",
                "64": "分決狐疑",
                "65": "發皇耳目",
                "66": "當是之時",
                "67": "雖有淹病滯疾",
                "68": "猶將伸傴起躄",
                "69": "發瞽披聾而觀望之也",
                "70": "況直眇小煩懣",
                "71": "酲醲病酒之徒哉",
                "72": "故曰發蒙解惑",
                "73": "不足以言也",
                "74": "太子曰",
                "75": "善",
                "76": "然則濤何氣哉"
            }
        },
        "11": {
            "23": {
                "1": "客曰",
                "2": "不記也",
                "3": "然聞於師曰",
                "4": "似神而非者三",
                "5": "疾雷聞百里",
                "6": "江水逆流",
                "7": "海水上潮",
                "8": "山出內雲",
                "9": "日夜不止",
                "10": "衍溢漂疾",
                "11": "波涌而濤起",
                "12": "其始起也",
                "13": "洪淋淋焉",
                "14": "若白鷺之下翔",
                "15": "其少進也",
                "16": "浩浩溰溰",
                "17": "如素車白馬帷蓋之張",
                "18": "其波涌而雲亂",
                "19": "擾擾焉如三軍之騰裝",
                "20": "其旁作而奔起也",
                "21": "飄飄焉如輕車之勒兵",
                "22": "六駕蛟龍",
                "23": "附從太白",
                "24": "純馳浩蜺",
                "25": "前後駱驛",
                "26": "顒顒卬卬",
                "27": "椐椐彊彊",
                "28": "莘莘將將",
                "29": "壁壘重堅",
                "30": "沓雜似軍行",
                "31": "訇隱匈磕",
                "32": "軋盤涌裔",
                "33": "原不可當",
                "34": "觀其兩傍",
                "35": "則滂渤怫鬱",
                "36": "闇漠感突",
                "37": "上擊下律",
                "38": "有似勇壯之卒",
                "39": "突怒而無畏",
                "40": "蹈壁衝津",
                "41": "窮曲隨隈",
                "42": "踰岸出追",
                "43": "遇者死",
                "44": "當者壞",
                "45": "初發乎或圍之津涯",
                "46": "荄軫谷分",
                "47": "迴翔青篾",
                "48": "銜枚檀桓",
                "49": "弭節伍子之山",
                "50": "通厲骨母之場",
                "51": "弭節",
                "52": "已見上文",
                "53": "史記曰",
                "54": "吳王殺子胥",
                "55": "投之於江",
                "56": "吳人立祠於江上",
                "57": "因名胥母山",
                "58": "王逸楚辭注曰",
                "59": "高厲",
                "60": "遠行也",
                "61": "越絕書曰",
                "62": "闔閭旦食䱉山",
                "63": "晝遊於胥母",
                "64": "疑骨母字之誤也",
                "65": "凌赤岸",
                "66": "篲扶桑",
                "67": "橫奔似雷行",
                "68": "誠奮厥武",
                "69": "如振如怒",
                "70": "沌沌渾渾",
                "71": "狀如奔馬",
                "72": "混混庉庉",
                "73": "聲如雷鼓",
                "74": "發怒庢沓",
                "75": "清升踰跇",
                "76": "侯波奮振",
                "77": "合戰於藉藉之口",
                "78": "鳥不及飛",
                "79": "魚不及迴",
                "80": "獸不及走",
                "81": "紛紛翼翼",
                "82": "波涌雲亂",
                "83": "蕩取南山",
                "84": "背擊北岸",
                "85": "覆虧丘陵",
                "86": "平夷西畔",
                "87": "險險戲戲",
                "88": "崩壞陂池",
                "89": "決勝乃罷",
                "90": "瀄汨潺湲",
                "91": "披揚流灑",
                "92": "橫暴之極",
                "93": "魚鱉失勢",
                "94": "顚倒偃側",
                "95": "沋沋湲湲",
                "96": "蒲伏連延",
                "97": "神物怪疑",
                "98": "不可勝言",
                "99": "直使人踣焉",
                "100": "洄闇悽愴焉",
                "101": "此天下怪異詭觀也",
                "102": "太子能強起觀之乎",
                "103": "太子曰",
                "104": "僕病",
                "105": "未能也"
            }
        },
        "12": {
            "25": {
                "1": "客曰",
                "2": "將爲太子奏方術之士有資略者",
                "3": "若莊周魏牟楊朱墨翟便蜎詹何之倫",
                "4": "使之論天下之釋微",
                "5": "理萬物之是非",
                "6": "孔老覽觀",
                "7": "孟子持籌而筭之",
                "8": "萬不失一",
                "9": "此亦天下要言妙道也",
                "10": "太子豈欲聞之乎",
                "11": "於是太子據几而起曰",
                "12": "渙乎若一聽聖人辯士之言",
                "13": "涊然汗出",
                "14": "霍然病已"
            }
        }
    }
}