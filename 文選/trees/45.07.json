{
    "45.07": {
        "篇名": "卜子夏 毛詩序 鄭氏箋",
        "1": {
            "3": {
                "1": "關雎",
                "2": "后妃之德也",
                "3": "風之始也",
                "4": "所以風天下而正夫婦也",
                "5": "故用之鄕人焉",
                "6": "用之邦國焉",
                "7": "風",
                "8": "風也",
                "9": "教也",
                "10": "風以動之",
                "11": "教以化之",
                "12": "詩者",
                "13": "志之所之也",
                "14": "在心爲志",
                "15": "發言爲詩",
                "16": "情動於中而形於言",
                "17": "言之不足",
                "18": "故嗟歎之",
                "19": "嗟歎之不足",
                "20": "故永歌之",
                "21": "永歌之不足",
                "22": "不知手之舞之",
                "23": "足之蹈之也",
                "24": "情發於聲",
                "25": "聲成文謂之音",
                "26": "治世之音安以樂",
                "27": "其政和",
                "28": "亂世之音怨以怒",
                "29": "其政乖",
                "30": "亡國之音哀以思",
                "31": "其民困",
                "32": "故正得失",
                "33": "動天地",
                "34": "感鬼神",
                "35": "莫近於詩",
                "36": "先王以是經夫婦",
                "37": "成孝敬",
                "38": "厚人倫",
                "39": "美教化",
                "40": "移風俗",
                "41": "故詩有六義焉",
                "42": "一曰風",
                "43": "二曰賦",
                "44": "三曰比",
                "45": "四曰興",
                "46": "五曰雅",
                "47": "六曰頌"
            }
        },
        "2": {
            "5": {
                "1": "上以風化下",
                "2": "下以風刺上",
                "3": "主文而譎諫",
                "4": "言之者無罪",
                "5": "聞之者足以戒",
                "6": "故曰風",
                "7": "至於王道衰",
                "8": "禮義廢",
                "9": "政教失",
                "10": "國異政",
                "11": "家殊俗",
                "12": "而變風變雅作矣",
                "13": "國史明乎得失之迹",
                "14": "傷人倫之廢",
                "15": "哀刑政之苛",
                "16": "吟詠情性",
                "17": "以風其上",
                "18": "達於事變",
                "19": "而懷其舊俗者也",
                "20": "故變風發乎情",
                "21": "止乎禮義",
                "22": "發乎情",
                "23": "民之性也",
                "24": "止乎禮義",
                "25": "先王之澤也",
                "26": "是以一國之事",
                "27": "繫一人之本",
                "28": "謂之風",
                "29": "言天下之事",
                "30": "形四方之風",
                "31": "謂之雅",
                "32": "雅者",
                "33": "正也",
                "34": "言王政之所由廢興也",
                "35": "政有小大",
                "36": "故有小雅焉",
                "37": "有大雅焉",
                "38": "頌者",
                "39": "美盛德之形容",
                "40": "以其成功告於神明者也",
                "41": "是謂四始",
                "42": "詩之志也"
            }
        },
        "3": {
            "7": {
                "1": "然則關雎麟趾之化",
                "2": "王者之風",
                "3": "故繫之周公",
                "4": "南",
                "5": "言化自北而南也",
                "6": "鵲巢騶虞之德",
                "7": "諸侯之風也",
                "8": "先王之所以教",
                "9": "故繫之召公",
                "10": "周南召南",
                "11": "正始之道",
                "12": "王化之基",
                "13": "是以關雎樂得淑女以配君子",
                "14": "憂在進賢",
                "15": "不淫其色",
                "16": "哀窈窕",
                "17": "思賢才",
                "18": "而無傷善之心焉",
                "19": "是關雎之義也"
            }
        }
    }
}