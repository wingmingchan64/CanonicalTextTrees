{
    "11.04": {
        "篇名": "王文考 魯靈光殿賦[幷序]",
        "1": {
            "3": {
                "1": "魯靈光殿者",
                "2": "蓋景帝程姬之子恭王餘之所立也",
                "3": "初",
                "4": "恭王始都下國",
                "5": "好治宮室",
                "6": "遂因魯僖基兆而營焉",
                "7": "遭漢中微",
                "8": "盜賊奔突",
                "9": "自西京未央建章之殿",
                "10": "皆見隳壞",
                "11": "而靈光巋然獨存",
                "12": "意者豈非神明依憑支持以保漢室者也",
                "13": "然其規矩制度",
                "14": "上應星宿",
                "15": "亦所以永安也",
                "16": "予客自南鄙",
                "17": "觀蓺於魯",
                "18": "睹斯而眙曰",
                "19": "嗟乎",
                "20": "詩人之興",
                "21": "感物而作",
                "22": "故奚斯頌僖",
                "23": "歌其路寢",
                "24": "而功績存乎辭",
                "25": "德音昭乎聲",
                "26": "物以賦顯",
                "27": "事以頌宣",
                "28": "匪賦匪頌",
                "29": "將何述焉",
                "30": "遂作賦曰"
            }
        },
        "2": {
            "5": {
                "1": "粵若稽古帝漢",
                "2": "祖宗濬哲欽明",
                "3": "殷五代之純熙",
                "4": "紹伊唐之炎精",
                "5": "荷天衢以元亨",
                "6": "廓宇宙而作京",
                "7": "敷皇極以創業",
                "8": "協神道而大寧",
                "9": "於是百姓昭明",
                "10": "九族敦序",
                "11": "乃命孝孫",
                "12": "俾侯於魯",
                "13": "錫介珪以作瑞",
                "14": "宅附庸而開宇",
                "15": "乃立靈光之祕殿",
                "16": "配紫微而爲輔",
                "17": "承明堂於少陽",
                "18": "昭列顯於奎之分野"
            }
        },
        "3": {
            "7": {
                "1": "瞻彼靈光之爲狀也",
                "2": "則嵯峨嶵嵬",
                "3": "峞巍㠥𡸖",
                "4": "吁",
                "5": "可畏乎其駭人也",
                "6": "迢嶢倜儻",
                "7": "豐麗博敞",
                "8": "洞轇轕乎其無垠也",
                "9": "邈希世而特出",
                "10": "羌瑰譎而鴻紛",
                "11": "屹山峙以紆鬱",
                "12": "隆崛岉乎青雲",
                "13": "鬱坱圠以嶒𡵓",
                "14": "崱繒綾而龍鱗",
                "15": "汩磑磑以璀璨",
                "16": "赫燡燡而爥坤",
                "17": "狀若積石之鏘鏘",
                "18": "又似乎帝室之威神",
                "19": "崇墉岡連以嶺屬",
                "20": "朱闕巖巖而雙立",
                "21": "高門擬於閶闔",
                "22": "方二軌而並入"
            }
        },
        "4": {
            "9": {
                "1": "於是乎乃歷夫太階",
                "2": "以造其堂",
                "3": "俯仰顧眄",
                "4": "東西周章",
                "5": "彤彩之飾",
                "6": "徒何爲乎",
                "7": "澔澔涆涆",
                "8": "流離爛漫",
                "9": "皓壁皜曜以月照",
                "10": "丹柱歙赩而電烻",
                "11": "霞駮雲蔚",
                "12": "若陰若陽",
                "13": "瀖濩燐亂",
                "14": "煒煒煌煌",
                "15": "隱陰夏以中處",
                "16": "霐寥窲以崢嶸",
                "17": "鴻爌炾以爣閬",
                "18": "飋蕭條而清泠",
                "19": "動滴瀝以成響",
                "20": "殷雷應其若驚",
                "21": "耳嘈嘈以失聽",
                "22": "目矎矎而喪精",
                "23": "騈密石與琅玕",
                "24": "齊玉璫與璧英"
            }
        },
        "5": {
            "11": {
                "1": "遂排金扉而北入",
                "2": "霄靄靄而晻曖",
                "3": "旋室㛹娟以窈窕",
                "4": "洞房叫窱而幽邃",
                "5": "西廂踟躕以閑宴",
                "6": "東序重深而奧祕",
                "7": "屹鏗瞑以勿罔",
                "8": "屑黶翳以懿濞",
                "9": "魂悚悚其驚斯",
                "10": "心𤟧𤟧而發悸"
            }
        },
        "6": {
            "13": {
                "1": "於是詳察其棟宇",
                "2": "觀其結構",
                "3": "規矩應天",
                "4": "上憲觜陬",
                "5": "倔佹雲起",
                "6": "嶔崟離摟",
                "7": "三間四表",
                "8": "八維九隅",
                "9": "萬楹叢倚",
                "10": "磊砢相扶",
                "11": "浮柱岧嵽以星懸",
                "12": "漂嶢𡸣而枝拄",
                "13": "飛梁偃蹇以虹指",
                "14": "揭蘧蘧而騰湊",
                "15": "層櫨磥垝以岌峨",
                "16": "曲枅要紹而環句",
                "17": "芝栭欑羅以戢孴",
                "18": "枝牚杈枒而斜據",
                "19": "傍夭蟜以橫出",
                "20": "互黝糾而搏負",
                "21": "下岪蔚以璀錯",
                "22": "上崎嶬而重注",
                "23": "捷獵鱗集",
                "24": "支離分赴",
                "25": "縱橫駱驛",
                "26": "各有所趣"
            }
        },
        "7": {
            "15": {
                "1": "爾乃懸棟結阿",
                "2": "天窗綺疏",
                "3": "圓淵方井",
                "4": "反植荷蕖",
                "5": "發秀吐榮",
                "6": "菡萏披敷",
                "7": "綠房紫菂",
                "8": "窋吒垂珠",
                "9": "雲楶藻梲",
                "10": "龍桷雕鏤",
                "11": "飛禽走獸",
                "12": "因木生姿",
                "13": "奔虎攫挐以梁倚",
                "14": "仡奮舋而軒鬐",
                "15": "虯龍騰驤以蜿蟺",
                "16": "頷若動而躨跜",
                "17": "朱鳥舒翼以峙衡",
                "18": "騰蛇蟉虯而遶榱",
                "19": "白鹿孑蜺於欂櫨",
                "20": "蟠螭宛轉而承楣",
                "21": "狡兔跧伏於柎側",
                "22": "猿狖攀椽而相追",
                "23": "玄熊舑舕以齗齗",
                "24": "卻負載而蹲跠",
                "25": "齊首目以瞪眄",
                "26": "徒眽眽而狋狋",
                "27": "胡人遙集於上楹",
                "28": "儼雅跽而相對",
                "29": "仡欺𤟧以雕𥄴",
                "30": "𪃨顤顟而睽睢",
                "31": "狀若悲愁於危處",
                "32": "憯嚬蹙而含悴",
                "33": "神仙岳岳於棟間",
                "34": "玉女闚窗而下視",
                "35": "忽瞟眇以響像",
                "36": "若鬼神之髣彿"
            }
        },
        "8": {
            "17": {
                "1": "圖畫天地",
                "2": "品類羣生",
                "3": "雜物奇怪",
                "4": "山神海靈",
                "5": "寫載其狀",
                "6": "託之丹青",
                "7": "千變萬化",
                "8": "事各繆形",
                "9": "隨色象類",
                "10": "曲得其情",
                "11": "上紀開闢",
                "12": "遂古之初",
                "13": "五龍比翼",
                "14": "人皇九頭",
                "15": "伏羲鱗身",
                "16": "女媧蛇軀",
                "17": "鴻荒朴略",
                "18": "厥狀睢盱",
                "19": "煥炳可觀",
                "20": "黃帝唐虞",
                "21": "軒冕以庸",
                "22": "衣裳有殊",
                "23": "下及三后",
                "24": "婬妃亂主",
                "25": "忠臣孝子",
                "26": "烈士貞女",
                "27": "賢愚成敗",
                "28": "靡不載敍",
                "29": "惡以誡世",
                "30": "善以示後"
            }
        },
        "9": {
            "19": {
                "1": "於是乎連閣承宮",
                "2": "馳道周環",
                "3": "陽榭外望",
                "4": "高樓飛觀",
                "5": "長途升降",
                "6": "軒檻曼延",
                "7": "漸臺臨池",
                "8": "層曲九成",
                "9": "屹然特立",
                "10": "的爾殊形",
                "11": "高徑華蓋",
                "12": "仰看天庭",
                "13": "飛陛揭孼",
                "14": "緣雲上征",
                "15": "中坐垂景",
                "16": "頫視流星",
                "17": "千門相似",
                "18": "萬戶如一",
                "19": "巖突洞出",
                "20": "逶迆詰屈",
                "21": "周行數里",
                "22": "仰不見日",
                "23": "何宏麗之靡靡",
                "24": "咨用力之妙勤",
                "25": "非夫通神之俊才",
                "26": "誰能剋成乎此勳"
            }
        },
        "10": {
            "21": {
                "1": "據坤靈之寶勢",
                "2": "承蒼昊之純殷",
                "3": "包陰陽之變化",
                "4": "含元氣之煙熅",
                "5": "玄醴騰涌於陰溝",
                "6": "甘靈被宇而下臻",
                "7": "朱桂黝儵於南北",
                "8": "蘭芝阿那於東西",
                "9": "祥風翕習以颯灑",
                "10": "激芳香而常芬",
                "11": "神靈扶其棟宇",
                "12": "歷千載而彌堅",
                "13": "永安寧以祉福",
                "14": "長與大漢而久存",
                "15": "實至尊之所御",
                "16": "保延壽而宜子孫",
                "17": "苟可貴其若斯",
                "18": "孰亦有云而不珍"
            }
        },
        "11": {
            "23": {
                "1": "亂曰",
                "2": "彤彤靈宮",
                "3": "巋嶵穹崇",
                "4": "紛庬鴻兮",
                "5": "崱屴嵫釐",
                "6": "岑崟崰嶷",
                "7": "騈巃嵷兮",
                "8": "連拳偃蹇",
                "9": "崙菌踡嵼",
                "10": "傍攲傾兮",
                "11": "歇欻幽藹",
                "12": "雲覆霮䨴",
                "13": "洞杳冥兮",
                "14": "蔥翠紫蔚",
                "15": "礧碨瑰瑋",
                "16": "含光晷兮",
                "17": "窮奇極妙",
                "18": "棟宇已來",
                "19": "未之有兮",
                "20": "神之營之",
                "21": "瑞我漢室",
                "22": "永不朽兮"
            }
        }
    }
}