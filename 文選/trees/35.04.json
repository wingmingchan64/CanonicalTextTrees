{
    "35.04": {
        "篇名": "潘元茂 冊魏公九錫文",
        "1": {
            "3": {
                "1": "制詔",
                "2": "使持節丞相領冀州牧武平侯",
                "3": "朕以不德",
                "4": "少遭閔凶",
                "5": "越在西土",
                "6": "遷於唐衞",
                "7": "當此之時",
                "8": "若綴旒然",
                "9": "宗廟乏祀",
                "10": "社稷無位",
                "11": "羣凶覬覦",
                "12": "分裂諸夏",
                "13": "一人尺土",
                "14": "朕無獲焉",
                "15": "卽我高祖之命",
                "16": "將墜於地",
                "17": "朕用夙興假寐",
                "18": "震悼於厥心",
                "19": "曰",
                "20": "惟祖惟父",
                "21": "股肱先正",
                "22": "其孰卹朕躬",
                "23": "乃誘天衷",
                "24": "誕育丞相",
                "25": "保乂我皇家",
                "26": "弘濟於艱難",
                "27": "朕實賴之",
                "28": "今將授君典禮",
                "29": "其敬聽朕命"
            }
        },
        "2": {
            "5": {
                "1": "昔者",
                "2": "董卓初興國難",
                "3": "羣后失位",
                "4": "以謀王室",
                "5": "君則攝進",
                "6": "首啟戎行",
                "7": "此君之忠於本朝也",
                "8": "後及黃巾",
                "9": "反易天常",
                "10": "侵我三州",
                "11": "延於平民",
                "12": "君又討之",
                "13": "剪除其迹",
                "14": "以寧東夏",
                "15": "此又君之功也",
                "16": "韓暹楊奉",
                "17": "專用威命",
                "18": "又賴君勳",
                "19": "克黜其難",
                "20": "遂建許都",
                "21": "造我京畿",
                "22": "設官兆祀",
                "23": "不失舊物",
                "24": "天地鬼神",
                "25": "於是獲乂",
                "26": "此又君之功也",
                "27": "袁術僭逆",
                "28": "肆於淮南",
                "29": "懾憚君靈",
                "30": "用丕顯謀",
                "31": "蘄陽之役",
                "32": "橋蕤授首",
                "33": "稜威南厲",
                "34": "術以殞潰",
                "35": "此又君之功也",
                "36": "迴戈東指",
                "37": "呂布就戮",
                "38": "乘軒將反",
                "39": "張揚沮斃",
                "40": "眭固伏罪",
                "41": "張繡稽服",
                "42": "此又君之功也",
                "43": "袁紹逆常",
                "44": "謀危社稷",
                "45": "憑恃其眾",
                "46": "稱兵內侮",
                "47": "當此之時",
                "48": "王師寡弱",
                "49": "天下寒心",
                "50": "莫有固志",
                "51": "君執大節",
                "52": "精貫白日",
                "53": "奮其武怒",
                "54": "運諸神策",
                "55": "致屆官渡",
                "56": "大殲醜類",
                "57": "俾我國家",
                "58": "拯於危墜",
                "59": "此又君之功也",
                "60": "濟師洪河",
                "61": "拓定四州",
                "62": "袁譚高幹",
                "63": "咸梟其首",
                "64": "海盜奔逬",
                "65": "黑山順軌",
                "66": "此又君之功也",
                "67": "烏丸三種",
                "68": "崇亂二世",
                "69": "袁尙因之",
                "70": "逼據塞北",
                "71": "束馬懸車",
                "72": "一征而滅",
                "73": "此又君之功也",
                "74": "劉表背誕",
                "75": "不供貢職",
                "76": "王師首路",
                "77": "威風先逝",
                "78": "百城八郡",
                "79": "交臂屈膝",
                "80": "此又君之功也",
                "81": "馬超成宜",
                "82": "同惡相濟",
                "83": "濱據河潼",
                "84": "求逞所欲",
                "85": "殄之渭南",
                "86": "獻馘萬計",
                "87": "遂定邊城",
                "88": "撫和戎狄",
                "89": "此又君之功也",
                "90": "鮮卑丁令",
                "91": "重譯而至",
                "92": "箄於白屋",
                "93": "請吏帥職",
                "94": "此又君之功也",
                "95": "君有定天下之功",
                "96": "重以明德",
                "97": "班敍海內",
                "98": "宣美風俗",
                "99": "旁施勤教",
                "100": "卹愼刑獄",
                "101": "吏無苛政",
                "102": "民不回慝",
                "103": "敦崇帝族",
                "104": "援繼絕世",
                "105": "舊德前功",
                "106": "罔不咸秩",
                "107": "雖伊尹格於皇天",
                "108": "周公光於四海",
                "109": "方之薎如也"
            }
        },
        "3": {
            "7": {
                "1": "朕聞先王並建明德",
                "2": "胙之以土",
                "3": "分之以民",
                "4": "崇其寵章",
                "5": "備其禮物",
                "6": "所以蕃衞王室",
                "7": "左右厥世也",
                "8": "其在周成",
                "9": "管蔡不靖",
                "10": "懲難念功",
                "11": "乃使邵康公錫齊太公履",
                "12": "東至於海",
                "13": "西至於河",
                "14": "南至於穆陵",
                "15": "北至於無棣",
                "16": "五侯九伯",
                "17": "實得征之",
                "18": "世胙太師",
                "19": "以表東海",
                "20": "爰及襄王",
                "21": "亦有楚人",
                "22": "不供王職",
                "23": "又命晉文",
                "24": "登爲侯伯",
                "25": "錫以二輅",
                "26": "虎賁鈇鉞",
                "27": "秬鬯弓矢",
                "28": "大啟南陽",
                "29": "世作盟主",
                "30": "故周室之不壞",
                "31": "繄二國是賴",
                "32": "今君稱丕顯德",
                "33": "明保朕躬",
                "34": "奉答天命",
                "35": "導揚弘烈",
                "36": "綏爰九域",
                "37": "罔不率俾",
                "38": "功高乎伊周",
                "39": "而賞卑乎齊晉",
                "40": "朕甚恧焉",
                "41": "朕以眇身",
                "42": "託於兆民之上",
                "43": "永思厥艱",
                "44": "若涉淵水",
                "45": "非君攸濟",
                "46": "朕無任焉",
                "47": "今以冀州之河東河內魏郡趙國中山鉅鹿常山安平甘陵平原凡十郡",
                "48": "封君爲魏公",
                "49": "使使持節御史大夫慮",
                "50": "授君印綬冊書",
                "51": "金虎符第一至第五",
                "52": "竹使符第一至第十",
                "53": "錫君玄土",
                "54": "苴以白茅",
                "55": "爰契爾龜",
                "56": "用建冢社",
                "57": "昔在周室",
                "58": "畢公毛公",
                "59": "入爲卿佐",
                "60": "周邵師保",
                "61": "出爲二伯",
                "62": "外內之任",
                "63": "君實宜之",
                "64": "其以丞相領冀州牧如故",
                "65": "今更下傳璽",
                "66": "肅將朕命",
                "67": "以允華夏",
                "68": "其上故傳武平侯印綬",
                "69": "今又加君九錫",
                "70": "其敬聽後命",
                "71": "以君經緯禮律",
                "72": "爲民軌儀",
                "73": "使安職業",
                "74": "無或遷志",
                "75": "是用錫君大輅戎輅各一",
                "76": "玄牡二駟",
                "77": "君勸分務本",
                "78": "嗇民昏作",
                "79": "粟帛滯積",
                "80": "大業惟興",
                "81": "是用錫君衮冕之服",
                "82": "赤舄副焉",
                "83": "君敦尙謙讓",
                "84": "俾民興行",
                "85": "少長有禮",
                "86": "上下咸和",
                "87": "是用錫君軒懸之樂",
                "88": "六佾之舞",
                "89": "君翼宣風化",
                "90": "爰發四方",
                "91": "遠人回面",
                "92": "華夏充實",
                "93": "是用錫君朱戶以居",
                "94": "君硏其明哲",
                "95": "思帝所難",
                "96": "官才任賢",
                "97": "羣善必舉",
                "98": "是用錫君納陛以登",
                "99": "君秉國之均",
                "100": "正色處中",
                "101": "纖毫之惡",
                "102": "靡不抑退",
                "103": "是用錫君虎賁之士三百人",
                "104": "君糾虔天刑",
                "105": "章厥有罪",
                "106": "犯關干紀",
                "107": "莫不誅殛",
                "108": "是用錫君鈇鉞各一",
                "109": "君龍驤虎視",
                "110": "旁眺八維",
                "111": "揜討逆節",
                "112": "折衝四海",
                "113": "是用錫君彤弓一",
                "114": "彤矢百",
                "115": "玈弓十",
                "116": "玈矢千",
                "117": "君以溫恭爲基",
                "118": "孝友爲德",
                "119": "明允篤誠",
                "120": "感乎朕思",
                "121": "是用錫君秬鬯一卣",
                "122": "珪瓚副焉",
                "123": "魏國置丞相以下羣卿百僚",
                "124": "皆如漢初諸王之制",
                "125": "君往欽哉",
                "126": "敬服朕命",
                "127": "簡卹爾眾",
                "128": "時亮庶功",
                "129": "用終爾顯德",
                "130": "對揚我高祖之休命"
            }
        }
    }
}