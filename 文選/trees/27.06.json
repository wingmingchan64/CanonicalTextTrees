{
    "27.06": {
        "篇名": "謝玄暉 敬亭山詩",
        "1": {
            "3": {
                "1": "茲山亙百里",
                "2": "合沓與雲齊",
                "3": "隱淪旣已託",
                "4": "靈異俱然栖",
                "5": "上干蔽白日",
                "6": "下屬帶迴谿",
                "7": "交藤荒且蔓",
                "8": "樛枝聳復低",
                "9": "獨鶴方朝唳",
                "10": "飢鼯此夜啼",
                "11": "渫雲已漫漫",
                "12": "多雨亦淒淒",
                "13": "我行雖紆組",
                "14": "兼得尋幽蹊",
                "15": "緣源殊未極",
                "16": "歸徑窅如迷",
                "17": "要欲追奇趣",
                "18": "卽此陵丹梯",
                "19": "皇恩竟已矣",
                "20": "茲理庶無睽"
            }
        }
    }
}