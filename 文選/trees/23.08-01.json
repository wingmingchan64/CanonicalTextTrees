{
    "23.08-01": {
        "篇名": "潘安仁 悼亡詩三首·其一",
        "1": {
            "3": {
                "1": "荏苒冬春謝",
                "2": "寒暑忽流易",
                "3": "之子歸窮泉",
                "4": "重壤永幽隔",
                "5": "私懷誰克從",
                "6": "淹留亦何益",
                "7": "僶俛恭朝命",
                "8": "迴心反初役",
                "9": "望廬思其人",
                "10": "入室想所歷",
                "11": "帷屛無髣髴",
                "12": "翰墨有餘迹",
                "13": "流芳未及歇",
                "14": "遺挂猶在壁",
                "15": "悵怳如或存",
                "16": "周遑忡驚惕",
                "17": "如彼翰林鳥",
                "18": "雙栖一朝隻",
                "19": "如彼遊川魚",
                "20": "比目中路析",
                "21": "春風緣隟來",
                "22": "晨霤承檐滴",
                "23": "寢息何時忘",
                "24": "沈憂日盈積",
                "25": "庶幾有時衰",
                "26": "莊缶猶可擊"
            }
        }
    }
}