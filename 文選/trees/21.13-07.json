{
    "21.13-07": {
        "篇名": "郭景純 遊仙詩七首·其七",
        "1": {
            "3": {
                "1": "晦朔如循環",
                "2": "月盈已見魄",
                "3": "蓐收清西陸",
                "4": "朱羲將由白",
                "5": "寒露拂陵苕",
                "6": "女蘿辭松柏",
                "7": "蕣榮不終朝",
                "8": "蜉蝣豈見夕",
                "9": "圓丘有奇草",
                "10": "鍾山出靈液",
                "11": "王孫列八珍",
                "12": "安期鍊五石",
                "13": "長揖當塗人",
                "14": "去來山林客"
            }
        }
    }
