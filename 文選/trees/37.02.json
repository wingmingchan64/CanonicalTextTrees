{
    "37.02": {
        "篇名": "諸葛孔明 出師表",
        "1": {
            "3": {
                "1": "臣亮言",
                "2": "先帝創業未半",
                "3": "而中道崩徂",
                "4": "今天下三分",
                "5": "益州罷敝",
                "6": "此誠危急存亡之秋也",
                "7": "然侍衞之臣不懈於內",
                "8": "忠志之士亡身於外者",
                "9": "蓋追先帝之遇",
                "10": "欲報之於陛下也",
                "11": "誠宜開張聖聽",
                "12": "以光先帝遺德",
                "13": "恢志士之氣",
                "14": "不宜妄自菲薄",
                "15": "引喩失義",
                "16": "以塞忠諫之路也",
                "17": "宮中府中",
                "18": "俱爲一體",
                "19": "陟罰臧否",
                "20": "不宜異同",
                "21": "若有作姦犯科及爲忠善者",
                "22": "宜付有司",
                "23": "論其刑賞",
                "24": "以昭陛下平明之理",
                "25": "不宜偏私",
                "26": "使內外異法也"
            }
        },
        "2": {
            "5": {
                "1": "侍中侍郎郭攸之費禕董允等",
                "2": "此皆良實",
                "3": "志慮忠純",
                "4": "是以先帝簡拔以遺陛下",
                "5": "愚以爲宮中之事",
                "6": "事無大小",
                "7": "悉以咨之",
                "8": "然後施行",
                "9": "必能裨補闕漏",
                "10": "有所廣益也",
                "11": "將軍向寵",
                "12": "性行淑均",
                "13": "曉暢軍事",
                "14": "試用於昔日",
                "15": "先帝稱之曰能",
                "16": "是以眾議舉寵爲督",
                "17": "愚以爲營中之事",
                "18": "悉以諮之",
                "19": "必能使行陣和穆",
                "20": "優劣得所也",
                "21": "親賢臣",
                "22": "遠小人",
                "23": "此先漢所以興隆也",
                "24": "親小人",
                "25": "遠賢士",
                "26": "此後漢所以傾頹也",
                "27": "先帝在時",
                "28": "每與臣論此事",
                "29": "未嘗不歎息痛恨於桓靈也",
                "30": "侍中尙書長史參軍",
                "31": "此悉貞亮死節之臣也",
                "32": "願陛下親之信之",
                "33": "則漢室之隆",
                "34": "可計日而待也"
            }
        },
        "3": {
            "7": {
                "1": "臣本布衣",
                "2": "躬耕於南陽",
                "3": "苟全性命於亂世",
                "4": "不求聞達於諸侯",
                "5": "先帝不以臣卑鄙",
                "6": "猥自枉屈",
                "7": "三顧臣於草廬之中",
                "8": "諮臣以當世之事",
                "9": "由是感激",
                "10": "遂許先帝以驅馳",
                "11": "後値傾覆",
                "12": "受任於敗軍之際",
                "13": "奉命於危難之間",
                "14": "爾來二十有一年矣",
                "15": "先帝知臣謹愼",
                "16": "故臨崩寄臣以大事也",
                "17": "受命以來",
                "18": "夙夜憂歎",
                "19": "恐託付不效",
                "20": "以傷先帝之明",
                "21": "故五月度瀘",
                "22": "深入不毛",
                "23": "今南方已定",
                "24": "兵甲已足",
                "25": "當獎帥三軍",
                "26": "北定中原",
                "27": "庶竭駑鈍",
                "28": "攘除姦凶",
                "29": "興復漢室",
                "30": "還於舊都",
                "31": "此臣之所以報先帝而忠陛下之職分也"
            }
        },
        "4": {
            "9": {
                "1": "至於斟酌損益",
                "2": "進盡忠言",
                "3": "則攸之禕允之任也",
                "4": "願陛下託臣以討賊興復之效",
                "5": "不效",
                "6": "則治臣之罪",
                "7": "以告先帝之靈",
                "8": "責攸之禕允等咎",
                "9": "以章其慢",
                "10": "陛下亦宜自課",
                "11": "以咨諏善道",
                "12": "察納雅言",
                "13": "深追先帝遺詔",
                "14": "臣不勝受恩感激",
                "15": "今當遠離",
                "16": "臨表涕泣",
                "17": "不知所云"
            }
        }
    }
}