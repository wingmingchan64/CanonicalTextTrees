{
    "29.07-01": {
        "篇名": "魏文帝 雜詩二首·其一",
        "1": {
            "3": {
                "1": "漫漫秋夜長",
                "2": "烈烈北風涼",
                "3": "展轉不能寐",
                "4": "披衣起彷徨",
                "5": "彷徨忽已久",
                "6": "白露霑我裳",
                "7": "俯視清水波",
                "8": "仰看明月光",
                "9": "天漢迴西流",
                "10": "三五正從橫",
                "11": "草蟲鳴何悲",
                "12": "孤雁獨南翔",
                "13": "鬱鬱多悲思",
                "14": "綿綿思故鄕",
                "15": "願飛安得翼",
                "16": "欲濟河無梁",
                "17": "向風長歎息",
                "18": "斷絕我中腸"
            }
        }
    }
}