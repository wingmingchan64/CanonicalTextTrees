{
    "39.03": {
        "篇名": "鄒陽 獄中上書自明",
        "1": {
            "3": {
                "1": "臣聞忠無不報",
                "2": "信不見疑",
                "3": "臣常以爲然",
                "4": "徒虛語耳",
                "5": "昔者荊軻慕燕丹之義",
                "6": "白虹貫日",
                "7": "太子畏之",
                "8": "衞先生爲秦畫長平之事",
                "9": "太白食昴",
                "10": "昭王疑之",
                "11": "夫精誠變天地",
                "12": "而信不諭兩主",
                "13": "豈不哀哉",
                "14": "今臣盡忠竭誠",
                "15": "畢議願知",
                "16": "左右不明",
                "17": "卒從吏訊",
                "18": "爲世所疑",
                "19": "是使荊軻衞先生復起",
                "20": "而燕秦不寤也",
                "21": "願大王熟察之"
            }
        },
        "2": {
            "5": {
                "1": "昔玉人獻寶",
                "2": "楚王誅之",
                "3": "李斯竭忠",
                "4": "胡亥極刑",
                "5": "是以箕子陽狂",
                "6": "接輿避世",
                "7": "恐遭此患",
                "8": "願大王察玉人",
                "9": "李斯之意",
                "10": "而後楚王胡亥之聽",
                "11": "毋使臣爲箕子接輿所笑",
                "12": "臣聞比干剖心",
                "13": "子胥鴟夷",
                "14": "臣始不信",
                "15": "乃今知之",
                "16": "願大王熟察",
                "17": "少加憐焉"
            }
        },
        "3": {
            "7": {
                "1": "語曰",
                "2": "白頭如新",
                "3": "傾蓋如故",
                "4": "何則",
                "5": "知與不知也",
                "6": "故樊於期逃秦之燕",
                "7": "藉荊軻首以奉丹事",
                "8": "王奢去齊之魏",
                "9": "臨城自剄以卻齊而存魏",
                "10": "夫王奢樊於期非新於齊秦而故於燕魏也",
                "11": "所以去二國",
                "12": "死兩君者",
                "13": "行合於志",
                "14": "而慕義無窮也",
                "15": "是以蘇秦不信於天下",
                "16": "爲燕尾生",
                "17": "白圭戰亡六城",
                "18": "爲魏取中山",
                "19": "何則",
                "20": "誠有以相知也",
                "21": "蘇秦相燕",
                "22": "人惡之於燕王",
                "23": "燕王按劍而怒",
                "24": "食以駃騠",
                "25": "白圭顯於中山",
                "26": "人惡之於魏文侯",
                "27": "文侯投以夜光之璧",
                "28": "何則",
                "29": "兩主二臣",
                "30": "剖心析肝相信",
                "31": "豈移於浮辭哉"
            }
        },
        "4": {
            "9": {
                "1": "故女無美惡",
                "2": "入宮見妬",
                "3": "士無賢不肖",
                "4": "入朝見嫉",
                "5": "昔者司馬喜臏腳於宋",
                "6": "卒相中山",
                "7": "范雎摺脅折齒於魏",
                "8": "卒爲應侯",
                "9": "此二人者",
                "10": "皆信必然之畫",
                "11": "捐朋黨之私",
                "12": "挾孤獨之交",
                "13": "故不能自免於嫉妬之人也",
                "14": "是以申徒狄蹈雍之河",
                "15": "徐衍負石入海",
                "16": "不容身於世",
                "17": "義不苟取比周於朝",
                "18": "以移主上之心",
                "19": "故百里奚乞食於路",
                "20": "穆公委之以政",
                "21": "甯戚飯牛車下",
                "22": "而桓公任之以國",
                "23": "此二人豈素宦於朝",
                "24": "借譽於左右",
                "25": "然後二主用之哉",
                "26": "感於心",
                "27": "合於意",
                "28": "堅如膠漆",
                "29": "昆弟不能離",
                "30": "豈惑於眾口哉",
                "31": "故偏聽生姦",
                "32": "獨任成亂",
                "33": "昔魯聽季孫之說而逐孔子",
                "34": "宋信子冉之計囚墨翟",
                "35": "夫以孔墨之辯",
                "36": "不能自免於讒諛",
                "37": "而二國以危",
                "38": "何則",
                "39": "眾口鑠金",
                "40": "積毀銷骨",
                "41": "是以秦用戎人由余而霸中國",
                "42": "齊用越人子臧而彊威宣",
                "43": "此二國豈拘於俗",
                "44": "牽於世",
                "45": "繫奇偏之辭哉",
                "46": "公聽並觀",
                "47": "垂明當世",
                "48": "故意合則胡越爲昆弟",
                "49": "由余子臧是矣",
                "50": "不合則骨肉爲讎敵",
                "51": "朱象管蔡是矣",
                "52": "今人主誠能用齊秦之明",
                "53": "後宋魯之聽",
                "54": "則五霸不足侔",
                "55": "三王易爲比也"
            }
        },
        "5": {
            "11": {
                "1": "是以聖王覺悟",
                "2": "捐子之之心",
                "3": "而不悅田常之賢",
                "4": "封比干之後",
                "5": "修孕婦之墓",
                "6": "故功業覆於天下",
                "7": "何則",
                "8": "欲善無厭也",
                "9": "夫晉文公親其讎而彊霸諸侯",
                "10": "齊桓公用其仇而一匡天下",
                "11": "何則",
                "12": "慈仁殷勤",
                "13": "誠嘉於心",
                "14": "此不可以虛辭借也",
                "15": "至夫秦用商鞅之法",
                "16": "東弱韓魏",
                "17": "立彊天下",
                "18": "而卒車裂之",
                "19": "越用大夫種之謀",
                "20": "禽勁吳而霸中國",
                "21": "遂誅其身",
                "22": "是以孫叔敖三去相而不悔",
                "23": "於陵子仲辭三公爲人灌園",
                "24": "今人主誠能去驕傲之心",
                "25": "懷可報之意",
                "26": "披心腹",
                "27": "見情素",
                "28": "隳肝膽",
                "29": "施德厚",
                "30": "終與之窮達",
                "31": "無愛於士",
                "32": "則桀之㺃可使吠堯",
                "33": "而跖之客可使刺由",
                "34": "應劭曰",
                "35": "由",
                "36": "許由也",
                "37": "跖",
                "38": "盜跖也",
                "39": "韋昭曰",
                "40": "言恩厚無不使",
                "41": "善曰",
                "42": "戰國策",
                "43": "刀鞮謂田單曰",
                "44": "跖之㺃或𠲎堯",
                "45": "非其主也",
                "46": "𠲎",
                "47": "音吠",
                "48": "並同",
                "49": "何況因萬乘之權",
                "50": "假聖王之資乎",
                "51": "然則荊軻湛七族",
                "52": "要離燔妻子",
                "53": "豈足爲大王道哉"
            }
        },
        "6": {
            "13": {
                "1": "臣聞明月之珠",
                "2": "夜光之璧",
                "3": "以暗投人於道",
                "4": "眾莫不按劍相眄者",
                "5": "何則",
                "6": "無因而至前也",
                "7": "蟠木根柢",
                "8": "輪囷離奇",
                "9": "而爲萬乘器者",
                "10": "何則",
                "11": "以左右先爲之容也",
                "12": "故無因而至前",
                "13": "雖出隋侯之珠",
                "14": "夜光之璧",
                "15": "秪足結怨而不見德",
                "16": "故有人先談",
                "17": "則枯木朽株",
                "18": "樹功而不忘",
                "19": "今天下布衣窮居之士",
                "20": "身在貧賤",
                "21": "雖蒙堯舜之術",
                "22": "挾伊管之辯",
                "23": "懷龍逢比干之意",
                "24": "欲盡忠當世之君",
                "25": "而素無根柢之容",
                "26": "雖竭精神",
                "27": "欲開忠信",
                "28": "輔人主之治",
                "29": "則人主必襲按劍相眄之迹矣",
                "30": "是使布衣之士",
                "31": "不得爲枯木朽株之資也"
            }
        },
        "7": {
            "15": {
                "1": "是以聖王制世御俗",
                "2": "獨化於陶鈞之上",
                "3": "而不牽乎卑辭之語",
                "4": "不奪乎眾多之口",
                "5": "故秦皇帝任中庶子蒙嘉之言",
                "6": "以信荊軻之說",
                "7": "而匕首竊發",
                "8": "周文獵涇渭",
                "9": "載呂尙而歸",
                "10": "以王天下",
                "11": "秦信左右而亡",
                "12": "周用烏集而王",
                "13": "何則",
                "14": "以其能越拘攣之語",
                "15": "馳域外之義",
                "16": "獨觀於昭曠之道也",
                "17": "今人主沈諂諛之辭",
                "18": "牽於帷牆之制",
                "19": "使不羈之士與牛驥同皁",
                "20": "此鮑焦所以忿於世而不留富貴之樂也"
            }
        },
        "8": {
            "17": {
                "1": "臣聞盛飾入朝者",
                "2": "不以私汙義",
                "3": "砥厲名號者",
                "4": "不以利傷行",
                "5": "故里名勝母",
                "6": "曾子不入",
                "7": "邑號朝歌",
                "8": "墨子迴車",
                "9": "今欲使天下恢廓之士",
                "10": "誘於威重之權",
                "11": "脅於位勢之貴",
                "12": "回面汙行",
                "13": "以事諂諛之人",
                "14": "而求親近於左右",
                "15": "則士有伏死堀穴巖藪之中耳",
                "16": "安有盡忠信而趨闕下者哉"
            }
        }
    }
}