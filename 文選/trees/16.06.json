{
    "16.06": {
        "篇名": "潘安仁 寡婦賦[幷序]",
        "1": {
            "3": {
                "1": "樂安任子咸有韜世之量",
                "2": "與余少而歡焉",
                "3": "雖兄弟之愛",
                "4": "無以加也",
                "5": "不幸弱冠而終",
                "6": "良友旣沒",
                "7": "何痛如之",
                "8": "其妻又吾姨也",
                "9": "少喪父母",
                "10": "適人而所天又殞",
                "11": "孤女藐焉始孩",
                "12": "斯亦生民之至艱",
                "13": "而荼毒之極哀也",
                "14": "昔阮瑀旣歿",
                "15": "魏文悼之",
                "16": "並命知舊作寡婦之賦",
                "17": "余遂擬之以敍其孤寡之心焉",
                "18": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "嗟予生之不造兮",
                "2": "哀天難之匪忱",
                "3": "少伶俜而偏孤兮",
                "4": "痛忉怛以摧心",
                "5": "覽寒泉之遺歎兮",
                "6": "詠蓼莪之餘音",
                "7": "情長慼以永慕兮",
                "8": "思彌遠而逾深",
                "9": "伊女子之有行兮",
                "10": "爰奉嬪於高族",
                "11": "承慶雲之光覆兮",
                "12": "荷君子之惠渥",
                "13": "顧葛藟之蔓延兮",
                "14": "託微莖於樛木",
                "15": "懼身輕而施重兮",
                "16": "若履冰而臨谷",
                "17": "遵義方之明訓兮",
                "18": "憲女史之典戒",
                "19": "奉蒸嘗以效順兮",
                "20": "供灑掃以彌載"
            }
        },
        "3": {
            "7": {
                "1": "彼詩人之攸歎兮",
                "2": "徒願言而心痗",
                "3": "何遭命之奇薄兮",
                "4": "遘天禍之未悔",
                "5": "榮華曄其始茂兮",
                "6": "良人忽以捐背",
                "7": "靜闔門以窮居兮",
                "8": "塊煢獨而靡依",
                "9": "易錦茵以苫席兮",
                "10": "代羅幬以素帷",
                "11": "命阿保而就列兮",
                "12": "覽巾箑以舒悲",
                "13": "口嗚咽以失聲兮",
                "14": "淚橫逬而霑衣",
                "15": "愁煩冤其誰告兮",
                "16": "提孤孩於坐側"
            }
        },
        "4": {
            "9": {
                "1": "時曖曖而向昏兮",
                "2": "日杳杳而西匿",
                "3": "雀羣飛而赴楹兮",
                "4": "雞登栖而斂翼",
                "5": "歸空館而自怜兮",
                "6": "撫衾裯以歎息",
                "7": "思纏綿以瞀亂兮",
                "8": "心摧傷以愴惻"
            }
        },
        "5": {
            "11": {
                "1": "曜靈曄而遄邁兮",
                "2": "四節運而推移",
                "3": "天凝露以降霜兮",
                "4": "木落葉而隕枝",
                "5": "仰神宇之寥寥兮",
                "6": "瞻靈衣之披披",
                "7": "退幽悲於堂隅兮",
                "8": "進獨拜於牀垂",
                "9": "耳傾想於疇昔兮",
                "10": "目仿佛乎平素",
                "11": "雖冥冥而罔覿兮",
                "12": "猶依依以憑附",
                "13": "痛存亡之殊制兮",
                "14": "將遷神而安厝",
                "15": "龍轜儼其星駕兮",
                "16": "飛旐翩以啟路",
                "17": "輪按軌以徐進兮",
                "18": "馬悲鳴而跼顧",
                "19": "潛靈邈其不反兮",
                "20": "殷憂結而靡訴",
                "21": "睎形影於几筵兮",
                "22": "馳精爽於丘墓"
            }
        },
        "6": {
            "13": {
                "1": "自仲秋而在疚兮",
                "2": "踰履霜以踐冰",
                "3": "雪霏霏而驟落兮",
                "4": "風瀏瀏而夙興",
                "5": "霤泠泠以夜下兮",
                "6": "水溓溓以微凝",
                "7": "意忽怳以遷越兮",
                "8": "神一夕而九升",
                "9": "庶浸遠而哀降兮",
                "10": "情惻惻而彌甚",
                "11": "願假夢以通靈兮",
                "12": "目炯炯而不寢",
                "13": "夜漫漫以悠悠兮",
                "14": "寒淒淒以凜凜",
                "15": "氣憤薄而乘胸兮",
                "16": "涕交橫而流枕",
                "17": "亡魂逝而永遠兮",
                "18": "時歲忽其遒盡",
                "19": "容貌儡以頓顇兮",
                "20": "左右悽其相慜",
                "21": "感三良之殉秦兮",
                "22": "甘捐生而自引",
                "23": "鞠稚子於懷抱兮",
                "24": "羌低徊而不忍",
                "25": "獨指景而心誓兮",
                "26": "雖形存而志隕"
            }
        },
        "7": {
            "15": {
                "1": "重曰",
                "2": "仰皇穹兮歎息",
                "3": "私自憐兮何極",
                "4": "省微身兮孤弱",
                "5": "顧稚子兮未識",
                "6": "如涉川兮無梁",
                "7": "若陵虛兮失翼",
                "8": "上瞻兮遺象",
                "9": "下臨兮泉壤",
                "10": "窈冥兮潛翳",
                "11": "心存兮目想",
                "12": "奉虛坐兮肅清",
                "13": "愬空宇兮曠朗",
                "14": "廓孤立兮顧影",
                "15": "塊獨言兮聽響",
                "16": "顧影兮傷摧",
                "17": "聽響兮增哀",
                "18": "遙逝兮逾遠",
                "19": "緬邈兮長乖"
            }
        },
        "8": {
            "17": {
                "1": "四節流兮忽代序",
                "2": "歲云暮兮日西頹",
                "3": "霜被庭兮風入室",
                "4": "夜旣分兮星漢迴",
                "5": "夢良人兮來遊",
                "6": "若閶闔兮洞開",
                "7": "怛驚悟兮無聞",
                "8": "超𢠵怳兮慟懷",
                "9": "慟懷兮柰何",
                "10": "言陟兮山阿",
                "11": "墓門兮肅肅",
                "12": "修壟兮峨峨",
                "13": "孤鳥嚶兮悲鳴",
                "14": "長松萋兮振柯",
                "15": "哀鬱結兮交集",
                "16": "淚橫流兮滂遝",
                "17": "蹈恭姜兮明誓",
                "18": "詠柏舟兮清歌",
                "19": "終歸骨兮山足",
                "20": "存憑託兮餘華",
                "21": "要吾君兮同穴",
                "22": "之死矢兮靡佗"
            }
        }
    }
}