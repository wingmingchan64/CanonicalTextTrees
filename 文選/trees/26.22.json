{
    "26.22": {
        "篇名": "謝靈運 永初三年七月十六日之郡初發都",
        "1": {
            "3": {
                "1": "述職期闌暑",
                "2": "理棹變金素",
                "3": "秋岸澄夕陰",
                "4": "火旻團朝露",
                "5": "辛苦誰爲情",
                "6": "遊子値頹暮",
                "7": "愛似莊念昔",
                "8": "久敬曾存故",
                "9": "如何懷土心",
                "10": "持此謝遠度",
                "11": "李牧愧長袖",
                "12": "郤克慚鵕步",
                "13": "良時不見遺",
                "14": "醜狀不成惡",
                "15": "曰余亦支離",
                "16": "依方早有慕",
                "17": "生幸休明世",
                "18": "親蒙英達顧",
                "19": "空班趙氏璧",
                "20": "徒乖魏王瓠",
                "21": "從來漸二紀",
                "22": "始得傍歸路",
                "23": "將窮山海迹",
                "24": "永絕賞心悟"
            }
        }
    }
}