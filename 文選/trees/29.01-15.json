{
    "29.01-15": {
        "篇名": "古詩一十九首·生年不滿百",
        "1": {
            "3": {
                "1": "生年不滿百",
                "2": "常懷千歲憂",
                "3": "晝短苦夜長",
                "4": "何不秉燭遊",
                "5": "爲樂當及時",
                "6": "何能待來茲",
                "7": "愚者愛惜費",
                "8": "但爲後世嗤",
                "9": "仙人王子喬",
                "10": "難可與等期"
            }
        }
    }
}