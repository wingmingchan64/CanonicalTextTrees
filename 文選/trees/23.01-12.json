{
    "23.01-12": {
        "篇名": "阮嗣宗 詠懷詩十七首·其十二",
        "1": {
            "3": {
                "1": "徘徊蓬池上",
                "2": "還顧望大梁"
            },
            "4": {
                "1": "綠水揚洪波",
                "2": "曠野莽茫茫"
            },
            "5": {
                "1": "走獸交橫馳",
                "2": "飛鳥相隨翔"
            },
            "6": {
                "1": "是時鶉火中",
                "2": "日月正相望"
            },
            "7": {
                "1": "朔風厲嚴寒",
                "2": "陰氣下微霜"
            },
            "8": {
                "1": "羈旅無疇匹",
                "2": "俛仰懷哀傷"
            },
            "9": {
                "1": "小人計其功",
                "2": "君子道其常"
            },
            "10": {
                "1": "豈惜終憔悴",
                "2": "詠言著斯章"
            }
        }
    }
