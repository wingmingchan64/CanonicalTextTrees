{
    "51.01": {
        "篇名": "賈誼 過秦論",
        "1": {
            "3": {
                "1": "秦孝公據殽函之固",
                "2": "擁雍州之地",
                "3": "君臣固守",
                "4": "以窺周室",
                "5": "有席卷天下",
                "6": "包舉宇內",
                "7": "囊括四海之意",
                "8": "幷吞八荒之心",
                "9": "當是時也",
                "10": "商君佐之",
                "11": "內立法度",
                "12": "務耕織",
                "13": "修守戰之具",
                "14": "外連衡而鬥諸侯",
                "15": "於是秦人拱手而取西河之外",
                "16": "孝公旣沒",
                "17": "惠文武昭",
                "18": "蒙故業",
                "19": "因遺策",
                "20": "南取漢中",
                "21": "西舉巴蜀",
                "22": "東割膏腴之地",
                "23": "收要害之郡",
                "24": "諸候恐懼",
                "25": "會盟而謀弱秦",
                "26": "不愛珍器重寶肥饒之地",
                "27": "以致天下之士",
                "28": "合從締交",
                "29": "相與爲一",
                "30": "當此之時",
                "31": "齊有孟嘗",
                "32": "趙有平原",
                "33": "楚有春申",
                "34": "魏有信陵",
                "35": "此四君者",
                "36": "皆明智而忠信",
                "37": "寬厚而愛人",
                "38": "尊賢而重士",
                "39": "約從離橫",
                "40": "兼韓魏燕趙宋衞中山之眾",
                "41": "於是六國之士",
                "42": "有寗越徐尙蘇秦杜赫之屬爲之謀",
                "43": "齊明周最陳軫召滑樓緩翟景蘇厲樂毅之徒通其意",
                "44": "吳起孫臏帶佗兒良王廖田忌廉頗趙奢之倫制其兵",
                "45": "嘗以十倍之地",
                "46": "百萬之眾",
                "47": "叩關而攻秦",
                "48": "秦人開關而延敵",
                "49": "九國之師遁逃而不敢進",
                "50": "秦無亡矢遺鏃之費",
                "51": "而天下諸侯已困矣",
                "52": "於是從散約解",
                "53": "爭割地而賂秦",
                "54": "秦有餘力而制其敝",
                "55": "追亡逐北",
                "56": "伏尸百萬",
                "57": "流血漂櫓因利乘便",
                "58": "宰割天下",
                "59": "分裂河山",
                "60": "彊國請伏",
                "61": "弱國入朝",
                "62": "施及孝文王莊襄王",
                "63": "享國之日淺",
                "64": "國家無事"
            }
        },
        "2": {
            "5": {
                "1": "及至始皇",
                "2": "奮六世之餘烈",
                "3": "振長策而御宇內",
                "4": "吞二周而亡諸候",
                "5": "履至尊而制六合",
                "6": "執敲扑以鞭笞天下",
                "7": "威振四海",
                "8": "南取百越之地",
                "9": "以爲桂林象郡",
                "10": "百越之君",
                "11": "俛首係頸",
                "12": "委命下吏",
                "13": "乃使蒙恬北築長城而守蕃籬",
                "14": "卻匈奴七百餘里",
                "15": "胡人不敢南下而牧馬",
                "16": "士不敢彎弓而報怨",
                "17": "於是廢先王之道",
                "18": "燔百家之言",
                "19": "以愚黔首",
                "20": "隳名城",
                "21": "殺豪俊",
                "22": "收天下之兵聚之咸陽",
                "23": "銷鋒鍉鑄以爲金人十二",
                "24": "以弱天下之民",
                "25": "然後踐華爲城",
                "26": "因河爲池",
                "27": "據億丈之城",
                "28": "臨不測之谿以爲固",
                "29": "良將勁弩",
                "30": "守要害之處",
                "31": "信臣精卒",
                "32": "陳利兵而誰何",
                "33": "天下已定",
                "34": "始皇之心",
                "35": "自以爲關中之固",
                "36": "金城千里",
                "37": "子孫帝王",
                "38": "萬世之業"
            }
        },
        "3": {
            "7": {
                "1": "始皇旣沒",
                "2": "餘威震於殊俗",
                "3": "然而陳涉",
                "4": "甕牖繩樞之子",
                "5": "甿隸之人",
                "6": "而遷徙之徒也",
                "7": "材能不及中庸",
                "8": "非有仲尼墨翟之賢",
                "9": "陶朱猗頓之富",
                "10": "躡足行伍之間",
                "11": "俛起阡陌之中",
                "12": "率罷散之卒",
                "13": "將數百之眾",
                "14": "轉而攻秦",
                "15": "斬木爲兵",
                "16": "揭竿爲旗",
                "17": "天下雲集而響應",
                "18": "嬴糧而景從",
                "19": "山東豪俊",
                "20": "遂並起而亡秦族矣"
            }
        },
        "4": {
            "9": {
                "1": "且夫天下非小弱也",
                "2": "雍州之地",
                "3": "殽函之固自若也",
                "4": "陳涉之位",
                "5": "非尊於齊楚燕趙韓魏宋衞中山之君也",
                "6": "鋤耰棘矜非銛於鉤戟長鎩也",
                "7": "謫戍之眾",
                "8": "非抗於九國之師也",
                "9": "深謀遠慮",
                "10": "行軍用兵之道",
                "11": "非及曩時之士也",
                "12": "然而成敗異變",
                "13": "功業相反",
                "14": "試使山東之國與陳涉度長絜大",
                "15": "比權量力",
                "16": "則不可同年而語矣",
                "17": "然秦以區區之地",
                "18": "致萬乘之權",
                "19": "招八州而朝同列",
                "20": "百有餘年矣",
                "21": "然後以六合爲家",
                "22": "殽函爲宮",
                "23": "一夫作難而七廟隳",
                "24": "身死人手",
                "25": "爲天下笑者",
                "26": "何也",
                "27": "仁義不施",
                "28": "而攻守之勢異也"
            }
        }
    }
}