{
    "09.04": {
        "篇名": "曹大家 東征賦",
        "1": {
            "3": {
                "1": "惟永初之有七兮",
                "2": "余隨子乎東征",
                "3": "時孟春之吉日兮",
                "4": "撰良辰而將行",
                "5": "乃舉趾而升輿兮",
                "6": "夕予宿乎偃師",
                "7": "遂去故而就新兮",
                "8": "志愴悢而懷悲"
            }
        },
        "2": {
            "5": {
                "1": "明發曙而不寐兮",
                "2": "心遲遲而有違",
                "3": "酌尊酒以弛念兮",
                "4": "喟抑情而自非",
                "5": "諒不登樔而椓蠡兮",
                "6": "得不陳力而相追",
                "7": "且從眾而就列兮",
                "8": "聽天命之所歸",
                "9": "遵通衢之大道兮",
                "10": "求捷徑欲從誰",
                "11": "乃遂往而徂逝兮",
                "12": "聊遊目而遨魂"
            }
        },
        "3": {
            "7": {
                "1": "歷七邑而觀覽兮",
                "2": "遭鞏縣之多艱",
                "3": "望河洛之交流兮",
                "4": "看成皋之旋門",
                "5": "旣免脫於峻嶮兮",
                "6": "歷滎陽而過卷",
                "7": "食原武之息足",
                "8": "宿陽武之桑間",
                "9": "涉封丘而踐路兮",
                "10": "慕京師而竊歎",
                "11": "小人性之懷土兮",
                "12": "自書傳而有焉"
            }
        },
        "4": {
            "9": {
                "1": "遂進道而少前兮",
                "2": "得平丘之北邊",
                "3": "入匡郭而追遠兮",
                "4": "念夫子之厄勤",
                "5": "彼衰亂之無道兮",
                "6": "乃困畏乎聖人",
                "7": "悵容與而久駐兮",
                "8": "忘日夕而將昏",
                "9": "到長垣之境界",
                "10": "察農野之居民",
                "11": "睹蒲城之丘墟兮",
                "12": "生荊棘之榛榛",
                "13": "惕覺寤而顧問兮",
                "14": "想子路之威神",
                "15": "衞人嘉其勇義兮",
                "16": "訖於今而稱云",
                "17": "蘧氏在城之東南兮",
                "18": "民亦尙其丘墳",
                "19": "唯令德爲不朽兮",
                "20": "身旣沒而名存"
            }
        },
        "5": {
            "11": {
                "1": "惟經典之所美兮",
                "2": "貴道德與仁賢",
                "3": "吳札稱多君子兮",
                "4": "其言信而有徵",
                "5": "後衰微而遭患兮",
                "6": "遂陵遲而不興",
                "7": "知性命之在天",
                "8": "由力行而近仁",
                "9": "勉仰高而蹈景兮",
                "10": "盡忠恕而與人",
                "11": "好正直而不回兮",
                "12": "精誠通於明神",
                "13": "庶靈祇之鑒照兮",
                "14": "祐貞良而輔信"
            }
        },
        "6": {
            "13": {
                "1": "亂曰",
                "2": "君子之思",
                "3": "必成文兮",
                "4": "盍各言志",
                "5": "慕古人兮",
                "6": "先君行止",
                "7": "則有作兮",
                "8": "雖其不敏",
                "9": "敢不法兮",
                "10": "貴賤貧富",
                "11": "不可求兮",
                "12": "正身履道",
                "13": "以俟時兮",
                "14": "修短之運",
                "15": "愚智同兮",
                "16": "靖恭委命",
                "17": "唯吉凶兮",
                "18": "敬愼無怠",
                "19": "思嗛約兮",
                "20": "清靜少欲",
                "21": "師公綽兮"
            }
        }
    }
}