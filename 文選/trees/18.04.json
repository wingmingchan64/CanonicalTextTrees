{
    "18.04": {
        "篇名": "成公子安 嘯賦",
        "1": {
            "3": {
                "1": "逸羣公子",
                "2": "體奇好異",
                "3": "傲世忘榮",
                "4": "絕棄人事",
                "5": "睎高慕古",
                "6": "長想遠思",
                "7": "將登箕山以抗節",
                "8": "浮滄海以遊志",
                "9": "於是延友生",
                "10": "集同好",
                "11": "精性命之至機",
                "12": "硏道德之玄奧",
                "13": "愍流俗之未悟",
                "14": "獨超然而先覺",
                "15": "狹世路之阨僻",
                "16": "仰天衢而高蹈",
                "17": "邈姱俗而遺身",
                "18": "乃慷慨而長嘯"
            }
        },
        "2": {
            "5": {
                "1": "於時曜靈俄景",
                "2": "流光濛汜",
                "3": "逍遙攜手",
                "4": "踟跦步趾",
                "5": "發妙聲於丹脣",
                "6": "激哀音於皓齒",
                "7": "響抑揚而潛轉",
                "8": "氣衝鬱而熛起",
                "9": "協黃宮於清角",
                "10": "雜商羽於流徵",
                "11": "飄遊雲於泰清",
                "12": "集長風乎萬里",
                "13": "曲旣終而響絕",
                "14": "遺餘玩而未已",
                "15": "良自然之至音",
                "16": "非絲竹之所擬",
                "17": "是故聲不假器",
                "18": "用不借物",
                "19": "近取諸身",
                "20": "役心御氣",
                "21": "動脣有曲",
                "22": "發口成音",
                "23": "觸類感物",
                "24": "因歌隨吟",
                "25": "大而不洿",
                "26": "細而不沈",
                "27": "清激切於竽笙",
                "28": "優潤和於瑟琴",
                "29": "玄妙足以通神悟靈",
                "30": "精微足以窮幽測深",
                "31": "收激楚之哀荒",
                "32": "節北里之奢淫",
                "33": "濟洪災於炎旱",
                "34": "反亢陽於重陰",
                "35": "唱引萬變",
                "36": "曲用無方",
                "37": "和樂怡懌",
                "38": "悲傷摧藏",
                "39": "時幽散而將絕",
                "40": "中矯厲而慨慷",
                "41": "徐婉約而優遊",
                "42": "紛繁騖而激揚",
                "43": "情旣思而能反",
                "44": "心雖哀而不傷",
                "45": "總八音之至和",
                "46": "固極樂而無荒"
            }
        },
        "3": {
            "7": {
                "1": "若乃登高臺以臨遠",
                "2": "披文軒而騁望",
                "3": "喟仰抃而抗首",
                "4": "嘈長引而憀亮",
                "5": "或舒肆而自反",
                "6": "或徘徊而復放",
                "7": "或冉弱而柔撓",
                "8": "或澎濞而奔壯",
                "9": "橫鬱鳴而滔涸",
                "10": "冽飄眇而清昶",
                "11": "逸氣奮湧",
                "12": "繽紛交錯",
                "13": "列列飆揚",
                "14": "啾啾響作",
                "15": "奏胡馬之長思",
                "16": "向寒風乎北朔",
                "17": "又似鴻雁之將雛",
                "18": "羣鳴號乎沙漠",
                "19": "故能因形創聲",
                "20": "隨事造曲",
                "21": "應物無窮",
                "22": "機發響速",
                "23": "怫鬱衝流",
                "24": "參譚雲屬",
                "25": "若離若合",
                "26": "將絕復續",
                "27": "飛廉鼓於幽隧",
                "28": "猛虎應於中谷",
                "29": "南箕動於穹蒼",
                "30": "清飆振乎喬木",
                "31": "散滯積而播揚",
                "32": "蕩埃藹之溷濁",
                "33": "變陰陽之至和",
                "34": "移淫風之穢俗"
            }
        },
        "4": {
            "9": {
                "1": "若乃遊崇崗",
                "2": "陵景山",
                "3": "臨巖側",
                "4": "望流川",
                "5": "坐盤石",
                "6": "漱清泉",
                "7": "藉皋蘭之猗靡",
                "8": "蔭修竹之蟬蜎",
                "9": "乃吟詠而發散",
                "10": "聲駱驛而響連",
                "11": "舒蓄思之悱憤",
                "12": "奮久結之纏綿",
                "13": "心滌蕩而無累",
                "14": "志離俗而飄然"
            }
        },
        "5": {
            "11": {
                "1": "若夫假象金革",
                "2": "擬則陶匏",
                "3": "眾聲繁奏",
                "4": "若笳若簫",
                "5": "磞硠震隱",
                "6": "訇磕㗦嘈",
                "7": "發徵則隆冬熙蒸",
                "8": "騁羽則嚴霜夏凋",
                "9": "動商則秋霖春降",
                "10": "奏角則谷風鳴條",
                "11": "音均不恆",
                "12": "曲無定制",
                "13": "行而不流",
                "14": "止而不滯",
                "15": "隨口吻而發揚",
                "16": "假芳氣而遠逝",
                "17": "音要妙而流響",
                "18": "聲激嚁而清厲",
                "19": "信自然之極麗",
                "20": "羌殊尤而絕世",
                "21": "越韶夏與咸池",
                "22": "何徒取異乎鄭衞"
            }
        },
        "6": {
            "13": {
                "1": "於時綿駒結舌而喪精",
                "2": "王豹杜口而失色",
                "3": "虞公輟聲而止歌",
                "4": "寗子檢手而歎息",
                "5": "鍾期棄琴而改聽",
                "6": "孔父忘味而不食",
                "7": "百獸率舞而抃足",
                "8": "鳳皇來儀而拊翼",
                "9": "乃知長嘯之奇妙",
                "10": "蓋亦音聲之至極"
            }
        }
    }
}