{
    "26.17-01": {
        "篇名": "陸士衡 赴洛二首·其一",
        "1": {
            "3": {
                "1": "希世無高符",
                "2": "營道無烈心",
                "3": "靖端肅有命",
                "4": "假楫越江潭",
                "5": "親友贈予邁",
                "6": "揮淚廣川陰",
                "7": "撫膺解攜手",
                "8": "永歎結遺音",
                "9": "無迹有所匿",
                "10": "寂漠聲必沈",
                "11": "肆目眇不及",
                "12": "緬然若雙潛",
                "13": "南望泣玄渚",
                "14": "北邁涉長林",
                "15": "谷風拂修薄",
                "16": "油雲翳高岑",
                "17": "亹亹孤獸騁",
                "18": "嚶嚶思鳥吟",
                "19": "感物戀堂室",
                "20": "離思一何深",
                "21": "佇立愾我歎",
                "22": "寤寐涕盈衿",
                "23": "惜無懷歸志",
                "24": "辛苦誰爲心"
            }
        }
    }
