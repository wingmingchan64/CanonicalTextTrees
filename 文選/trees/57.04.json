{
    "57.04": {
        "篇名": "顏延年 陶徵士誄[幷序]",
        "1": {
            "3": {
                "1": "夫璿玉致美",
                "2": "不爲池隍之寶",
                "3": "桂椒信芳",
                "4": "而非園林之實",
                "5": "豈其深而好遠哉",
                "6": "蓋云殊性而已",
                "7": "故無足而至者",
                "8": "物之藉也",
                "9": "隨踵而立者",
                "10": "人之薄也",
                "11": "若乃巢高之抗行",
                "12": "夷皓之峻節",
                "13": "故已父老堯禹",
                "14": "錙銖周漢",
                "15": "而綿世浸遠",
                "16": "光靈不屬",
                "17": "至使菁華隱沒",
                "18": "芳流歇絕",
                "19": "不其惜乎",
                "20": "雖今之作者",
                "21": "人自爲量",
                "22": "而首路同塵",
                "23": "輟塗殊軌者多矣",
                "24": "豈所以昭末景",
                "25": "泛餘波"
            }
        },
        "2": {
            "5": {
                "1": "有晉徵士尋陽陶淵明",
                "2": "南岳之幽居者也",
                "3": "弱不好弄",
                "4": "長實素心",
                "5": "學非稱師",
                "6": "文取指達",
                "7": "在眾不失其寡",
                "8": "處言愈見其默",
                "9": "少而貧病",
                "10": "居無僕妾",
                "11": "井臼弗任",
                "12": "藜菽不給",
                "13": "母老子幼",
                "14": "就養勤匱",
                "15": "遠惟田生致親之議",
                "16": "追悟毛子捧檄之懷",
                "17": "初辭州府三命",
                "18": "後爲彭澤令",
                "19": "道不偶物",
                "20": "棄官從好",
                "21": "遂乃解體世紛",
                "22": "結志區外",
                "23": "定迹深栖",
                "24": "於是乎遠",
                "25": "灌畦鬻蔬",
                "26": "爲供魚菽之祭",
                "27": "織絇緯蕭",
                "28": "以充糧粒之費",
                "29": "心好異書",
                "30": "性樂酒德",
                "31": "簡棄煩促",
                "32": "就成省曠",
                "33": "殆所謂國爵屛貴",
                "34": "家人忘貧者與",
                "35": "有詔徵爲著作郎",
                "36": "稱疾不到",
                "37": "春秋若干",
                "38": "元嘉四年月日",
                "39": "卒於尋陽縣之某里",
                "40": "近識悲悼",
                "41": "遠士傷情",
                "42": "冥默福應",
                "43": "嗚呼淑貞"
            }
        },
        "3": {
            "7": {
                "1": "夫實以誄華",
                "2": "名由謚高",
                "3": "苟允德義",
                "4": "貴賤何筭焉",
                "5": "若其寬樂令終之美",
                "6": "好廉克己之操",
                "7": "有合謚典",
                "8": "無愆前志",
                "9": "故詢諸友好",
                "10": "宜謚曰靖節徵士",
                "11": "其辭曰"
            }
        },
        "4": {
            "9": {
                "1": "物尙孤生",
                "2": "人固介立",
                "3": "豈伊時遘",
                "4": "曷云世及",
                "5": "嗟乎若士",
                "6": "望古遙集",
                "7": "韜此洪族",
                "8": "蔑彼名級",
                "9": "睦親之行",
                "10": "至自非敦",
                "11": "然諾之信",
                "12": "重於布言",
                "13": "廉深簡絜",
                "14": "貞夷粹溫",
                "15": "和而能峻",
                "16": "博而不繁",
                "17": "依世尙同",
                "18": "詭時則異",
                "19": "有一於此",
                "20": "兩非默置",
                "21": "豈若夫子",
                "22": "因心違事",
                "23": "畏榮好古",
                "24": "薄身厚志",
                "25": "世霸虛禮",
                "26": "州壤推風",
                "27": "孝惟義養",
                "28": "道必懷邦",
                "29": "人之秉彝",
                "30": "不隘不恭",
                "31": "爵同下士",
                "32": "祿等上農",
                "33": "度量難鈞",
                "34": "進退可限",
                "35": "長卿棄官",
                "36": "稚賓自免",
                "37": "子之悟之",
                "38": "何悟之辯",
                "39": "賦詩歸來",
                "40": "高蹈獨善",
                "41": "亦旣超曠",
                "42": "無適非心",
                "43": "汲流舊巘",
                "44": "葺宇家林",
                "45": "晨煙暮藹",
                "46": "春煦秋陰",
                "47": "陳書輟卷",
                "48": "置酒絃琴",
                "49": "居備勤儉",
                "50": "躬兼貧病",
                "51": "人否其憂",
                "52": "子然其命",
                "53": "隱約就閑",
                "54": "遷延辭聘",
                "55": "非直也明",
                "56": "是惟道性",
                "57": "糾纆斡流",
                "58": "冥漠報施",
                "59": "孰云與仁",
                "60": "實疑明智",
                "61": "謂天蓋高",
                "62": "胡諐斯義",
                "63": "履信曷憑",
                "64": "思順何寘",
                "65": "年在中身",
                "66": "疢維痁疾",
                "67": "視死如歸",
                "68": "臨凶若吉",
                "69": "藥劑弗嘗",
                "70": "禱祀非卹",
                "71": "傃幽告終",
                "72": "懷和長畢",
                "73": "嗚呼哀哉"
            }
        },
        "5": {
            "11": {
                "1": "敬述靖節",
                "2": "式尊遺占",
                "3": "存不願豐",
                "4": "沒無求贍",
                "5": "省訃卻賻",
                "6": "輕哀薄斂",
                "7": "遭壤以穿",
                "8": "旋葬而窆",
                "9": "嗚呼哀哉"
            }
        },
        "6": {
            "13": {
                "1": "深心追往",
                "2": "遠情逐化",
                "3": "自爾介居",
                "4": "及我多暇",
                "5": "伊好之洽",
                "6": "接閻鄰舍",
                "7": "宵盤晝憩",
                "8": "非舟非駕",
                "9": "念昔宴私",
                "10": "舉觴相誨",
                "11": "獨正者危",
                "12": "至方則礙",
                "13": "哲人卷舒",
                "14": "布在前載",
                "15": "取鑒不遠",
                "16": "吾規子佩",
                "17": "爾實愀然",
                "18": "中言而發",
                "19": "違眾速尤",
                "20": "迕風先蹶",
                "21": "身才非實",
                "22": "榮聲有歇",
                "23": "叡音永矣",
                "24": "誰箴余闕",
                "25": "嗚呼哀哉",
                "26": "仁焉而終",
                "27": "智焉而斃",
                "28": "黔婁旣沒",
                "29": "展禽亦逝",
                "30": "其在先生",
                "31": "同塵往世",
                "32": "旌此靖節",
                "33": "加彼康惠",
                "34": "嗚呼哀哉"
            }
        }
    }
}