{
    "28.06-03": {
        "篇名": "陸士衡 輓歌詩三首·其三",
        "1": {
            "3": {
                "1": "流離親友思",
                "2": "惆悵神不泰",
                "3": "素驂佇轜軒",
                "4": "玄駟騖飛蓋",
                "5": "哀鳴興殯宮",
                "6": "迴遲悲野外",
                "7": "魂輿寂無響",
                "8": "但見冠與帶",
                "9": "備物象平生",
                "10": "長旌誰爲旆",
                "11": "悲風徽行軌",
                "12": "傾雲結流藹",
                "13": "振策指靈丘",
                "14": "駕言從此逝"
            }
        }
    }
