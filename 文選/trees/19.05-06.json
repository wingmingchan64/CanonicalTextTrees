{
    "19.05-06": {
        "篇名": "束廣微 補亡詩六首由儀。萬物之生。各得其儀也。",
        "1": {
            "3": {
                "1": "肅肅君子",
                "2": "由儀率性",
                "3": "明明后辟",
                "4": "仁以爲政",
                "5": "魚遊清沼",
                "6": "鳥萃平林",
                "7": "濯鱗鼓翼",
                "8": "振振其音",
                "9": "賓寫爾誠",
                "10": "主竭其心",
                "11": "時之和矣",
                "12": "何思何修",
                "13": "文化內輯",
                "14": "武功外悠"
            }
        }
    }
