{
    "45.06": {
        "篇名": "陶淵明 歸去來[幷序]",
        "1": {
            "3": {
                "1": "序曰",
                "2": "余家貧",
                "3": "又心憚遠役",
                "4": "彭澤縣去家百里",
                "5": "故便求之",
                "6": "及少日",
                "7": "眷然有歸與之情",
                "8": "自免去職",
                "9": "因事順心",
                "10": "命篇曰歸去來"
            }
        },
        "2": {
            "5": {
                "1": "歸去來兮",
                "2": "田園將蕪胡不歸",
                "3": "旣自以心爲形役",
                "4": "奚惆悵而獨悲",
                "5": "悟已往之不諫",
                "6": "知來者之可追",
                "7": "寔迷途其未遠",
                "8": "覺今是而昨非",
                "9": "舟遙遙以輕颺",
                "10": "風飄飄而吹衣",
                "11": "問征夫以前路",
                "12": "恨晨光之熹微",
                "13": "乃瞻衡宇",
                "14": "載欣載奔",
                "15": "僮僕歡迎",
                "16": "稚子候門",
                "17": "三徑就荒",
                "18": "松菊猶存",
                "19": "攜幼入室",
                "20": "有酒盈尊",
                "21": "引壺觴以自酌",
                "22": "眄庭柯以怡顏",
                "23": "倚南窗以寄傲",
                "24": "審容膝之易安",
                "25": "園日涉以成趣",
                "26": "門雖設而常關",
                "27": "策扶老以流憩",
                "28": "時矯首而遐觀",
                "29": "雲無心以出岫",
                "30": "鳥倦飛而知還",
                "31": "景翳翳以將入",
                "32": "撫孤松而盤桓"
            }
        },
        "3": {
            "7": {
                "1": "歸去來兮",
                "2": "請息交以絕遊",
                "3": "世與我而相遺",
                "4": "復駕言兮焉求",
                "5": "悅親戚之情話",
                "6": "樂琴書以消憂",
                "7": "農人告余以春兮",
                "8": "將有事乎西疇",
                "9": "或命巾車",
                "10": "或棹孤舟",
                "11": "旣窈窕以尋壑",
                "12": "亦崎嶇而經丘",
                "13": "木欣欣以向榮",
                "14": "泉涓涓而始流",
                "15": "善萬物之得時",
                "16": "感吾生之行休",
                "17": "已矣乎",
                "18": "寓形宇內復幾時",
                "19": "曷不委心任去留",
                "20": "胡爲遑遑欲何之",
                "21": "富貴非吾願",
                "22": "帝鄕不可期",
                "23": "懷良辰以孤往",
                "24": "或植杖而耘耔",
                "25": "登東皋以舒嘯",
                "26": "臨清流而賦詩",
                "27": "聊乘化以歸盡",
                "28": "樂夫天命復奚疑"
            }
        }
    }
}