{
    "41.03": {
        "篇名": "楊子幼 報孫會宗書",
        "1": {
            "3": {
                "1": "惲材朽行穢",
                "2": "文質無所底",
                "3": "幸賴先人餘業",
                "4": "得備宿衞",
                "5": "遭遇時變",
                "6": "以獲爵位",
                "7": "終非其任",
                "8": "卒與禍會",
                "9": "足下哀其愚矇",
                "10": "賜書教督以所不及",
                "11": "慇懃甚厚",
                "12": "然竊恨足下不深惟其終始",
                "13": "而猥隨俗之毀譽也",
                "14": "言鄙陋之愚心",
                "15": "則若逆指而文過",
                "16": "默而自守",
                "17": "恐違孔氏各言爾志之義",
                "18": "故敢略陳其愚",
                "19": "惟君子察焉"
            }
        },
        "2": {
            "5": {
                "1": "惲家方隆盛時",
                "2": "乘朱輪者十人",
                "3": "位在列卿",
                "4": "爵爲通侯",
                "5": "總領從官",
                "6": "與聞政事",
                "7": "曾不能以此時有所建明",
                "8": "以宣德化",
                "9": "又不能與羣僚幷力",
                "10": "陪輔朝廷之遺忘",
                "11": "已負竊位素餐之責久矣",
                "12": "懷祿貪勢",
                "13": "不能自退",
                "14": "遂遭變故",
                "15": "橫被口語",
                "16": "身幽北闕",
                "17": "妻子滿獄",
                "18": "當此之時",
                "19": "自以夷滅不足以塞責",
                "20": "豈得全其首領",
                "21": "復奉先人之丘墓乎",
                "22": "伏惟聖主之恩",
                "23": "不可勝量",
                "24": "君子遊道",
                "25": "樂以忘憂",
                "26": "小人全軀",
                "27": "說以忘罪",
                "28": "竊自念過已大矣",
                "29": "行已虧矣",
                "30": "長爲農夫以沒世矣",
                "31": "是故身率妻子",
                "32": "勠力耕桑",
                "33": "灌園治產",
                "34": "以給公上",
                "35": "不意當復用此爲譏議也"
            }
        },
        "3": {
            "7": {
                "1": "夫人情所不能止者",
                "2": "聖人弗禁",
                "3": "故君父至尊親",
                "4": "送其終也",
                "5": "有時而旣",
                "6": "臣之得罪",
                "7": "已三年矣",
                "8": "田家作苦",
                "9": "歲時伏臘",
                "10": "烹羊炮羔",
                "11": "斗酒自勞",
                "12": "家本秦也",
                "13": "能爲秦聲",
                "14": "婦趙女也",
                "15": "雅善鼓琴",
                "16": "奴婢歌者數人",
                "17": "酒後耳熱",
                "18": "仰天撫缶而呼嗚嗚",
                "19": "其詩曰",
                "20": "田彼南山",
                "21": "蕪穢不治",
                "22": "種一頃豆",
                "23": "落而爲萁",
                "24": "人生行樂耳",
                "25": "須富貴何時",
                "26": "是日也",
                "27": "拂衣而喜",
                "28": "奮袖低昂",
                "29": "頓足起舞",
                "30": "誠淫荒無度",
                "31": "不知其不可也",
                "32": "惲幸有餘祿",
                "33": "方糴賤販貴",
                "34": "逐什一之利",
                "35": "此賈豎之事",
                "36": "汙辱之處",
                "37": "惲親行之",
                "38": "下流之人",
                "39": "眾毀所歸",
                "40": "不寒而慄",
                "41": "雖雅知惲者",
                "42": "猶隨風而靡",
                "43": "尙何稱譽之有",
                "44": "董生不云乎",
                "45": "明明求仁義",
                "46": "常恐不能化民者",
                "47": "卿大夫之意也",
                "48": "明明求財利",
                "49": "常恐困乏者",
                "50": "庶人之事也",
                "51": "故道不同不相爲謀",
                "52": "今子尙安得以卿大夫之制而責僕哉"
            }
        },
        "4": {
            "9": {
                "1": "夫西河魏土",
                "2": "文侯所興",
                "3": "有段干木田子方之遺風",
                "4": "稟然皆有節槪",
                "5": "知去就之分",
                "6": "頃者足下離舊土",
                "7": "臨安定",
                "8": "安定山谷之間",
                "9": "昆夷舊壤",
                "10": "子弟貪鄙",
                "11": "豈習俗之移人哉",
                "12": "於今乃睹子之志矣",
                "13": "方當盛漢之隆",
                "14": "願勉旃",
                "15": "無多談"
            }
        }
    }
}