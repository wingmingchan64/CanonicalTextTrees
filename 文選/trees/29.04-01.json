{
    "29.04-01": {
        "篇名": "張平子 四愁詩四首[幷序]",
        "1": {
            "3": {
                "1": "張衡不樂久處機密",
                "2": "陽嘉中",
                "3": "出爲河間相",
                "4": "時國王驕奢",
                "5": "不遵法度",
                "6": "又多豪右幷兼之家",
                "7": "衡下車",
                "8": "治威嚴",
                "9": "能內察屬縣",
                "10": "姦滑行巧劫",
                "11": "皆密知名",
                "12": "下吏收捕",
                "13": "盡服摛",
                "14": "諸豪俠遊客",
                "15": "悉惶懼逃出境",
                "16": "郡中大治",
                "17": "爭訟息",
                "18": "獄無繫囚",
                "19": "時天下漸獘",
                "20": "鬱鬱不得志",
                "21": "爲四愁詩",
                "22": "屈原以美人爲君子",
                "23": "以珍寶爲仁義",
                "24": "以水深雪雰爲小人",
                "25": "思以道術相報",
                "26": "貽於時君",
                "27": "而懼讒邪不得以通",
                "28": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "一思曰",
                "2": "我所思兮在太山",
                "3": "欲往從之梁父艱",
                "4": "側身東望涕霑翰",
                "5": "美人贈我金錯刀",
                "6": "何以報之英瓊瑤",
                "7": "路遠莫致倚逍遙",
                "8": "何爲懷憂心煩勞"
            }
        }
    }
}