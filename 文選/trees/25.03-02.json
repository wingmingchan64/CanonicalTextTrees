{
    "25.03-02": {
        "篇名": "陸士龍 爲顧彥先贈婦二首·其二",
        "1": {
            "3": {
                "1": "浮海難爲水",
                "2": "遊林難爲觀",
                "3": "容色貴及時",
                "4": "朝華忌日晏",
                "5": "皎皎彼姝子",
                "6": "灼灼懷春粲",
                "7": "西城善雅儛",
                "8": "總章饒清彈",
                "9": "鳴簧發丹脣",
                "10": "朱絃繞素腕",
                "11": "輕裾猶電揮",
                "12": "雙袂如霧散",
                "13": "華容溢藻幄",
                "14": "哀響入雲漢",
                "15": "知音世所希",
                "16": "非君誰能讚",
                "17": "棄置北辰星",
                "18": "問此玄龍煥",
