{
    "48.02": {
        "篇名": "楊子雲 劇秦美新",
        "1": {
            "3": {
                "1": "諸吏中散大夫臣雄",
                "2": "稽首再拜上封事皇帝陛下",
                "3": "臣雄經術淺薄",
                "4": "行能無異",
                "5": "數蒙渥恩",
                "6": "拔擢倫比",
                "7": "與羣賢並",
                "8": "愧無以稱職",
                "9": "臣伏惟陛下以至聖之德",
                "10": "龍興登庸",
                "11": "欽明尙古",
                "12": "作民父母",
                "13": "爲天下主",
                "14": "執粹清之道",
                "15": "鏡照四海",
                "16": "聽聆風俗",
                "17": "博覽廣包",
                "18": "參天貳地",
                "19": "兼並神明",
                "20": "配五帝",
                "21": "冠三王",
                "22": "開闢以來",
                "23": "未之聞也",
                "24": "臣誠樂昭著新德",
                "25": "光之罔極",
                "26": "往時司馬相如作封禪一篇",
                "27": "以彰漢氏之休",
                "28": "臣常有顚眴病",
                "29": "恐一旦先犬馬",
                "30": "塡溝壑",
                "31": "所懷不章",
                "32": "長恨黃泉",
                "33": "敢竭肝膽",
                "34": "寫腹心",
                "35": "作劇秦美新一篇",
                "36": "雖未究萬分之一",
                "37": "亦臣之極思也",
                "38": "臣雄稽首再拜以聞",
                "39": "曰"
            }
        },
        "2": {
            "5": {
                "1": "權輿天地未袪",
                "2": "睢睢盱盱",
                "3": "或玄而萌",
                "4": "或黃而牙",
                "5": "玄黃剖判",
                "6": "上下相嘔",
                "7": "爰初生民",
                "8": "帝王始存",
                "9": "在乎混混茫茫之時",
                "10": "舋聞罕漫而不昭察",
                "11": "世莫得而云也",
                "12": "厥有云者",
                "13": "上罔顯於羲皇",
                "14": "中莫盛於唐虞",
                "15": "邇靡著於成周",
                "16": "仲尼不遭用",
                "17": "春秋困斯發",
                "18": "言神明所祚",
                "19": "兆民所託",
                "20": "罔不云道德仁義禮智",
                "21": "獨秦屈起西戎",
                "22": "邠荒岐雍之疆",
                "23": "因襄文宣靈之僭迹",
                "24": "立基孝公",
                "25": "茂惠文",
                "26": "奮昭莊",
                "27": "至政破縱擅衡",
                "28": "幷吞六國",
                "29": "遂稱乎始皇",
                "30": "盛從鞅儀韋斯之邪政",
                "31": "馳騖起剪恬賁之用兵",
                "32": "滅滅古文",
                "33": "刮語燒書",
                "34": "弛禮崩樂",
                "35": "塗民耳目",
                "36": "遂欲流唐漂虞",
                "37": "滌殷蕩周",
                "38": "㸐除仲尼之篇籍",
                "39": "自勒功業",
                "40": "㸐",
                "41": "古然字",
                "42": "改制度軌量",
                "43": "咸稽之於秦紀",
                "44": "是以耆儒碩老",
                "45": "抱其書而遠遜",
                "46": "禮官博士",
                "47": "卷其舌而不談",
                "48": "來儀之鳥",
                "49": "肉角之獸",
                "50": "狙獷而不臻",
                "51": "甘露嘉醴",
                "52": "景曜浸潭之瑞潛",
                "53": "大茀經霣",
                "54": "巨狄鬼信之妖發",
                "55": "神歇靈繹",
                "56": "海水羣飛",
                "57": "二世而亡",
                "58": "何其劇與",
                "59": "帝王之道",
                "60": "兢兢乎不可離已",
                "61": "夫能貞而明之者窮祥瑞",
                "62": "回而昧之者極妖愆",
                "63": "上覽古在昔",
                "64": "有憑應而尙缺",
                "65": "焉壞徹而能全",
                "66": "故若古者稱堯舜",
                "67": "威侮者陷桀紂",
                "68": "況盡汛掃前聖數千載功業",
                "69": "專用己之私而能享祐者哉"
            }
        },
        "3": {
            "7": {
                "1": "會漢祖龍騰豐沛",
                "2": "奮迅宛葉",
                "3": "自武關與項羽戮力咸陽",
                "4": "創業蜀漢",
                "5": "發迹三秦",
                "6": "克項山東",
                "7": "而帝天下",
                "8": "擿秦政慘酷尤煩者",
                "9": "應時而蠲",
                "10": "如儒林",
                "11": "刑辟",
                "12": "歷紀",
                "13": "圖典之用稍增焉",
                "14": "秦餘制度",
                "15": "項氏爵號",
                "16": "雖違古而猶襲之",
                "17": "是以帝典闕而不補",
                "18": "王綱弛而未張",
                "19": "道極數殫",
                "20": "闇忽不還"
            }
        },
        "4": {
            "9": {
                "1": "逮至大新受命",
                "2": "上帝還資",
                "3": "后土顧懷",
                "4": "玄符靈契",
                "5": "黃瑞涌出",
                "6": "滭浡沕潏",
                "7": "川流海渟",
                "8": "雲動風偃",
                "9": "霧集雨散",
                "10": "誕彌八圻",
                "11": "上陳天庭",
                "12": "震聲日景",
                "13": "炎光飛響",
                "14": "盈塞天淵之間",
                "15": "必有不可辭讓云爾",
                "16": "於是乃奉若天命",
                "17": "窮寵極崇",
                "18": "與天剖神符",
                "19": "地合靈契",
                "20": "創億兆",
                "21": "規萬世",
                "22": "奇偉倜儻譎詭",
                "23": "天祭地事",
                "24": "其異物殊怪",
                "25": "存乎五威將帥",
                "26": "班乎天下者",
                "27": "四十有八章",
                "28": "登假皇穹",
                "29": "鋪衍下土",
                "30": "非新家其疇離之",
                "31": "卓哉煌煌",
                "32": "眞天子之表也",
                "33": "若夫白鳩丹烏",
                "34": "素魚斷蛇",
                "35": "方斯薎矣",
                "36": "受命甚易",
                "37": "格來甚勤",
                "38": "昔帝纘皇",
                "39": "王纘帝",
                "40": "隨前踵古",
                "41": "或無爲而治",
                "42": "或損益而亡",
                "43": "豈知新室委心積意",
                "44": "儲思垂務",
                "45": "旁作穆穆",
                "46": "明旦不寐",
                "47": "勤勤懇懇者",
                "48": "非秦之爲與﹖夫不勤勤",
                "49": "則前人不當",
                "50": "不懇懇",
                "51": "則覺德不愷",
                "52": "是以發祕府",
                "53": "覽書林",
                "54": "遙集乎文雅之囿",
                "55": "翱翔乎禮樂之場",
                "56": "胤殷周之失業",
                "57": "紹唐虞之絕風",
                "58": "懿律嘉量",
                "59": "金科玉條",
                "60": "神卦靈兆",
                "61": "古文畢發",
                "62": "炳煥照曜",
                "63": "靡不宣臻",
                "64": "式軨軒旂旗以示之",
                "65": "揚和鸞肆夏以節之",
                "66": "施黼黻衮冕以昭之",
                "67": "正嫁娶送終以尊之",
                "68": "親九族淑賢以穆之"
            }
        },
        "5": {
            "11": {
                "1": "夫改定神祇",
                "2": "上儀也",
                "3": "欽修百祀",
                "4": "咸秩也",
                "5": "明堂雍臺",
                "6": "壯觀也",
                "7": "九廟長壽",
                "8": "極孝也",
                "9": "制成六經",
                "10": "洪業也",
                "11": "北懷單於",
                "12": "廣德也",
                "13": "若復五爵",
                "14": "度三壤",
                "15": "經井田",
                "16": "免人役",
                "17": "方甫刑",
                "18": "匡馬法",
                "19": "恢崇祇庸爍德懿和之風",
                "20": "廣彼搢紳講習言諫箴誦之塗",
                "21": "振鷺之聲充庭",
                "22": "鴻鸞之黨漸階",
                "23": "俾前聖之緒",
                "24": "布濩流衍而不韞韣",
                "25": "郁郁乎煥哉",
                "26": "天人之事盛矣",
                "27": "鬼神之望允塞",
                "28": "羣公先正",
                "29": "罔不夷儀",
                "30": "姦宄寇賊",
                "31": "罔不振威",
                "32": "紹少典之苗",
                "33": "著黃虞之裔",
                "34": "帝典闕者已補",
                "35": "王綱弛者已張",
                "36": "炳炳麟麟",
                "37": "豈不懿哉",
                "38": "厥被風濡化者",
                "39": "京師沈潛",
                "40": "甸內匝洽",
                "41": "侯衞厲揭",
                "42": "要荒濯沐",
                "43": "而術前典",
                "44": "巡四民",
                "45": "迄四嶽",
                "46": "增封泰山",
                "47": "禪梁父",
                "48": "斯受命者之典業也"
            }
        },
        "6": {
            "13": {
                "1": "蓋受命日不暇給",
                "2": "或不受命",
                "3": "然猶有事矣",
                "4": "況堂堂有新",
                "5": "正丁厥時",
                "6": "崇嶽渟海通瀆之神",
                "7": "咸設壇場",
                "8": "望受命之臻焉",
                "9": "海外遐方",
                "10": "信延頸企踵",
                "11": "回面內嚮",
                "12": "喁喁如也",
                "13": "帝者雖勤",
                "14": "惡可以已乎﹖宜命賢哲作帝典一篇",
                "15": "舊三爲一襲",
                "16": "以示來人",
                "17": "摛之罔極",
                "18": "令萬世常戴巍巍",
                "19": "履栗栗",
                "20": "臭馨香",
                "21": "令甘實",
                "22": "鏡純粹之至精",
                "23": "聆清和之正聲",
                "24": "則百工伊凝",
                "25": "庶績咸喜",
                "26": "荷天衢",
                "27": "提地釐",
                "28": "斯天下之上則已",
                "29": "庶可試哉"
            }
        }
    }
}