{
    "58.02": {
        "篇名": "謝玄暉 齊敬皇后哀策文",
        "1": {
            "3": {
                "1": "惟永泰元年",
                "2": "秋九月朔日",
                "3": "敬皇后梓宮啟自先塋",
                "4": "將祔於某陵",
                "5": "其日",
                "6": "至尊親奉奠某皇帝",
                "7": "乃使兼太尉某設祖於行宮",
                "8": "禮也",
                "9": "翠帟舒阜",
                "10": "玄堂啟扉",
                "11": "俎徹三獻",
                "12": "筵卷六衣",
                "13": "哀子嗣皇帝",
                "14": "懷蜃衞而延首",
                "15": "想鷖輅而撫心",
                "16": "痛椒塗之先廓",
                "17": "哀長信之莫臨",
                "18": "身隔兩赴",
                "19": "時無二展",
                "20": "旋詔左言",
                "21": "光敷聖善",
                "22": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "帝唐遠冑",
                "2": "御龍遙緒",
                "3": "在秦作劉",
                "4": "在漢開楚",
                "5": "肇惟淑聖",
                "6": "克柔克令",
                "7": "清漢表靈",
                "8": "曾沙膺慶",
                "9": "爰定厥祥",
                "10": "徽音允穆",
                "11": "光華沼沚",
                "12": "榮曜中谷",
                "13": "敬始紘綖",
                "14": "教先穜稑",
                "15": "睿問川流",
                "16": "神襟蘭郁"
            }
        },
        "3": {
            "7": {
                "1": "先德韜光",
                "2": "君道方被",
                "3": "於佐求賢",
                "4": "在謁無詖",
                "5": "顧史弘式",
                "6": "陳詩展義",
                "7": "厚下曰仁",
                "8": "藏往伊智",
                "9": "十亂斯俟",
                "10": "四教罔忒",
                "11": "思媚諸姑",
                "12": "貽我嬪則",
                "13": "化自公宮",
                "14": "遠被南國",
                "15": "軒曜懷光",
                "16": "素舒佇德"
            }
        },
        "4": {
            "9": {
                "1": "閔予不祐",
                "2": "慈訓早違",
                "3": "方年沖藐",
                "4": "懷袖靡依",
                "5": "家臻寶業",
                "6": "身嗣昌暉",
                "7": "壽宮寂遠",
                "8": "清廟虛歸",
                "9": "嗚呼哀哉"
            }
        },
        "5": {
            "11": {
                "1": "帝遷明命",
                "2": "民神胥悅",
                "3": "乾景外臨",
                "4": "陰儀內缺",
                "5": "空悲故劍",
                "6": "徒嗟金穴",
                "7": "璋瓚奚獻",
                "8": "褘褕罔設",
                "9": "嗚呼哀哉"
            }
        },
        "6": {
            "13": {
                "1": "馮相告祲",
                "2": "宸居長往",
                "3": "貽厥遠圖",
                "4": "末命是獎",
                "5": "懷豐沛之綢繆兮",
                "6": "背神京之弘敞",
                "7": "陋蒼梧之不從兮",
                "8": "遵鮒隅以同壤",
                "9": "嗚呼哀哉"
            }
        },
        "7": {
            "15": {
                "1": "陳象設於園寢兮",
                "2": "映輿鍐於松楸",
                "3": "望承明而不入兮",
                "4": "度清洛而南遊",
                "5": "繼池綍於通軌兮",
                "6": "接龍帷於造舟",
                "7": "迴塘寂其已暮兮",
                "8": "東川澹而不流",
                "9": "嗚呼哀哉"
            }
        },
        "8": {
            "17": {
                "1": "籍閟宮之遠烈兮",
                "2": "聞纘女之遐慶",
                "3": "始協德於蘋蘩兮",
                "4": "終配祇而表命",
                "5": "慕方纏於賜衣兮",
                "6": "哀日隆於撫鏡",
                "7": "思寒泉之罔極兮",
                "8": "託彤管於遺詠",
                "9": "嗚呼哀哉"
            }
        }
    }
}