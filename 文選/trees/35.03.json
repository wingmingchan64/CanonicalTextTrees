{
    "35.03": {
        "篇名": "漢武帝 賢良詔",
        "1": {
            "3": {
                "1": "朕聞昔在唐虞",
                "2": "畫象而民不犯",
                "3": "日月所燭",
                "4": "罔不率俾",
                "5": "周之成康",
                "6": "刑措不用",
                "7": "德及鳥獸",
                "8": "教通四海",
                "9": "海外肅愼",
                "10": "北發渠搜",
                "11": "氐羌來服",
                "12": "星辰不孛",
                "13": "日月不蝕",
                "14": "山陵不崩",
                "15": "川谷不塞",
                "16": "麟鳳在郊藪",
                "17": "河洛出圖書",
                "18": "嗚呼",
                "19": "何施而臻此乎"
            }
        },
        "2": {
            "5": {
                "1": "今朕獲奉宗廟",
                "2": "夙興以求",
                "3": "夜寐以思",
                "4": "若涉淵水",
                "5": "未知所濟",
                "6": "猗歟偉歟",
                "7": "何行而可以彰先帝之洪業休德",
                "8": "上參堯舜",
                "9": "下配三王",
                "10": "朕之不敏",
                "11": "不能遠德",
                "12": "此子大夫之所睹聞也",
                "13": "賢良明於古今王事之體",
                "14": "受策察問",
                "15": "咸以書對",
                "16": "著之於篇",
                "17": "朕親覽焉"
            }
        }
    }
}