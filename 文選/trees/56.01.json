{
    "56.01": {
        "篇名": "張茂先 女史箴",
        "1": {
            "3": {
                "1": "茫茫造化",
                "2": "二儀旣分",
                "3": "散氣流形",
                "4": "旣陶旣甄",
                "5": "在帝庖羲",
                "6": "肇經天人",
                "7": "爰始夫婦",
                "8": "以及君臣",
                "9": "家道以正",
                "10": "王猷有倫",
                "11": "婦德尙柔",
                "12": "含章貞吉",
                "13": "婉嫕淑愼",
                "14": "正位居室",
                "15": "施衿結褵",
                "16": "虔恭中饋",
                "17": "肅愼爾儀",
                "18": "式瞻清懿",
                "19": "樊姬感莊",
                "20": "不食鮮禽",
                "21": "衞女矯桓",
                "22": "耳忘和音",
                "23": "志厲義高",
                "24": "而二主易心",
                "25": "玄熊攀檻",
                "26": "馮媛趍進",
                "27": "夫豈無畏",
                "28": "知死不恡",
                "29": "班妾有辭",
                "30": "割歡同輦",
                "31": "夫豈不懷",
                "32": "防微慮遠"
            }
        },
        "2": {
            "5": {
                "1": "道罔隆而不殺",
                "2": "物無盛而不衰",
                "3": "日中則昃",
                "4": "月滿則微",
                "5": "崇猶塵積",
                "6": "替若駭機",
                "7": "人咸知飾其容",
                "8": "而莫知飾其性",
                "9": "性之不飾",
                "10": "或愆禮正",
                "11": "斧之藻之",
                "12": "克念作聖",
                "13": "出其言善",
                "14": "千里應之",
                "15": "苟違斯義",
                "16": "則同衾以疑",
                "17": "夫出言如微",
                "18": "而榮辱由茲",
                "19": "勿謂幽昧",
                "20": "靈監無象",
                "21": "勿謂玄漠",
                "22": "神聽無響",
                "23": "無矜爾榮",
                "24": "天道惡盈",
                "25": "無恃爾貴",
                "26": "隆隆者墜",
                "27": "鑒於小星",
                "28": "戒彼攸遂",
                "29": "比心螽斯",
                "30": "則繁爾類",
                "31": "歡不可以黷",
                "32": "寵不可以專",
                "33": "專實生慢",
                "34": "愛極則遷",
                "35": "致盈必損",
                "36": "理有固然",
                "37": "美者自美",
                "38": "翩以取尤",
                "39": "冶容求好",
                "40": "君子所讎",
                "41": "結恩而絕",
                "42": "職此之由"
            }
        },
        "3": {
            "7": {
                "1": "故曰",
                "2": "翼翼矜矜",
                "3": "福所以興",
                "4": "靖恭自思",
                "5": "榮顯所期",
                "6": "女史司箴",
                "7": "敢告庶姬"
            }
        }
    }
}