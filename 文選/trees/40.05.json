{
    "40.05": {
        "篇名": "繁休伯 與魏文帝牋",
        "1": {
            "3": {
                "1": "正月八日壬寅",
                "2": "領主簿繁欽",
                "3": "死罪死罪",
                "4": "近屢奉牋",
                "5": "不足自宣",
                "6": "頃諸鼓吹",
                "7": "廣求異妓",
                "8": "時都尉薛訪車子",
                "9": "年始十四",
                "10": "能喉囀引聲",
                "11": "與笳同音",
                "12": "白上呈見",
                "13": "果如其言",
                "14": "卽日故共觀試",
                "15": "乃知天壤之所生",
                "16": "誠有自然之妙物也",
                "17": "潛氣內轉",
                "18": "哀音外激",
                "19": "大不抗越",
                "20": "細不幽散",
                "21": "聲悲舊笳",
                "22": "曲美常均",
                "23": "及與黃門鼓吹溫胡",
                "24": "迭唱迭和",
                "25": "喉所發音",
                "26": "無不響應",
                "27": "曲折沈浮",
                "28": "尋變入節",
                "29": "自初呈試",
                "30": "中間二旬",
                "31": "胡欲傲其所不知",
                "32": "尙之以一曲",
                "33": "巧竭意匱",
                "34": "旣已不能",
                "35": "而此孺子遺聲抑揚",
                "36": "不可勝窮",
                "37": "優遊轉化",
                "38": "餘弄未盡",
                "39": "曁其清激悲吟",
                "40": "雜以怨慕",
                "41": "詠北狄之遐征",
                "42": "奏胡馬之長思",
                "43": "悽入肝脾",
                "44": "哀感頑豔",
                "45": "是時日在西隅",
                "46": "涼風拂衽",
                "47": "背山臨谿",
                "48": "流泉東逝",
                "49": "同坐仰歎",
                "50": "觀者俯聽",
                "51": "莫不泫泣殞涕",
                "52": "悲懷慷慨",
                "53": "自左𩥄史妠謇姐名倡",
                "54": "魏志",
                "55": "文帝令杜夔與左𩥄等於賓客之中吹笙鼓琴",
                "56": "然𩥄與㒹音同也",
                "57": "其史妠",
                "58": "謇姐",
                "59": "蓋亦當時之樂人",
                "60": "聲類曰",
                "61": "妠",
                "62": "奴紺切",
                "63": "說文曰",
                "64": "㜘字或作姐",
                "65": "古字假借也",
                "66": "姐",
                "67": "子也切",
                "68": "能識以來",
                "69": "耳目所見",
                "70": "僉曰詭異",
                "71": "未之聞也"
            }
        },
        "2": {
            "5": {
                "1": "竊惟聖體",
                "2": "兼愛好奇",
                "3": "是以因牋",
                "4": "先白委曲",
                "5": "伏想御聞",
                "6": "必含餘歡",
                "7": "冀事速訖",
                "8": "旋侍光塵",
                "9": "寓目階庭",
                "10": "與聽斯調",
                "11": "宴喜之樂",
                "12": "蓋亦無量",
                "13": "欽死罪死罪"
            }
        }
    }
}