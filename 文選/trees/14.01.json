{
    "14.01": {
        "篇名": "顏延年 赭白馬賦[幷序]",
        "1": {
            "3": {
                "1": "驥不稱力",
                "2": "馬以龍名",
                "3": "豈不以國尙威容",
                "4": "軍𩢰趫迅而已",
                "5": "實有騰光吐圖",
                "6": "疇德瑞聖之符焉",
                "7": "是以語崇其靈",
                "8": "世榮其至",
                "9": "我高祖之造宋也",
                "10": "五方率職",
                "11": "四隩入貢",
                "12": "祕寶盈於玉府",
                "13": "文駟列乎華廏",
                "14": "乃有乘輿赭白",
                "15": "特稟逸異之姿",
                "16": "妙簡帝心",
                "17": "用錫聖皁",
                "18": "服御順志",
                "19": "馳驟合度",
                "20": "齒歷雖衰",
                "21": "而藝美不忒",
                "22": "襲養兼年",
                "23": "恩隱周渥",
                "24": "歲老氣殫",
                "25": "斃於內棧",
                "26": "少盡其力",
                "27": "有惻上仁",
                "28": "乃詔陪侍",
                "29": "奉述中旨",
                "30": "末臣庸蔽",
                "31": "敢同獻賦",
                "32": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "惟宋二十有二載",
                "2": "盛烈光乎重葉",
                "3": "武義粵其肅陳",
                "4": "文教迄已優洽",
                "5": "泰階之平可升",
                "6": "興王之軌可接",
                "7": "訪國美於舊史",
                "8": "考方載於往牒",
                "9": "昔帝軒陟位",
                "10": "飛黃服皁",
                "11": "后唐膺籙",
                "12": "赤文候日",
                "13": "漢道亨而天驥呈才",
                "14": "魏德楙而澤馬效質",
                "15": "伊逸倫之妙足",
                "16": "自前代而間出",
                "17": "幷榮光於瑞典",
                "18": "登郊歌乎司律",
                "19": "所以崇衞威神",
                "20": "扶護警蹕",
                "21": "精曜協從",
                "22": "靈物咸秩",
                "23": "曁明命之初基",
                "24": "罄九區而率順",
                "25": "有肆險以稟朔",
                "26": "或踰遠而納賮",
                "27": "聞王會之阜昌",
                "28": "知函夏之充牣",
                "29": "總六服以收賢",
                "30": "掩七戎而得駿",
                "31": "蓋乘風之淑類",
                "32": "實先景之洪胤",
                "33": "故能代驂象輿",
                "34": "歷配鉤陳",
                "35": "齒筭延長",
                "36": "聲價隆振",
                "37": "信聖祖之蕃錫",
                "38": "留皇情而驟進"
            }
        },
        "3": {
            "7": {
                "1": "徒觀其附筋樹骨",
                "2": "垂梢植髮",
                "3": "雙瞳夾鏡",
                "4": "兩權協月",
                "5": "異體峯生",
                "6": "殊相逸發",
                "7": "超攄絕夫塵轍",
                "8": "驅騖迅於滅沒",
                "9": "簡偉塞門",
                "10": "獻狀絳闕",
                "11": "旦刷幽燕",
                "12": "晝秣荊越",
                "13": "教敬不易之典",
                "14": "訓人必書之舉",
                "15": "惟帝惟祖",
                "16": "爰遊爰豫",
                "17": "飛輶軒以戒道",
                "18": "環彀騎而清路",
                "19": "勒五營使按部",
                "20": "聲八鸞以節步",
                "21": "具服金組",
                "22": "兼飾丹雘寶鉸星纏",
                "23": "鏤章霞布",
                "24": "進迫遮迾",
                "25": "卻屬輦輅",
                "26": "欻聳擢以鴻驚",
                "27": "時濩略而龍翥",
                "28": "弭雄姿以奉引",
                "29": "婉柔心而待御"
            }
        },
        "4": {
            "9": {
                "1": "至於露滋月肅",
                "2": "霜戾秋登",
                "3": "王於興言",
                "4": "闡肄威稜",
                "5": "臨廣望",
                "6": "坐百層",
                "7": "料武藝",
                "8": "品驍騰",
                "9": "流藻周施",
                "10": "和鈴重設",
                "11": "睨影高鳴",
                "12": "將超中折",
                "13": "分馳迥場",
                "14": "角壯永埒",
                "15": "別輩越羣",
                "16": "絢練敻絕",
                "17": "捷趫夫之敏手",
                "18": "促華鼓之繁節",
                "19": "經玄蹄而雹散",
                "20": "歷素支而冰裂",
                "21": "膺門沬赭",
                "22": "汗溝走血",
                "23": "踠迹回唐",
                "24": "畜怒未泄",
                "25": "乾心降而微怡",
                "26": "都人仰而朋悅",
                "27": "姸變之態旣畢",
                "28": "凌遽之氣方屬",
                "29": "跼鑣轡之牽制",
                "30": "隘通都之圈束",
                "31": "眷西極而驤首",
                "32": "望朔雲而蹀足",
                "33": "將使紫燕騈衡",
                "34": "綠蛇衞轂",
                "35": "纖驪接趾",
                "36": "秀騏齊亍",
                "37": "覲王母於崑墟",
                "38": "要帝臺於宣嶽",
                "39": "跨中州之轍迹",
                "40": "窮神行之軌躅"
            }
        },
        "5": {
            "11": {
                "1": "然而般於遊畋",
                "2": "作鏡前王",
                "3": "肆於人上",
                "4": "取悔義方",
                "5": "天子乃輟駕迴慮",
                "6": "息徒解裝",
                "7": "鑒武穆",
                "8": "憲文光",
                "9": "振民隱",
                "10": "修國章",
                "11": "戒出豕之敗御",
                "12": "惕飛鳥之跱衡",
                "13": "故祇愼乎所常忽",
                "14": "敬備乎所未防",
                "15": "輿有重輪之安",
                "16": "馬無泛駕之佚",
                "17": "處以濯龍之奧",
                "18": "委以紅粟之秩",
                "19": "服養知仁",
                "20": "從老得卒",
                "21": "加敝帷",
                "22": "收仆質",
                "23": "天情周",
                "24": "皇恩畢"
            }
        },
        "6": {
            "13": {
                "1": "亂曰",
                "2": "惟德動天",
                "3": "神物儀兮",
                "4": "於時駔駿",
                "5": "充階街兮",
                "6": "稟靈月駟",
                "7": "祖雲螭兮",
                "8": "雄志倜儻",
                "9": "精權奇兮",
                "10": "旣剛且淑",
                "11": "服鞿羈兮",
                "12": "效足中黃",
                "13": "殉驅馳兮",
                "14": "願終惠養",
                "15": "蔭本枝兮",
                "16": "竟先朝露",
                "17": "長委離兮"
            }
        }
    }
}