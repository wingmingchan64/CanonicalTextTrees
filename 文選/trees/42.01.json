{
    "42.01": {
        "篇名": "阮元瑜 爲曹公作書與孫權",
        "1": {
            "3": {
                "1": "離絕以來",
                "2": "於今三年",
                "3": "無一日而忘前好",
                "4": "亦猶姻媾之義",
                "5": "恩情已深",
                "6": "違異之恨",
                "7": "中間尙淺也",
                "8": "孤懷此心",
                "9": "君豈同哉",
                "10": "每覽古今所由改趣",
                "11": "因緣侵辱",
                "12": "或起瑕舋",
                "13": "心忿意危",
                "14": "用成大變",
                "15": "若韓信傷心於失楚",
                "16": "彭寵積望於無異",
                "17": "盧綰嫌畏於已隙",
                "18": "英布憂迫於情漏",
                "19": "此事之緣也",
                "20": "孤與將軍",
                "21": "恩如骨肉",
                "22": "割授江南",
                "23": "不屬本州",
                "24": "豈若淮陰捐舊之恨",
                "25": "抑遏劉馥",
                "26": "相厚益隆",
                "27": "寧放朱浮顯露之奏",
                "28": "無匿張勝貸故之變",
                "29": "匪有陰構賁赫之告",
                "30": "固非燕王淮南之舋也",
                "31": "而忍絕王命",
                "32": "明棄碩交",
                "33": "實爲佞人所構會也",
                "34": "夫似是之言",
                "35": "莫不動聽",
                "36": "因形設象",
                "37": "易爲變觀",
                "38": "示之以禍難",
                "39": "激之以恥辱",
                "40": "大丈夫雄心",
                "41": "能無憤發",
                "42": "昔蘇秦說韓",
                "43": "羞以牛後",
                "44": "韓王按劍作色而怒",
                "45": "雖兵折地割",
                "46": "猶不爲悔",
                "47": "人之情也",
                "48": "仁君年壯氣盛",
                "49": "緒信所嬖",
                "50": "旣懼患至",
                "51": "兼懷忿恨",
                "52": "不能復遠度孤心",
                "53": "近慮事勢",
                "54": "遂齎見薄之決計",
                "55": "秉翻然之成議",
                "56": "加劉備相扇揚",
                "57": "事結舋連",
                "58": "推而行之",
                "59": "想暢本心",
                "60": "不願於此也"
            }
        },
        "2": {
            "5": {
                "1": "孤之薄德",
                "2": "位高任重",
                "3": "幸蒙國朝將泰之運",
                "4": "蕩平天下",
                "5": "懷集異類",
                "6": "喜得全功",
                "7": "長享其福",
                "8": "而姻親坐離",
                "9": "厚援生隙",
                "10": "常恐海內多以相責",
                "11": "以爲老夫苞藏禍心",
                "12": "陰有鄭武取胡之詐",
                "13": "乃使仁君翻然自絕",
                "14": "以是忿忿",
                "15": "懷慚反側",
                "16": "常思除棄小事",
                "17": "更申前好",
                "18": "二族俱榮",
                "19": "流祚後嗣",
                "20": "以明雅素中誠之效",
                "21": "抱懷數年",
                "22": "未得散意",
                "23": "昔赤壁之役",
                "24": "遭離疫氣",
                "25": "燒船自還",
                "26": "以避惡地",
                "27": "非周瑜水軍所能抑挫也",
                "28": "江陵之守",
                "29": "物盡穀殫",
                "30": "無所復據",
                "31": "徙民還師",
                "32": "又非瑜之所能敗也",
                "33": "荊土本非己分",
                "34": "我盡與君",
                "35": "冀取其餘",
                "36": "非相侵肌膚",
                "37": "有所割損也",
                "38": "思計此變",
                "39": "無傷於孤",
                "40": "何必自遂於此",
                "41": "不復還之",
                "42": "高帝設爵以延田橫",
                "43": "光武指河而誓朱鮪",
                "44": "君之負累",
                "45": "豈如二子",
                "46": "是以至情",
                "47": "願聞德音"
            }
        },
        "3": {
            "7": {
                "1": "往年在譙",
                "2": "新造舟船",
                "3": "取足自載",
                "4": "以至九江",
                "5": "貴欲觀湖漅之形",
                "6": "定江濱之民耳",
                "7": "非有深入攻戰之計",
                "8": "將恐議者大爲己榮",
                "9": "自謂策得",
                "10": "長無西患",
                "11": "重以此故",
                "12": "未肯迴情",
                "13": "然智者之慮",
                "14": "慮於未形",
                "15": "達者所規",
                "16": "規於未兆",
                "17": "是故子胥知姑蘇之有麋鹿",
                "18": "輔果識智伯之爲趙禽",
                "19": "穆生謝病",
                "20": "以免楚難",
                "21": "鄒陽北遊",
                "22": "不同吳禍",
                "23": "此四士者",
                "24": "豈聖人哉",
                "25": "徒通變思深",
                "26": "以微知著耳",
                "27": "以君之明",
                "28": "觀孤術數",
                "29": "量君所據",
                "30": "相計土地",
                "31": "豈勢少力乏",
                "32": "不能遠舉",
                "33": "割江之表",
                "34": "宴安而已哉",
                "35": "甚未然也",
                "36": "若恃水戰",
                "37": "臨江塞要",
                "38": "欲令王師終不得渡",
                "39": "亦未必也",
                "40": "夫水戰千里",
                "41": "情巧萬端",
                "42": "越爲三軍",
                "43": "吳曾不禦",
                "44": "漢潛夏陽",
                "45": "魏豹不意",
                "46": "江河雖廣",
                "47": "其長難衞也"
            }
        },
        "4": {
            "9": {
                "1": "凡事有宜",
                "2": "不得盡言",
                "3": "將修舊好而張形勢",
                "4": "更無以威脅重敵人",
                "5": "然有所恐",
                "6": "恐書無益",
                "7": "何則",
                "8": "往者軍逼而自引還",
                "9": "今日在遠而興慰納",
                "10": "辭遜意狹",
                "11": "謂其力盡",
                "12": "適以增驕",
                "13": "不足相動",
                "14": "但明效古",
                "15": "當自圖之耳",
                "16": "昔淮南信左吳之策",
                "17": "漢隗囂納王元之言",
                "18": "彭寵受親吏之計",
                "19": "三夫不寤",
                "20": "終爲世笑",
                "21": "梁王不受詭勝",
                "22": "竇融近逐張玄",
                "23": "二賢旣覺",
                "24": "福亦隨之",
                "25": "願君少留意焉",
                "26": "若能內取子布",
                "27": "外擊劉備",
                "28": "以效赤心",
                "29": "用復前好",
                "30": "則江表之任",
                "31": "長以相付",
                "32": "高位重爵",
                "33": "坦然可觀",
                "34": "上令聖朝無東顧之勞",
                "35": "下令百姓保安全之福",
                "36": "君享其榮",
                "37": "孤受其利",
                "38": "豈不快哉",
                "39": "若忽至誠以處僥倖",
                "40": "婉彼二人",
                "41": "不忍加罪",
                "42": "所謂小人之仁",
                "43": "大仁之賊",
                "44": "大雅之人",
                "45": "不肯爲此也",
                "46": "若憐子布",
                "47": "願言俱存",
                "48": "亦能傾心去恨",
                "49": "順君之情",
                "50": "更與從事",
                "51": "取其後善",
                "52": "但禽劉備",
                "53": "亦足爲效",
                "54": "開設二者",
                "55": "審處一焉"
            }
        },
        "5": {
            "11": {
                "1": "聞荊楊諸將",
                "2": "並得降者",
                "3": "皆言交州爲君所執",
                "4": "豫章距命",
                "5": "不承執事",
                "6": "疫旱並行",
                "7": "人兵減損",
                "8": "各求進軍",
                "9": "其言云云",
                "10": "孤聞此言",
                "11": "未以爲悅",
                "12": "然道路旣遠",
                "13": "降者難信",
                "14": "幸人之災",
                "15": "君子不爲",
                "16": "且又百姓國家之有",
                "17": "加懷區區",
                "18": "樂欲崇和",
                "19": "庶幾明德",
                "20": "來見昭副",
                "21": "不勞而定",
                "22": "於孤益貴",
                "23": "是故按兵守次",
                "24": "遣書致意",
                "25": "古者兵交",
                "26": "使在其中",
                "27": "願仁君及孤虛心回意",
                "28": "以應詩人補衮之歎",
                "29": "而愼周易牽復之義",
                "30": "濯鱗清流",
                "31": "飛翼天衢",
                "32": "良時在茲",
                "33": "勖之而已"
            }
        }
    }
}