{
    "20.19": {
        "篇名": "孫子荊 征西官屬送於陟陽候作詩",
        "1": {
            "3": {
                "1": "晨風飄歧路",
                "2": "零雨被秋草",
                "3": "傾城遠追送",
                "4": "餞我千里道",
                "5": "三命皆有極",
                "6": "咄嗟安可保",
                "7": "莫大於殤子",
                "8": "彭聃猶爲夭",
                "9": "吉凶如糾纆",
                "10": "憂喜相紛繞",
                "11": "天地爲我爐",
                "12": "萬物一何小",
                "13": "達人垂大觀",
                "14": "誡此苦不早",
                "15": "乖離卽長衢",
                "16": "惆悵盈懷抱",
                "17": "孰能察其心",
                "18": "鑒之以蒼昊",
                "19": "齊契在今朝",
                "20": "守之與偕老"
            }
        }
    }
}