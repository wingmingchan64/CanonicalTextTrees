{
    "22.06": {
        "篇名": "謝叔源 遊西池",
        "1": {
            "3": {
                "1": "悟彼蟋蟀唱",
                "2": "信此勞者歌",
                "3": "有來豈不疾",
                "4": "良遊常蹉跎",
                "5": "逍遙越城肆",
                "6": "願言屢經過",
                "7": "回阡被陵闕",
                "8": "高臺眺飛霞",
                "9": "惠風蕩繁囿",
                "10": "白雲屯曾阿",
                "11": "景昃鳴禽集",
                "12": "水木湛清華",
                "13": "褰裳順蘭沚",
                "14": "徙倚引芳柯",
                "15": "美人愆歲月",
                "16": "遲暮獨如何",
                "17": "無爲牽所思",
                "18": "南榮誡其多"
            }
        }
