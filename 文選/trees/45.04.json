{
    "45.04": {
        "篇名": "班孟堅 答賓戲[幷序]",
        "1": {
            "3": {
                "1": "永平中爲郎",
                "2": "典校祕書",
                "3": "專篤志於儒學",
                "4": "以著述爲業",
                "5": "或譏以無功",
                "6": "又感東方朔楊雄自喩",
                "7": "以不遭蘇張范蔡之時",
                "8": "曾不折之以正道",
                "9": "明君子之所守",
                "10": "故聊復應焉",
                "11": "其辭曰"
            }
        },
        "2": {
            "5": {
                "1": "賓戲主人曰",
                "2": "蓋聞聖人有一定之論",
                "3": "烈士有不易之分",
                "4": "亦云名而已矣",
                "5": "故太上有立德",
                "6": "其次有立功",
                "7": "夫德不得後身而特盛",
                "8": "功不得背時而獨彰",
                "9": "是以聖哲之治",
                "10": "栖栖遑遑",
                "11": "孔席不㬉",
                "12": "墨突不黔",
                "13": "韋昭曰",
                "14": "㬉",
                "15": "溫也",
                "16": "言坐不㬉席也",
                "17": "文子曰",
                "18": "墨子無黔突",
                "19": "孔子無暖席",
                "20": "非以貪祿慕位",
                "21": "欲起天下之利",
                "22": "除萬民之害也",
                "23": "小雅曰",
                "24": "黔",
                "25": "黑也",
                "26": "巨炎切",
                "27": "由此言之",
                "28": "取舍者昔人之上務",
                "29": "著作者前列之餘事耳",
                "30": "今吾子幸遊帝王之世",
                "31": "躬帶紱冕之服",
                "32": "浮英華",
                "33": "湛道德",
                "34": "矕龍虎之文",
                "35": "舊矣",
                "36": "卒不能攄首尾",
                "37": "奮翼鱗",
                "38": "振拔洿塗",
                "39": "跨騰風雲",
                "40": "使見之者影駭",
                "41": "聞之者響震",
                "42": "徒樂枕經籍書",
                "43": "紆體衡門",
                "44": "上無所蔕",
                "45": "下無所根",
                "46": "獨攄意乎宇宙之外",
                "47": "銳思於毫芒之內",
                "48": "潛神默記",
                "49": "緪以年歲",
                "50": "然而器不賈於當己",
                "51": "用不效於一世",
                "52": "雖馳辯如濤波",
                "53": "摛藻如春華",
                "54": "猶無益於殿最也",
                "55": "意者",
                "56": "且運朝夕之策",
                "57": "定合會之計",
                "58": "使存有顯號",
                "59": "亡有美謚",
                "60": "不亦優乎"
            }
        },
        "3": {
            "7": {
                "1": "主人逌爾而笑曰",
                "2": "若賓之言",
                "3": "所謂見世利之華",
                "4": "闇道德之實",
                "5": "守窔奧之熒燭",
                "6": "未仰天庭而覩白日也",
                "7": "曩者王塗蕪穢",
                "8": "周失其馭",
                "9": "侯伯方軌",
                "10": "戰國橫騖",
                "11": "於是七雄虓闞",
                "12": "分裂諸夏",
                "13": "龍戰虎爭",
                "14": "遊說之徒",
                "15": "風颮電激",
                "16": "並起而救之",
                "17": "其餘猋飛景附",
                "18": "霅煜其間者",
                "19": "蓋不可勝載",
                "20": "當此之時",
                "21": "搦朽摩鈍",
                "22": "鉛刀皆能一斷",
                "23": "是故魯連飛一矢而蹶千金",
                "24": "虞卿以顧眄而捐相印",
                "25": "夫啾發投曲",
                "26": "感耳之聲",
                "27": "合之律度",
                "28": "淫䵷而不可聽者",
                "29": "非韶夏之樂也",
                "30": "李奇曰",
                "31": "淫䵷",
                "32": "不正也",
                "33": "因勢合變",
                "34": "遇時之容",
                "35": "風移俗易",
                "36": "乖迕而不可通者",
                "37": "非君子之法也",
                "38": "及至從人合之",
                "39": "衡人散之",
                "40": "亡命漂說",
                "41": "羈旅騁辭",
                "42": "商鞅挾三術以鑽孝公",
                "43": "李斯奮時務而要始皇",
                "44": "彼皆躡風塵之會",
                "45": "履顚沛之勢",
                "46": "據徼乘邪",
                "47": "以求一日之富貴",
                "48": "朝爲榮華",
                "49": "夕爲憔悴",
                "50": "福不盈眥",
                "51": "禍溢於世",
                "52": "凶人且以自悔",
                "53": "況吉士而是賴乎",
                "54": "且功不可虛成",
                "55": "名不可以僞立",
                "56": "韓設辨以激君",
                "57": "呂行詐以賈國",
                "58": "說難旣遒",
                "59": "其身乃囚",
                "60": "秦貨旣貴",
                "61": "厥宗亦墜",
                "62": "是以仲尼抗浮雲之志",
                "63": "孟軻養浩然之氣",
                "64": "彼豈樂爲迂闊哉",
                "65": "道不可以貳也",
                "66": "方今大漢灑埽羣穢",
                "67": "夷險芟荒",
                "68": "廓帝紘",
                "69": "恢皇綱",
                "70": "基隆於羲農",
                "71": "規廣於黃唐",
                "72": "其君天下也",
                "73": "炎之如日",
                "74": "威之如神",
                "75": "函之如海",
                "76": "養之如春",
                "77": "是以六合之內",
                "78": "莫不同源共流",
                "79": "沐浴玄德",
                "80": "稟仰太龢",
                "81": "枝附葉著",
                "82": "譬猶草木之植山林",
                "83": "鳥魚之毓川澤",
                "84": "得氣者蕃滋",
                "85": "失時者零落",
                "86": "參天地而施化",
                "87": "豈云人事之厚薄哉",
                "88": "今吾子處皇代而論戰國",
                "89": "曜所聞而疑所覿",
                "90": "欲從堥敦而度高乎泰山",
                "91": "懷氿濫而測深乎重淵",
                "92": "亦未至也",
                "93": "服虔曰",
                "94": "敦音頓",
                "95": "頓丘也",
                "96": "應劭曰",
                "97": "爾雅曰",
                "98": "前高堥丘如覆敦者",
                "99": "敦",
                "100": "丘也",
                "101": "爾雅曰",
                "102": "氿泉穴出",
                "103": "穴出",
                "104": "仄出也",
                "105": "濫泉正出",
                "106": "正出",
                "107": "湧出也",
                "108": "服虔曰",
                "109": "氿音軌",
                "110": "韋昭曰",
                "111": "濫音㩜",
                "112": "堥音旄",
                "113": "郭璞爾雅注曰",
                "114": "敦",
                "115": "盂也",
                "116": "都回切"
            }
        },
        "4": {
            "9": {
                "1": "賓曰",
                "2": "若夫鞅斯之倫",
                "3": "衰周之凶人",
                "4": "旣聞命矣",
                "5": "敢問上古之士",
                "6": "處身行道",
                "7": "輔世成名",
                "8": "可述於後者",
                "9": "默而已乎"
            }
        },
        "5": {
            "11": {
                "1": "主人曰",
                "2": "何爲其然也",
                "3": "昔者咎繇謨虞",
                "4": "箕子訪周",
                "5": "言通帝王",
                "6": "謀合神聖",
                "7": "殷說夢發於傅巖",
                "8": "周望兆動於渭濱",
                "9": "齊甯激聲於康衢",
                "10": "漢良受書於邳垠",
                "11": "皆俟命而神交",
                "12": "匪詞言之所信",
                "13": "故能建必然之策",
                "14": "展無窮之勳也",
                "15": "近者陸子優遊",
                "16": "新語以興",
                "17": "董生下帷",
                "18": "發藻儒林",
                "19": "劉向司籍",
                "20": "辨章舊聞",
                "21": "揚雄譚思",
                "22": "法言太玄",
                "23": "皆及時君之門闈",
                "24": "究先聖之壼奧",
                "25": "婆娑乎術藝之場",
                "26": "休息乎篇籍之囿",
                "27": "以全其質而發其文",
                "28": "用納乎聖德",
                "29": "烈炳乎後人",
                "30": "斯非亞與",
                "31": "若乃伯夷抗行於首陽",
                "32": "柳惠降志於辱仕",
                "33": "顏潛樂於簞瓢",
                "34": "孔終篇於西狩",
                "35": "聲盈塞於天淵",
                "36": "眞吾徒之師表也",
                "37": "且吾聞之",
                "38": "一陰一陽",
                "39": "天地之方",
                "40": "乃文乃質",
                "41": "王道之綱",
                "42": "有同有異",
                "43": "聖哲之常",
                "44": "故曰",
                "45": "愼修所志",
                "46": "守爾天符",
                "47": "委命供己",
                "48": "味道之腴",
                "49": "神之聽之",
                "50": "名其舍諸",
                "51": "賓又不聞和氏之璧",
                "52": "韞於荊石",
                "53": "隋侯之珠",
                "54": "藏於蚌蛤乎",
                "55": "歷世莫眡",
                "56": "不知其將含景曜",
                "57": "吐英精",
                "58": "曠千載而流光也",
                "59": "應龍潛於潢汙",
                "60": "魚黿媟之",
                "61": "不覩其能奮靈德",
                "62": "合風雲",
                "63": "超忽荒而躆昊蒼也",
                "64": "故夫泥蟠而天飛者",
                "65": "應龍之神也",
                "66": "先賤而後貴者",
                "67": "和隋之珍也",
                "68": "時暗而久章者",
                "69": "君子之眞也",
                "70": "若乃牙曠清耳於管絃",
                "71": "離婁眇目於毫分",
                "72": "逢蒙絕技於弧矢",
                "73": "般輸搉巧於斧斤",
                "74": "良樂軼能於相馭",
                "75": "烏獲抗力於千鈞",
                "76": "和鵲發精於鍼石",
                "77": "硏桑心計於無垠",
                "78": "走亦不任廁技於彼列",
                "79": "故密爾自娛於斯文"
            }
        }
    }
}