{
    "39.02": {
        "篇名": "鄒陽 上書吳王",
        "1": {
            "3": {
                "1": "臣聞秦倚曲臺之宮懸衡天下",
                "2": "畫地而人不犯",
                "3": "兵加胡越",
                "4": "至其晚節末路",
                "5": "張耳陳勝連從兵之",
                "6": "據以叩函谷",
                "7": "咸陽遂危",
                "8": "何則",
                "9": "列郡不相親",
                "10": "萬室不相救也",
                "11": "今胡數涉北河之外",
                "12": "上覆飛鳥",
                "13": "下不見伏兔",
                "14": "鬥城不休",
                "15": "救兵不至",
                "16": "死者相隨",
                "17": "輦車相屬",
                "18": "轉粟流輸",
                "19": "千里不絕",
                "20": "何則",
                "21": "彊趙責於河間六齊望於惠后城陽顧於盧博",
                "22": "三淮南之心思墳墓",
                "23": "大王不憂",
                "24": "臣恐救兵之不專",
                "25": "胡馬遂進窺於邯鄲",
                "26": "越水長沙",
                "27": "還舟青陽",
                "28": "雖使梁幷淮陽之兵",
                "29": "下淮東",
                "30": "越廣陵",
                "31": "以遏越人之糧",
                "32": "漢亦折西河而下",
                "33": "北守漳水以輔大國",
                "34": "胡亦益進",
                "35": "越亦益深",
                "36": "此臣之所爲大王患也"
            }
        },
        "2": {
            "5": {
                "1": "臣聞蛟龍驤首奮翼",
                "2": "則浮雲出流",
                "3": "霧雨咸集",
                "4": "聖王底節修德",
                "5": "則遊談之士",
                "6": "歸義思名",
                "7": "今臣盡知畢議",
                "8": "易精極慮",
                "9": "則無國而不可奸",
                "10": "飾固陋之心",
                "11": "則何王之門不可曳長裾乎",
                "12": "然臣所以歷數王之朝",
                "13": "背淮千里而自致者",
                "14": "非惡臣國而樂吳民",
                "15": "竊高下風之行",
                "16": "尤悅大王之義",
                "17": "故願大王無忽",
                "18": "察聽其至"
            }
        },
        "3": {
            "7": {
                "1": "臣聞鷙鳥累百",
                "2": "不如一鶚",
                "3": "夫全趙之時",
                "4": "武力鼎士",
                "5": "袨服叢臺之下者",
                "6": "一旦成市",
                "7": "不能止幽王之湛患",
                "8": "淮南連山東之俠",
                "9": "死士盈朝",
                "10": "不能還厲王之西也",
                "11": "然則計議不得",
                "12": "雖諸賁不能安其位",
                "13": "亦明矣",
                "14": "故願大王審畫而已"
            }
        },
        "4": {
            "9": {
                "1": "始孝文皇帝據關入立",
                "2": "寒心銷志",
                "3": "不明求衣",
                "4": "自立天子之後",
                "5": "使東牟朱虛東襃儀父之後",
                "6": "深割嬰兒王之",
                "7": "壤子王梁代",
                "8": "益以淮陽",
                "9": "卒仆濟北",
                "10": "囚弟於雍者",
                "11": "豈非象新垣等哉",
                "12": "今天子新據先帝之遺業",
                "13": "左規山東",
                "14": "右制關中",
                "15": "變權易勢",
                "16": "大臣難知",
                "17": "大王弗察",
                "18": "臣恐周鼎復起於漢",
                "19": "新垣過計於朝",
                "20": "則我吳遺嗣",
                "21": "不可期於世矣",
                "22": "高皇帝燒棧道",
                "23": "灌章邯",
                "24": "兵不留行",
                "25": "收敝人之倦",
                "26": "東馳函谷",
                "27": "西楚大破",
                "28": "水攻則章邯以亡其城",
                "29": "陸擊則荊王以失其地",
                "30": "此皆國家之不幾者也",
                "31": "願大王熟察之"
            }
        }
    }
}