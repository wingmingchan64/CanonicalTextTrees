{
    "29.05": {
        "篇名": "王仲宣 雜詩",
        "1": {
            "3": {
                "1": "日暮遊西園",
                "2": "冀寫憂思情",
                "3": "曲池揚素波",
                "4": "列樹敷丹榮",
                "5": "上有特栖鳥",
                "6": "懷春向我鳴",
                "7": "褰衽欲從之",
                "8": "路嶮不得征",
                "9": "徘徊不能去",
                "10": "佇立望爾形",
                "11": "風飆揚塵起",
                "12": "白日忽已冥",
                "13": "迴身入空房",
                "14": "託夢通精誠",
                "15": "人欲天不違",
                "16": "何懼不合幷"
            }
        }
    }
}