{
    "56.03": {
        "篇名": "崔子玉 座右銘",
        "1": {
            "3": {
                "1": "無道人之短",
                "2": "無說己之長",
                "3": "施人愼勿念",
                "4": "受施愼勿忘",
                "5": "世譽不足慕",
                "6": "唯仁爲紀綱",
                "7": "隱心而後動",
                "8": "謗議庸何傷",
                "9": "無使名過實",
                "10": "守愚聖所臧",
                "11": "在涅貴不淄",
                "12": "曖曖內含光",
                "13": "柔弱生之徒",
                "14": "老氏誡剛強",
                "15": "行行鄙夫志",
                "16": "悠悠故難量",
                "17": "愼言節飲食",
                "18": "知足勝不祥",
                "19": "行之苟有恆",
                "20": "久久自芬芳"
            }
        }
    }
}