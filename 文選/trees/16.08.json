{
    "16.08": {
        "篇名": "江文通 別賦",
        "1": {
            "3": {
                "1": "黯然銷魂者",
                "2": "唯別而已矣",
                "3": "況秦吳兮絕國",
                "4": "復燕宋兮千里",
                "5": "或春苔兮始生",
                "6": "乍秋風兮暫起",
                "7": "是以行子腸斷",
                "8": "百感悽惻",
                "9": "風蕭蕭而異響",
                "10": "雲漫漫而奇色",
                "11": "舟凝滯於水濱",
                "12": "車逶遲於山側",
                "13": "櫂容與而詎前",
                "14": "馬寒鳴而不息",
                "15": "掩金觴而誰御",
                "16": "橫玉柱而霑軾",
                "17": "居人愁臥",
                "18": "怳若有亡",
                "19": "日下壁而沈彩",
                "20": "月上軒而飛光",
                "21": "見紅蘭之受露",
                "22": "望青楸之離霜",
                "23": "巡曾楹而空揜",
                "24": "撫錦幕而虛涼",
                "25": "知離夢之躑躅",
                "26": "意別魂之飛揚"
            }
        },
        "2": {
            "5": {
                "1": "故別雖一緒",
                "2": "事乃萬族",
                "3": "至若龍馬銀鞍",
                "4": "朱軒繡軸",
                "5": "帳飲東都",
                "6": "送客金谷",
                "7": "琴羽張兮簫鼓陳",
                "8": "燕趙歌兮傷美人",
                "9": "珠與玉兮豔暮秋",
                "10": "羅與綺兮嬌上春",
                "11": "驚駟馬之仰秣",
                "12": "聳淵魚之赤鱗",
                "13": "造分手而銜涕",
                "14": "感寂漠而傷神"
            }
        },
        "3": {
            "7": {
                "1": "乃有劍客慚恩",
                "2": "少年報士",
                "3": "韓國趙廁",
                "4": "吳宮燕市",
                "5": "割慈忍愛",
                "6": "離邦去里",
                "7": "瀝泣共訣",
                "8": "抆血相視",
                "9": "驅征馬而不顧",
                "10": "見行塵之時起",
                "11": "方銜感於一劍",
                "12": "非買價於泉里",
                "13": "金石震而色變",
                "14": "骨肉悲而心死"
            }
        },
        "4": {
            "9": {
                "1": "或乃邊郡未和",
                "2": "負羽從軍",
                "3": "遼水無極",
                "4": "雁山參雲",
                "5": "閨中風暖",
                "6": "陌上草薰",
                "7": "日出天而耀景",
                "8": "露下地而騰文",
                "9": "鏡朱塵之照爛",
                "10": "襲青氣之煙熅",
                "11": "攀桃李兮不忍別",
                "12": "送愛子兮霑羅裙"
            }
        },
        "5": {
            "11": {
                "1": "至如一赴絕國",
                "2": "詎相見期",
                "3": "視喬木兮故里",
                "4": "決北梁兮永辭",
                "5": "左右兮魂動",
                "6": "親賓兮淚滋",
                "7": "可班荊兮贈恨",
                "8": "唯尊酒兮敍悲",
                "9": "値秋雁兮飛日",
                "10": "當白露兮下時",
                "11": "怨復怨兮遠山曲",
                "12": "去復去兮長河湄"
            }
        },
        "6": {
            "13": {
                "1": "又若君居淄右",
                "2": "妾家河陽",
                "3": "同瓊珮之晨照",
                "4": "共金爐之夕香",
                "5": "君結綬兮千里",
                "6": "惜瑤草之徒芳",
                "7": "慚幽閨之琴瑟",
                "8": "晦高臺之流黃",
                "9": "春宮閟此青苔色",
                "10": "秋帳含茲明月光",
                "11": "夏簟清兮晝不暮",
                "12": "冬釭凝兮夜何長",
                "13": "織錦曲兮泣已盡",
                "14": "迴文詩兮影獨傷"
            }
        },
        "7": {
            "15": {
                "1": "儻有華陰上士",
                "2": "服食還山",
                "3": "術旣妙而猶學",
                "4": "道已寂而未傳",
                "5": "守丹竃而不顧",
                "6": "鍊金鼎而方堅",
                "7": "駕鶴上漢",
                "8": "驂鸞騰天",
                "9": "暫遊萬里",
                "10": "少別千年",
                "11": "惟世間兮重別",
                "12": "謝主人兮依然"
            }
        },
        "8": {
            "17": {
                "1": "下有芍藥之詩",
                "2": "佳人之歌",
                "3": "桑中衞女",
                "4": "上宮陳娥",
                "5": "春草碧色",
                "6": "春水淥波",
                "7": "送君南浦",
                "8": "傷如之何",
                "9": "至乃秋露如珠",
                "10": "秋月如珪",
                "11": "明月白露",
                "12": "光陰往來",
                "13": "與子之別",
                "14": "思心徘徊"
            }
        },
        "9": {
            "19": {
                "1": "是以別方不定",
                "2": "別理千名",
                "3": "有別必怨",
                "4": "有怨必盈",
                "5": "使人意奪神駭",
                "6": "心折骨驚",
                "7": "雖淵雲之墨妙",
                "8": "嚴樂之筆精",
                "9": "金閨之諸彥",
                "10": "蘭臺之羣英",
                "11": "賦有凌雲之稱",
                "12": "辯有雕龍之聲",
                "13": "誰能摹暫離之狀",
                "14": "寫永訣之情者乎"
            }
        }
    }
}