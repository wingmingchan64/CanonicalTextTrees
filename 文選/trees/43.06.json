{
    "43.06": {
        "篇名": "劉子駿 移書讓太常博士[幷序]",
        "1": {
            "3": {
                "1": "歆親近",
                "2": "欲建立左氏春秋及毛詩逸禮古文尙書",
                "3": "皆列於學官",
                "4": "哀帝令歆與五經博士講論其議",
                "5": "諸儒博士或不肯置對",
                "6": "歆因移書太常博士責讓之曰"
            }
        },
        "2": {
            "5": {
                "1": "昔唐虞旣衰",
                "2": "而三代迭興",
                "3": "聖帝明王",
                "4": "累起相襲",
                "5": "其道甚著",
                "6": "周室旣微",
                "7": "而禮樂不正",
                "8": "道之難全也如此",
                "9": "是故孔子憂道不行",
                "10": "歷國應聘",
                "11": "自衞反魯",
                "12": "然後樂正",
                "13": "雅頌乃得其所",
                "14": "修易序書",
                "15": "制作春秋",
                "16": "以記帝王之道",
                "17": "及夫子沒而微言絕",
                "18": "七十子卒而大義乖",
                "19": "重遭戰國",
                "20": "棄籩豆之禮",
                "21": "理軍旅之陣",
                "22": "孔氏之道抑",
                "23": "而孫吳之術興",
                "24": "陵夷至於暴秦",
                "25": "焚經書",
                "26": "殺儒士",
                "27": "設挾書之法",
                "28": "行是古之罪",
                "29": "道術由此遂滅"
            }
        },
        "3": {
            "7": {
                "1": "漢興",
                "2": "去聖帝明王遐遠",
                "3": "仲尼之道又絕",
                "4": "法度無所因襲",
                "5": "時獨有一叔孫通",
                "6": "略定禮儀",
                "7": "天下惟有易卜",
                "8": "未有他書",
                "9": "至於孝惠之世",
                "10": "乃除挾書之律",
                "11": "然公卿大臣絳灌之屬",
                "12": "咸介冑武夫",
                "13": "莫以爲意",
                "14": "至孝文皇帝",
                "15": "始使掌故晁錯",
                "16": "從伏生受尙書",
                "17": "尙書初出於屋壁",
                "18": "朽折散絕",
                "19": "今其書見在",
                "20": "時師傳讀而已",
                "21": "詩始萌芽",
                "22": "天下眾書",
                "23": "往往頗出",
                "24": "皆諸子傳說",
                "25": "猶廣立於學官",
                "26": "爲置博士",
                "27": "在朝之儒",
                "28": "唯賈生而已",
                "29": "至孝武皇帝",
                "30": "然後鄒魯梁趙",
                "31": "頗有詩禮春秋先師",
                "32": "皆出於建元之間",
                "33": "當此之時",
                "34": "一人不能獨盡其經",
                "35": "或爲雅",
                "36": "或爲頌",
                "37": "相合而成",
                "38": "泰誓後得",
                "39": "博士集而讚之",
                "40": "故詔書曰",
                "41": "禮壞樂崩",
                "42": "書缺簡脫",
                "43": "朕甚閔焉",
                "44": "時漢興已七八十年",
                "45": "離於全經固以遠矣"
            }
        },
        "4": {
            "9": {
                "1": "及魯恭王壞孔子宅",
                "2": "欲以爲宮",
                "3": "而得古文於壞壁之中",
                "4": "逸禮有三十九篇",
                "5": "書十六篇",
                "6": "天漢之後",
                "7": "孔安國獻之",
                "8": "遭巫蠱倉卒之難",
                "9": "未及施行",
                "10": "及春秋左氏丘明所修",
                "11": "皆古文舊書",
                "12": "多者二十餘通",
                "13": "藏於祕府",
                "14": "伏而未發",
                "15": "孝成皇帝愍學殘文缺",
                "16": "稍離其眞",
                "17": "乃陳發祕藏",
                "18": "校理舊文",
                "19": "得此三事",
                "20": "以考學官所傳經",
                "21": "或脫簡",
                "22": "或脫編",
                "23": "博問人間",
                "24": "則有魯國桓公",
                "25": "趙國貫公",
                "26": "膠東庸生之遺學與此同",
                "27": "抑而未施",
                "28": "此乃有識者之所歎癏",
                "29": "士君子之所嗟痛也"
            }
        },
        "5": {
            "11": {
                "1": "往者綴學之士",
                "2": "不思廢絕之闕",
                "3": "苟因陋就寡",
                "4": "分文析字",
                "5": "煩言碎辭",
                "6": "學者罷老",
                "7": "且不能究其一藝",
                "8": "信口說而背傳記",
                "9": "是末師而非往古",
                "10": "至於國家將有大事",
                "11": "若立辟雍封禪巡狩之儀",
                "12": "則幽冥而莫知其原",
                "13": "猶欲保殘守缺",
                "14": "挾恐見破之私意",
                "15": "而亡從善服義之公心",
                "16": "或懷疾妬",
                "17": "不考情實",
                "18": "雷同相從",
                "19": "隨聲是非",
                "20": "抑此三學",
                "21": "以尙書爲不備",
                "22": "謂左氏不傳春秋",
                "23": "豈不哀哉"
            }
        },
        "6": {
            "13": {
                "1": "今聖上德通神明",
                "2": "繼統揚業",
                "3": "亦愍此文教錯亂",
                "4": "學士若茲",
                "5": "雖深照其情",
                "6": "猶依違謙讓",
                "7": "樂與士君子同之",
                "8": "故下明詔",
                "9": "試左氏可立不",
                "10": "遣近臣奉旨銜命",
                "11": "將以輔弱扶微",
                "12": "與二三君子比意同力",
                "13": "冀得廢遺",
                "14": "今則不然",
                "15": "深閉固距而不肯試",
                "16": "猥以不誦絕之",
                "17": "欲以杜塞餘道",
                "18": "絕滅微學",
                "19": "夫可與樂成",
                "20": "難與慮始",
                "21": "此乃眾庶之所爲耳",
                "22": "非所望於士君子也",
                "23": "且此數家之事",
                "24": "皆先帝所親論",
                "25": "今上所考視",
                "26": "其爲古文舊書",
                "27": "皆有徵驗",
                "28": "內外相應",
                "29": "豈苟而已哉",
                "30": "夫禮失求之於野",
                "31": "古文不猶愈於野乎"
            }
        },
        "7": {
            "15": {
                "1": "往者博士書有歐陽",
                "2": "春秋公羊",
                "3": "易則施孟",
                "4": "然孝宣帝猶復廣立穀梁春秋梁丘易大小夏侯尙書",
                "5": "義雖相反",
                "6": "猶並置之",
                "7": "何則",
                "8": "與其過而廢之",
                "9": "寧過而立之",
                "10": "傳曰",
                "11": "文武之道",
                "12": "未墜於地",
                "13": "在人",
                "14": "賢者志其大者",
                "15": "不賢者志其小者",
                "16": "今此數家之言",
                "17": "所以兼包大小之義",
                "18": "豈可偏絕哉",
                "19": "若必專己守殘",
                "20": "黨同門",
                "21": "妬道眞",
                "22": "違明詔",
                "23": "失聖意",
                "24": "以陷於文吏之議",
                "25": "甚爲二三君子不取也"
            }
        }
    }
}