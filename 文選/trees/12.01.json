{
    "12.01": {
        "篇名": "木玄虛 海賦",
        "1": {
            "3": {
                "1": "昔在帝嬀",
                "2": "臣唐之代",
                "3": "天綱浡潏",
                "4": "爲凋爲瘵",
                "5": "洪濤瀾汗",
                "6": "萬里無際",
                "7": "長波涾𣵺",
                "8": "迆涎八裔",
                "9": "於是乎禹也",
                "10": "乃鏟臨崖之阜陸",
                "11": "決陂潢而相沷",
                "12": "啟龍門之岝𡾆",
                "13": "𡓚陵巒而嶄鑿",
                "14": "羣山旣略",
                "15": "百川潛渫",
                "16": "泱漭澹泞",
                "17": "騰波赴勢",
                "18": "江河旣導",
                "19": "萬穴俱流",
                "20": "掎拔五嶽",
                "21": "竭涸九州",
                "22": "瀝滴滲淫",
                "23": "薈蔚雲霧",
                "24": "涓流泱瀼",
                "25": "莫不來注",
                "26": "於廓靈海",
                "27": "長爲委輸"
            }
        },
        "2": {
            "5": {
                "1": "其爲廣也",
                "2": "其爲怪也",
                "3": "宜其爲大也",
                "4": "爾其爲狀也",
                "5": "則乃浟湙瀲灩",
                "6": "浮天無岸",
                "7": "浺瀜沆瀁",
                "8": "渺瀰湠漫",
                "9": "波如連山",
                "10": "乍合乍散",
                "11": "噓噏百川",
                "12": "洗滌淮漢",
                "13": "襄陵廣舄",
                "14": "㶀㵧浩汗",
                "15": "若乃大明㩠轡於金樞之穴",
                "16": "翔陽逸駭於扶桑之津",
                "17": "彯沙礐石",
                "18": "蕩𩘻島濱",
                "19": "於是鼓怒",
                "20": "溢浪揚浮",
                "21": "更相觸搏",
                "22": "飛沫起濤",
                "23": "狀如天輪",
                "24": "膠戾而激轉",
                "25": "又似地軸",
                "26": "挺拔而爭迴",
                "27": "岑嶺飛騰而反覆",
                "28": "五嶽鼓舞而相磓",
                "29": "渭濆淪而滀漯",
                "30": "鬱沏迭而隆頹",
                "31": "盤盓激而成窟",
                "32": "𣺰𣶞滐而爲魁",
                "33": "㴸泊柏而迆颺",
                "34": "磊匒匌而相豗",
                "35": "驚浪雷奔",
                "36": "駭水逬集",
                "37": "開合解會",
                "38": "瀼瀼濕濕",
                "39": "葩華踧沑",
                "40": "㴿濘潗㵫"
            }
        },
        "3": {
            "7": {
                "1": "若乃霾曀潛銷",
                "2": "莫振莫竦",
                "3": "輕塵不飛",
                "4": "纖蘿不動",
                "5": "猶尙呀呷",
                "6": "餘波獨湧",
                "7": "澎濞灪䃶",
                "8": "碨磊山壟",
                "9": "爾其枝岐潭瀹",
                "10": "渤蕩成汜",
                "11": "乖蠻隔夷",
                "12": "迴互萬里",
                "13": "若乃偏荒速告",
                "14": "王命急宣",
                "15": "飛駿鼓楫",
                "16": "泛海淩山",
                "17": "於是候勁風",
                "18": "揭百尺",
                "19": "維長綃",
                "20": "挂帆席",
                "21": "望濤遠決",
                "22": "冏然鳥逝",
                "23": "鷸如驚鳧之失侶",
                "24": "倏如六龍之所掣",
                "25": "一越三千",
                "26": "不終朝而濟所屆"
            }
        },
        "4": {
            "9": {
                "1": "若其負穢臨深",
                "2": "虛誓愆祈",
                "3": "則有海童邀路",
                "4": "馬銜當蹊",
                "5": "天吳乍見而髣彿",
                "6": "蝄像暫曉而閃屍",
                "7": "羣妖遘迕",
                "8": "眇䁘冶夷",
                "9": "決帆摧橦",
                "10": "戕風起惡",
                "11": "廓如靈變",
                "12": "惚怳幽暮",
                "13": "氣似天霄",
                "14": "靉靅雲布",
                "15": "䨹昱絕電",
                "16": "百色妖露",
                "17": "呵㗵掩鬱",
                "18": "矆睒無度",
                "19": "飛澇相磢",
                "20": "激勢相沏",
                "21": "崩雲屑雨",
                "22": "浤浤汨汨",
                "23": "𧿒踔湛𤄶",
                "24": "沸潰渝溢",
                "25": "瀖泋濩渭",
                "26": "蕩雲沃日",
                "27": "於是舟人漁子",
                "28": "徂南極東",
                "29": "或屑沒於黿鼉之穴",
                "30": "或挂罥於岑㟼之峯",
                "31": "或掣掣泄泄於裸人之國",
                "32": "或泛泛悠悠於黑齒之邦",
                "33": "或乃萍流而浮轉",
                "34": "或因歸風以自反",
                "35": "徒識觀怪之多駭",
                "36": "乃不悟所歷之近遠"
            }
        },
        "5": {
            "11": {
                "1": "爾其爲大量也",
                "2": "則南澰朱崖",
                "3": "北灑天墟",
                "4": "東演析木",
                "5": "西薄青徐",
                "6": "經途瀴溟",
                "7": "萬萬有餘",
                "8": "吐雲霓",
                "9": "含龍魚",
                "10": "隱鯤鱗",
                "11": "潛靈居",
                "12": "豈徒積太顚之寶貝",
                "13": "與隨侯之明珠",
                "14": "將世之所收者常聞",
                "15": "所未名者若無",
                "16": "且希世之所聞",
                "17": "惡審其名",
                "18": "故可仿像其色",
                "19": "靉霼其形"
            }
        },
        "6": {
            "13": {
                "1": "爾其水府之內",
                "2": "極深之庭",
                "3": "則有崇島巨鼇",
                "4": "峌𡸣孤亭",
                "5": "擘洪波",
                "6": "指太清",
                "7": "竭磐石",
                "8": "栖百靈",
                "9": "颺凱風而南逝",
                "10": "廣莫至而北征",
                "11": "其垠則有天琛水怪",
                "12": "鮫人之室",
                "13": "瑕石詭暉",
                "14": "鱗甲異質"
            }
        },
        "7": {
            "15": {
                "1": "若乃雲錦散文於沙汭之際",
                "2": "綾羅被光於螺蚌之節",
                "3": "繁采揚華",
                "4": "萬色隱鮮",
                "5": "陽冰不冶",
                "6": "陰火潛然",
                "7": "熺炭重燔",
                "8": "吹炯九泉",
                "9": "朱𤒦綠煙",
                "10": "䁏眇蟬蜎",
                "11": "珊瑚虎珀",
                "12": "羣產接連",
                "13": "車渠馬瑙",
                "14": "全積如山",
                "15": "魚則橫海之鯨",
                "16": "突扤孤遊",
                "17": "戛巖㟼",
                "18": "偃高濤",
                "19": "茹鱗甲",
                "20": "吞龍舟",
                "21": "噏波則洪漣踧蹜",
                "22": "吹澇則百川倒流",
                "23": "或乃蹭蹬窮波",
                "24": "陸死鹽田",
                "25": "巨鱗插雲",
                "26": "鬐鬣刺天",
                "27": "顱骨成嶽",
                "28": "流膏爲淵"
            }
        },
        "8": {
            "17": {
                "1": "若乃巖坻之隈",
                "2": "沙石之嶔",
                "3": "毛翼產鷇",
                "4": "剖卵成禽",
                "5": "鳧雛離褷",
                "6": "鶴子淋滲",
                "7": "羣飛侶浴",
                "8": "戲廣浮深",
                "9": "翔霧連軒",
                "10": "泄泄淫淫",
                "11": "翻動成雷",
                "12": "擾翰爲林",
                "13": "更相叫嘯",
                "14": "詭色殊音"
            }
        },
        "9": {
            "19": {
                "1": "若乃三光旣清",
                "2": "天地融朗",
                "3": "不泛陽侯",
                "4": "乘蹻絕往",
                "5": "覿安期於蓬萊",
                "6": "見喬山之帝像",
                "7": "羣仙縹眇",
                "8": "餐玉清涯",
                "9": "履阜鄕之留舄",
                "10": "被羽翮之襂纚",
                "11": "翔天沼",
                "12": "戲窮溟",
                "13": "甄有形於無欲",
                "14": "永悠悠以長生"
            }
        },
        "10": {
            "21": {
                "1": "且其爲器也",
                "2": "包乾之奧",
                "3": "括坤之區",
                "4": "惟神是宅",
                "5": "亦祇是廬",
                "6": "何奇不有",
                "7": "何怪不儲",
                "8": "芒芒積流",
                "9": "含形內虛",
                "10": "曠哉坎德",
                "11": "卑以自居",
                "12": "弘往納來",
                "13": "以宗以都",
                "14": "品物類生",
                "15": "何有何無"
            }
        }
    }
}