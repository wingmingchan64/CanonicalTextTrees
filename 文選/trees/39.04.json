{
    "39.04": {
        "篇名": "司馬長卿 上書諫獵",
        "1": {
            "3": {
                "1": "臣聞物有同類而殊能者",
                "2": "故力稱烏獲",
                "3": "捷言慶忌",
                "4": "勇期賁育",
                "5": "臣之愚暗",
                "6": "竊以爲人誠有之",
                "7": "獸亦宜然",
                "8": "今陛下好凌岨險",
                "9": "射猛獸",
                "10": "卒然遇軼才之獸",
                "11": "駭不存之地",
                "12": "犯屬車之清塵",
                "13": "輿不及還轅",
                "14": "人不暇施功",
                "15": "雖有烏獲逢蒙之伎",
                "16": "力不得用",
                "17": "枯木朽株盡爲難矣",
                "18": "是胡越起於轂下",
                "19": "而羌夷接軫也",
                "20": "豈不殆哉",
                "21": "雖萬全無患",
                "22": "然本非天子所宜近也"
            }
        },
        "2": {
            "5": {
                "1": "且夫清道而後行",
                "2": "中路而馳",
                "3": "猶時有銜橛之變",
                "4": "而況乎涉豐草",
                "5": "騁丘墟",
                "6": "前有利獸之樂",
                "7": "而內無存變之意",
                "8": "其爲害也",
                "9": "不亦難矣",
                "10": "夫輕萬乘之重不以爲安",
                "11": "而樂出萬有一危之塗以爲娛",
                "12": "臣竊爲陛下不取也",
                "13": "蓋聞明者遠見於未萌",
                "14": "而智者避危於無形",
                "15": "禍固多藏於隱微",
                "16": "而發於人所忽者也",
                "17": "故鄙諺曰",
                "18": "家累千金",
                "19": "坐不垂堂",
                "20": "此言雖小",
                "21": "可以喩大",
                "22": "臣願陛下留意幸察"
            }
        }
    }
}