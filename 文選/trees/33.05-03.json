{
    "33.05-03": {
        "篇名": "宋玉 九辯五首·其三",
        "1": {
            "3": {
                "1": "皇天平分四時兮",
                "2": "竊獨悲此凜秋",
                "3": "白露旣下降百草兮",
                "4": "奄離披此梧楸",
                "5": "去白日之昭昭兮",
                "6": "襲長夜之悠悠",
                "7": "離芳藹之方壯兮",
                "8": "余委約而悲愁",
                "9": "秋旣先戒以白露兮",
                "10": "冬又申之以嚴霜",
                "11": "收恢炱之孟夏兮",
                "12": "然坎傺而沈藏",
                "13": "葉菸邑而無色兮",
                "14": "枝煩挐而交橫",
                "15": "顏淫溢而將罷兮",
                "16": "柯彷彿而委黃",
                "17": "萷櫹槮之可哀兮",
                "18": "形銷鑠而瘀傷",
                "19": "惟其紛糅而將落兮",
                "20": "恨其失時而無當",
                "21": "覽騑轡而下節兮",
                "22": "聊逍遙以相羊",
                "23": "歲忽忽而遒盡兮",
                "24": "恐余壽之弗將",
                "25": "悼余生之不時兮",
                "26": "逢此世之俇攘",
                "27": "澹容與而獨倚兮",
                "28": "蟋蟀鳴此西堂",
                "29": "心怵惕而震盪兮",
                "30": "何所憂之多方",
                "31": "仰明月而太息兮",
                "32": "步列星而極明"
            }
        }
    }
}