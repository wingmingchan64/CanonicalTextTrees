{
    "49.01": {
        "篇名": "班孟堅 公孫弘傳贊",
        "1": {
            "3": {
                "1": "贊曰",
                "2": "公孫弘卜式倪寬",
                "3": "皆以鴻漸之翼",
                "4": "困於燕雀",
                "5": "遠迹羊豕之間",
                "6": "非遇其時",
                "7": "焉能致此位乎",
                "8": "是時漢興六十餘載",
                "9": "海內乂安",
                "10": "府庫充實",
                "11": "而四夷未賓",
                "12": "制度多闕",
                "13": "上方欲用文武",
                "14": "求之如弗及",
                "15": "始以蒲輪迎枚生",
                "16": "見主父而歎息",
                "17": "羣士慕響",
                "18": "異人並出",
                "19": "卜式拔於芻牧",
                "20": "弘羊擢於賈豎",
                "21": "衞青奮於奴僕",
                "22": "日磾出於降虜",
                "23": "斯亦曩時版築飯牛之明已"
            }
        },
        "2": {
            "5": {
                "1": "漢之得人",
                "2": "於茲爲盛",
                "3": "儒雅則公孫弘董仲舒倪寬",
                "4": "篤行則石建石慶",
                "5": "質直則汲黯卜式",
                "6": "推賢則韓安國鄭當時",
                "7": "定令則趙禹張湯",
                "8": "文章則司馬遷相如",
                "9": "滑稽則東方朔枚皋",
                "10": "應對則嚴助朱買臣",
                "11": "歷數則唐都落下閎",
                "12": "協律則李延年",
                "13": "運籌則桑弘羊",
                "14": "奉使則張騫蘇武",
                "15": "將帥則衞青霍去病",
                "16": "受遺則霍光金日磾",
                "17": "其餘不可勝紀",
                "18": "是以興造功業",
                "19": "制度遺文",
                "20": "後世莫及"
            }
        },
        "3": {
            "7": {
                "1": "孝宣承統",
                "2": "纂修洪業",
                "3": "亦講論六藝",
                "4": "招選茂異",
                "5": "而蕭望之梁丘賀夏侯勝韋玄成嚴彭祖尹更始以儒術進",
                "6": "劉向王襃以文章顯",
                "7": "將相則張安世趙充國魏相邴吉於定國杜延年",
                "8": "治民則黃霸王成龔遂鄭弘召信臣韓延壽尹翁歸趙廣漢嚴延年張敞之屬",
                "9": "皆有功迹見述於後世",
                "10": "參其名臣",
                "11": "亦其次也"
            }
        }
    }
}